<!-- Toast Notification Container -->
<div id="toast-container" class="fixed top-4 right-4 space-y-2" style="z-index: 9999 !important">
  <!-- Toast notifications will be dynamically inserted here -->
</div>

<script>
  // Standardized Toast Notification System
  class ToastManager {
    constructor() {
      this.container = document.getElementById("toast-container");
      this.toasts = new Map(); // Track active toasts
    }

    show(message, type = "info", duration = 6000) {
      const id = Date.now() + Math.random();
      const toast = this.createToast(id, message, type);

      this.container.appendChild(toast);
      this.toasts.set(id, toast);

      // Animate in
      setTimeout(() => {
        toast.classList.remove("translate-x-full");
      }, 100);

      // Auto remove
      setTimeout(() => {
        this.hide(id);
      }, duration);

      return id;
    }

    hide(id) {
      const toast = this.toasts.get(id);
      if (!toast) return;

      toast.classList.add("translate-x-full");

      setTimeout(() => {
        if (toast.parentNode) {
          toast.parentNode.removeChild(toast);
        }
        this.toasts.delete(id);
      }, 300);
    }

    createToast(id, message, type) {
      const toast = document.createElement("div");
      toast.id = `toast-${id}`;
      toast.className = `
        transform transition-all duration-300 ease-in-out
        translate-x-full
        border-l-4 shadow-xl rounded-lg p-4 min-w-80 max-w-96
        ${this.getTypeClasses(type)}
      `;

      toast.innerHTML = `
      <div class="flex items-start">
        <div class="flex-shrink-0">
          ${this.getIcon(type)}
        </div>
        <div class="ml-3 flex-1">
          <p class="text-sm font-semibold">${message}</p>
        </div>
        <div class="ml-4 flex-shrink-0 flex">
          <button onclick="toastManager.hide('${id}')" 
                  class="rounded-md inline-flex text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500">
            <span class="sr-only">Close</span>
            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </button>
        </div>
      </div>
    `;

      return toast;
    }

    getTypeClasses(type) {
      const typeMap = {
        success: "border-green-500 bg-white text-gray-900 dark:bg-gray-800 dark:text-gray-100",
        error: "border-red-500 bg-white text-gray-900 dark:bg-gray-800 dark:text-gray-100",
        warning: "border-yellow-500 bg-white text-gray-900 dark:bg-gray-800 dark:text-gray-100",
        info: "border-blue-500 bg-white text-gray-900 dark:bg-gray-800 dark:text-gray-100",
      };
      return typeMap[type] || typeMap.info;
    }

    getIcon(type) {
      const iconMap = {
        success: `
        <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
      `,
        error: `
        <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
        </svg>
      `,
        warning: `
        <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
        </svg>
      `,
        info: `
        <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
        </svg>
      `,
      };
      return iconMap[type] || iconMap.info;
    }

    // Convenience methods
    success(message, duration) {
      return this.show(message, "success", duration);
    }
    error(message, duration) {
      return this.show(message, "error", duration);
    }
    warning(message, duration) {
      return this.show(message, "warning", duration);
    }
    info(message, duration) {
      return this.show(message, "info", duration);
    }
  }

  // Global toast manager instance
  window.toastManager = new ToastManager();

  // Convenience functions for backward compatibility
  window.showToast = (title, message, type = "info", duration = 6000) => {
    const fullMessage = message ? `${title}: ${message}` : title;
    return toastManager.show(fullMessage, type, duration);
  };

  // Enhanced convenience functions
  window.showSuccessToast = (message, duration = 6000) => toastManager.success(message, duration);
  window.showErrorToast = (message, duration = 6000) => toastManager.error(message, duration);
  window.showWarningToast = (message, duration = 6000) => toastManager.warning(message, duration);
  window.showInfoToast = (message, duration = 6000) => toastManager.info(message, duration);
</script>

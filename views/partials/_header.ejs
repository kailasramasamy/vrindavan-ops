<!-- /views/partials/_header.ejs -->
<header class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 sticky top-0 z-50 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 py-4">
    <div class="flex items-center justify-between min-w-0">
      <!-- Brand -->
      <div class="flex items-center gap-4">
        <a href="/" class="flex items-center gap-3 group">
          <div class="w-10 h-10 bg-gradient-to-br from-blue-600 to-indigo-600 rounded-lg flex items-center justify-center group-hover:from-blue-700 group-hover:to-indigo-700 transition-all duration-200">
            <div class="w-8 h-8 bg-white rounded-full flex items-center justify-center">
              <img src="/assets/img/vrindavan-logo.png" alt="Vrindavan Farm" class="w-5 h-5 object-contain" />
            </div>
          </div>
          <div>
            <div class="font-bold text-lg text-gray-900 dark:text-white">Dairy Plant Ops</div>
            <div class="text-xs text-gray-500 dark:text-gray-400">Operations Management</div>
          </div>
        </a>
      </div>

      <!-- Navigation -->
      <nav class="hidden md:flex items-center gap-2 flex-shrink-0">
        <!-- Inward POs Link -->
        <% if (typeof user !== 'undefined' && user) { %>
        <a href="/inward-po" class="flex items-center space-x-2 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg transition-colors duration-200 border border-transparent hover:border-blue-200 dark:hover:border-blue-800">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
          <span>Inward POs</span>
        </a>
        <% } %>

        <!-- Admin Link - Only for Admin users -->
        <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
        <a href="/admin" class="flex items-center space-x-2 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg transition-colors duration-200 border border-transparent hover:border-blue-200 dark:hover:border-blue-800">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          <span>Admin</span>
        </a>
        <% } %>

        <!-- Settings Dropdown - Only for Admin users -->
        <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
        <div class="relative" id="headerSettingsDropdown">
          <button id="headerSettingsButton" class="flex items-center space-x-2 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg transition-colors duration-200 border border-transparent hover:border-blue-200 dark:hover:border-blue-800">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
            </svg>
            <span>Settings</span>
            <svg id="headerDropdownArrow" class="w-3 h-3 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>

          <!-- Settings Dropdown Menu -->
          <div id="headerSettingsMenu" class="absolute right-0 mt-2 w-64 bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 opacity-0 invisible transition-all duration-200 z-50">
            <div class="py-2">
              <!-- User Management -->
              <a href="/admin/users" class="flex items-center space-x-3 px-4 py-3 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors duration-200">
                <div class="w-8 h-8 bg-indigo-100 dark:bg-indigo-900/30 rounded-lg flex items-center justify-center">
                  <svg class="w-4 h-4 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-medium text-gray-900 dark:text-white">User Management</h3>
                  <p class="text-sm text-gray-600 dark:text-gray-400">Manage users & permissions</p>
                </div>
              </a>

              <!-- User Permissions -->
              <a href="/admin/users/permissions" class="flex items-center space-x-3 px-4 py-3 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors duration-200">
                <div class="w-8 h-8 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center">
                  <svg class="w-4 h-4 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-medium text-gray-900 dark:text-white">User Permissions</h3>
                  <p class="text-sm text-gray-600 dark:text-gray-400">Manage module permissions</p>
                </div>
              </a>

              <!-- Email Settings -->
              <a href="/email-settings" class="flex items-center space-x-3 px-4 py-3 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors duration-200">
                <div class="w-8 h-8 bg-gray-100 dark:bg-gray-700 rounded-lg flex items-center justify-center">
                  <svg class="w-4 h-4 text-gray-600 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-medium text-gray-900 dark:text-white">Email Settings</h3>
                  <p class="text-sm text-gray-600 dark:text-gray-400">Configure notifications</p>
                </div>
              </a>
            </div>
          </div>
        </div>
        <% } %>
      </nav>

      <!-- User Info & Actions -->
      <div class="flex items-center gap-2 flex-shrink-0">
        <!-- System Status -->
        <div class="hidden lg:flex items-center gap-2 px-3 py-1.5 bg-gray-800/90 rounded-full">
          <div class="w-2 h-2 bg-green-500 rounded-full"></div>
          <span class="text-xs font-medium text-gray-200">System Active</span>
        </div>

        <!-- Logout Button (Desktop Only) -->
        <button onclick="logout()" class="hidden md:inline-flex items-center px-3 py-1.5 text-xs font-medium text-gray-300 dark:text-gray-300 bg-gray-700/80 dark:bg-gray-700 hover:bg-gray-600/80 dark:hover:bg-gray-600 hover:text-white rounded-full transition-colors">
          <svg class="w-3 h-3 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
          </svg>
          Logout
        </button>
      </div>

      <!-- Mobile Menu Button -->
      <button type="button" class="md:hidden inline-flex items-center justify-center p-2 rounded-md text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500" aria-controls="mobile-menu" aria-expanded="false" data-mobile-menu-toggle>
        <span class="sr-only">Open main menu</span>
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="md:hidden hidden mt-4 pt-4 border-t border-gray-200 dark:border-gray-700">
      <div class="space-y-3">
        <!-- Inward POs Link -->
        <% if (typeof user !== 'undefined' && user) { %>
        <a href="/inward-po" class="flex items-center space-x-2 px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-blue-50 dark:hover:bg-gray-700 rounded-lg transition-colors border border-transparent hover:border-blue-200 dark:hover:border-blue-800">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
          <span>Inward POs</span>
        </a>
        <% } %>

        <!-- Admin Link - Only for Admin users -->
        <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
        <a href="/admin" class="flex items-center space-x-2 px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-blue-50 dark:hover:bg-gray-700 rounded-lg transition-colors border border-transparent hover:border-blue-200 dark:hover:border-blue-800">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          <span>Admin</span>
        </a>
        <% } %>

        <div class="pt-3 border-t border-gray-200 dark:border-gray-700">
          <div class="flex items-center gap-2 px-3 py-2 bg-gray-800/90 rounded-lg">
            <div class="w-2 h-2 bg-green-500 rounded-full"></div>
            <span class="text-xs font-medium text-gray-200">System Active</span>
          </div>

          <!-- Settings in Mobile - Only for Admin users -->
          <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
          <div class="px-3 py-2 mt-3">
            <div class="flex items-center space-x-2 mb-3">
              <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
              </svg>
              <div class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Settings</div>
            </div>
            <a href="/admin/users" class="block px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-md transition-colors">
              <svg class="w-4 h-4 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"></path>
              </svg>
              User Management
            </a>
            <a href="/admin/users/permissions" class="block px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-md transition-colors">
              <svg class="w-4 h-4 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
              User Permissions
            </a>
            <a href="/email-settings" class="block px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-md transition-colors">
              <svg class="w-4 h-4 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
              Email Settings
            </a>
          </div>
          <% } %>

          <!-- Logout in Mobile -->
          <form method="POST" action="/logout" class="block mt-3">
            <button type="submit" class="w-full text-left px-3 py-2 text-sm font-medium text-gray-300 bg-gray-700/80 hover:bg-gray-600/80 hover:text-white rounded-lg transition-colors flex items-center">
              <svg class="w-4 h-4 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
              </svg>
              Logout
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Menu Script -->
  <script>
    (() => {
      if (window.__ops_nav_init) return;
      window.__ops_nav_init = true;

      const toggle = document.querySelector("[data-mobile-menu-toggle]");
      const menu = document.getElementById("mobile-menu");
      if (!toggle || !menu) return;

      const setOpen = (open) => {
        menu.classList.toggle("hidden", !open);
        toggle.setAttribute("aria-expanded", String(open));
      };

      toggle.addEventListener("click", (e) => {
        e.preventDefault();
        setOpen(menu.classList.contains("hidden"));
      });

      // Close on outside click
      document.addEventListener("click", (e) => {
        if (!menu.contains(e.target) && !toggle.contains(e.target)) {
          setOpen(false);
        }
      });

      // Close on Escape
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") setOpen(false);
      });

      // Header Settings Dropdown
      const headerSettingsButton = document.getElementById("headerSettingsButton");
      const headerSettingsMenu = document.getElementById("headerSettingsMenu");
      const headerDropdownArrow = document.getElementById("headerDropdownArrow");
      let headerSettingsOpen = false;

      if (headerSettingsButton && headerSettingsMenu && headerDropdownArrow) {
        // Toggle dropdown on button click
        headerSettingsButton.addEventListener("click", function (e) {
          e.stopPropagation();
          headerSettingsOpen = !headerSettingsOpen;

          if (headerSettingsOpen) {
            headerSettingsMenu.classList.remove("opacity-0", "invisible");
            headerSettingsMenu.classList.add("opacity-100", "visible");
            headerDropdownArrow.style.transform = "rotate(180deg)";
          } else {
            headerSettingsMenu.classList.remove("opacity-100", "visible");
            headerSettingsMenu.classList.add("opacity-0", "invisible");
            headerDropdownArrow.style.transform = "rotate(0deg)";
          }
        });

        // Close dropdown when clicking outside
        document.addEventListener("click", function (e) {
          if (!headerSettingsButton.contains(e.target) && !headerSettingsMenu.contains(e.target)) {
            if (headerSettingsOpen) {
              headerSettingsMenu.classList.remove("opacity-100", "visible");
              headerSettingsMenu.classList.add("opacity-0", "invisible");
              headerDropdownArrow.style.transform = "rotate(0deg)";
              headerSettingsOpen = false;
            }
          }
        });

        // Close dropdown when pressing Escape key
        document.addEventListener("keydown", function (e) {
          if (e.key === "Escape" && headerSettingsOpen) {
            headerSettingsMenu.classList.remove("opacity-100", "visible");
            headerSettingsMenu.classList.add("opacity-0", "invisible");
            headerDropdownArrow.style.transform = "rotate(0deg)";
            headerSettingsOpen = false;
          }
        });
      }
    })();

    // Logout function
    function logout() {
      const form = document.createElement("form");
      form.method = "POST";
      form.action = "/logout";
      document.body.appendChild(form);
      form.submit();
    }
  </script>
</header>

  <script>
    // Initialize page
    document.addEventListener('DOMContentLoaded', function() {
      initializeProductionEntry();
      loadExistingData();
      loadPoolAllocations();
      updateProductVolumes();
    });

    function initializeProductionEntry() {
      // Add data button handlers
      document.querySelectorAll('.add-data-btn').forEach(btn => {
        btn.addEventListener('click', function() {
          const productId = this.dataset.productId;
          openAddProductionModal(productId);
        });
      });

      // Edit data button handlers
      document.querySelectorAll('.edit-data-btn').forEach(btn => {
        btn.addEventListener('click', function() {
          const productId = this.dataset.productId;
          openEditProductionModal(productId);
        });
      });

      // Delete data button handlers
      document.querySelectorAll('.delete-data-btn').forEach(btn => {
        btn.addEventListener('click', function() {
          const productId = this.dataset.productId;
          deleteProductionData(productId);
        });
      });

      // Add milk button handlers
      document.querySelectorAll('.add-milk-btn').forEach(btn => {
        btn.addEventListener('click', function() {
          const milkType = this.dataset.milkType;
          openAddMilkModal(milkType);
        });
      });

      // Edit milk button handlers
      document.querySelectorAll('.edit-milk-btn').forEach(btn => {
        btn.addEventListener('click', function() {
          const milkType = this.dataset.milkType;
          openEditMilkModal(milkType);
        });
      });

      // Modal close handlers
      const closeAddProductionModalEl = document.getElementById('closeAddProductionModal');

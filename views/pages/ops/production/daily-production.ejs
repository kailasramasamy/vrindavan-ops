      const allocatedSpan = card.querySelector('.pool-allocated');
      const addBtn = card.querySelector('.pool-add-btn');
      const editBtn = card.querySelector('.pool-edit-btn');
      const deleteBtn = card.querySelector('.pool-delete-btn');
      
      if (allocatedSpan) {
        allocatedSpan.textContent = allocatedAmount.toFixed(1);

      const productImage = document.getElementById('editProductImage');
      const productImageSrc = document.getElementById('editProductImageSrc');
      if (product.image_url) {
        productImageSrc.src = product.image_url;
        productImageSrc.alt = product.name;
        productImage.classList.remove('hidden');
      } else {
        productImage.classList.add('hidden');
      }

      // Show/hide milk input sections
      const milkUsedSection = document.getElementById('editMilkUsedSection');
      const autoMilkSection = document.getElementById('editAutoMilkSection');
      
      if (product.auto_calculate_milk) {
        milkUsedSection.classList.add('hidden');
        autoMilkSection.classList.remove('hidden');
      } else {
        milkUsedSection.classList.remove('hidden');
        autoMilkSection.classList.add('hidden');
      }

      // Fetch current production data from API
      try {
        const productionDate = document.getElementById('productionDate').value;
        const response = await fetch(`/production/daily-production/api?date=${productionDate}`);
        const result = await response.json();
        
        if (result.success && result.production) {
          const existingData = result.production.find(entry => entry.product_id == productId);
          if (existingData) {
            // Set current production data
            document.getElementById('editCurrentQuantity').textContent = existingData.quantity_produced || '0';
            document.getElementById('editCurrentMilkUsed').textContent = `${parseFloat(existingData.milk_used || 0).toFixed(1)} L`;
            
            // Clear adjustment fields
            const quantityAdjustment = document.getElementById('editQuantityAdjustment');
            const milkUsedAdjustment = document.getElementById('editMilkUsedAdjustment');
            const notes = document.getElementById('editNotes');
            
            if (quantityAdjustment) quantityAdjustment.value = '';
            if (milkUsedAdjustment) milkUsedAdjustment.value = '';
            if (notes) notes.value = '';
            
            // Set default action to "add"
            const addRadio = document.querySelector('input[name="editProductionAction"][value="add"]');
            if (addRadio) {
              addRadio.checked = true;
            }
            
            if (product.auto_calculate_milk) {
              const autoMilkAdjustment = document.getElementById('editAutoMilkAdjustment');
              if (autoMilkAdjustment) {
                autoMilkAdjustment.textContent = '0.0 L';
              }
            }
          } else {
            showErrorToast('No existing production data found for this product');
            return;
          }
        } else {
          throw new Error(result.error || 'Failed to fetch production data');
        }
      } catch (error) {
        console.error('Error fetching production data for edit modal:', error);
        showErrorToast('Failed to load current production data');
        return;
      }

      // Add event listener for quantity adjustment to update auto-calculated milk
      const quantityAdjustmentInput = document.getElementById('editQuantityAdjustment');
      const actionRadios = document.querySelectorAll('input[name="editProductionAction"]');
      
      const updateMilkAdjustment = () => {
        if (product.auto_calculate_milk && quantityAdjustmentInput) {
          const adjustment = parseFloat(quantityAdjustmentInput.value) || 0;
          const actionRadio = document.querySelector('input[name="editProductionAction"]:checked');
          if (actionRadio) {
            const action = actionRadio.value;
            const milkAdjustment = adjustment * product.milk_per_unit;
            const displayAdjustment = action === 'remove' ? -milkAdjustment : milkAdjustment;
            const autoMilkElement = document.getElementById('editAutoMilkAdjustment');
            if (autoMilkElement) {
              autoMilkElement.textContent = `${displayAdjustment.toFixed(1)} L`;
            }
          }
        }
      };
      
      if (quantityAdjustmentInput) {
        quantityAdjustmentInput.addEventListener('input', updateMilkAdjustment);
      }
      actionRadios.forEach(radio => {
        if (radio) {
          radio.addEventListener('change', updateMilkAdjustment);
        }
      });

      // Show modal
      document.getElementById('editProductionModal').classList.remove('hidden');
    }


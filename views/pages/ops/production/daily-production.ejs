    function getExistingMilkInventoryData(milkType) {
      const milkInventory = <%- JSON.stringify(milkInventory || []) %>;
      return milkInventory.find(inventory => inventory.milk_type === milkType);
    }

    function calculateUsedMilkForType(milkType) {
      const existingProduction = <%- JSON.stringify(existingProduction || []) %>;
      const categories = <%- JSON.stringify(categories || []) %>;
      
      let totalUsed = 0;
      
      // Get all products of this milk type
      const productsOfType = [];
      categories.forEach(category => {
        if (category.products) {
          category.products.forEach(product => {
            if (product.milk_type === milkType) {
              productsOfType.push(product.id);
            }
          });
        }
      });

      // Sum up milk used for products of this type
      existingProduction.forEach(entry => {
        if (productsOfType.includes(entry.product_id)) {
          totalUsed += parseFloat(entry.milk_used) || 0;
        }
      });

      return totalUsed;
    }

    async function saveAddMilkData(event) {
      if (event) event.preventDefault();
      
      const milkType = document.getElementById('addMilkType').value;
      const available = parseFloat(document.getElementById('addAvailableMilk').value) || 0;
      const wasted = parseFloat(document.getElementById('addWastedMilk').value) || 0;
      const notes = document.getElementById('addMilkNotes').value;
      const productionDate = document.getElementById('addMilkProductionDate').value;
      
      if (available <= 0) {
        showErrorToast('Please enter a valid available milk quantity');
        return;
      }

      const milkData = {
        milk_type: milkType,
        quantity_available: available,
        quantity_used: 0, // For new entries, used is 0
        quantity_wasted: wasted,
        notes: notes,
        inventory_date: productionDate
      };

      try {
        const response = await fetch('/production/daily-production', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            date: productionDate,
            milkInventory: [milkData]
          })
        });

        const result = await response.json();

        if (result.success) {
          showSuccessToast('Milk inventory added successfully');
          closeAddMilkModal();
          // Refresh milk inventory cards from API to get updated remaining values
          await refreshMilkInventoryCards();
          // Update Production Entry cards with new remaining milk values
          updateProductVolumes();
        } else {
          throw new Error(result.error || 'Failed to add milk inventory');
        }
      } catch (error) {
        console.error('Error adding milk inventory:', error);
        showErrorToast('Failed to add milk inventory: ' + error.message);
      }
    }

    async function saveEditMilkData(event) {
      if (event) event.preventDefault();
      
      const milkType = document.getElementById('editMilkType').value;
      const volumeChange = parseFloat(document.getElementById('editVolumeChange').value) || 0;
      const actionRadio = document.querySelector('input[name="editMilkAction"]:checked');
      if (!actionRadio) {
        showErrorToast('Please select an action (Add or Remove)');
        return;
      }
      const action = actionRadio.value;
      const wasted = parseFloat(document.getElementById('editWastedMilk').value) || 0;
      const notes = document.getElementById('editMilkNotes').value;
      const productionDate = document.getElementById('editMilkProductionDate').value;
      
      if (volumeChange <= 0) {
        showErrorToast('Please enter a valid volume adjustment');
        return;
      }

      // Get current inventory data from API
      let existingData;
      try {
        const response = await fetch(`/production/milk-inventory/api?date=${productionDate}`);
        const result = await response.json();
        
        if (result.success && result.milkInventory) {
          existingData = result.milkInventory.find(inventory => inventory.milk_type === milkType);
        }
        
        if (!existingData) {
          showErrorToast('No existing milk inventory found for this type');
          return;
        }
      } catch (error) {
        console.error('Error fetching current milk inventory:', error);
        showErrorToast('Failed to fetch current milk inventory data');
        return;
      }

          // Calculate new available volume based on action
          const currentAvailable = parseFloat(existingData.quantity_available || 0);
          let newAvailable;
          if (action === 'add') {
            newAvailable = currentAvailable + volumeChange;
          } else {
            newAvailable = Math.max(0, currentAvailable - volumeChange);
          }

      const milkData = {
        milk_type: milkType,
        quantity_available: newAvailable,
        quantity_used: parseFloat(existingData.quantity_used || 0), // Keep existing used amount
        quantity_wasted: wasted,
        notes: notes,
        inventory_date: productionDate
      };

      try {
        const response = await fetch('/production/daily-production', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            date: productionDate,
            milkInventory: [milkData]
          })
        });

        const result = await response.json();

        if (result.success) {
          showSuccessToast(`Milk inventory updated successfully (${action === 'add' ? '+' : '-'}${volumeChange}L)`);
          closeEditMilkModal();
          // Refresh milk inventory cards from API to get updated remaining values
          await refreshMilkInventoryCards();
          // Update Production Entry cards with new remaining milk values
          updateProductVolumes();
        } else {
          throw new Error(result.error || 'Failed to update milk inventory');
        }
      } catch (error) {
        console.error('Error updating milk inventory:', error);
        showErrorToast('Failed to update milk inventory: ' + error.message);
      }
    }

    function updateMilkInventoryCard(milkType, milkData) {
      const card = document.querySelector(`.milk-inventory-card[data-milk-type="${milkType}"]`);
      if (!card) return;

      const availableSpan = card.querySelector('.milk-available');
      const usedSpan = card.querySelector('.milk-used');
      const wastedSpan = card.querySelector('.milk-wasted');
      const remainingSpan = card.querySelector('.milk-remaining');
      const addBtn = card.querySelector('.add-milk-btn');
      const editBtn = card.querySelector('.edit-milk-btn');

      // Convert string values to numbers
      const available = parseFloat(milkData.quantity_available) || 0;
      const used = parseFloat(milkData.quantity_used) || 0;
      const wasted = parseFloat(milkData.quantity_wasted) || 0;
      const remaining = parseFloat(milkData.quantity_remaining) || 0;

      if (availableSpan) availableSpan.textContent = `${available.toFixed(1)} L`;
      if (usedSpan) usedSpan.textContent = `${used.toFixed(1)} L`;
      if (wastedSpan) wastedSpan.textContent = `${wasted.toFixed(1)} L`;
      if (remainingSpan) remainingSpan.textContent = `${remaining.toFixed(1)} L`;

      // Show/hide buttons based on available milk
      if (addBtn) {
        if (available === 0) {
          addBtn.classList.remove('hidden');
        } else {
          addBtn.classList.add('hidden');
        }
      }

      if (editBtn) {
        if (available === 0) {
          editBtn.classList.add('hidden');
        } else {
          editBtn.classList.remove('hidden');
        }
      }

      // Update usage breakdown if available
      if (milkData.usage_breakdown) {
        updateUsageBreakdown(milkType, milkData.usage_breakdown);
      }

              // Update product cards with remaining milk for direct source products
              updateProductCardsWithAvailableMilk(milkType, remaining);
    }

    function updateUsageBreakdown(milkType, breakdown) {
      const card = document.querySelector(`.milk-inventory-card[data-milk-type="${milkType}"]`);
      if (!card) return;

      const poolBreakdown = card.querySelector('.pool-breakdown');
      const productBreakdown = card.querySelector('.product-breakdown');

      // Update pool allocations
      if (poolBreakdown) {
        if (breakdown.pool_allocations.items.length > 0) {
          poolBreakdown.innerHTML = breakdown.pool_allocations.items.map(item => 
            `<div class="flex justify-between">
              <span>${item.name}</span>
              <span class="font-medium">${item.amount.toFixed(1)}L</span>
            </div>`
          ).join('');
        } else {
          poolBreakdown.innerHTML = '<div class="text-gray-500 italic">No pool allocations</div>';
        }
      }

      // Update product production
      if (productBreakdown) {
        if (breakdown.product_production.items.length > 0) {
          productBreakdown.innerHTML = breakdown.product_production.items.map(item => 
            `<div class="flex justify-between">
              <span>${item.name}</span>
              <span class="font-medium">${item.amount.toFixed(1)}L</span>
            </div>`
          ).join('');
        } else {
          productBreakdown.innerHTML = '<div class="text-gray-500 italic">No product production</div>';
        }
      }
    }

    // Update available volumes for products
    function updateProductVolumes() {
      // Update direct milk volumes
      document.querySelectorAll('.direct-volume').forEach(element => {
        const milkType = element.dataset.milkType;
        const milkCard = document.querySelector(`.milk-inventory-card[data-milk-type="${milkType}"]`);
        if (milkCard) {
          const remainingSpan = milkCard.querySelector('.milk-remaining');
          if (remainingSpan) {
            const remaining = parseFloat(remainingSpan.textContent) || 0;
            element.textContent = `${remaining.toFixed(1)}L`;
            // Preserve the direct-volume class and add color classes
            element.className = `direct-volume ${remaining > 0 ? 'text-green-600 font-medium' : 'text-red-600 font-medium'}`;
          }
        }
      });

      // Update pool volumes by fetching allocation data from API
      updatePoolVolumesFromAPI();
    }

    // Update pool volumes by fetching allocation data from API
    async function updatePoolVolumesFromAPI() {
      try {
        const productionDate = document.getElementById('productionDate').value;
        
        // Fetch current pool allocations from API
        const response = await fetch(`/production/pool-allocations/api?date=${productionDate}`);
        const result = await response.json();
        
        if (result.success && result.allocations) {
          // Create a map of pool allocations for quick lookup
          const allocationMap = {};
          result.allocations.forEach(allocation => {
            allocationMap[allocation.pool_id] = allocation;
          });
          
          // Instead of looking for .pool-volume elements, find product cards with pool source
          // and update their pool volume display directly
          const poolProductCards = document.querySelectorAll('.product-card[data-milk-source="pool"]');
          
          poolProductCards.forEach(productCard => {
            const poolId = productCard.dataset.poolId;
            const allocation = allocationMap[poolId];
            
            // Find the pool volume element within this product card
            let poolVolumeElement = productCard.querySelector('.pool-volume');
            
            // If the pool-volume element doesn't exist, find the element that should contain it
            if (!poolVolumeElement) {
              // Look for the span that might have the pool volume text
              const poolSpans = productCard.querySelectorAll('span');
              for (const span of poolSpans) {
                if (span.textContent.includes('Not allocated') || span.textContent.includes('L') || span.textContent.includes('Pool:')) {
                  poolVolumeElement = span;
                  // Add the pool-volume class and data-pool-id if missing
                  if (!poolVolumeElement.classList.contains('pool-volume')) {
                    poolVolumeElement.classList.add('pool-volume');
                    poolVolumeElement.setAttribute('data-pool-id', poolId);
                  }
                  break;
                }
              }
            }
            
            // If we still don't have a pool volume element, create one
            if (!poolVolumeElement) {
              // Find the container where pool volume should be displayed
              const poolContainer = productCard.querySelector('div:has(> .font-medium)') || 
                                  productCard.querySelector('.text-xs.text-gray-500');
              if (poolContainer) {
                poolVolumeElement = document.createElement('span');
                poolVolumeElement.className = 'pool-volume';
                poolVolumeElement.setAttribute('data-pool-id', poolId);
                
                // Create the full structure
                poolContainer.innerHTML = `<span class="font-medium">Pool:</span> <span class="pool-volume" data-pool-id="${poolId}">Not allocated</span>`;
                poolVolumeElement = poolContainer.querySelector('.pool-volume');
              }
            }
            
            // Update the pool volume element
            if (poolVolumeElement) {
              if (allocation && allocation.milk_allocated > 0) {
                poolVolumeElement.textContent = `${parseFloat(allocation.milk_allocated).toFixed(1)}L`;
                poolVolumeElement.className = 'pool-volume text-green-600 font-medium';
              } else {
                poolVolumeElement.textContent = 'Not allocated';
                poolVolumeElement.className = 'pool-volume text-red-600 font-medium';
              }
            }
          });
        }
      } catch (error) {
        console.error('Error updating pool volumes from API:', error);
      }
    }

    // Update product cards with remaining milk for a specific milk type
    function updateProductCardsWithAvailableMilk(milkType, remaining) {
      // Wait for DOM to be ready if needed
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
          updateProductCardsWithAvailableMilk(milkType, remaining);
        });
        return;
      }
      
      // Update direct volume elements for this milk type
      const selector = `.direct-volume[data-milk-type="${milkType}"]`;
      const elements = document.querySelectorAll(selector);
      
      elements.forEach((element) => {
        element.textContent = `${remaining.toFixed(1)}L`;
        // Preserve the direct-volume class and add color classes
        element.className = `direct-volume ${remaining > 0 ? 'text-green-600 font-medium' : 'text-red-600 font-medium'}`;
      });
    }

    function updateMilkInventoryCards() {
      const milkInventory = <%- JSON.stringify(milkInventory || []) %>;
      
      milkInventory.forEach(inventory => {
        updateMilkInventoryCard(inventory.milk_type, inventory);
      });

      // Show/hide buttons based on available milk
      ['A1', 'A2', 'Buffalo'].forEach(milkType => {
        const card = document.querySelector(`.milk-inventory-card[data-milk-type="${milkType}"]`);
        const addBtn = card?.querySelector('.add-milk-btn');
        const editBtn = card?.querySelector('.edit-milk-btn');
        const availableSpan = card?.querySelector('.milk-available');
        
        if (availableSpan) {
          const available = parseFloat(availableSpan.textContent) || 0;
          
          // Add button: show when no milk available
          if (addBtn) {
          if (available === 0) {
            addBtn.classList.remove('hidden');
          } else {
            addBtn.classList.add('hidden');
            }
          }
          
          // Edit button: hide when no milk available
          if (editBtn) {
            if (available === 0) {
              editBtn.classList.add('hidden');
            } else {
              editBtn.classList.remove('hidden');
            }
          }
        }
      });

      // Update product cards with available milk volumes
      updateProductVolumes();
    }

    async function refreshMilkInventoryCards() {
      try {
        const productionDate = document.getElementById('productionDate').value;
        
        // Fetch updated milk inventory data from API
        const response = await fetch(`/production/milk-inventory/api?date=${productionDate}`);
        const result = await response.json();
        
        if (result.success && result.milkInventory) {
          // Update each milk inventory card
          result.milkInventory.forEach(inventory => {
            updateMilkInventoryCard(inventory.milk_type, inventory);
          });
          
          // Update button visibility based on available milk
          ['A1', 'A2', 'Buffalo'].forEach(milkType => {
            const card = document.querySelector(`.milk-inventory-card[data-milk-type="${milkType}"]`);
            const addBtn = card?.querySelector('.add-milk-btn');
            const editBtn = card?.querySelector('.edit-milk-btn');
            const availableSpan = card?.querySelector('.milk-available');
            
            if (availableSpan) {
              const available = parseFloat(availableSpan.textContent) || 0;
              
              // Add button: show when no milk available
              if (addBtn) {
                if (available === 0) {
                  addBtn.classList.remove('hidden');
                } else {
                  addBtn.classList.add('hidden');
                }
              }
              
              // Edit button: hide when no milk available
              if (editBtn) {
                if (available === 0) {
                  editBtn.classList.add('hidden');
                } else {
                  editBtn.classList.remove('hidden');
                }
              }
            }
          });

          // Update product cards with available milk volumes
          updateProductVolumes();
        } else {
          throw new Error(result.error || 'Failed to fetch milk inventory');
        }
      } catch (error) {
        console.error('Error refreshing milk inventory cards:', error);
        showErrorToast('Failed to refresh milk inventory');
      }
    }

    async function refreshPoolAllocations() {
      try {
        const productionDate = document.getElementById('productionDate').value;
        
        // Fetch updated pool allocations data from API
        const response = await fetch(`/production/pool-allocations/api?date=${productionDate}`);
        const result = await response.json();
        
        if (result.success && result.allocations) {
          // Re-render pool allocation cards with updated data
          const pools = window.availablePools || [];
          renderPoolAllocations(pools, result.allocations);
        } else {
          throw new Error(result.error || 'Failed to fetch pool allocations');
        }
      } catch (error) {
        console.error('Error refreshing pool allocations:', error);
        showErrorToast('Failed to refresh pool allocations');
      }
    }

    // Pool Allocation Modal Functions
    function closeAddPoolModal() {
      const modal = document.getElementById('addPoolAllocationModal');
      modal.style.display = 'none';
    }

    function closeEditPoolModal() {
      const modal = document.getElementById('editPoolAllocationModal');
      modal.style.display = 'none';
    }

    function closeDeletePoolModal() {
      const modal = document.getElementById('deletePoolAllocationModal');
      const modalContent = modal.querySelector('.relative');
      
      if (modalContent) {
        // Animate out
        modalContent.classList.remove('scale-100', 'opacity-100');
        modalContent.classList.add('scale-95', 'opacity-0');
        
        // Hide modal after animation completes
        setTimeout(() => {
          modal.classList.add('hidden');
        }, 300);
      }
      
      window.currentDeletePoolId = null;
    }

    function showDeletePoolModal() {
      const modal = document.getElementById('deletePoolAllocationModal');
      
      // Show modal with animation
      modal.classList.remove('hidden');
      
      // Trigger animation after a small delay to ensure the modal is visible
      setTimeout(() => {
        const modalContent = modal.querySelector('.relative');
        if (modalContent) {
          modalContent.classList.remove('scale-95', 'opacity-0');
          modalContent.classList.add('scale-100', 'opacity-100');
        }
      }, 10);
    }

    async function saveAddPoolAllocation(event) {
      if (event) event.preventDefault();
      
      const poolId = document.getElementById('addPoolId').value;
      const allocatedAmount = parseFloat(document.getElementById('addMilkAllocated').value) || 0;
      
      if (allocatedAmount <= 0) {
        showErrorToast('Please enter a valid positive number');
        return;
      }
      
      try {
        await savePoolAllocation(poolId, allocatedAmount);
        closeAddPoolModal();
        // Success toast is already shown by savePoolAllocation()
      } catch (error) {
        console.error('Error saving pool allocation:', error);
        showErrorToast('Failed to save pool allocation');
      }
    }

    async function saveEditPoolAllocation(event) {
      if (event) event.preventDefault();
      
      const poolId = document.getElementById('editPoolId').value;
      const allocatedAmount = parseFloat(document.getElementById('editMilkAllocated').value) || 0;
      const notes = document.getElementById('editPoolNotes').value;
      
      if (allocatedAmount < 0) {
        showErrorToast('Please enter a valid non-negative number');
        return;
      }
      
      try {
        await savePoolAllocation(poolId, allocatedAmount);
        closeEditPoolModal();
      } catch (error) {
        console.error('Error saving pool allocation:', error);
        showErrorToast('Failed to save pool allocation');
      }
    }

    async function confirmDeletePool() {
      if (!window.currentDeletePoolId) return;

      const poolIdToDelete = window.currentDeletePoolId;
      const productionDate = document.getElementById('productionDate').value;

      try {
        const response = await fetch('/production/pool-allocations/api', {
          method: 'DELETE',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            allocation_date: productionDate,
            pool_id: poolIdToDelete
          })
        });
        
        const result = await response.json();
        
        if (result.success) {
          // Update the UI to reflect the deletion
          updatePoolAllocationCard(poolIdToDelete, 0);
          
          // Refresh pool allocations and milk inventory
          await refreshPoolAllocations();
          await refreshMilkInventoryCards();
          
          // Update product volumes
          updateProductVolumes();
          
          closeDeletePoolModal();
          showSuccessToast('Pool allocation deleted successfully');
        } else {
          throw new Error(result.error || 'Failed to delete pool allocation');
        }
      } catch (error) {
        console.error('Error deleting pool allocation:', error);
        showErrorToast('Failed to delete pool allocation');
        closeDeletePoolModal();
      }
    }



  </script>

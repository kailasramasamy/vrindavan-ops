<%- include('../../../partials/_head', { seo, pageKey }) %>

<body class="bg-gray-50 dark:bg-gray-900">
  <div class="min-h-screen pt-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-2 pb-8">
      <!-- Breadcrumb Navigation -->
      <nav class="mb-6">
        <ol class="flex items-center space-x-2 text-sm text-gray-500 dark:text-gray-400">
          <li><a href="/" class="hover:text-gray-700 dark:hover:text-gray-300">Ops</a></li>
          <li class="flex items-center">
            <svg class="w-4 h-4 mx-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
            </svg>
            <a href="/production" class="hover:text-gray-700 dark:hover:text-gray-300">Production</a>
          </li>
          <li class="flex items-center">
            <svg class="w-4 h-4 mx-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span class="text-gray-900 dark:text-white font-medium">Daily Production</span>
          </li>
        </ol>
      </nav>

      <!-- Page Header -->
      <div class="mb-8">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
          <div>
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Daily Production Entry</h1>
            <p class="text-gray-600 dark:text-gray-300">Record production quantities and track milk usage for each product</p>
          </div>
          <div class="mt-4 sm:mt-0">
            <input type="date" id="productionDate" value="<%= date || new Date().toISOString().split('T')[0] %>" 
                   class="border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
          </div>
        </div>
      </div>

      <!-- Milk Inventory Section -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 mb-8">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Milk Inventory</h2>
          <p class="text-sm text-gray-600 dark:text-gray-300">Track milk quantities for each type</p>
        </div>
        <div class="p-6">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- A1 Milk Card -->
            <div class="milk-inventory-card bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-4 relative" data-milk-type="A1">
              <div class="flex items-center justify-between mb-4">
                <div class="flex items-center">
                  <div class="w-4 h-4 bg-green-500 dark:bg-green-600 rounded-full mr-3"></div>
                  <h3 class="font-semibold text-gray-900 dark:text-white">A1 Milk</h3>
                </div>
                <div class="flex items-center gap-2">
                  <button class="edit-milk-btn p-1.5 text-green-600 dark:text-green-400 hover:text-green-800 dark:hover:text-green-300 hover:bg-green-100 dark:hover:bg-green-900/40 rounded-lg transition-colors"
                          data-milk-type="A1" title="Edit Milk Inventory" onclick="openEditMilkModal('A1')">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                  </button>
                  <button class="add-milk-btn bg-green-600 text-white text-sm font-medium py-1.5 px-3 rounded-lg hover:bg-green-700 transition-colors hidden"
                          data-milk-type="A1" onclick="openAddMilkModal('A1')">
                    <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                    </svg>
                    Add Milk
                  </button>
                </div>
              </div>
              
              <div class="space-y-3">
                <div class="flex justify-between items-center">
                  <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Available:</span>
                  <span class="text-lg font-semibold text-green-600 dark:text-green-400 milk-available">0.0 L</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Used:</span>
                  <span class="text-lg font-semibold text-green-600 dark:text-green-400 milk-used">0.0 L</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Wasted:</span>
                  <span class="text-lg font-semibold text-red-600 dark:text-red-400 milk-wasted">0.0 L</span>
                </div>
                <div class="flex justify-between items-center pt-2 border-t border-green-200 dark:border-green-800">
                  <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Remaining:</span>
                  <span class="text-lg font-semibold text-gray-900 dark:text-white milk-remaining">0.0 L</span>
                </div>
              </div>

              <!-- Usage Breakdown Section -->
              <div class="mt-4 pt-3 border-t border-green-200 dark:border-green-800">
                <div class="flex items-center justify-between mb-2">
                  <h4 class="text-sm font-medium text-gray-700 dark:text-gray-300">Usage Breakdown</h4>
                  <button class="text-xs text-green-600 dark:text-green-400 hover:text-green-800 dark:hover:text-green-300 toggle-breakdown-btn" data-milk-type="A1">
                    <span class="show-text hidden">Show Details</span>
                    <span class="hide-text">Hide Details</span>
                  </button>
                </div>
                <div class="usage-breakdown text-xs space-y-2">
                  <div class="breakdown-content">
                    <!-- Pool Allocations -->
                    <div class="mb-2">
                      <div class="font-medium text-gray-600 dark:text-gray-300 mb-1">Pool Allocations:</div>
                      <div class="pool-breakdown space-y-1">
                        <div class="text-gray-500 dark:text-gray-400 italic">No pool allocations</div>
                      </div>
                    </div>
                    <!-- Product Production -->
                    <div>
                      <div class="font-medium text-gray-600 dark:text-gray-300 mb-1">Product Production:</div>
                      <div class="product-breakdown space-y-1">
                        <div class="text-gray-500 dark:text-gray-400 italic">No product production</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- A2 Milk Card -->
            <div class="milk-inventory-card bg-orange-50 dark:bg-orange-900/20 border border-orange-200 dark:border-orange-800 rounded-lg p-4 relative" data-milk-type="A2">
              <div class="flex items-center justify-between mb-4">
                <div class="flex items-center">
                  <div class="w-4 h-4 bg-orange-500 dark:bg-orange-600 rounded-full mr-3"></div>
                  <h3 class="font-semibold text-gray-900 dark:text-white">A2 Milk</h3>
                </div>
                <div class="flex items-center gap-2">
                  <button class="edit-milk-btn p-1.5 text-orange-600 dark:text-orange-400 hover:text-orange-800 dark:hover:text-orange-300 hover:bg-orange-100 dark:hover:bg-orange-900/40 rounded-lg transition-colors"
                          data-milk-type="A2" title="Edit Milk Inventory" onclick="openEditMilkModal('A2')">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                  </button>
                  <button class="add-milk-btn bg-orange-600 text-white text-sm font-medium py-1.5 px-3 rounded-lg hover:bg-orange-700 transition-colors hidden"
                          data-milk-type="A2" onclick="openAddMilkModal('A2')">
                    <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                    </svg>
                    Add Milk
                  </button>
                </div>
              </div>
              
              <div class="space-y-3">
                <div class="flex justify-between items-center">
                  <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Available:</span>
                  <span class="text-lg font-semibold text-orange-600 dark:text-orange-400 milk-available">0.0 L</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Used:</span>
                  <span class="text-lg font-semibold text-orange-600 dark:text-orange-400 milk-used">0.0 L</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Wasted:</span>
                  <span class="text-lg font-semibold text-red-600 dark:text-red-400 milk-wasted">0.0 L</span>
                </div>
                <div class="flex justify-between items-center pt-2 border-t border-orange-200 dark:border-orange-800">
                  <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Remaining:</span>
                  <span class="text-lg font-semibold text-gray-900 dark:text-white milk-remaining">0.0 L</span>
                </div>
              </div>

              <!-- Usage Breakdown Section -->
              <div class="mt-4 pt-3 border-t border-orange-200 dark:border-orange-800">
                <div class="flex items-center justify-between mb-2">
                  <h4 class="text-sm font-medium text-gray-700 dark:text-gray-300">Usage Breakdown</h4>
                  <button class="text-xs text-orange-600 dark:text-orange-400 hover:text-orange-800 dark:hover:text-orange-300 toggle-breakdown-btn" data-milk-type="A2">
                    <span class="show-text hidden">Show Details</span>
                    <span class="hide-text">Hide Details</span>
                  </button>
                </div>
                <div class="usage-breakdown text-xs space-y-2">
                  <div class="breakdown-content">
                    <!-- Pool Allocations -->
                    <div class="mb-2">
                      <div class="font-medium text-gray-600 dark:text-gray-300 mb-1">Pool Allocations:</div>
                      <div class="pool-breakdown space-y-1">
                        <div class="text-gray-500 dark:text-gray-400 italic">No pool allocations</div>
                      </div>
                    </div>
                    <!-- Product Production -->
                    <div>
                      <div class="font-medium text-gray-600 dark:text-gray-300 mb-1">Product Production:</div>
                      <div class="product-breakdown space-y-1">
                        <div class="text-gray-500 dark:text-gray-400 italic">No product production</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Buffalo Milk Card -->
            <div class="milk-inventory-card bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-4 relative" data-milk-type="Buffalo">
              <div class="flex items-center justify-between mb-4">
                <div class="flex items-center">
                  <div class="w-4 h-4 bg-blue-500 dark:bg-blue-600 rounded-full mr-3"></div>
                  <h3 class="font-semibold text-gray-900 dark:text-white">Buffalo Milk</h3>
                </div>
                <div class="flex items-center gap-2">
                  <button class="edit-milk-btn p-1.5 text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 hover:bg-blue-100 dark:hover:bg-blue-900/40 rounded-lg transition-colors"
                          data-milk-type="Buffalo" title="Edit Milk Inventory" onclick="openEditMilkModal('Buffalo')">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                  </button>
                  <button class="add-milk-btn bg-blue-600 text-white text-sm font-medium py-1.5 px-3 rounded-lg hover:bg-blue-700 transition-colors hidden"
                          data-milk-type="Buffalo" onclick="openAddMilkModal('Buffalo')">
                    <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                    </svg>
                    Add Milk
                  </button>
                </div>
              </div>
              
              <div class="space-y-3">
                <div class="flex justify-between items-center">
                  <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Available:</span>
                  <span class="text-lg font-semibold text-blue-600 dark:text-blue-400 milk-available">0.0 L</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Used:</span>
                  <span class="text-lg font-semibold text-blue-600 dark:text-blue-400 milk-used">0.0 L</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Wasted:</span>
                  <span class="text-lg font-semibold text-red-600 dark:text-red-400 milk-wasted">0.0 L</span>
                </div>
                <div class="flex justify-between items-center pt-2 border-t border-blue-200 dark:border-blue-800">
                  <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Remaining:</span>
                  <span class="text-lg font-semibold text-gray-900 dark:text-white milk-remaining">0.0 L</span>
                </div>
              </div>

              <!-- Usage Breakdown Section -->
              <div class="mt-4 pt-3 border-t border-blue-200 dark:border-blue-800">
                <div class="flex items-center justify-between mb-2">
                  <h4 class="text-sm font-medium text-gray-700 dark:text-gray-300">Usage Breakdown</h4>
                  <button class="text-xs text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 toggle-breakdown-btn" data-milk-type="Buffalo">
                    <span class="show-text hidden">Show Details</span>
                    <span class="hide-text">Hide Details</span>
                  </button>
            </div>
                <div class="usage-breakdown text-xs space-y-2">
                  <div class="breakdown-content">
                    <!-- Pool Allocations -->
                    <div class="mb-2">
                      <div class="font-medium text-gray-600 dark:text-gray-300 mb-1">Pool Allocations:</div>
                      <div class="pool-breakdown space-y-1">
                        <div class="text-gray-500 dark:text-gray-400 italic">No pool allocations</div>
                      </div>
                    </div>
                    <!-- Product Production -->
                    <div>
                      <div class="font-medium text-gray-600 dark:text-gray-300 mb-1">Product Production:</div>
                      <div class="product-breakdown space-y-1">
                        <div class="text-gray-500 dark:text-gray-400 italic">No product production</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

        <!-- Pool Allocations Section -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 mb-8">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
            <div class="flex items-center justify-between">
              <div>
                <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Pool Allocations</h2>
                <p class="text-sm text-gray-600 dark:text-gray-300">Allocate milk to production pools for batch processing</p>
              </div>
            </div>
          </div>
          <div class="p-6">
            <div id="poolAllocationsContainer" class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <!-- Pool allocation cards will be dynamically loaded here -->
              <div class="col-span-full text-center py-8">
                <div class="w-16 h-16 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center mx-auto mb-4">
                  <svg class="w-8 h-8 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                  </svg>
                </div>
                <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">Loading Pool Allocations...</h3>
                <p class="text-gray-600 dark:text-gray-300">Fetching available pools for allocation</p>
              </div>
            </div>
          </div>
        </div>

      <!-- Production Entries -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Production Entries</h2>
          <p class="text-sm text-gray-600 dark:text-gray-300">Enter quantities produced for each product</p>
        </div>
        <div class="p-6">
          <% if (categories && categories.length > 0) { %>
            <% 
              // Group all products by milk type
              const productsByMilkType = { A1: [], A2: [], Buffalo: [] };
              categories.forEach(category => {
                if (category.products && category.products.length > 0) {
                  category.products.forEach(product => {
                    if (productsByMilkType[product.milk_type]) {
                      productsByMilkType[product.milk_type].push(product);
                    }
                  });
                }
              });
              
              // Define product order: milk, curd, paneer, butter, ghee
              const productOrder = ['milk', 'curd', 'paneer', 'butter', 'ghee'];
              
              // Sort products within each milk type by category/name
              Object.keys(productsByMilkType).forEach(milkType => {
                productsByMilkType[milkType].sort((a, b) => {
                  // Get product name in lowercase for comparison
                  const nameA = (a.name || '').toLowerCase();
                  const nameB = (b.name || '').toLowerCase();
                  
                  // Get category name in lowercase if available
                  const categoryA = (a.category_name || '').toLowerCase();
                  const categoryB = (b.category_name || '').toLowerCase();
                  
                  // Find index in product order (check both name and category)
                  let indexA = -1;
                  let indexB = -1;
                  
                  for (let i = 0; i < productOrder.length; i++) {
                    const orderTerm = productOrder[i];
                    if (indexA === -1 && (nameA.includes(orderTerm) || categoryA.includes(orderTerm))) {
                      indexA = i;
                    }
                    if (indexB === -1 && (nameB.includes(orderTerm) || categoryB.includes(orderTerm))) {
                      indexB = i;
                    }
                    if (indexA !== -1 && indexB !== -1) break;
                  }
                  
                  // If both found in order, sort by order
                  if (indexA !== -1 && indexB !== -1) {
                    return indexA - indexB;
                  }
                  // If only one found, prioritize it
                  if (indexA !== -1) return -1;
                  if (indexB !== -1) return 1;
                  // If neither found, sort alphabetically
                  return nameA.localeCompare(nameB);
                });
              });
              
              // Define the milk types order
              const milkTypes = ['A1', 'A2', 'Buffalo'];
            %>
            
            <% milkTypes.forEach(milkType => { %>
              <% if (productsByMilkType[milkType].length > 0) { %>
                <!-- Milk Type Section -->
                <div class="mb-8 last:mb-0">
                  <div class="mb-4 flex items-center">
                    <% 
                      const typeColorScheme = milkType === 'A1' ? {
                        bg: 'bg-green-50 dark:bg-green-900/20',
                        text: 'text-green-700 dark:text-green-300',
                        icon: 'text-green-500 dark:text-green-400'
                      } : milkType === 'A2' ? {
                        bg: 'bg-orange-50 dark:bg-orange-900/20',
                        text: 'text-orange-700 dark:text-orange-300',
                        icon: 'text-orange-500 dark:text-orange-400'
                      } : {
                        bg: 'bg-blue-50 dark:bg-blue-900/20',
                        text: 'text-blue-700 dark:text-blue-300',
                        icon: 'text-blue-500 dark:text-blue-400'
                      };
                    %>
                    <div class="flex items-center <%= typeColorScheme.bg %> <%= typeColorScheme.text %> px-4 py-2 rounded-lg font-semibold">
                      <svg class="w-5 h-5 mr-2 <%= typeColorScheme.icon %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                      </svg>
                      <%= milkType %> Milk Products
                    </div>
                    <div class="flex-1 h-px bg-gray-200 dark:bg-gray-700 ml-4"></div>
                  </div>
                  
                  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                    <% productsByMilkType[milkType].forEach(product => { %>
                      <% 
                        // Define color scheme based on milk type
                        const colorScheme = product.milk_type === 'A1' ? {
                          bg: 'bg-green-50 dark:bg-green-900/15',
                          border: 'border-green-200 dark:border-green-800/60',
                          hoverBorder: 'hover:border-green-300 dark:hover:border-green-700/80',
                          badge: 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 border border-green-200 dark:border-green-800/60',
                          quantity: 'text-green-700 dark:text-green-400',
                          milk: 'text-green-700 dark:text-green-400',
                          addBtn: 'bg-green-500 dark:bg-green-700 hover:bg-green-600 dark:hover:bg-green-600',
                          editBtn: 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 hover:bg-green-200 dark:hover:bg-green-900/50'
                        } : product.milk_type === 'A2' ? {
                          bg: 'bg-orange-50 dark:bg-orange-900/15',
                          border: 'border-orange-200 dark:border-orange-800/60',
                          hoverBorder: 'hover:border-orange-300 dark:hover:border-orange-700/80',
                          badge: 'bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-300 border border-orange-200 dark:border-orange-800/60',
                          quantity: 'text-orange-700 dark:text-orange-400',
                          milk: 'text-orange-700 dark:text-orange-400',
                          addBtn: 'bg-orange-500 dark:bg-orange-700 hover:bg-orange-600 dark:hover:bg-orange-600',
                          editBtn: 'bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-400 hover:bg-orange-200 dark:hover:bg-orange-900/50'
                        } : {
                          bg: 'bg-blue-50 dark:bg-blue-900/15',
                          border: 'border-blue-200 dark:border-blue-800/60',
                          hoverBorder: 'hover:border-blue-300 dark:hover:border-blue-700/80',
                          badge: 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 border border-blue-200 dark:border-blue-800/60',
                          quantity: 'text-blue-700 dark:text-blue-400',
                          milk: 'text-blue-700 dark:text-blue-400',
                          addBtn: 'bg-blue-500 dark:bg-blue-700 hover:bg-blue-600 dark:hover:bg-blue-600',
                          editBtn: 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 hover:bg-blue-200 dark:hover:bg-blue-900/50'
                        };
                      %>
                      <div class="product-card <%= colorScheme.bg %> border-2 <%= colorScheme.border %> rounded-xl p-4 hover:shadow-lg <%= colorScheme.hoverBorder %> transition-all duration-200 relative"
                           data-product-id="<%= product.id %>" data-milk-type="<%= product.milk_type %>" data-milk-source="<%= product.milk_source || 'direct' %>" data-pool-id="<%= product.pool_id || '' %>">
                        
                        <!-- Product Info Row: Image Left, Name Right -->
                        <div class="flex items-start mb-3">
                          <!-- Product Image (Left) -->
                          <div class="flex-shrink-0 mr-4">
                            <% if (product.image_url) { %>
                              <div class="w-16 h-16 bg-gray-100 dark:bg-gray-700 rounded-xl overflow-hidden">
                                <img src="<%= product.image_url %>" alt="<%= product.name %>" class="w-full h-full object-cover">
                              </div>
                            <% } else { %>
                              <div class="w-16 h-16 bg-gray-100 dark:bg-gray-700 rounded-xl flex items-center justify-center">
                                <svg class="w-8 h-8 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                </svg>
                              </div>
                            <% } %>
                            <!-- Milk Type Badge (Below Product Image) -->
                            <span class="inline-flex items-center justify-center px-2 py-0.5 rounded-full text-xs font-semibold shadow-sm <%= colorScheme.badge %> mt-2 w-full">
                              <%= product.milk_type %>
                            </span>
                          </div>
                          
                          <!-- Product Name and Unit Size (Right) -->
                          <div class="flex-1 min-w-0">
                            <h4 class="font-bold text-gray-900 dark:text-white text-lg mb-1 leading-tight"><%= product.name %></h4>
                            <p class="text-sm text-gray-600 dark:text-gray-300"><%= product.unit_size %></p>
                            <!-- Available Milk/Pool Volume -->
                            <div class="mt-2">
                              <% if (product.milk_source === 'pool' && product.pool_id) { %>
                                <div class="text-xs text-gray-500 dark:text-gray-400">
                                  <span class="font-medium">Pool:</span> <span class="pool-volume" data-pool-id="<%= product.pool_id %>">Not allocated</span>
                                </div>
                              <% } else { %>
                                <div class="text-xs text-gray-500 dark:text-gray-400">
                                  <span class="font-medium">Direct:</span> <span class="direct-volume" data-milk-type="<%= product.milk_type %>" data-product-id="<%= product.id %>">Loading...</span>
                                </div>
                              <% } %>
                            </div>
                          </div>
                        </div>
                        
                        <!-- Production Data Display -->
                        <div class="production-data mb-3 hidden">
                          <div class="flex justify-between items-center mb-2">
                            <span class="text-sm text-gray-600 dark:text-gray-300">Quantity:</span>
                            <span class="text-xl font-bold <%= colorScheme.quantity %> production-quantity">0</span>
                          </div>
                          <div class="flex justify-between items-center">
                            <span class="text-sm text-gray-600 dark:text-gray-300">Milk Used:</span>
                            <span class="text-lg font-semibold <%= colorScheme.milk %> production-milk">0.0 L</span>
                          </div>
                        </div>
                        
                        <!-- Add Data Button -->
                        <button class="add-data-btn w-full <%= colorScheme.addBtn %> text-white text-sm font-semibold py-2.5 px-4 rounded-lg transition-colors"
                                data-product-id="<%= product.id %>">
                          <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                          </svg>
                          Add Production Data
                        </button>
                        
                        <!-- Action Buttons (hidden initially) -->
                        <div class="action-buttons flex gap-2 justify-end hidden">
             <!-- Edit Data Button -->
             <button class="edit-data-btn <%= colorScheme.editBtn %> p-2 rounded-lg transition-colors"
                     data-product-id="<%= product.id %>" title="Edit Production Data">
               <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
               </svg>
             </button>
             
             <!-- Delete Data Button -->
             <button class="delete-data-btn bg-red-100 text-red-500 p-2 rounded-lg hover:bg-red-200 transition-colors"
                     data-product-id="<%= product.id %>" title="Delete Production Data">
               <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
               </svg>
             </button>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                </div>
              <% } %>
            <% }) %>
          <% } else { %>
            <div class="text-center py-8">
              <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                </svg>
              </div>
              <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">No Products Found</h3>
              <p class="text-gray-600 dark:text-gray-300 mb-4">You need to add products before you can record production.</p>
              <a href="/production/products" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
                Manage Products
                <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Add Production Data Modal -->
      <div id="addProductionModal" class="fixed inset-0 bg-slate-900 overflow-y-auto h-full w-full hidden z-50" style="background-color: rgba(15, 23, 42, 0.75);">
        <div class="relative top-10 sm:top-20 mx-auto p-4 sm:p-5 border w-11/12 sm:w-5/6 md:w-3/4 lg:w-2/3 xl:w-1/2 max-w-2xl shadow-lg rounded-md bg-white dark:bg-gray-800 border-gray-200 dark:border-gray-700">
          <div class="mt-3">
            <div class="flex items-center justify-between mb-4 sm:mb-6 pb-3 border-b border-gray-200 dark:border-gray-700">
              <div class="flex items-center">
                <div class="w-8 h-8 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center mr-3">
                  <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg sm:text-xl font-semibold text-slate-900 dark:text-white">Add Production Data</h3>
                  <p class="text-sm text-gray-600 dark:text-gray-300">Record production data for this product</p>
                </div>
              </div>
              <button id="closeAddProductionModal" class="text-slate-400 dark:text-gray-500 hover:text-slate-600 dark:hover:text-gray-300 transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </button>
            </div>
            
            <form id="addProductionForm" class="space-y-3 sm:space-y-4">
              <input type="hidden" id="addProductId" name="product_id">
              <input type="hidden" id="addProductionDate" name="production_date">
              
              <!-- Product Info -->
              <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-3 sm:p-4 mb-3 sm:mb-4">
                <div class="flex items-center">
                  <div id="addProductImage" class="w-12 h-12 bg-gray-100 dark:bg-gray-700 rounded-lg overflow-hidden mr-3 flex-shrink-0 hidden">
                    <img id="addProductImageSrc" src="" alt="" class="w-full h-full object-cover">
                  </div>
                  <div class="flex-1">
                    <h4 id="addProductName" class="font-medium text-gray-900 dark:text-white"></h4>
                    <p id="addProductDetails" class="text-sm text-gray-600 dark:text-gray-300"></p>
                  </div>
                  <span id="addProductMilkType" class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium"></span>
                </div>
              </div>
              
              <!-- Quantity -->
              <div>
                <label class="block text-sm font-semibold text-slate-700 dark:text-gray-300 mb-1">Quantity Produced</label>
                <input type="number" id="addQuantity" name="quantity" step="0.1" min="0" required
                       class="w-full border border-slate-300 dark:border-gray-600 rounded-lg px-3 py-2 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                       placeholder="Enter quantity">
              </div>
              
              <!-- Milk Used (for manual entry products) -->
              <div id="addMilkUsedSection" class="hidden">
                <label class="block text-sm font-semibold text-slate-700 dark:text-gray-300 mb-1">Milk Used (Liters)</label>
                <input type="number" id="addMilkUsed" name="milk_used" step="0.1" min="0"
                       class="w-full border border-slate-300 dark:border-gray-600 rounded-lg px-3 py-2 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                       placeholder="Enter milk used">
              </div>
              
              <!-- Auto-calculated Milk Display -->
              <div id="addAutoMilkSection" class="hidden">
                <div class="bg-blue-50 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-800 rounded-lg p-3">
                  <div class="flex justify-between items-center">
                    <span class="text-sm font-medium text-blue-800 dark:text-blue-300">Milk Used (Auto-calculated):</span>
                    <span id="addAutoMilkAmount" class="text-sm font-semibold text-blue-900 dark:text-blue-200">0.0 L</span>
                  </div>
                </div>
              </div>
              
              <!-- Notes -->
              <div>
                <label class="block text-sm font-semibold text-slate-700 dark:text-gray-300 mb-1">Notes (Optional)</label>
                <textarea id="addNotes" name="notes" rows="3"
                          class="w-full border border-slate-300 dark:border-gray-600 rounded-lg px-3 py-2 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                          placeholder="Add any notes about this production..."></textarea>
              </div>
              
              <!-- Modal Actions -->
              <div class="flex flex-col sm:flex-row justify-end gap-3 pt-3 sm:pt-4">
                <button type="button" id="cancelAddProduction" class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors">
                  Cancel
                </button>
                <button type="submit" class="px-6 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors">
                  Save Production Data
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <!-- Edit Production Data Modal -->
      <div id="editProductionModal" class="fixed inset-0 bg-slate-900 overflow-y-auto h-full w-full hidden z-50" style="background-color: rgba(15, 23, 42, 0.75);">
        <div class="relative top-10 sm:top-20 mx-auto p-4 sm:p-5 border w-11/12 sm:w-5/6 md:w-3/4 lg:w-2/3 xl:w-1/2 max-w-2xl shadow-lg rounded-md bg-white">
          <div class="mt-3">
            <div class="flex items-center justify-between mb-4 sm:mb-6 pb-3 border-b border-gray-200">
              <div class="flex items-center">
                <div class="w-8 h-8 bg-orange-100 dark:bg-orange-900/30 rounded-lg flex items-center justify-center mr-3">
                  <svg class="w-5 h-5 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg sm:text-xl font-semibold text-slate-900 dark:text-white">Edit Production Data</h3>
                  <p class="text-sm text-gray-600 dark:text-gray-300">Adjust production data for this product</p>
                </div>
              </div>
              <button id="closeEditProductionModal" class="text-slate-400 dark:text-gray-500 hover:text-slate-600 dark:hover:text-gray-300 transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </button>
            </div>
            
            <form id="editProductionForm" class="space-y-3 sm:space-y-4">
              <input type="hidden" id="editProductId" name="product_id">
              <input type="hidden" id="editProductionDate" name="production_date">
              
              <!-- Product Info -->
              <div class="bg-gray-50 rounded-lg p-3 sm:p-4 mb-3 sm:mb-4">
                <div class="flex items-center">
                  <div id="editProductImage" class="w-12 h-12 bg-gray-100 rounded-lg overflow-hidden mr-3 flex-shrink-0 hidden">
                    <img id="editProductImageSrc" src="" alt="" class="w-full h-full object-cover">
                  </div>
                  <div class="flex-1">
                    <h4 id="editProductName" class="font-medium text-gray-900 dark:text-white"></h4>
                    <p id="editProductDetails" class="text-sm text-gray-600 dark:text-gray-300"></p>
                  </div>
                  <span id="editProductMilkType" class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium"></span>
                </div>
              </div>
              
              <!-- Current Production Data -->
              <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 mb-4">
                <h4 class="text-sm font-semibold text-blue-800 mb-2">Current Production Data</h4>
                <div class="grid grid-cols-2 gap-3 text-sm">
                  <div>
                    <span class="text-blue-700">Quantity Produced:</span>
                    <span id="editCurrentQuantity" class="font-medium text-blue-900 ml-1">0</span>
                  </div>
                  <div>
                    <span class="text-blue-700">Milk Used:</span>
                    <span id="editCurrentMilkUsed" class="font-medium text-blue-900 ml-1">0.0 L</span>
                  </div>
                </div>
              </div>
              
              <!-- Action Type -->
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Action</label>
                <div class="flex space-x-4">
                  <label class="flex items-center">
                    <input type="radio" id="editActionAdd" name="editProductionAction" value="add" class="h-4 w-4 text-green-600 focus:ring-green-500 border-gray-300 dark:border-gray-600" checked>
                    <span class="ml-2 text-sm text-gray-700">Add to production</span>
                  </label>
                  <label class="flex items-center">
                    <input type="radio" id="editActionRemove" name="editProductionAction" value="remove" class="h-4 w-4 text-red-600 focus:ring-red-500 border-gray-300 dark:border-gray-600">
                    <span class="ml-2 text-sm text-gray-700">Remove from production</span>
                  </label>
                </div>
              </div>
              
              <!-- Quantity Adjustment -->
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1">Quantity Adjustment</label>
                <div class="space-y-3">
                  
                  <!-- Adjustment Amount -->
                  <div>
                    <input type="number" id="editQuantityAdjustment" name="quantity_adjustment" step="0.1" min="0" required
                           class="w-full border border-slate-300 rounded-lg px-3 py-2 text-slate-900 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           placeholder="Enter adjustment amount">
                  </div>
                </div>
              </div>
              
              <!-- Milk Used Adjustment (for manual entry products) -->
              <div id="editMilkUsedSection" class="hidden">
                <label class="block text-sm font-semibold text-slate-700 mb-1">Milk Used Adjustment (Liters)</label>
                <input type="number" id="editMilkUsedAdjustment" name="milk_used_adjustment" step="0.1" min="0"
                       class="w-full border border-slate-300 rounded-lg px-3 py-2 text-slate-900 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                       placeholder="Enter milk used adjustment">
              </div>
              
              <!-- Auto-calculated Milk Adjustment Display -->
              <div id="editAutoMilkSection" class="hidden">
                <div class="bg-orange-50 border border-orange-200 rounded-lg p-3">
                  <div class="flex justify-between items-center">
                    <span class="text-sm font-medium text-orange-800">Milk Adjustment (Auto-calculated):</span>
                    <span id="editAutoMilkAdjustment" class="text-sm font-semibold text-orange-900">0.0 L</span>
                  </div>
                </div>
              </div>
              
              <!-- Notes -->
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1">Notes (Optional)</label>
                <textarea id="editNotes" name="notes" rows="3"
                          class="w-full border border-slate-300 rounded-lg px-3 py-2 text-slate-900 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                          placeholder="Add any notes about this adjustment..."></textarea>
              </div>
              
              <!-- Modal Actions -->
              <div class="flex flex-col sm:flex-row justify-end gap-3 pt-3 sm:pt-4">
                <button type="button" id="cancelEditProduction" class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 border border-gray-300 rounded-lg hover:bg-gray-200 transition-colors">
                  Cancel
                </button>
                <button type="submit" class="px-6 py-2 text-sm font-medium text-white bg-orange-600 rounded-lg hover:bg-orange-700 transition-colors">
                  Update Production Data
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <!-- Add Milk Modal -->
      <div id="addMilkModal" class="fixed inset-0 bg-slate-900 overflow-y-auto h-full w-full hidden z-50" style="background-color: rgba(15, 23, 42, 0.75);">
        <div class="relative top-10 sm:top-20 mx-auto p-4 sm:p-5 border border-gray-200 dark:border-gray-700 w-11/12 sm:w-5/6 md:w-3/4 lg:w-2/3 xl:w-1/2 max-w-2xl shadow-lg rounded-md bg-white dark:bg-gray-800">
          <div class="mt-3">
            <div class="flex items-center justify-between mb-4 sm:mb-6 pb-3 border-b border-gray-200 dark:border-gray-700">
              <div class="flex items-center">
                <div class="w-8 h-8 bg-green-100 dark:bg-green-900/30 rounded-lg flex items-center justify-center mr-3">
                  <svg class="w-5 h-5 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg sm:text-xl font-semibold text-slate-900 dark:text-white">Add Initial Milk Inventory</h3>
                  <p class="text-sm text-gray-600 dark:text-gray-300">Enter initial milk inventory for production</p>
                </div>
              </div>
              <button id="closeAddMilkModal" class="text-slate-400 dark:text-gray-400 hover:text-slate-600 dark:hover:text-gray-300 transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </button>
            </div>
            
            <form id="addMilkForm" class="space-y-3 sm:space-y-4">
              <input type="hidden" id="addMilkType" name="milk_type">
              <input type="hidden" id="addMilkProductionDate" name="production_date">
              
              <!-- Milk Type Info -->
              <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-3 sm:p-4 mb-3 sm:mb-4">
                <div class="flex items-center">
                  <div id="addMilkTypeIndicator" class="w-4 h-4 rounded-full mr-3"></div>
                  <div class="flex-1">
                    <h4 id="addMilkTypeName" class="font-medium text-gray-900 dark:text-white"></h4>
                    <p class="text-sm text-gray-600 dark:text-gray-300">Enter initial milk inventory for this type</p>
                  </div>
                </div>
              </div>
              
              <!-- Initial Available Milk -->
              <div>
                <label class="block text-sm font-semibold text-slate-700 dark:text-gray-300 mb-1">Initial Available Milk (Liters)</label>
                <input type="number" id="addAvailableMilk" name="available" step="0.1" min="0" required
                       class="w-full border border-slate-300 dark:border-gray-600 rounded-lg px-3 py-2 text-slate-900 dark:text-white bg-white dark:bg-gray-700 focus:ring-2 focus:ring-green-500 focus:border-green-500"
                       placeholder="Enter initial available milk quantity">
              </div>
              
              <!-- Wasted Milk -->
              <div>
                <label class="block text-sm font-semibold text-slate-700 dark:text-gray-300 mb-1">Wasted Milk (Liters)</label>
                <input type="number" id="addWastedMilk" name="wasted" step="0.1" min="0"
                       class="w-full border border-slate-300 dark:border-gray-600 rounded-lg px-3 py-2 text-slate-900 dark:text-white bg-white dark:bg-gray-700 focus:ring-2 focus:ring-green-500 focus:border-green-500"
                       placeholder="Enter wasted milk quantity">
              </div>
              
              <!-- Notes -->
              <div>
                <label class="block text-sm font-semibold text-slate-700 dark:text-gray-300 mb-1">Notes (Optional)</label>
                <textarea id="addMilkNotes" name="notes" rows="3"
                          class="w-full border border-slate-300 dark:border-gray-600 rounded-lg px-3 py-2 text-slate-900 dark:text-white bg-white dark:bg-gray-700 focus:ring-2 focus:ring-green-500 focus:border-green-500"
                          placeholder="Add any notes about this milk inventory..."></textarea>
              </div>
              

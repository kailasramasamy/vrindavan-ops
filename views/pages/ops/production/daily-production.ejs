    async function saveAddProductionData(event) {
      if (event) event.preventDefault();
      
      
      const productId = document.getElementById('addProductId').value;
      const quantity = parseFloat(document.getElementById('addQuantity').value) || 0;
      const milkUsed = parseFloat(document.getElementById('addMilkUsed').value) || 0;
      const notes = document.getElementById('addNotes').value;
      const productionDate = document.getElementById('addProductionDate').value;
      
      
      if (quantity <= 0) {
        showErrorToast('Please enter a valid quantity');
        return;
      }

      // Get product data for validation
      const product = getProductById(productId);
      if (!product) {
        showErrorToast('Product not found');
        return;
      }
      
      // Calculate final milk usage
      let finalMilkUsed = milkUsed;
      if (product.auto_calculate_milk) {
        finalMilkUsed = quantity * product.milk_per_unit;
      }

      // Validate available milk/pool volume
      const productCard = document.querySelector(`.product-card[data-product-id="${productId}"]`);
      if (!productCard) {
        showErrorToast('Product card not found');
        return;
      }

      const milkSource = productCard.dataset.milkSource;
      
      if (milkSource === 'pool') {
        const poolId = productCard.dataset.poolId;
        if (!poolId) {
          showErrorToast('No pool assigned to this product');
          return;
        }
        
        const poolCard = document.querySelector(`[data-pool-id="${poolId}"]`);
        if (!poolCard) {
          showErrorToast('Pool not found');
          return;
        }
        
        const allocatedSpan = poolCard.querySelector('.pool-allocated');
        if (!allocatedSpan) {
          showErrorToast('Pool allocation data not found');
          return;
        }
        
        const availableVolume = parseFloat(allocatedSpan.textContent) || 0;
        if (availableVolume <= 0) {
          showErrorToast('No milk allocated to this pool. Please allocate milk to the pool first.');
          return;
        }
        
        if (finalMilkUsed > availableVolume) {
          showErrorToast(`Insufficient pool volume. Available: ${availableVolume.toFixed(1)}L, Required: ${finalMilkUsed.toFixed(1)}L`);
          return;
        }
      } else {
        // Direct milk source
        const milkType = productCard.dataset.milkType;
        const milkCard = document.querySelector(`.milk-inventory-card[data-milk-type="${milkType}"]`);
        if (!milkCard) {
          showErrorToast('Milk inventory not found');
          return;
        }
        
        const remainingSpan = milkCard.querySelector('.milk-remaining');
        if (!remainingSpan) {
          showErrorToast('Milk inventory data not found');
          return;
        }
        
        const availableVolume = parseFloat(remainingSpan.textContent) || 0;
        if (availableVolume <= 0) {
          showErrorToast('No milk available in inventory. Please add milk to inventory first.');
          return;
        }
        
        if (finalMilkUsed > availableVolume) {
          showErrorToast(`Insufficient milk in inventory. Available: ${availableVolume.toFixed(1)}L, Required: ${finalMilkUsed.toFixed(1)}L`);
          return;
        }
      }

      const productionData = {
        product_id: productId,
        quantity_produced: quantity,
        milk_used: finalMilkUsed,
        notes: notes,
        production_date: productionDate
      };

      try {
        const response = await fetch('/production/daily-production', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(productionData)
        });

        const result = await response.json();

        if (result.success) {
          showSuccessToast('Production data saved successfully');
          closeAddProductionModal();
          updateProductCard(productId, productionData);
          updateMilkInventoryAfterProduction(productId, finalMilkUsed);
        } else {
          throw new Error(result.error || 'Failed to save production data');
        }
      } catch (error) {
        console.error('Error saving production data:', error);
        showErrorToast('Failed to save production data: ' + error.message);
      }
    }

    async function saveEditProductionData(event) {
      if (event) event.preventDefault();
      
      
      const productId = document.getElementById('editProductId').value;
      const quantityAdjustment = parseFloat(document.getElementById('editQuantityAdjustment').value) || 0;
      const action = document.querySelector('input[name="editProductionAction"]:checked').value;
      const milkUsedAdjustment = parseFloat(document.getElementById('editMilkUsedAdjustment').value) || 0;
      const notes = document.getElementById('editNotes').value;
      const productionDate = document.getElementById('editProductionDate').value;
      
      
      if (quantityAdjustment <= 0) {
        showErrorToast('Please enter a valid adjustment amount');
        return;
      }

      // Get product data for validation
      const product = getProductById(productId);
      if (!product) {
        showErrorToast('Product not found');
        return;
      }

      // Get current production data from API
      let currentData;
      try {
        const response = await fetch(`/production/daily-production/api?date=${productionDate}`);
        const result = await response.json();
        
        if (result.success && result.production) {
          currentData = result.production.find(entry => entry.product_id == productId);
          if (!currentData) {
            showErrorToast('No existing production data found for this product');
            return;
          }
        } else {
          throw new Error(result.error || 'Failed to fetch production data');
        }
      } catch (error) {
        console.error('Error fetching current production data:', error);
        showErrorToast('Failed to load current production data');
        return;
      }

      // For remove operations, validate that we don't remove more than available
      if (action === 'remove') {
        const currentQuantity = parseFloat(currentData.quantity_produced || 0);
        if (quantityAdjustment > currentQuantity) {
          showErrorToast(`Cannot remove ${quantityAdjustment} units. Only ${currentQuantity} units available.`);
          return;
        }
      }

      // Calculate new quantities
      let newQuantity;
      if (action === 'add') {
        newQuantity = parseFloat(currentData.quantity_produced || 0) + quantityAdjustment;
      } else {
        newQuantity = Math.max(0, parseFloat(currentData.quantity_produced || 0) - quantityAdjustment);
      }

      // Calculate milk adjustment
      let milkAdjustment;
      if (product.auto_calculate_milk) {
        // Auto-calculate based on quantity adjustment
        milkAdjustment = quantityAdjustment * product.milk_per_unit;
      } else {
        // Use manual milk adjustment
        milkAdjustment = milkUsedAdjustment;
      }

      // Apply action to milk adjustment
      if (action === 'remove') {
        milkAdjustment = -milkAdjustment;
      }

      const newMilkUsed = Math.max(0, parseFloat(currentData.milk_used || 0) + milkAdjustment);

      // Validate available milk/pool volume for the adjustment
      const productCard = document.querySelector(`.product-card[data-product-id="${productId}"]`);
      if (!productCard) {
        showErrorToast('Product card not found');
        return;
      }

      const milkSource = productCard.dataset.milkSource;
      
      if (milkSource === 'pool') {
        const poolId = productCard.dataset.poolId;
        if (!poolId) {
          showErrorToast('No pool assigned to this product');
          return;
        }
        
        const poolCard = document.querySelector(`[data-pool-id="${poolId}"]`);
        if (!poolCard) {
          showErrorToast('Pool not found');
          return;
        }
        
        const allocatedSpan = poolCard.querySelector('.pool-allocated');
        if (!allocatedSpan) {
          showErrorToast('Pool allocation data not found');
          return;
        }
        
        const availableVolume = parseFloat(allocatedSpan.textContent) || 0;
        if (availableVolume <= 0) {
          showErrorToast('No milk allocated to this pool. Please allocate milk to the pool first.');
          return;
        }
        
        // For add operations, check if we have enough additional milk in pool
        // For remove operations, we don't need to check (we're freeing up milk)
        if (action === 'add' && milkAdjustment > availableVolume) {
          showErrorToast(`Insufficient pool volume. Available: ${availableVolume.toFixed(1)}L, Additional Required: ${milkAdjustment.toFixed(1)}L`);
          return;
        }
      } else {
        // Direct milk source
        const milkType = productCard.dataset.milkType;
        const milkCard = document.querySelector(`.milk-inventory-card[data-milk-type="${milkType}"]`);
        if (!milkCard) {
          showErrorToast('Milk inventory not found');
          return;
        }
        
        const remainingSpan = milkCard.querySelector('.milk-remaining');
        if (!remainingSpan) {
          showErrorToast('Milk inventory data not found');
          return;
        }
        
        const availableVolume = parseFloat(remainingSpan.textContent) || 0;
        if (availableVolume <= 0) {
          showErrorToast('No milk available in inventory. Please add milk to inventory first.');
          return;
        }
        
        // For add operations, check if we have enough additional milk
        // For remove operations, we don't need to check (we're freeing up milk)
        if (action === 'add' && milkAdjustment > availableVolume) {
          showErrorToast(`Insufficient milk in inventory. Available: ${availableVolume.toFixed(1)}L, Additional Required: ${milkAdjustment.toFixed(1)}L`);
          return;
        }
      }

      const productionData = {
        product_id: productId,
        quantity_produced: newQuantity,
        milk_used: newMilkUsed,
        notes: notes,
        production_date: productionDate
      };

      try {
        const response = await fetch('/production/daily-production', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(productionData)
        });

        const result = await response.json();

        if (result.success) {
          showSuccessToast(`Production data updated successfully (${action === 'add' ? '+' : '-'}${quantityAdjustment} units)`);
          closeEditProductionModal();
          updateProductCard(productId, productionData);

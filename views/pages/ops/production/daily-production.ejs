    async function savePoolAllocation(poolId, allocatedAmount) {
      try {
        const productionDate = document.getElementById('productionDate').value;
        
        const allocation = {
          allocation_date: productionDate,
          pool_id: parseInt(poolId),
          milk_allocated: allocatedAmount,
          notes: ''
        };
        
        const response = await fetch('/production/pool-allocations/api', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(allocation)
        });
        
        const result = await response.json();
        if (!result.success) {
          throw new Error(result.error || 'Failed to save allocation');
        }
        
        // Update the UI immediately
        updatePoolAllocationCard(poolId, allocatedAmount);
        
        // Refresh pool allocations to ensure they're fully rendered
        await refreshPoolAllocations();
        
        // Refresh milk inventory cards to reflect pool allocations
        await refreshMilkInventoryCards();
        
        // Update product volumes after both pool allocations and milk inventory are refreshed
        updateProductVolumes();
        
        if (allocatedAmount > 0) {
          showSuccessToast('Pool allocation saved successfully');
        }
        // Note: For deletion (allocatedAmount === 0), toast is handled by the calling function
      } catch (error) {
        console.error('Error saving pool allocation:', error);
        showErrorToast('Error saving pool allocation');
      }
    }
    

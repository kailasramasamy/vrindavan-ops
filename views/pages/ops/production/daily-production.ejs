    async function confirmDeleteProduction() {
      if (!currentDeleteProductId) return;

      // Store the product ID in a local variable to prevent it from being reset
      const productIdToDelete = currentDeleteProductId;

      try {
        const productionDate = document.getElementById('productionDate').value;
        
        // Get existing data BEFORE deletion for milk inventory update
        const existingData = getExistingProductionDataFromDOM(productIdToDelete);
        const product = getProductById(productIdToDelete);
        
        const response = await fetch('/production/daily-production', {
          method: 'DELETE',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            product_id: productIdToDelete,
            production_date: productionDate
          })
        });

        const result = await response.json();

        if (result.success) {
          showSuccessToast('Production data deleted successfully');
          closeDeleteProductionModal();
          
          // Reset the product card to fresh state
          resetProductCard(productIdToDelete);
          
          // Refresh milk inventory display (server already updated the inventory)
          await refreshMilkInventoryCards();
        } else {
          throw new Error(result.error || 'Failed to delete production data');
        }
      } catch (error) {
        console.error('Error deleting production data:', error);
        showErrorToast('Failed to delete production data: ' + error.message);
        closeDeleteProductionModal();
      }
    }


<%- include('../../../partials/_head', { seo, pageKey }) %>

<body class="bg-gray-50 dark:bg-gray-900">
  <%- include('../../../partials/_subnav', { user, section, subsection }) %>
  
  <div class="min-h-screen pt-16">
  <!-- Main Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Pool Management</h1>
          <p class="mt-1 text-sm text-gray-600 dark:text-gray-300">Manage milk pools for production allocation</p>
        </div>
        <button id="addPoolBtn" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors flex items-center space-x-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
          </svg>
          <span>Add New Pool</span>
        </button>
      </div>
    </div>

    <!-- Pools Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% if (pools && pools.length > 0) { %> <% pools.forEach(pool => { %>
      <% 
        // Define color scheme based on milk type
        const colorScheme = pool.milk_type === 'A1' ? {
          bg: 'bg-green-50',
          border: 'border-green-200',
          hoverShadow: 'hover:shadow-lg hover:shadow-green-100',
          badge: 'bg-green-100 text-green-800',
          editBtn: 'bg-green-100 text-green-600 hover:bg-green-200'
        } : pool.milk_type === 'A2' ? {
          bg: 'bg-orange-50',
          border: 'border-orange-200',
          hoverShadow: 'hover:shadow-lg hover:shadow-orange-100',
          badge: 'bg-orange-100 text-orange-800',
          editBtn: 'bg-orange-100 text-orange-600 hover:bg-orange-200'
        } : {
          bg: 'bg-blue-50',
          border: 'border-blue-200',
          hoverShadow: 'hover:shadow-lg hover:shadow-blue-100',
          badge: 'bg-blue-100 text-blue-800',
          editBtn: 'bg-blue-100 text-blue-600 hover:bg-blue-200'
        };
      %>
      <div class="<%= colorScheme.bg %> rounded-lg shadow-md border-2 <%= colorScheme.border %> p-6 <%= colorScheme.hoverShadow %> transition-all duration-200">
        <div class="flex items-start justify-between mb-4">
          <div class="flex-1">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1"><%= pool.name %></h3>
            <p class="text-sm text-gray-600 dark:text-gray-300 mb-2"><%= pool.description || 'No description' %></p>
            <div class="flex items-center space-x-4">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= colorScheme.badge %>"><%= pool.milk_type %> Milk</span>
              <span class="text-sm text-gray-500"><%= pool.product_count %> products</span>
            </div>
          </div>
          <div class="flex space-x-2">
            <button class="edit-pool-btn <%= colorScheme.editBtn %> p-2 rounded-lg transition-colors" data-pool-id="<%= pool.id %>" title="Edit Pool">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
              </svg>
            </button>
            <button class="delete-pool-btn bg-red-100 text-red-500 p-2 rounded-lg hover:bg-red-200 transition-colors" data-pool-id="<%= pool.id %>" title="Delete Pool">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
              </svg>
            </button>
          </div>
        </div>
        <div class="text-sm text-gray-500">Created: <%= new Date(pool.created_at).toLocaleDateString() %></div>
      </div>
      <% }); %> <% } else { %>
      <div class="col-span-full text-center py-12">
        <svg class="w-16 h-16 mx-auto text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
        </svg>
        <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">No milk pools found</h3>
        <p class="text-gray-500 mb-4">Create your first milk pool to get started with production allocation.</p>
        <button id="addFirstPoolBtn" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors">Create First Pool</button>
      </div>
      <% } %>
    </div>
  </div>
</div>

<!-- Add/Edit Pool Modal -->
<div id="poolModal" class="fixed inset-0 bg-slate-900 overflow-y-auto h-full w-full hidden z-50 transition-opacity duration-300" style="background-color: rgba(15, 23, 42, 0.7)">
  <div class="relative top-20 mx-auto p-5 border w-11/12 md:w-1/2 lg:w-1/3 max-w-md shadow-2xl rounded-lg bg-white dark:bg-gray-800 ring-1 ring-slate-200 dark:ring-gray-700 transform transition-all duration-300 scale-95 opacity-0">
    <div class="mt-3">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-slate-900" id="poolModalTitle">Add New Pool</h3>
        <button id="closePoolModal" class="text-slate-400 hover:text-slate-600">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <form id="poolForm">
        <div class="space-y-4">
          <div>
            <label for="poolName" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Pool Name</label>
            <input type="text" id="poolName" name="name" required class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
          </div>

          <div>
            <label for="poolDescription" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Description</label>
            <textarea id="poolDescription" name="description" rows="3" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"></textarea>
          </div>

          <div>
            <label for="poolMilkType" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Milk Type</label>
            <select id="poolMilkType" name="milk_type" required class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
              <option value="">Select milk type</option>
              <option value="A1">A1 Milk</option>
              <option value="A2">A2 Milk</option>
              <option value="Buffalo">Buffalo Milk</option>
            </select>
          </div>

          <div class="flex items-center">
            <input type="checkbox" id="poolIsActive" name="is_active" checked class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 dark:border-gray-600 rounded" />
            <label for="poolIsActive" class="ml-2 block text-sm text-gray-700 dark:text-gray-300">Active</label>
          </div>
        </div>

        <div class="flex justify-end space-x-3 mt-6">
          <button type="button" id="cancelPoolBtn" class="px-4 py-2 bg-gray-300 dark:bg-gray-600 text-gray-700 dark:text-gray-300 text-sm font-medium rounded-lg hover:bg-gray-400 dark:hover:bg-gray-500 transition-colors">Cancel</button>
          <button type="submit" id="savePoolBtn" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">Save Pool</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="deletePoolModal" class="fixed inset-0 bg-slate-900 overflow-y-auto h-full w-full hidden z-50 transition-opacity duration-300" style="background-color: rgba(15, 23, 42, 0.7)">
  <div class="relative top-20 mx-auto p-5 border w-11/12 md:w-1/3 lg:w-1/4 xl:w-1/5 max-w-sm shadow-2xl rounded-lg bg-white dark:bg-gray-800 ring-1 ring-slate-200 dark:ring-gray-700 transform transition-all duration-300 scale-95 opacity-0">
    <div class="mt-3">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-slate-900">Delete Pool</h3>
        <button id="closeDeletePoolModal" class="text-slate-400 hover:text-slate-600">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <div class="text-center">
        <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
          </svg>
        </div>
        <h4 class="text-lg font-semibold text-slate-900 mb-2">Are you sure?</h4>
        <p class="text-slate-600 mb-6">This action cannot be undone. This will permanently delete the milk pool and remove it from all associated products.</p>

        <div class="flex justify-center space-x-3">
          <button id="cancelDeletePoolBtn" class="px-4 py-2 bg-slate-300 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-400 transition-colors">Cancel</button>
          <button id="confirmDeletePoolBtn" class="px-4 py-2 bg-red-600 text-white text-sm font-medium rounded-lg hover:bg-red-700 transition-colors">Delete Pool</button>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../../../partials/_footer') %> <%- include('../../../partials/_toast') %>

<script>
  let currentPoolId = null;
  let isEditMode = false;

  // Modal functions
  function showPoolModal(editMode = false, poolData = null) {
    isEditMode = editMode;
    currentPoolId = poolData ? poolData.id : null;

    const modal = document.getElementById("poolModal");
    const modalTitle = document.getElementById("poolModalTitle");
    const form = document.getElementById("poolForm");

    if (editMode && poolData) {
      modalTitle.textContent = "Edit Pool";
      document.getElementById("poolName").value = poolData.name;
      document.getElementById("poolDescription").value = poolData.description || "";
      document.getElementById("poolMilkType").value = poolData.milk_type;
      document.getElementById("poolIsActive").checked = poolData.is_active;
    } else {
      modalTitle.textContent = "Add New Pool";
      form.reset();
      document.getElementById("poolIsActive").checked = true;
    }

    modal.classList.remove("hidden");
    setTimeout(() => {
      const modalContent = modal.querySelector(".relative");
      if (modalContent) {
        modalContent.classList.remove("scale-95", "opacity-0");
        modalContent.classList.add("scale-100", "opacity-100");
      }
    }, 10);
  }

  function closePoolModal() {
    const modal = document.getElementById("poolModal");
    const modalContent = modal.querySelector(".relative");
    if (modalContent) {
      modalContent.classList.remove("scale-100", "opacity-100");
      modalContent.classList.add("scale-95", "opacity-0");
      setTimeout(() => {
        modal.classList.add("hidden");
      }, 300);
    }
    currentPoolId = null;
    isEditMode = false;
  }

  function showDeletePoolModal(poolId) {
    currentPoolId = poolId;
    const modal = document.getElementById("deletePoolModal");
    modal.classList.remove("hidden");
    setTimeout(() => {
      const modalContent = modal.querySelector(".relative");
      if (modalContent) {
        modalContent.classList.remove("scale-95", "opacity-0");
        modalContent.classList.add("scale-100", "opacity-100");
      }
    }, 10);
  }

  function closeDeletePoolModal() {
    const modal = document.getElementById("deletePoolModal");
    const modalContent = modal.querySelector(".relative");
    if (modalContent) {
      modalContent.classList.remove("scale-100", "opacity-100");
      modalContent.classList.add("scale-95", "opacity-0");
      setTimeout(() => {
        modal.classList.add("hidden");
      }, 300);
    }
    currentPoolId = null;
  }

  // Toast functions are provided by the _toast partial

  // Event listeners
  document.addEventListener("DOMContentLoaded", function () {
    // Add pool buttons
    const addPoolBtn = document.getElementById("addPoolBtn");
    if (addPoolBtn) {
      addPoolBtn.addEventListener("click", () => showPoolModal(false));
    }
    
    const addFirstPoolBtn = document.getElementById("addFirstPoolBtn");
    if (addFirstPoolBtn) {
      addFirstPoolBtn.addEventListener("click", () => showPoolModal(false));
    }

    // Edit pool buttons
    document.querySelectorAll(".edit-pool-btn").forEach((btn) => {
      btn.addEventListener("click", async function () {
        const poolId = this.dataset.poolId;
        try {
          const response = await fetch(`/production/milk-pools/api/${poolId}`);
          const result = await response.json();
          if (result.success) {
            showPoolModal(true, result.pool);
          } else {
            showErrorToast("Failed to fetch pool data");
          }
        } catch (error) {
          showErrorToast("Error fetching pool data");
        }
      });
    });

    // Delete pool buttons
    document.querySelectorAll(".delete-pool-btn").forEach((btn) => {
      btn.addEventListener("click", function () {
        showDeletePoolModal(this.dataset.poolId);
      });
    });

    // Modal close buttons
    const closePoolModalBtn = document.getElementById("closePoolModal");
    if (closePoolModalBtn) {
      closePoolModalBtn.addEventListener("click", closePoolModal);
    }
    
    const cancelPoolBtn = document.getElementById("cancelPoolBtn");
    if (cancelPoolBtn) {
      cancelPoolBtn.addEventListener("click", closePoolModal);
    }
    
    const closeDeletePoolModalBtn = document.getElementById("closeDeletePoolModal");
    if (closeDeletePoolModalBtn) {
      closeDeletePoolModalBtn.addEventListener("click", closeDeletePoolModal);
    }
    
    const cancelDeletePoolBtn = document.getElementById("cancelDeletePoolBtn");
    if (cancelDeletePoolBtn) {
      cancelDeletePoolBtn.addEventListener("click", closeDeletePoolModal);
    }

    // Form submission
    const poolForm = document.getElementById("poolForm");
    if (poolForm) {
      poolForm.addEventListener("submit", async function (e) {
      e.preventDefault();

      const formData = new FormData(this);
      const poolData = {
        name: formData.get("name"),
        description: formData.get("description"),
        milk_type: formData.get("milk_type"),
        is_active: formData.get("is_active") === "on",
      };

      try {
        const url = isEditMode ? `/production/milk-pools/api/${currentPoolId}` : "/production/milk-pools/api";
        const method = isEditMode ? "PUT" : "POST";

        const response = await fetch(url, {
          method: method,
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(poolData),
        });

        const result = await response.json();

        if (result.success) {
          showSuccessToast(isEditMode ? "Pool updated successfully" : "Pool created successfully");
          closePoolModal();
          setTimeout(() => {
            window.location.reload();
          }, 1000);
        } else {
          showErrorToast(result.error || "Failed to save pool");
        }
      } catch (error) {
        showErrorToast("Error saving pool");
      }
      });
    }

    // Delete confirmation
    const confirmDeletePoolBtn = document.getElementById("confirmDeletePoolBtn");
    if (confirmDeletePoolBtn) {
      confirmDeletePoolBtn.addEventListener("click", async function () {
      if (!currentPoolId) return;

      try {
        const response = await fetch(`/production/milk-pools/api/${currentPoolId}`, {
          method: "DELETE",
        });

        const result = await response.json();

        if (result.success) {
          showSuccessToast("Pool deleted successfully");
          closeDeletePoolModal();
          setTimeout(() => {
            window.location.reload();
          }, 1000);
        } else {
          showErrorToast(result.error || "Failed to delete pool");
        }
      } catch (error) {
        showErrorToast("Error deleting pool");
      }
      });
    }
  });
</script>

</body>
</html>

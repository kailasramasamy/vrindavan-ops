<%- include('../../../partials/_head', { seo, pageKey }) %>

<body class="bg-gray-50 dark:bg-gray-900">
  <%- include('../../../partials/_subnav', { user, section: 'Production', page: 'Dashboard' }) %>
  
  <div class="min-h-screen pt-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">

      <!-- Page Header -->
      <div class="mb-8">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
          <div>
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Production Dashboard</h1>
            <p class="text-gray-600 dark:text-gray-300">Overview of daily production and key performance indicators</p>
          </div>
          <div class="mt-4 sm:mt-0 flex flex-col sm:flex-row gap-4">
            <input type="date" id="dateFilter" value="<%= date %>" 
                   class="border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            <select id="timeFilter" class="border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
              <option value="day" <%= time === 'day' ? 'selected' : '' %>>Day</option>
              <option value="week" <%= time === 'week' ? 'selected' : '' %>>Week</option>
              <option value="month" <%= time === 'month' ? 'selected' : '' %>>Month</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Quick Action Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <!-- Daily Production Entry -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden hover:shadow-md transition-shadow">
          <div class="p-6">
            <div class="flex items-center mb-4">
              <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                </svg>
              </div>
              <h3 class="ml-3 text-lg font-semibold text-gray-900 dark:text-white">Daily Production</h3>
            </div>
            <p class="text-gray-600 dark:text-gray-300 mb-4">Record today's production quantities and track milk usage for each product.</p>
            <a href="/production/daily-production" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
              Enter Production
              <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>

        <!-- Analytics -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden hover:shadow-md transition-shadow">
          <div class="p-6">
            <div class="flex items-center mb-4">
              <div class="w-10 h-10 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
              </div>
              <h3 class="ml-3 text-lg font-semibold text-gray-900 dark:text-white">Analytics</h3>
            </div>
            <p class="text-gray-600 dark:text-gray-300 mb-4">Analyze production trends, milk usage patterns, and efficiency metrics.</p>
            <a href="/production/analytics" class="inline-flex items-center px-4 py-2 bg-purple-600 text-white text-sm font-medium rounded-lg hover:bg-purple-700 transition-colors">
              View Analytics
              <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Summary Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <!-- Total Products Produced -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm p-6 border border-gray-200 dark:border-gray-700">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                </svg>
              </div>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Products Produced</p>
              <p class="text-2xl font-semibold text-gray-900 dark:text-white">
                <%= productionSummary ? productionSummary.total_products_produced || 0 : 0 %>
              </p>
            </div>
          </div>
        </div>

        <!-- Total Milk Used -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm p-6 border border-gray-200 dark:border-gray-700">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 bg-green-100 dark:bg-green-900/30 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                </svg>
              </div>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Total Milk Used</p>
              <p class="text-2xl font-semibold text-gray-900 dark:text-white">
                <%= milkInventory ? (parseFloat(milkInventory.total_used) || 0).toFixed(1) : '0.0' %> L
              </p>
            </div>
          </div>
        </div>

        <!-- Total Quantity Produced -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm p-6 border border-gray-200 dark:border-gray-700">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 bg-yellow-100 dark:bg-yellow-900/30 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-yellow-600 dark:text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
              </div>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Total Quantity</p>
              <p class="text-2xl font-semibold text-gray-900 dark:text-white">
                <%= productionSummary ? (parseFloat(productionSummary.total_quantity_produced) || 0).toFixed(1) : '0.0' %>
              </p>
            </div>
          </div>
        </div>

        <!-- Production Efficiency -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm p-6 border border-gray-200 dark:border-gray-700">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                </svg>
              </div>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Efficiency</p>
              <p class="text-2xl font-semibold text-gray-900 dark:text-white">
                <% if (productionSummary && milkInventory) { %>
                  <% const totalAvailable = (milkInventory.a1_available || 0) + (milkInventory.a2_available || 0) + (milkInventory.buffalo_available || 0); %>
                  <% const totalUsed = parseFloat(productionSummary.total_milk_used) || 0; %>
                  <% const efficiency = totalAvailable > 0 ? ((totalUsed / totalAvailable) * 100).toFixed(1) : 0; %>
                  <%= efficiency %>%
                <% } else { %>
                  0%
                <% } %>
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Milk Usage by Type - Individual Cards -->
      <div class="mb-8">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-6">Milk Usage by Type</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- A1 Milk Card -->
          <div class="bg-gradient-to-br from-green-50 to-green-100 dark:from-green-900/30 dark:to-green-800/30 rounded-xl shadow-sm border border-green-200 dark:border-green-800 p-6">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center">
                <div class="w-12 h-12 bg-green-500 dark:bg-green-600 rounded-lg flex items-center justify-center mr-3">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-green-900 dark:text-green-200">A1 Milk</h3>
                  <p class="text-sm text-green-600 dark:text-green-400">Cow Milk Type A1</p>
                </div>
              </div>
            </div>
            
            <div class="space-y-3">
              <div class="flex justify-between items-center">
                <span class="text-sm font-medium text-green-700 dark:text-green-300">Total Volume</span>
                <span class="text-lg font-bold text-green-900 dark:text-green-200">
                  <%= milkInventory ? (parseFloat(milkInventory.a1_available) || 0).toFixed(1) : '0.0' %> L
                </span>
              </div>
              
              <div class="flex justify-between items-center">
                <span class="text-sm font-medium text-green-700 dark:text-green-300">Used Volume</span>
                <span class="text-lg font-bold text-green-900 dark:text-green-200">
                  <%= milkInventory ? (parseFloat(milkInventory.a1_used) || 0).toFixed(1) : '0.0' %> L
                </span>
              </div>
              
              <div class="flex justify-between items-center">
                <span class="text-sm font-medium text-green-700 dark:text-green-300">Remaining Volume</span>
                <span class="text-lg font-bold text-green-900 dark:text-green-200">
                  <% 
                    const a1Total = parseFloat(milkInventory?.a1_available) || 0;
                    const a1Used = parseFloat(milkInventory?.a1_used) || 0;
                    const a1Wasted = parseFloat(milkInventory?.a1_wasted) || 0;
                    const a1Remaining = Math.max(0, a1Total - a1Used - a1Wasted);
                  %>
                  <%= a1Remaining.toFixed(1) %> L
                </span>
              </div>
              
              <div class="pt-2 border-t border-green-200 dark:border-green-800">
                <div class="flex justify-between items-center mb-2">
                  <span class="text-sm font-medium text-green-700 dark:text-green-300">Usage</span>
                  <span class="text-lg font-bold text-green-900 dark:text-green-200">
                    <% 
                      const a1Percentage = a1Total > 0 ? (a1Used / a1Total * 100) : 0;
                    %>
                    <%= a1Percentage.toFixed(1) %>%
                  </span>
                </div>
                <div class="w-full bg-green-200 dark:bg-green-900/50 rounded-full h-2">
                  <div class="bg-green-500 dark:bg-green-600 h-2 rounded-full transition-all duration-300" style="width: <%= Math.min(100, a1Percentage) %>%"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- A2 Milk Card -->
          <div class="bg-gradient-to-br from-red-50 to-red-100 dark:from-red-900/30 dark:to-red-800/30 rounded-xl shadow-sm border border-red-200 dark:border-red-800 p-6">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center">
                <div class="w-12 h-12 bg-red-500 dark:bg-red-600 rounded-lg flex items-center justify-center mr-3">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-red-900 dark:text-red-200">A2 Milk</h3>
                  <p class="text-sm text-red-600 dark:text-red-400">Cow Milk Type A2</p>
                </div>
              </div>
            </div>
            
            <div class="space-y-3">
              <div class="flex justify-between items-center">
                <span class="text-sm font-medium text-red-700 dark:text-red-300">Total Volume</span>
                <span class="text-lg font-bold text-red-900 dark:text-red-200">
                  <%= milkInventory ? (parseFloat(milkInventory.a2_available) || 0).toFixed(1) : '0.0' %> L
                </span>
              </div>
              
              <div class="flex justify-between items-center">
                <span class="text-sm font-medium text-red-700 dark:text-red-300">Used Volume</span>
                <span class="text-lg font-bold text-red-900 dark:text-red-200">
                  <%= milkInventory ? (parseFloat(milkInventory.a2_used) || 0).toFixed(1) : '0.0' %> L
                </span>
              </div>
              
              <div class="flex justify-between items-center">
                <span class="text-sm font-medium text-red-700 dark:text-red-300">Remaining Volume</span>
                <span class="text-lg font-bold text-red-900 dark:text-red-200">
                  <% 
                    const a2Total = parseFloat(milkInventory?.a2_available) || 0;
                    const a2Used = parseFloat(milkInventory?.a2_used) || 0;
                    const a2Wasted = parseFloat(milkInventory?.a2_wasted) || 0;
                    const a2Remaining = Math.max(0, a2Total - a2Used - a2Wasted);
                  %>
                  <%= a2Remaining.toFixed(1) %> L
                </span>
              </div>
              
              <div class="pt-2 border-t border-red-200 dark:border-red-800">
                <div class="flex justify-between items-center mb-2">
                  <span class="text-sm font-medium text-red-700 dark:text-red-300">Usage</span>
                  <span class="text-lg font-bold text-red-900 dark:text-red-200">
                    <% 
                      const a2Percentage = a2Total > 0 ? (a2Used / a2Total * 100) : 0;
                    %>
                    <%= a2Percentage.toFixed(1) %>%
                  </span>
                </div>
                <div class="w-full bg-red-200 dark:bg-red-900/50 rounded-full h-2">
                  <div class="bg-red-500 dark:bg-red-600 h-2 rounded-full transition-all duration-300" style="width: <%= Math.min(100, a2Percentage) %>%"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Buffalo Milk Card -->
          <div class="bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-900/30 dark:to-blue-800/30 rounded-xl shadow-sm border border-blue-200 dark:border-blue-800 p-6">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center">
                <div class="w-12 h-12 bg-blue-500 dark:bg-blue-600 rounded-lg flex items-center justify-center mr-3">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-blue-900 dark:text-blue-200">Buffalo Milk</h3>
                  <p class="text-sm text-blue-600 dark:text-blue-400">Buffalo Milk</p>
                </div>
              </div>
            </div>
            
            <div class="space-y-3">
              <div class="flex justify-between items-center">
                <span class="text-sm font-medium text-blue-700 dark:text-blue-300">Total Volume</span>
                <span class="text-lg font-bold text-blue-900 dark:text-blue-200">
                  <%= milkInventory ? (parseFloat(milkInventory.buffalo_available) || 0).toFixed(1) : '0.0' %> L
                </span>
              </div>
              
              <div class="flex justify-between items-center">
                <span class="text-sm font-medium text-blue-700 dark:text-blue-300">Used Volume</span>
                <span class="text-lg font-bold text-blue-900 dark:text-blue-200">
                  <%= milkInventory ? (parseFloat(milkInventory.buffalo_used) || 0).toFixed(1) : '0.0' %> L
                </span>
              </div>
              
              <div class="flex justify-between items-center">
                <span class="text-sm font-medium text-blue-700 dark:text-blue-300">Remaining Volume</span>
                <span class="text-lg font-bold text-blue-900 dark:text-blue-200">
                  <% 
                    const buffaloTotal = parseFloat(milkInventory?.buffalo_available) || 0;
                    const buffaloUsed = parseFloat(milkInventory?.buffalo_used) || 0;
                    const buffaloWasted = parseFloat(milkInventory?.buffalo_wasted) || 0;
                    const buffaloRemaining = Math.max(0, buffaloTotal - buffaloUsed - buffaloWasted);
                  %>
                  <%= buffaloRemaining.toFixed(1) %> L
                </span>
              </div>
              
              <div class="pt-2 border-t border-blue-200 dark:border-blue-800">
                <div class="flex justify-between items-center mb-2">
                  <span class="text-sm font-medium text-blue-700 dark:text-blue-300">Usage</span>
                  <span class="text-lg font-bold text-blue-900 dark:text-blue-200">
                    <% 
                      const buffaloPercentage = buffaloTotal > 0 ? (buffaloUsed / buffaloTotal * 100) : 0;
                    %>
                    <%= buffaloPercentage.toFixed(1) %>%
                  </span>
                </div>
                <div class="w-full bg-blue-200 dark:bg-blue-900/50 rounded-full h-2">
                  <div class="bg-blue-500 dark:bg-blue-600 h-2 rounded-full transition-all duration-300" style="width: <%= Math.min(100, buffaloPercentage) %>%"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>


      <!-- Product Overview - Tables -->
      <div class="space-y-6">
        <div class="flex items-center mb-6">
          <div class="w-12 h-12 bg-gradient-to-r from-purple-500 to-pink-600 rounded-xl flex items-center justify-center mr-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900 dark:text-white">Product Overview</h3>
            <p class="text-sm text-gray-600 dark:text-gray-300">Production summary by milk type</p>
          </div>
        </div>

        <!-- A1 Milk Table -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
          <div class="bg-gradient-to-r from-green-50 to-green-100 dark:from-green-900/30 dark:to-green-800/30 border-b border-green-200 dark:border-green-800 px-6 py-4">
            <div class="flex items-center justify-between">
              <div class="flex items-center">
                <div class="w-10 h-10 bg-green-500 dark:bg-green-600 rounded-lg flex items-center justify-center mr-3">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                  </svg>
                </div>
                <div>
                  <h4 class="text-lg font-bold text-green-900 dark:text-green-200">A1 Milk Products</h4>
                  <p class="text-sm text-green-600 dark:text-green-400">Cow Milk Type A1</p>
                </div>
              </div>
              <div class="px-3 py-1 bg-green-100 dark:bg-green-900/40 rounded-full border border-green-200 dark:border-green-800">
                <span class="text-sm font-bold text-green-900 dark:text-green-200" id="a1-compact-total">0</span>
                <span class="text-xs text-green-600 dark:text-green-400 ml-1">products</span>
              </div>
            </div>
          </div>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
              <thead class="bg-gray-50 dark:bg-gray-700/50">
                <tr>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Product</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Unit Size</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Quantity Produced</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Milk Used</th>
                </tr>
              </thead>

  <%- include('../../../partials/_footer') %>

  <script>
    // Filter change handlers
    function navigateWithFilters() {
      const date = document.getElementById('dateFilter').value;
      const time = document.getElementById('timeFilter').value;
      
      if (date && time) {
        const url = new URL(window.location);
        url.searchParams.set('date', date);
        url.searchParams.set('time', time);
        window.location.href = url.toString();
      }
    }
    
    // Initialize filter functionality when DOM is ready
    function initializeFilters() {
      const dateFilter = document.getElementById('dateFilter');
      const timeFilter = document.getElementById('timeFilter');
      
      if (dateFilter) {
        dateFilter.addEventListener('change', navigateWithFilters);
      }
      
      if (timeFilter) {
        timeFilter.addEventListener('change', navigateWithFilters);
      }
    }
    
    // Initialize when DOM is ready
    document.addEventListener('DOMContentLoaded', initializeFilters);
    
    // Also call immediately in case DOM is already ready
    if (document.readyState !== 'loading') {
      initializeFilters();
    }

    // Load products data for modern overview
    async function loadProductsData() {
      try {
        const response = await fetch('/production/products-api');
        const result = await response.json();
        
        if (result.success && result.products) {
          const products = result.products;
          
          // Group products by milk type and sort by product_id
          const a1Products = products.filter(p => p.milk_type === 'A1').sort((a, b) => a.product_id - b.product_id);
          const a2Products = products.filter(p => p.milk_type === 'A2').sort((a, b) => a.product_id - b.product_id);
          const buffaloProducts = products.filter(p => p.milk_type === 'Buffalo').sort((a, b) => a.product_id - b.product_id);
          
          
          // Update modern overview
          updateModernOverview(a1Products, a2Products, buffaloProducts);
        }
      } catch (error) {
        console.error('Error loading production data:', error);
      }
    }
    
    function updateModernOverview(a1Products, a2Products, buffaloProducts) {
      const totalProducts = a1Products.length + a2Products.length + buffaloProducts.length;
      
      // Note: Quick stats cards removed, so no need to update those elements
      
      // Note: Product Distribution section removed, so no need to update those elements
      
      // Note: Progress bars removed with quick stats cards, so no need to update those elements
      
      // Update Compact Product Overview section
      updateCompactProductOverviewSection(a1Products, a2Products, buffaloProducts);
    }
    
    // ========================================
    // COMPACT PRODUCT OVERVIEW SECTION FUNCTIONS
    // ========================================
    function updateCompactProductOverviewSection(a1Products, a2Products, buffaloProducts) {
      // Update compact total counts
      const a1CompactTotal = document.getElementById('a1-compact-total');
      const a2CompactTotal = document.getElementById('a2-compact-total');
      const buffaloCompactTotal = document.getElementById('buffalo-compact-total');
      
      if (a1CompactTotal) a1CompactTotal.textContent = a1Products.length;
      if (a2CompactTotal) a2CompactTotal.textContent = a2Products.length;
      if (buffaloCompactTotal) buffaloCompactTotal.textContent = buffaloProducts.length;
      
      // Populate vertical compact cards
      populateVerticalCards(a1Products, 'a1-vertical-products', 'green');
      populateVerticalCards(a2Products, 'a2-vertical-products', 'red');
      populateVerticalCards(buffaloProducts, 'buffalo-vertical-products', 'blue');
    }
    
    function populateVerticalCards(products, containerId, colorTheme) {
      const container = document.getElementById(containerId);
      
      if (!container) {
        console.error(`Container with id '${containerId}' not found`);
        return;
      }
      
      container.innerHTML = '';
      
      if (products.length === 0) {
        container.innerHTML = `
          <tr>
            <td colspan="4" class="px-6 py-8 text-center text-sm text-gray-500 dark:text-gray-400">No products found</td>
          </tr>
        `;
        return;
      }
      
      products.forEach((product, index) => {
        const tableRow = createTableRow(product, colorTheme, index);
        container.appendChild(tableRow);
      });
    }
    
    function createTableRow(product, colorTheme, index) {
      const row = document.createElement('tr');
      row.className = 'hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors';
      
      // Get color classes based on theme
      const colorClasses = {
        green: {
          accent: 'text-green-600 dark:text-green-400',
          bg: 'bg-green-50 dark:bg-green-900/20',
          border: 'border-green-200 dark:border-green-800'
        },
        red: {
          accent: 'text-red-600 dark:text-red-400',
          bg: 'bg-red-50 dark:bg-red-900/20',
          border: 'border-red-200 dark:border-red-800'
        },
        blue: {
          accent: 'text-blue-600 dark:text-blue-400',
          bg: 'bg-blue-50 dark:bg-blue-900/20',
          border: 'border-blue-200 dark:border-blue-800'
        }
      };
      
      const colors = colorClasses[colorTheme];
      
      // Use real production data - ensure values are numbers
      const productionCount = parseFloat(product.total_produced) || 0;
      const milkUsed = parseFloat(product.total_milk_used) || 0;
      
      row.innerHTML = `
        <td class="px-6 py-4 whitespace-nowrap">
          <div class="flex items-center">
            <div class="flex-shrink-0 h-10 w-10">
              <div class="h-10 w-10 rounded-lg overflow-hidden border ${colors.border} ${colors.bg} flex items-center justify-center">
                ${product.image_url ? 
                  `<img src="${product.image_url}" alt="${product.name}" class="h-full w-full object-cover">` :
                  `<svg class="h-6 w-6 ${colors.accent}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                  </svg>`
                }
              </div>
            </div>
            <div class="ml-4">
              <div class="text-sm font-medium text-gray-900 dark:text-white">${product.name}</div>
            </div>
          </div>
        </td>
        <td class="px-6 py-4 whitespace-nowrap">
          <div class="text-sm text-gray-500 dark:text-gray-400">${product.unit_size || '-'}</div>
        </td>
        <td class="px-6 py-4 whitespace-nowrap">
          <div class="text-sm font-semibold ${colors.accent}">${productionCount}</div>
        </td>
        <td class="px-6 py-4 whitespace-nowrap">
          <div class="text-sm font-semibold ${colors.accent}">${milkUsed.toFixed(1)} L</div>
        </td>
      `;
      
      return row;
    }
    
    // Register Chart.js plugins
    Chart.register(ChartDataLabels);
    
    // Load products data when page loads
    document.addEventListener('DOMContentLoaded', function() {
      loadProductsData();
      loadMilkVolumeTrends();
    });

    // ========================================
    // MILK VOLUME TRENDS CHART FUNCTIONS
    // ========================================
    let milkVolumeChart = null;

    async function loadMilkVolumeTrends(days = 7) {
      try {
        const response = await fetch(`/production/milk-volume-trends/api?days=${days}`);
        const result = await response.json();
        
        if (result.success && result.trends) {
          const trends = result.trends;
          
          // Process data for chart
          const chartData = processTrendsData(trends, days);
          
          // Create or update chart
          createMilkVolumeChart(chartData);
        }
      } catch (error) {
        console.error('Error loading milk volume trends:', error);
      }
    }

    function processTrendsData(trends, days) {
      // Create date range
      const dates = [];
      const endDate = new Date();
      for (let i = days - 1; i >= 0; i--) {
        const date = new Date();
        date.setDate(endDate.getDate() - i);
        dates.push(date.toISOString().split('T')[0]);
      }

      // Initialize data structure
      const data = {
        labels: dates.map(date => {
          const d = new Date(date);
          return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        }),
        datasets: [
          {
            label: 'A1 Milk',
            data: new Array(dates.length).fill(0),
            borderColor: 'rgb(34, 197, 94)',
            backgroundColor: 'rgba(34, 197, 94, 0.1)',
            fill: true,
            tension: 0.4,
            pointBackgroundColor: 'rgb(34, 197, 94)',
            pointBorderColor: 'rgb(34, 197, 94)',
            pointRadius: 4,
            pointHoverRadius: 6
          },
          {
            label: 'A2 Milk',
            data: new Array(dates.length).fill(0),
            borderColor: 'rgb(239, 68, 68)',
            backgroundColor: 'rgba(239, 68, 68, 0.1)',
            fill: true,
            tension: 0.4,
            pointBackgroundColor: 'rgb(239, 68, 68)',
            pointBorderColor: 'rgb(239, 68, 68)',
            pointRadius: 4,
            pointHoverRadius: 6
          },
          {
            label: 'Buffalo Milk',
            data: new Array(dates.length).fill(0),
            borderColor: 'rgb(59, 130, 246)',
            backgroundColor: 'rgba(59, 130, 246, 0.1)',
            fill: true,
            tension: 0.4,
            pointBackgroundColor: 'rgb(59, 130, 246)',
            pointBorderColor: 'rgb(59, 130, 246)',
            pointRadius: 4,
            pointHoverRadius: 6
          }
        ]
      };

      // Populate data from trends
      trends.forEach(trend => {
        const dateIndex = dates.indexOf(trend.production_date);
        if (dateIndex !== -1) {
          const datasetIndex = trend.milk_type === 'A1' ? 0 : 
                             trend.milk_type === 'A2' ? 1 : 2;
          data.datasets[datasetIndex].data[dateIndex] = parseFloat(trend.daily_milk_volume) || 0;
        }
      });

      return data;
    }

    function createMilkVolumeChart(data) {
      const ctx = document.getElementById('milkVolumeChart');
      if (!ctx) {
        console.error('Chart canvas not found');
        return;
      }

      // Destroy existing chart if it exists
      if (milkVolumeChart) {
        milkVolumeChart.destroy();
      }

      milkVolumeChart = new Chart(ctx, {
        type: 'line',
        data: data,
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: {
            intersect: false,
            mode: 'index'
          },
            plugins: {
              legend: {
                display: false // We have custom legend below chart
              },
              tooltip: {
                backgroundColor: 'rgba(0, 0, 0, 0.8)',
                titleColor: 'white',
                bodyColor: 'white',
                borderColor: 'rgba(255, 255, 255, 0.1)',
                borderWidth: 1,
                cornerRadius: 8,
                displayColors: true,
                callbacks: {
                  title: function(context) {
                    return context[0].label;
                  },
                label: function(context) {
                  return `${context.dataset.label}: ${context.parsed.y.toFixed(1)}L available`;
                }
                }
              },
              datalabels: {
                display: true,
                color: function(context) {
                  // Use the same color as the line
                  return context.dataset.borderColor;
                },
                font: {
                  size: 11,
                  weight: 'bold'
                },
                backgroundColor: 'rgba(255, 255, 255, 0.9)',
                borderColor: function(context) {
                  return context.dataset.borderColor;
                },
                borderWidth: 1,
                borderRadius: 4,
                padding: 4,
                formatter: function(value, context) {
                  return value.toFixed(0) + 'L';
                },
                anchor: 'end',
                align: 'top',
                offset: 8
              }
            },
          scales: {
            x: {
              grid: {
                color: 'rgba(0, 0, 0, 0.05)',
                drawBorder: false
              },
              ticks: {
                color: 'rgb(107, 114, 128)',
                font: {
                  size: 12
                }
              }
            },
            y: {
              beginAtZero: true,
              grid: {
                color: 'rgba(0, 0, 0, 0.05)',
                drawBorder: false
              },
              ticks: {
                color: 'rgb(107, 114, 128)',
                font: {
                  size: 12
                },
                callback: function(value) {
                  return value.toFixed(0) + 'L';
                }
              },
              // Add padding at the top to ensure labels are visible
              suggestedMax: function(context) {
                const max = Math.max(...context.chart.data.datasets.flatMap(d => d.data));
                return max * 1.15; // Add 15% padding above the max value
              }
            }
          },
          elements: {
            point: {
              hoverBackgroundColor: 'white',
              hoverBorderWidth: 2
            }
          }
        }
      });
    }

    // Event listener for period filter
    document.addEventListener('DOMContentLoaded', function() {
      const periodFilter = document.getElementById('trend-period-filter');
      if (periodFilter) {
        periodFilter.addEventListener('change', function() {
          const days = parseInt(this.value);
          loadMilkVolumeTrends(days);
        });
      }
    });
  </script>

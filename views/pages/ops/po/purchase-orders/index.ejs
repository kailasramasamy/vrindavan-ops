        </span>
      </td>
      <td class="px-4 py-4">
        <div class="text-sm font-medium text-gray-900 dark:text-white break-words">${po.vendor_name || "Unknown Vendor"}</div>
        <div class="text-xs text-gray-500 mt-1 break-words">${po.contact_person_name || "No contact"}</div>
      </td>
       <td class="px-3 py-4 text-right amount-cell whitespace-nowrap">
         <div class="text-sm font-bold text-gray-900 dark:text-white">₹${parseFloat(po.total_amount || 0).toLocaleString("en-IN")}</div>
         <div class="text-xs text-gray-500">GST: ₹${parseFloat(po.gst_amount || 0).toLocaleString("en-IN")}</div>
       </td>
       <td class="px-3 py-4 text-right amount-cell whitespace-nowrap">
         <div class="text-sm font-medium text-gray-900 dark:text-white">₹${parseFloat(po.shipping_cost || 0).toLocaleString("en-IN")}</div>
         <div class="text-xs text-gray-500">Shipping</div>
       </td>
      <td class="px-3 py-4 whitespace-nowrap text-center">
        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-semibold ${getStatusColor(po.status)} border border-opacity-20 shadow-sm">
          ${getStatusText(po.status)}
        </span>
      </td>
      <td class="px-3 py-4 whitespace-nowrap text-center">
        <div class="flex flex-col items-center space-y-1">
          <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium ${getPaymentStatusColor(po.payment_status)}">
            ${getPaymentStatusText(po.payment_status)}
          </span>
          <div class="text-xs text-gray-500">₹${parseFloat(po.total_paid || 0).toLocaleString("en-IN")}</div>
        </div>
      </td>
      <td class="px-4 py-4 whitespace-nowrap">
        <div class="text-sm font-medium text-gray-900 dark:text-white">${formatDate(po.po_date)}</div>
        <div class="text-xs text-gray-500 mt-1">Due: ${formatDate(po.expected_delivery_date)}</div>
      </td>
      <td class="px-3 py-4 whitespace-nowrap text-center actions-cell">
        <div class="flex justify-center space-x-1">
          <a href="/po/purchase-orders/${po.id}" class="inline-flex items-center px-2 py-1.5 text-blue-600 dark:text-blue-400 hover:text-blue-900 hover:bg-blue-50 rounded-lg transition-colors" title="View Details">
            <i data-lucide="eye" class="h-4 w-4"></i>
          </a>
          <button onclick="changeStatus(${po.id})" class="inline-flex items-center px-2 py-1.5 text-green-600 dark:text-green-400 hover:text-green-900 hover:bg-green-50 rounded-lg transition-colors" title="Change Status">
            <i data-lucide="arrow-right" class="h-4 w-4"></i>
          </button>
        </div>
      </td>
    </tr>
  `,
          )
          .join("");

        // Update desktop table
        tbody.innerHTML = desktopTable;

        // Update mobile cards
        const mobileBody = document.getElementById("posMobileBody");
        if (mobileBody) {
          mobileBody.innerHTML = mobileCards;
        }

        // Update pagination info
        document.getElementById("showingStart").textContent = startIndex + 1;
        document.getElementById("showingEnd").textContent = Math.min(endIndex, purchaseOrders.length);
        document.getElementById("totalPOsCount").textContent = purchaseOrders.length;

        // Re-initialize icons
        if (typeof lucide !== "undefined") {
          lucide.createIcons();
        }
      }

      // Helper functions
      function getStatusColor(status) {
        const colors = {
          draft: "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200",
          submitted: "bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300",
          approved: "bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300",
          ordered: "bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-300",
          in_transit: "bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-300",
          received: "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300",
          closed: "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300",
          cancelled: "bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300",
        };
        return colors[status] || "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200";
      }

      function getStatusText(status) {
        const texts = {
          draft: "Draft",
          submitted: "Submitted",
          approved: "Approved",
          ordered: "Ordered",
          in_transit: "In Transit",
          received: "Received",
          closed: "Closed",
          cancelled: "Cancelled",
        };
        return texts[status] || status;
      }

      function getPaymentStatusText(status) {
        const texts = {
          pending: "Pending",
          partially_paid: "Partially Paid",
          paid: "Paid",
          overdue: "Overdue",
        };
        return texts[status] || status;
      }

      function getPaymentStatusColor(status) {
        const colors = {
          pending: "bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-300 border border-orange-200 dark:border-orange-700",
          partially_paid: "bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300 border border-yellow-200 dark:border-yellow-700",
          paid: "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300 border border-green-200 dark:border-green-700",
          overdue: "bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300 border border-red-200 dark:border-red-700",
        };
        return colors[status] || "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200 border border-gray-200 dark:border-gray-600";
      }

      function getPOTypeColor(poType) {
        return poType === "material" 
          ? "bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-300"
          : "bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300";
      }

      function formatDate(dateString) {
        if (!dateString) return "-";
        const date = new Date(dateString);
        return date.toLocaleDateString("en-IN");
      }

      // Modal state
      let currentPOId = null;

      // Action functions

      function changeStatus(id) {
        const po = purchaseOrders.find((p) => p.id === id);
        if (!po) return;

        currentPOId = id;

        // Set current status as default
        document.getElementById("newStatus").value = po.status || "";
        document.getElementById("statusNotes").value = "";

        // Update modal title
        document.getElementById("changeStatusTitle").textContent = `Change Status - ${po.po_number}`;
        document.getElementById("changeStatusSubtitle").textContent = `Current status: ${getStatusText(po.status)}`;

        // Show modal
        const modal = document.getElementById("changeStatusModal");
        modal.classList.remove("hidden");

        // Add animation
        setTimeout(() => {
          modal.querySelector(".transform").classList.add("scale-100", "opacity-100");
        }, 10);
      }

      // Modal close functions

      function closeChangeStatusModal() {
        const modal = document.getElementById("changeStatusModal");
        modal.querySelector(".transform").classList.remove("scale-100", "opacity-100");

        setTimeout(() => {
          modal.classList.add("hidden");
        }, 200);

        currentPOId = null;
        document.getElementById("changeStatusForm").reset();
      }

      // Setup filter listeners for auto-apply
      function setupFilterListeners() {
        const searchInput = document.getElementById("searchInput");
        const statusFilter = document.getElementById("statusFilter");
        const vendorFilter = document.getElementById("vendorFilter");
        const dateFilter = document.getElementById("dateFilter");

        // Add event listeners for auto-filtering
        searchInput.addEventListener("input", debounce(applyFilters, 300));
        statusFilter.addEventListener("change", applyFilters);
        vendorFilter.addEventListener("change", applyFilters);
        dateFilter.addEventListener("change", applyFilters);
      }

      // Debounce function to limit API calls
      function debounce(func, wait) {
        let timeout;
        return function executedFunction(...args) {
          const later = () => {
            clearTimeout(timeout);
            func(...args);
          };
          clearTimeout(timeout);
          timeout = setTimeout(later, wait);
        };
      }

      // Filter functions
      function applyFilters() {
        const search = document.getElementById("searchInput").value.toLowerCase();
        const status = document.getElementById("statusFilter").value;
        const vendor = document.getElementById("vendorFilter").value;
        const date = document.getElementById("dateFilter").value;
        const paymentStatus = window.urlPaymentStatus; // From URL parameter
        const missingInvoice = window.urlMissingInvoice; // From URL parameter

        let filteredPOs = [...purchaseOrders];

        // Apply search filter
        if (search) {
          filteredPOs = filteredPOs.filter((po) => po.po_number.toLowerCase().includes(search) || (po.vendor_name && po.vendor_name.toLowerCase().includes(search)) || (po.notes && po.notes.toLowerCase().includes(search)));
        }

        // Apply status filter
        if (status) {
          filteredPOs = filteredPOs.filter((po) => po.status === status);
        }

        // Apply payment status filter (from URL)
        if (paymentStatus) {
          filteredPOs = filteredPOs.filter((po) => po.payment_status === paymentStatus);
        }

        // Apply missing invoice filter (from URL)
        // Note: The API already filters this, so we don't need to filter again here
        // This is just for consistency with other filters
        if (missingInvoice) {
          filteredPOs = filteredPOs.filter((po) => po.invoice_count === 0 && po.status !== "draft" && po.status !== "cancelled");
        }

        // Apply vendor filter
        if (vendor) {
          filteredPOs = filteredPOs.filter((po) => po.vendor_id == vendor);
        }

        // Apply date filter
        if (date) {
          filteredPOs = filteredPOs.filter((po) => {
            const poDate = new Date(po.po_date).toISOString().split("T")[0];
            return poDate === date;
          });
        }

        // Update the display with filtered results
        displayFilteredPOs(filteredPOs);
      }

      // Display filtered purchase orders
      function displayFilteredPOs(filteredPOs) {
        const tbody = document.getElementById("posTableBody");
        const startIndex = (currentPage - 1) * posPerPage;
        const endIndex = startIndex + posPerPage;
        const pagePOs = filteredPOs.slice(startIndex, endIndex);

        if (pagePOs.length === 0) {
          tbody.innerHTML = `
            <tr>
              <td colspan="9" class="px-6 py-12 text-center text-gray-500">
                <div class="flex flex-col items-center space-y-2">
                  <i data-lucide="file-text" class="w-12 h-12 text-gray-300"></i>
                  <span class="text-lg font-medium">No purchase orders found</span>
                  <span class="text-sm">Try adjusting your filters or create a new purchase order</span>
                </div>
              </td>
            </tr>
          `;

          // Update mobile empty state
          const mobileBody = document.getElementById("posMobileBody");
          if (mobileBody) {
            mobileBody.innerHTML = `
              <div class="text-center py-12 text-gray-500">
                <div class="flex flex-col items-center space-y-2">
                  <i data-lucide="file-text" class="w-12 h-12 text-gray-300"></i>
                  <span class="text-lg font-medium">No purchase orders found</span>
                  <span class="text-sm">Try adjusting your filters or create a new purchase order</span>
                </div>
              </div>
            `;
          }
          return;
        }

        // Create both mobile and desktop views
        const mobileCards = pagePOs
          .map(
            (po) => `
        <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-600 p-4 mb-3">
          <!-- Header -->
          <div class="flex justify-between items-start mb-3">
            <div class="flex items-center space-x-3">
              <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/20 rounded-lg flex items-center justify-center">
                <i data-lucide="file-text" class="h-5 w-5 text-blue-600 dark:text-blue-400"></i>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 dark:text-white">${po.po_number}</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400">${po.vendor_name || "Unknown Vendor"}</p>
              </div>
            </div>
            <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium ${getPOTypeColor(po.po_type)}">
              ${po.po_type === "material" ? "Material" : "Product"}
            </span>
          </div>
          
          <!-- Amount and Status Row -->
          <div class="grid grid-cols-2 gap-4 mb-3">
            <div>
              <p class="text-xs text-gray-500">Total Amount</p>
              <p class="text-lg font-bold text-gray-900 dark:text-white">₹${parseFloat(po.total_amount || 0).toLocaleString("en-IN")}</p>
              <p class="text-xs text-gray-500">GST: ₹${parseFloat(po.gst_amount || 0).toLocaleString("en-IN")}</p>
            </div>
            <div>
              <p class="text-xs text-gray-500">Shipping</p>
              <p class="text-sm font-medium text-gray-900 dark:text-white">₹${parseFloat(po.shipping_cost || 0).toLocaleString("en-IN")}</p>
            </div>
          </div>
          
          <!-- Status Badges -->
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-semibold ${getStatusColor(po.status)} border border-opacity-20 shadow-sm">
              ${getStatusText(po.status)}
            </span>
            <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium ${getPaymentStatusColor(po.payment_status)}">
              ${getPaymentStatusText(po.payment_status)}
            </span>
          </div>
          
          <!-- Date and Payment Info -->
          <div class="grid grid-cols-2 gap-4 mb-3 text-sm">
            <div>
              <p class="text-xs text-gray-500">PO Date</p>
              <p class="font-medium text-gray-900 dark:text-white">${formatDate(po.po_date)}</p>
            </div>
            <div>
              <p class="text-xs text-gray-500">Due Date</p>
              <p class="font-medium text-gray-900 dark:text-white">${formatDate(po.expected_delivery_date)}</p>
            </div>
          </div>
          
          <!-- Payment Details -->
          <div class="bg-gray-50 dark:bg-gray-700 rounded-md p-3 mb-3">
            <div class="flex justify-between items-center text-sm">
              <span class="text-gray-600 dark:text-gray-400 dark:text-gray-400">Amount Paid:</span>
              <span class="font-medium text-gray-900 dark:text-white">₹${parseFloat(po.total_paid || 0).toLocaleString("en-IN")}</span>
            </div>
            <div class="flex justify-between items-center text-sm mt-1">
              <span class="text-gray-600 dark:text-gray-400 dark:text-gray-400">Items:</span>
              <span class="font-medium text-gray-900 dark:text-white">${po.item_count || 0} items</span>
            </div>
          </div>
          
          <!-- Actions -->
          <div class="flex justify-end space-x-2">
            <a href="/po/purchase-orders/${po.id}" class="inline-flex items-center px-3 py-1.5 text-sm text-blue-600 dark:text-blue-400 hover:text-blue-900 hover:bg-blue-50 rounded-lg transition-colors">
              <i data-lucide="eye" class="h-4 w-4 mr-1"></i>
              View
            </a>
            <button onclick="changeStatus(${po.id})" class="inline-flex items-center px-3 py-1.5 text-sm text-green-600 dark:text-green-400 hover:text-green-900 hover:bg-green-50 rounded-lg transition-colors">
              <i data-lucide="arrow-right" class="h-4 w-4 mr-1"></i>
              Status
            </button>
            <a href="/po/purchase-orders/${po.id}/edit" class="inline-flex items-center px-3 py-1.5 text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:text-white hover:bg-gray-50 rounded-lg transition-colors">
              <i data-lucide="edit" class="h-4 w-4 mr-1"></i>
              Edit
            </a>
          </div>
        </div>
      `,
          )
          .join("");

        const desktopTable = pagePOs
          .map(
            (po) => `
     <tr class="hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
       <td class="px-4 py-4 whitespace-nowrap">
         <div class="flex items-center space-x-3">
           <div class="flex-shrink-0">
             <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/20 rounded-lg flex items-center justify-center">
               <i data-lucide="file-text" class="h-5 w-5 text-blue-600 dark:text-blue-400"></i>
             </div>
           </div>
           <div class="min-w-0 flex-1">
             <div class="text-sm font-semibold text-gray-900 dark:text-white truncate">${po.po_number}</div>
             <div class="text-xs text-gray-500 mt-1 truncate">${po.item_count || 0} items</div>
             <div class="text-xs text-gray-500 mt-1 truncate">${po.payment_terms || "N/A"}</div>
           </div>
         </div>
       </td>
       <td class="px-3 py-4 whitespace-nowrap text-center">
         <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium ${getPOTypeColor(po.po_type)}">
           ${po.po_type === "material" ? "Material" : "Product"}
         </span>
       </td>
       <td class="px-4 py-4">
         <div class="text-sm font-medium text-gray-900 dark:text-white break-words">${po.vendor_name || "Unknown Vendor"}</div>
         <div class="text-xs text-gray-500 mt-1 break-words">${po.contact_person_name || "No contact"}</div>
       </td>
       <td class="px-3 py-4 text-right amount-cell whitespace-nowrap">
         <div class="text-sm font-bold text-gray-900 dark:text-white">₹${parseFloat(po.total_amount || 0).toLocaleString("en-IN")}</div>
         <div class="text-xs text-gray-500">GST: ₹${parseFloat(po.gst_amount || 0).toLocaleString("en-IN")}</div>
       </td>
       <td class="px-3 py-4 text-right amount-cell whitespace-nowrap">
         <div class="text-sm font-medium text-gray-900 dark:text-white">₹${parseFloat(po.shipping_cost || 0).toLocaleString("en-IN")}</div>
         <div class="text-xs text-gray-500">Shipping</div>
       </td>
       <td class="px-3 py-4 whitespace-nowrap text-center">
         <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-semibold ${getStatusColor(po.status)} border border-opacity-20 shadow-sm">
           ${getStatusText(po.status)}
         </span>
       </td>
       <td class="px-3 py-4 whitespace-nowrap text-center">
         <div class="flex flex-col items-center space-y-1">
           <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium ${getPaymentStatusColor(po.payment_status)}">
             ${getPaymentStatusText(po.payment_status)}
           </span>
           <div class="text-xs text-gray-500">₹${parseFloat(po.total_paid || 0).toLocaleString("en-IN")}</div>
         </div>
       </td>
       <td class="px-4 py-4 whitespace-nowrap">
         <div class="text-sm font-medium text-gray-900 dark:text-white">${formatDate(po.po_date)}</div>
         <div class="text-xs text-gray-500 mt-1">Due: ${formatDate(po.expected_delivery_date)}</div>
       </td>
       <td class="px-3 py-4 whitespace-nowrap text-center actions-cell">
         <div class="flex justify-center space-x-1">
           <a href="/po/purchase-orders/${po.id}" class="inline-flex items-center px-2 py-1.5 text-blue-600 dark:text-blue-400 hover:text-blue-900 hover:bg-blue-50 rounded-lg transition-colors" title="View Details">
             <i data-lucide="eye" class="h-4 w-4"></i>
           </a>
           <button onclick="changeStatus(${po.id})" class="inline-flex items-center px-2 py-1.5 text-green-600 dark:text-green-400 hover:text-green-900 hover:bg-green-50 rounded-lg transition-colors" title="Change Status">
             <i data-lucide="arrow-right" class="h-4 w-4"></i>
           </button>
         </div>
       </td>
     </tr>
   `,
          )
          .join("");

        // Update desktop table
        tbody.innerHTML = desktopTable;

        // Update mobile cards
        const mobileBody = document.getElementById("posMobileBody");
        if (mobileBody) {
          mobileBody.innerHTML = mobileCards;
        }

        // Update pagination info
        document.getElementById("showingStart").textContent = startIndex + 1;
        document.getElementById("showingEnd").textContent = Math.min(endIndex, filteredPOs.length);
        document.getElementById("totalPOsCount").textContent = filteredPOs.length;

        // Re-initialize icons
        if (typeof lucide !== "undefined") {
          lucide.createIcons();
        }
      }

      // Clear all filters
      function clearFilters() {
        document.getElementById("searchInput").value = "";
        document.getElementById("statusFilter").value = "";
        document.getElementById("vendorFilter").value = "";
        document.getElementById("dateFilter").value = "";
        currentPage = 1;
        renderPurchaseOrders();
      }

      function refreshPOs() {
        loadPurchaseOrders();
      }

      function exportPOs() {
        // TODO: Implement export functionality
        console.log("Export POs");
      }

      // Pagination
      function previousPage() {
        if (currentPage > 1) {
          currentPage--;
          renderPurchaseOrders();
        }
      }

      function nextPage() {
        const totalPages = Math.ceil(purchaseOrders.length / posPerPage);
        if (currentPage < totalPages) {
          currentPage++;
          renderPurchaseOrders();
        }
      }

      // Setup modal event listeners
      function setupModalEventListeners() {
        // Edit PO form submission

        // Change Status form submission
        document.getElementById("changeStatusForm").addEventListener("submit", async function (e) {
          e.preventDefault();

          if (!currentPOId) return;

          const formData = new FormData(this);
          const data = Object.fromEntries(formData.entries());

          try {
            const response = await fetch(`/po/api/v1/purchase-orders/${currentPOId}/status`, {
              method: "PUT",
              headers: {
                "Content-Type": "application/json",
              },
              body: JSON.stringify(data),
            });

            const result = await response.json();

            if (result.success) {
              if (typeof showSuccessToast !== "undefined") {
                showSuccessToast("Purchase order status updated successfully");
              } else {
                alert("Purchase order status updated successfully");
              }
              closeChangeStatusModal();
              loadPurchaseOrders(); // Refresh the list
            } else {
              if (typeof showErrorToast !== "undefined") {
                showErrorToast(result.error || "Error updating status");
              } else {
                alert("Error updating status: " + (result.error || "Unknown error"));
              }
            }
          } catch (error) {
            console.error("Error updating status:", error);
            if (typeof showErrorToast !== "undefined") {
              showErrorToast("Error updating status");
            } else {
              alert("Error updating status");
            }
          }
        });
      }

      // Toast notification
      function showToast(message, type = "info") {
        // TODO: Implement toast notification
        console.log(`${type.toUpperCase()}: ${message}`);
      }
    </script>

    <%- include('../../../../partials/_footer') %> <%- include('../../../../partials/_toast') %>
  </body>
</html>

            </div>
            <div class="flex justify-between items-center text-sm mt-1">
              <span class="text-gray-600 dark:text-gray-400 dark:text-gray-400">Items:</span>
              <span class="font-medium text-gray-900 dark:text-white">${po.item_count || 0} items</span>
            </div>
          </div>
          
          <!-- Actions -->
          <div class="flex justify-end space-x-2">
            <a href="/po/purchase-orders/${po.id}" class="inline-flex items-center px-3 py-1.5 text-sm text-blue-600 dark:text-blue-400 hover:text-blue-900 hover:bg-blue-50 rounded-lg transition-colors">
              <i data-lucide="eye" class="h-4 w-4 mr-1"></i>
              View
            </a>
            <button onclick="changeStatus(${po.id})" class="inline-flex items-center px-3 py-1.5 text-sm text-green-600 dark:text-green-400 hover:text-green-900 hover:bg-green-50 rounded-lg transition-colors">
              <i data-lucide="arrow-right" class="h-4 w-4 mr-1"></i>

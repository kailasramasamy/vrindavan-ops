            </button>
            <a href="/po/purchase-orders/${po.id}/edit" class="inline-flex items-center px-3 py-1.5 text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:text-white hover:bg-gray-50 rounded-lg transition-colors">
              <i data-lucide="edit" class="h-4 w-4 mr-1"></i>

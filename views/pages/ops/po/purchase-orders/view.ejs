    <script>
      let currentPOId = null;

      // Load PO details on page load
      document.addEventListener("DOMContentLoaded", function () {
        // Get PO ID from URL
        const pathParts = window.location.pathname.split("/");
        currentPOId = pathParts[pathParts.length - 1];

        if (currentPOId) {
          loadPODetails();
        } else {
          showError();
        }
      });

      async function loadPODetails() {
        try {
          showLoading();

          const response = await fetch(`/po/api/v1/purchase-orders/${currentPOId}`);
          const result = await response.json();

          if (result.success) {
            currentPODetails = result.data; // Store PO details globally
            displayPODetails(result.data);
            loadPaymentHistory(); // Load payment history after PO details
          } else {
            showError();
          }
        } catch (error) {
          console.error("Error loading PO details:", error);
          showError();
        }
      }

      async function loadPOItems(poId) {
        try {
          const response = await fetch(`/po/api/v1/purchase-orders/${poId}/items`);
          const result = await response.json();

          if (result.success) {
            displayPOItems(result.data);
          } else {
            // If no items endpoint, show empty state
            displayPOItems([]);
          }
        } catch (error) {
          console.error("Error loading PO items:", error);
          displayPOItems([]);
        }
      }

      function displayPOItems(items) {
        const tbody = document.getElementById("poItemsTableBody");

        if (items.length === 0) {
          tbody.innerHTML = `
            <tr>
              <td colspan="5" class="px-4 py-3 text-center text-gray-500 dark:text-gray-400 text-sm">
                No items found for this purchase order
              </td>
            </tr>
          `;
          return;
        }

        tbody.innerHTML = items
          .map(
            (item) => `
          <tr class="hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
            <td class="px-4 py-3 whitespace-nowrap">
              <div class="flex items-center space-x-2">
                <div class="w-6 h-6 bg-green-100 dark:bg-green-900/20 rounded-lg flex items-center justify-center">
                  <i data-lucide="package" class="w-3 h-3 text-green-600 dark:text-green-400"></i>
                </div>
                <div>
                  <div class="text-sm font-semibold text-gray-900 dark:text-white">${item.item_name || "Unknown Item"}</div>
                  <div class="text-xs text-gray-500 dark:text-gray-400">SKU: ${item.item_sku || "N/A"}</div>
                </div>
              </div>
            </td>
            <td class="px-4 py-3 whitespace-nowrap text-center">
              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 dark:bg-blue-900/20 text-blue-800 dark:text-blue-400">
                ${parseFloat(item.quantity || 0).toFixed(1)}
              </span>
            </td>
            <td class="px-4 py-3 whitespace-nowrap text-right text-sm font-semibold text-gray-900 dark:text-white">₹${parseFloat(item.unit_cost || 0).toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
            <td class="px-4 py-3 whitespace-nowrap text-center">
              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-orange-100 dark:bg-orange-900/20 text-orange-800 dark:text-orange-400">
                ${item.gst_percentage || 0}%
              </span>
            </td>
            <td class="px-4 py-3 whitespace-nowrap text-right text-sm font-bold text-gray-900 dark:text-white">₹${parseFloat(item.total_amount || (parseFloat(item.unit_cost || 0) * parseFloat(item.quantity || 0) + parseFloat(item.gst_amount || 0))).toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
          </tr>
        `,
          )
          .join("");

        // Re-initialize Lucide icons after rendering
        if (typeof lucide !== "undefined") {
          lucide.createIcons();
        }
      }

      function getStatusBadge(status) {
        const colors = {
          draft: "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200 border border-gray-200 dark:border-gray-600",
          submitted: "bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300 border border-blue-200 dark:border-blue-700",
          approved: "bg-indigo-100 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-300 border border-indigo-200 dark:border-indigo-700",
          ordered: "bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-300 border border-purple-200 dark:border-purple-700",
          in_transit: "bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300 border border-yellow-200 dark:border-yellow-700",
          received: "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300 border border-green-200 dark:border-green-700",
          closed: "bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400 border border-gray-200 dark:border-gray-600",
          cancelled: "bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300 border border-red-200 dark:border-red-700",
        };
        const colorClass = colors[status] || "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200 border border-gray-200 dark:border-gray-600";
        return `<span class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-semibold ${colorClass} shadow-sm">${status.replace("_", " ").toUpperCase()}</span>`;
      }

      function getPaymentStatusBadge(status) {
        const colors = {
          pending: "bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-300 border border-orange-200 dark:border-orange-700",
          partially_paid: "bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300 border border-yellow-200 dark:border-yellow-700",
          paid: "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300 border border-green-200 dark:border-green-700",
        };
        const colorClass = colors[status] || "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200 border border-gray-200 dark:border-gray-600";

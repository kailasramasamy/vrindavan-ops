      async function recordPayment() {
        const amount = document.getElementById("paymentAmount").value;
        const date = document.getElementById("paymentDate").value;
        const method = document.getElementById("paymentMethod").value;
        const reference = document.getElementById("paymentReference").value;
        const notes = document.getElementById("paymentNotes").value;

        // Validate required fields
        if (!amount || !date || !method) {
          showWarningToast("Please fill in all required payment fields");
          return;
        }

        if (parseFloat(amount) <= 0) {
          showWarningToast("Payment amount must be greater than 0");
          return;
        }

        // Check if payment amount exceeds outstanding amount
        const totalAmount = parseFloat(currentPODetails.total_amount || 0);
        const totalPaid = parseFloat(currentPODetails.total_paid || 0);
        const outstanding = totalAmount - totalPaid;

        if (parseFloat(amount) > outstanding) {
          showWarningToast(`Payment amount cannot exceed outstanding amount of ₹${outstanding.toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`);
          return;
        }

        try {
          const response = await fetch(`/po/api/v1/purchase-orders/${currentPOId}/payments`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            credentials: "same-origin",
            body: JSON.stringify({
              amount: parseFloat(amount),
              payment_date: date,
              payment_method: method,
              reference_number: reference || null,
              notes: notes || null,
              recorded_by: 1, // You might want to get this from session
            }),
          });

          const result = await response.json();
          if (result.success) {
            showSuccessToast(`Payment recorded successfully! Status updated to: ${result.data.payment_status}`);
            closeRecordPaymentModal();
            // Reload PO details to update payment information
            loadPODetails();
            // Reload payment history
            loadPaymentHistory();
          } else {
            showErrorToast(result.error || "Error recording payment");
          }
        } catch (error) {
          console.error("Error recording payment:", error);
          showErrorToast("Error recording payment");
        }
      }


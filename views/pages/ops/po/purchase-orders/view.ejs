      function generateWhatsAppMessage(po, items = []) {
        const poNumber = po.po_number || "N/A";
        const vendorName = po.vendor_name || "Vendor";
        const contactPerson = po.contact_person_name || "Sir/Madam";
        const poDate = po.po_date ? new Date(po.po_date).toLocaleDateString("en-IN") : "N/A";
        const expectedDelivery = po.expected_delivery_date ? new Date(po.expected_delivery_date).toLocaleDateString("en-IN") : "N/A";
        const logisticsPartner = po.logistics_partner_name ? (po.logistics_partner_city ? `${po.logistics_partner_name}, ${po.logistics_partner_city}` : po.logistics_partner_name) : "To be arranged";

        // Generate products list
        let productsList = "";
        if (items && items.length > 0) {
          productsList = "\n\n📦 *Products Required:*\n";
          items.forEach((item, index) => {
            const quantity = parseFloat(item.quantity || 0).toFixed(1);
            const itemName = item.item_name || item.product_name || "Unknown Item";
            const baseUnit = item.base_unit || "pc";

            productsList += `${index + 1}. ${itemName} - Qty: ${quantity} ${baseUnit}\n`;
          });
        } else {
          productsList = "\n\n📦 *Products Required:*\nNo items specified in this PO.";
        }

        return `Hello ${contactPerson},

I hope this message finds you well. We have created a new Purchase Order for the following products.

📋 *Purchase Order Details:*
• PO Number: ${poNumber}
• PO Date: ${poDate}
• Expected Delivery: ${expectedDelivery}
• Logistics Partner: ${logisticsPartner}${productsList}

Please confirm receipt of this PO and provide us with the expected delivery timeline.

We look forward to your prompt response and successful delivery.

Best regards,
Vrindavan Farm Team

---
*This is an automated message regarding PO ${poNumber}*`;
      }


                  ${payment.reference_number ? `<div class="text-sm text-gray-500 dark:text-gray-400">Ref: ${payment.reference_number}</div>` : ""}
                </div>
                ${payment.notes ? `<div class="text-sm text-gray-600 dark:text-gray-400 mt-2">${payment.notes}</div>` : ""}
              </div>
              <div class="text-xs text-gray-500 dark:text-gray-400">
                ${new Date(payment.created_at).toLocaleString()}
              </div>
            </div>
          </div>
        `,
          )
          .join("");

        // Re-initialize icons
        if (typeof lucide !== "undefined") {
          lucide.createIcons();
        }
      }

      // Calculate MRP function
      async function calculateMRP() {
        if (!currentPODetails) {
          showErrorToast("PO details not loaded yet. Please wait and try again.");
          return;
        }

        const poId = currentPODetails.id;

        try {
          // Show loading state on button
          const button = document.getElementById("calculateMRPButton");
          const originalText = button.innerHTML;
          button.innerHTML = '<i data-lucide="loader" class="h-4 w-4 mr-2 animate-spin"></i>Calculating...';
          button.disabled = true;

          // Show progress modal
          showMRPProgressModal();
          updateMRPProgress(10, "Connecting to server...", "Establishing connection...");

          // Simulate progress updates
          setTimeout(() => {
            updateMRPProgress(25, "Fetching PO data...", "Retrieving purchase order information...");
          }, 300);

          setTimeout(() => {
            updateMRPProgress(40, "Loading variant data...", "Collecting product variant information...");
          }, 600);

          setTimeout(() => {
            updateMRPProgress(55, "Calculating expenses...", "Processing expense settings and costs...");
          }, 900);

          setTimeout(() => {
            updateMRPProgress(70, "Computing MRP...", "Calculating Maximum Retail Price for all variants...");
          }, 1200);

          setTimeout(() => {
            updateMRPProgress(85, "Saving calculations...", "Storing pricing data to database...");
          }, 1500);

          const response = await fetch(`/po/api/v1/purchase-orders/${poId}/calculate-mrp`, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
          });

          updateMRPProgress(95, "Finalizing...", "Completing calculation process...");

          const result = await response.json();

          if (result.success) {
            updateMRPProgress(100, "Calculation completed!", "MRP calculation completed successfully!");
            
            // Close progress modal and show success modal after a brief delay
            setTimeout(() => {
              closeMRPProgressModal();
              setTimeout(() => {
                showMRPSuccessModal();
              }, 300);
            }, 500);
          } else {
            closeMRPProgressModal();
            showErrorToast("Error calculating MRP: " + result.error);
          }
        } catch (error) {
          console.error("Error calculating MRP:", error);
          closeMRPProgressModal();
          showErrorToast("Error calculating MRP. Please try again.");
        } finally {
          // Reset button state
          const button = document.getElementById("calculateMRPButton");
          button.innerHTML = '<i data-lucide="calculator" class="h-4 w-4 mr-2"></i>Calculate MRP';
          button.disabled = false;

          // Re-initialize icons
          if (typeof lucide !== "undefined") {
            lucide.createIcons();
          }
        }
      }

      // Store PO details when loaded
      function displayPODetails(po) {
        // Hide loading, show content
        document.getElementById("loadingState").classList.add("hidden");
        document.getElementById("errorState").classList.add("hidden");
        document.getElementById("poDetailsContent").classList.remove("hidden");

        // Store PO details for WhatsApp functionality
        currentPODetails = po;

        // Populate header info
        document.getElementById("poNumber").textContent = po.po_number || "-";
        document.getElementById("poStatus").innerHTML = getStatusBadge(po.status);
        // Total amount will be set after calculating with shipping cost

        // Populate details
        document.getElementById("vendorName").textContent = po.vendor_name || "-";
        document.getElementById("poDate").textContent = po.po_date ? new Date(po.po_date).toLocaleDateString("en-IN") : "-";
        document.getElementById("expectedDelivery").textContent = po.expected_delivery_date ? new Date(po.expected_delivery_date).toLocaleDateString("en-IN") : "-";
        document.getElementById("poType").innerHTML = getPOTypeBadge(po.po_type);
        document.getElementById("paymentStatus").innerHTML = getPaymentStatusBadge(po.payment_status);
        document.getElementById("paymentTerms").textContent = po.payment_terms || "-";
        document.getElementById("logisticsPartner").textContent = po.logistics_partner_name ? (po.logistics_partner_city ? `${po.logistics_partner_name}, ${po.logistics_partner_city}` : po.logistics_partner_name) : "Not assigned";
        document.getElementById("poInvoices").innerHTML = renderInvoices(po.invoices || []);
        document.getElementById("poNotes").textContent = po.notes || "No notes";

        // Re-initialize Lucide icons for the invoice section
        if (typeof lucide !== "undefined") {
          lucide.createIcons();
        }

        // Show Calculate MRP button for received Product POs only
        if (po.status === "received" && po.po_type === "product") {
          document.getElementById("calculateMRPButton").classList.remove("hidden");
        }

        // Populate financial summary
        const subtotal = parseFloat(po.subtotal || 0);
        const gstAmount = parseFloat(po.gst_amount || 0);
        const shippingCost = parseFloat(po.shipping_cost || 0);
        // Total = Subtotal (base cost) + GST Amount + Shipping
        const calculatedTotal = subtotal + gstAmount + shippingCost;

        document.getElementById("subtotal").textContent = `₹${subtotal.toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
        document.getElementById("gstTotal").textContent = `₹${gstAmount.toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
        document.getElementById("shippingCost").textContent = `₹${shippingCost.toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
        document.getElementById("totalAmount").textContent = `₹${calculatedTotal.toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;

        // Update PO header total amount
        document.getElementById("poTotalAmount").textContent = `₹${calculatedTotal.toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;

        // Update currentPODetails with calculated total for other functions to use
        currentPODetails.total_amount = calculatedTotal;

        // Populate payment summary
        const totalAmount = calculatedTotal;
        const totalPaid = parseFloat(po.total_paid || 0);
        const outstanding = totalAmount - totalPaid;

        document.getElementById("paymentTotalAmount").textContent = `₹${totalAmount.toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
        document.getElementById("paymentTotalPaid").textContent = `₹${totalPaid.toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
        document.getElementById("paymentOutstanding").textContent = `₹${outstanding.toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;

        // Load PO items (if available)
        loadPOItems(po.id);

        // Update progress stepper
        updateProgressStepper(po);
      }

      // Update progress stepper based on PO status
      function updateProgressStepper(po) {
        let progressPercentage = 0;

        // Check completion status for each step independently
        const isStep1Complete = true; // Always complete if PO exists
        const isStep2Complete = po.status === "received" || po.status === "closed" || po.actual_delivery_date;
        const isStep3Complete = po.invoices && po.invoices.length > 0;
        const isStep4Complete = po.payment_status === "paid";

        // Step 1: Submitted (always complete if PO exists)
        const step1 = document.getElementById("step1");
        const step1Icon = document.getElementById("step1Icon");
        const step1Date = document.getElementById("step1Date");
        if (step1 && step1Icon && step1Date && isStep1Complete) {
          step1.classList.remove("bg-gray-200");
          step1.classList.add("bg-green-600");
          step1Icon.classList.remove("text-gray-400", "dark:text-gray-500");
          step1Icon.classList.add("text-white");
          step1Date.textContent = po.po_date ? new Date(po.po_date).toLocaleDateString("en-IN") : "";
        }

        // Step 2: Received
        if (isStep2Complete) {
          const step2 = document.getElementById("step2");
          const step2Icon = document.getElementById("step2Icon");
          const step2Date = document.getElementById("step2Date");
          if (step2 && step2Icon && step2Date) {
            step2.classList.remove("bg-gray-200");
            step2.classList.add("bg-green-600");
            step2Icon.classList.remove("text-gray-400", "dark:text-gray-500");
            step2Icon.classList.add("text-white");
            step2Date.textContent = po.actual_delivery_date ? new Date(po.actual_delivery_date).toLocaleDateString("en-IN") : "";
          }
        }

        // Step 3: Invoice Attached
        if (isStep3Complete) {
          const step3 = document.getElementById("step3");
          const step3Icon = document.getElementById("step3Icon");
          const step3Date = document.getElementById("step3Date");
          if (step3 && step3Icon && step3Date) {
            step3.classList.remove("bg-gray-200");
            step3.classList.add("bg-green-600");
            step3Icon.classList.remove("text-gray-400", "dark:text-gray-500");
            step3Icon.classList.add("text-white");
            // Get the latest invoice date
            const latestInvoice = po.invoices.sort((a, b) => new Date(b.invoice_date) - new Date(a.invoice_date))[0];
            step3Date.textContent = latestInvoice.invoice_date ? new Date(latestInvoice.invoice_date).toLocaleDateString("en-IN") : "";
          }
        }

        // Step 4: Payment Completed
        if (isStep4Complete) {
          const step4 = document.getElementById("step4");
          const step4Icon = document.getElementById("step4Icon");
          const step4Date = document.getElementById("step4Date");
          if (step4 && step4Icon && step4Date) {
            step4.classList.remove("bg-gray-200");
            step4.classList.add("bg-green-600");
            step4Icon.classList.remove("text-gray-400", "dark:text-gray-500");
            step4Icon.classList.add("text-white");
            // Get the latest payment date
            if (po.payments && po.payments.length > 0) {
              const latestPayment = po.payments.sort((a, b) => new Date(b.payment_date) - new Date(a.payment_date))[0];
              step4Date.textContent = latestPayment.payment_date ? new Date(latestPayment.payment_date).toLocaleDateString("en-IN") : "";
            }
          }
        }

        // Calculate progress bar position - stop at first incomplete step in sequence
        if (isStep1Complete && isStep2Complete && isStep3Complete && isStep4Complete) {
          progressPercentage = 100; // All complete
        } else if (isStep1Complete && isStep2Complete && isStep3Complete) {
          progressPercentage = 66.66; // Up to step 3
        } else if (isStep1Complete && isStep2Complete) {
          progressPercentage = 33.33; // Up to step 2
        } else if (isStep1Complete) {
          progressPercentage = 0; // Only step 1
        }

        // Update progress bar
        const progressBar = document.getElementById("progressBar");
        if (progressBar) {
          progressBar.style.width = `${progressPercentage}%`;
        }
      }

      // Initialize Lucide icons
      if (typeof lucide !== "undefined") {
        lucide.createIcons();
      }
    </script>
  </body>
</html>

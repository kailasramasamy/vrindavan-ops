<!DOCTYPE html>
<html lang="en">
  <%- include('../../../../partials/_head', { seo: { title: 'Purchase Order Details - PO Management', description: 'View and manage purchase order' } }) %>
  <link rel="stylesheet" href="/assets/css/po-dark-mode.css" />

  <body class="bg-gray-50 dark:bg-gray-900">
    <%- include('../../../../partials/_subnav', { user, section: 'PO', subsection: 'View Purchase Order' }) %>

    <div class="min-h-screen pt-16">
      <!-- Header -->
      <div class="bg-white dark:bg-gray-800 shadow">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="py-6">
            <div class="md:flex md:items-center md:justify-between">
              <div class="flex-1 min-w-0">
                <h2 class="text-2xl font-bold leading-7 text-gray-900 dark:text-white sm:text-3xl sm:truncate">Purchase Order Details</h2>
                <p class="mt-1 text-sm text-gray-500 dark:text-gray-400 dark:text-gray-500">View and manage purchase order information</p>
              </div>
              <div class="mt-4 flex space-x-3 md:mt-0 md:ml-4">
                <button onclick="printPO()" class="inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                  <i data-lucide="printer" class="h-4 w-4 mr-2"></i>
                  Print
                </button>
                <button onclick="showWhatsAppMessage()" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                  <i data-lucide="message-circle" class="h-4 w-4 mr-2"></i>
                  WhatsApp
                </button>
                <button id="calculateMRPButton" onclick="calculateMRP()" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 hidden">
                  <i data-lucide="calculator" class="h-4 w-4 mr-2"></i>
                  Calculate MRP
                </button>
                <button onclick="showUploadInvoiceModal()" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                  <i data-lucide="upload" class="h-4 w-4 mr-2"></i>
                  Upload Invoice
                </button>
                <button onclick="editPO()" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                  <i data-lucide="edit" class="h-4 w-4 mr-2"></i>
                  Edit
                </button>
                <button onclick="deletePO()" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
                  <i data-lucide="trash-2" class="h-4 w-4 mr-2"></i>
                  Delete
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Main Content -->
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 space-y-4">
        <!-- Loading State -->
        <div id="loadingState" class="text-center py-12">
          <div class="inline-flex items-center justify-center w-12 h-12 bg-blue-100 dark:bg-blue-900/20 rounded-full mb-4">
            <i data-lucide="loader" class="w-6 h-6 text-blue-600 dark:text-blue-400 animate-spin"></i>
          </div>
          <h3 class="text-lg font-medium text-gray-900 dark:text-white dark:text-white mb-2">Loading Purchase Order</h3>
          <p class="text-gray-600 dark:text-gray-400 dark:text-gray-500">Please wait while we fetch the details...</p>
        </div>

        <!-- Error State -->
        <div id="errorState" class="hidden text-center py-12">
          <div class="inline-flex items-center justify-center w-12 h-12 bg-red-100 dark:bg-red-900/20 rounded-full mb-4">
            <i data-lucide="alert-circle" class="w-6 h-6 text-red-600 dark:text-red-400"></i>
          </div>
          <h3 class="text-lg font-medium text-gray-900 dark:text-white dark:text-white mb-2">Error Loading Details</h3>
          <p class="text-gray-600 dark:text-gray-400 dark:text-gray-500 mb-4">We couldn't load the purchase order details. Please try again.</p>
          <button onclick="loadPODetails()" class="inline-flex items-center px-4 py-2 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
            <i data-lucide="refresh-cw" class="h-4 w-4 mr-2"></i>
            Try Again
          </button>
        </div>

        <!-- PO Details Content -->
        <div id="poDetailsContent" class="hidden space-y-6">
          <!-- Progress Stepper -->
          <div class="bg-white dark:bg-gray-800 shadow-lg rounded-xl overflow-hidden border border-gray-200 dark:border-gray-600 dark:border-gray-600 p-6">
            <div class="relative px-5">
              <!-- Progress Bar Background -->
              <div class="absolute top-5 left-5 right-5 h-1 bg-gray-200 dark:bg-gray-600" style="z-index: 0"></div>
              <!-- Progress Bar Active -->
              <div id="progressBar" class="absolute top-5 left-5 h-1 bg-green-600 transition-all duration-500" style="z-index: 1; width: 0%"></div>

              <!-- Steps -->
              <div class="relative flex justify-between" style="z-index: 2">
                <!-- Step 1: Submitted -->
                <div class="flex flex-col items-center" style="flex: 1">
                  <div id="step1" class="w-10 h-10 rounded-full bg-gray-200 dark:bg-gray-600 border-4 border-white dark:border-gray-800 flex items-center justify-center mb-2 transition-all duration-300">
                    <i id="step1Icon" data-lucide="send" class="w-5 h-5 text-gray-400 dark:text-gray-500 dark:text-gray-500"></i>
                  </div>
                  <span class="text-xs font-medium text-gray-600 dark:text-gray-300 text-center">Submitted</span>
                  <span id="step1Date" class="text-xs text-gray-400 dark:text-gray-500 dark:text-gray-500 mt-1"></span>
                </div>

                <!-- Step 2: Received -->
                <div class="flex flex-col items-center" style="flex: 1">
                  <div id="step2" class="w-10 h-10 rounded-full bg-gray-200 dark:bg-gray-600 border-4 border-white dark:border-gray-800 flex items-center justify-center mb-2 transition-all duration-300">
                    <i id="step2Icon" data-lucide="package-check" class="w-5 h-5 text-gray-400 dark:text-gray-500"></i>
                  </div>
                  <span class="text-xs font-medium text-gray-600 dark:text-gray-300 text-center">Received</span>
                  <span id="step2Date" class="text-xs text-gray-400 dark:text-gray-500 mt-1"></span>
                </div>

                <!-- Step 3: Invoice Attached -->
                <div class="flex flex-col items-center" style="flex: 1">
                  <div id="step3" class="w-10 h-10 rounded-full bg-gray-200 dark:bg-gray-600 border-4 border-white dark:border-gray-800 flex items-center justify-center mb-2 transition-all duration-300">
                    <i id="step3Icon" data-lucide="file-text" class="w-5 h-5 text-gray-400 dark:text-gray-500"></i>
                  </div>
                  <span class="text-xs font-medium text-gray-600 dark:text-gray-300 text-center">Invoice Attached</span>
                  <span id="step3Date" class="text-xs text-gray-400 dark:text-gray-500 mt-1"></span>
                </div>

                <!-- Step 4: Payment Completed -->
                <div class="flex flex-col items-center" style="flex: 1">
                  <div id="step4" class="w-10 h-10 rounded-full bg-gray-200 dark:bg-gray-600 border-4 border-white dark:border-gray-800 flex items-center justify-center mb-2 transition-all duration-300">
                    <i id="step4Icon" data-lucide="check-circle" class="w-5 h-5 text-gray-400 dark:text-gray-500"></i>
                  </div>
                  <span class="text-xs font-medium text-gray-600 dark:text-gray-300 text-center">Payment Completed</span>
                  <span id="step4Date" class="text-xs text-gray-400 dark:text-gray-500 mt-1"></span>
                </div>
              </div>
            </div>
          </div>

          <!-- PO Details Section -->
          <div>
            <!-- PO Header Info - Compact Layout -->
            <div class="bg-white dark:bg-gray-800 shadow-lg rounded-xl overflow-hidden border border-gray-200 dark:border-gray-600 dark:border-gray-600">
              <div class="bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 px-4 py-4">
                <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between space-y-3 lg:space-y-0">
                  <div class="flex items-center space-x-3">
                    <div class="flex-shrink-0">
                      <div class="w-10 h-10 bg-blue-600 rounded-lg flex items-center justify-center">
                        <i data-lucide="file-text" class="w-5 h-5 text-white"></i>
                      </div>
                    </div>
                    <div>
                      <h1 class="text-xl font-bold text-gray-900 dark:text-white dark:text-white" id="poNumber">-</h1>
                      <div class="mt-1" id="poStatus">-</div>
                    </div>
                  </div>
                  <div class="text-center lg:text-right">
                    <div class="inline-flex flex-col items-center lg:items-end">
                      <p class="text-2xl font-bold text-gray-900 dark:text-white dark:text-white" id="poTotalAmount">-</p>
                      <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Total Amount</p>
                    </div>
                  </div>
                </div>
              </div>
              <div class="border-t border-gray-200 dark:border-gray-600 dark:border-gray-600">
                <div class="grid grid-cols-1 lg:grid-cols-5 gap-0">
                  <div class="p-4 border-b lg:border-b-0 lg:border-r border-gray-200 dark:border-gray-600 dark:border-gray-600">
                    <dt class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">Vendor</dt>
                    <dd class="text-sm font-medium text-gray-900 dark:text-white" id="vendorName">-</dd>
                  </div>
                  <div class="p-4 border-b lg:border-b-0 lg:border-r border-gray-200 dark:border-gray-600">
                    <dt class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">PO Date</dt>
                    <dd class="text-sm font-medium text-gray-900 dark:text-white" id="poDate">-</dd>
                  </div>
                  <div class="p-4 border-b lg:border-b-0 lg:border-r border-gray-200 dark:border-gray-600">
                    <dt class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">Delivery</dt>
                    <dd class="text-sm font-medium text-gray-900 dark:text-white" id="expectedDelivery">-</dd>
                  </div>
                  <div class="p-4 border-b lg:border-b-0 lg:border-r border-gray-200 dark:border-gray-600">
                    <dt class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">PO Type</dt>
                    <dd class="text-sm font-medium text-gray-900 dark:text-white" id="poType">-</dd>
                  </div>
                  <div class="p-4">
                    <dt class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">Payment</dt>
                    <dd class="mt-1" id="paymentStatus">-</dd>
                  </div>
                </div>
                <div class="border-t border-gray-200 dark:border-gray-600 p-4 bg-gray-50 dark:bg-gray-700">
                  <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                    <div>
                      <dt class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">Payment Terms</dt>
                      <dd class="text-sm font-medium text-gray-900 dark:text-white" id="paymentTerms">-</dd>
                    </div>
                    <div>
                      <dt class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">Logistics Partner</dt>
                      <dd class="text-sm font-medium text-gray-900 dark:text-white" id="logisticsPartner">-</dd>
                    </div>
                    <div>
                      <dt class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">Invoices</dt>
                      <dd class="text-sm font-medium text-gray-900 dark:text-white" id="poInvoices">-</dd>
                    </div>
                    <div>
                      <dt class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">Notes</dt>
                      <dd class="text-xs text-gray-700 dark:text-gray-300" id="poNotes">-</dd>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Purchase Order Items & Financial Summary (stacked vertically) -->
        <div class="space-y-4">
          <div>
            <!-- PO Items - Compact Layout -->
            <div class="bg-white dark:bg-gray-800 shadow-lg rounded-xl overflow-hidden border border-gray-200 dark:border-gray-600">
              <div class="bg-gradient-to-r from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 px-4 py-3">
                <div class="flex items-center space-x-2">
                  <div class="w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center">
                    <i data-lucide="package" class="w-4 h-4 text-white"></i>
                  </div>
                  <div>
                    <h3 class="text-lg font-bold text-gray-900 dark:text-white">Purchase Order Items</h3>
                    <p class="text-xs text-gray-600 dark:text-gray-400">Items included in this purchase order</p>
                  </div>
                </div>
              </div>
              <div class="border-t border-gray-200 dark:border-gray-600">
                <div class="overflow-x-auto">
                  <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-600">
                    <thead class="bg-gray-50 dark:bg-gray-700">
                      <tr>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase tracking-wider">Item Details</th>
                        <th class="px-4 py-3 text-center text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase tracking-wider">Qty</th>
                        <th class="px-4 py-3 text-right text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase tracking-wider">Unit Cost</th>
                        <th class="px-4 py-3 text-center text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase tracking-wider">GST %</th>
                        <th class="px-4 py-3 text-right text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase tracking-wider">Total</th>
                      </tr>
                    </thead>
                    <tbody id="poItemsTableBody" class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-600">
                      <!-- Items will be loaded here -->
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>

          <div>
            <!-- Financial Summary Section -->
            <div class="bg-white dark:bg-gray-800 shadow-lg rounded-xl overflow-hidden border border-gray-200 dark:border-gray-600">
              <div class="bg-gradient-to-r from-purple-50 to-pink-50 dark:from-purple-900/20 dark:to-pink-900/20 px-4 py-3">
                <div class="flex items-center space-x-2">
                  <div class="w-8 h-8 bg-purple-600 rounded-lg flex items-center justify-center">
                    <i data-lucide="calculator" class="w-4 h-4 text-white"></i>
                  </div>
                  <div>
                    <h3 class="text-lg font-bold text-gray-900 dark:text-white">Financial Summary</h3>
                    <p class="text-xs text-gray-600 dark:text-gray-400">Cost breakdown and total calculations</p>
                  </div>
                </div>
              </div>
              <div class="border-t border-gray-200 dark:border-gray-600">
                <div class="p-4">
                  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
                    <div class="text-center p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
                      <dt class="text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">
                        <div>Subtotal</div>
                        <div class="text-2xs text-gray-500 dark:text-gray-400">Exclusive of GST</div>
                      </dt>
                      <dd class="text-lg font-semibold text-gray-900 dark:text-white" id="subtotal">-</dd>
                    </div>
                    <div class="text-center p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
                      <dt class="text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">GST</dt>
                      <dd class="text-lg font-semibold text-gray-900 dark:text-white" id="gstTotal">-</dd>
                    </div>
                    <div class="text-center p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
                      <dt class="text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Shipping Cost</dt>
                      <dd class="text-lg font-semibold text-gray-900 dark:text-white" id="shippingCost">-</dd>
                    </div>
                    <div class="text-center p-3 bg-blue-50 dark:bg-blue-900/20 rounded-lg border-2 border-blue-200 dark:border-blue-700">
                      <dt class="text-sm font-bold text-gray-900 dark:text-white mb-1">Total Amount</dt>
                      <dd class="text-xl font-bold text-blue-900 dark:text-blue-400" id="totalAmount">-</dd>
                    </div>
                  </div>

                  <!-- Payment Management Section -->
                  <div class="border-t border-gray-200 dark:border-gray-600 pt-6">
                    <div class="flex items-center justify-between mb-4">
                      <div class="flex items-center space-x-2">
                        <div class="w-6 h-6 bg-green-600 rounded-lg flex items-center justify-center">
                          <i data-lucide="credit-card" class="h-3 w-3 text-white"></i>
                        </div>
                        <h4 class="text-md font-semibold text-gray-900 dark:text-white">Payment Management</h4>
                      </div>
                      <button onclick="showRecordPaymentModal()" class="inline-flex items-center px-3 py-1.5 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                        <i data-lucide="plus" class="h-3 w-3 mr-1"></i>
                        Record Payment
                      </button>
                    </div>

                    <!-- Payment Status Summary -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                      <div class="text-center p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
                        <dt class="text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Total Amount</dt>
                        <dd class="text-lg font-semibold text-gray-900 dark:text-white" id="paymentTotalAmount">-</dd>
                      </div>
                      <div class="text-center p-3 bg-yellow-50 dark:bg-yellow-900/20 rounded-lg border border-yellow-200 dark:border-yellow-700">
                        <dt class="text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Total Paid</dt>
                        <dd class="text-lg font-semibold text-yellow-800 dark:text-yellow-400" id="paymentTotalPaid">-</dd>
                      </div>
                      <div class="text-center p-3 bg-red-50 dark:bg-red-900/20 rounded-lg border border-red-200 dark:border-red-700">
                        <dt class="text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Outstanding</dt>
                        <dd class="text-lg font-semibold text-red-800 dark:text-red-400" id="paymentOutstanding">-</dd>
                      </div>
                    </div>

                    <!-- Payment History -->
                    <div>
                      <h5 class="text-sm font-medium text-gray-900 dark:text-white mb-3">Payment History</h5>
                      <div id="paymentHistory" class="space-y-3">
                        <!-- Payment records will be loaded here -->
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- MRP Calculation Progress Modal -->
    <div id="mrpProgressModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 dark:bg-gray-900 dark:bg-opacity-75 overflow-y-auto h-full w-full hidden z-50 backdrop-blur-sm">
      <div class="relative top-20 mx-auto p-5 border border-gray-200 dark:border-gray-600 w-11/12 md:w-1/2 lg:w-1/3 shadow-lg rounded-md bg-white dark:bg-gray-800">
        <div class="mt-3">
          <!-- Modal Header -->
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center">
              <div class="w-8 h-8 bg-purple-100 dark:bg-purple-900/20 rounded-lg flex items-center justify-center mr-3">
                <i data-lucide="loader" class="h-5 w-5 text-purple-600 dark:text-purple-400 animate-spin"></i>
              </div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Calculating MRP</h3>
            </div>
          </div>

          <!-- Modal Content -->
          <div class="mb-6">
            <div class="flex items-center justify-center mb-4">
              <div class="w-16 h-16 bg-purple-100 dark:bg-purple-900/20 rounded-full flex items-center justify-center">
                <i data-lucide="loader" class="w-8 h-8 text-purple-600 dark:text-purple-400 animate-spin"></i>
              </div>
            </div>
            <p class="text-center text-gray-700 dark:text-gray-300 mb-2" id="mrpProgressText">Initializing calculation...</p>
            <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2 mb-2">
              <div id="mrpProgressBar" class="bg-purple-600 h-2 rounded-full transition-all duration-300" style="width: 0%"></div>
            </div>
            <p class="text-center text-xs text-gray-500 dark:text-gray-400" id="mrpProgressStatus">Please wait while we calculate MRP for all variants...</p>
          </div>
        </div>
      </div>
    </div>

    <!-- MRP Calculation Success Modal -->
    <div id="mrpSuccessModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 dark:bg-gray-900 dark:bg-opacity-75 overflow-y-auto h-full w-full hidden z-50 backdrop-blur-sm">
      <div class="relative top-20 mx-auto p-5 border border-gray-200 dark:border-gray-600 w-11/12 md:w-1/2 lg:w-3/8 shadow-lg rounded-md bg-white dark:bg-gray-800">
        <div class="mt-3">
          <!-- Modal Header -->
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center">
              <div class="w-8 h-8 bg-green-100 dark:bg-green-900/20 rounded-lg flex items-center justify-center mr-3">
                <i data-lucide="check-circle" class="h-5 w-5 text-green-600 dark:text-green-400"></i>
              </div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white">MRP Calculation Completed</h3>
            </div>
            <button onclick="closeMRPSuccessModal()" class="text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors">
              <i data-lucide="x" class="h-6 w-6"></i>
            </button>
          </div>

          <!-- Modal Content -->
          <div class="mb-6">
            <p class="text-gray-700 dark:text-gray-300 mb-4">MRP calculation has been completed successfully! Would you like to view the pricing details?</p>
          </div>

          <!-- Modal Actions -->
          <div class="flex justify-end space-x-3">
            <button onclick="closeMRPSuccessModal()" class="px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 dark:focus:ring-offset-gray-800 focus:ring-indigo-500 transition-colors">Cancel</button>

<%- include('../../../../partials/_head', { seo: { title: 'Categories - PO Management', description: 'Manage product categories for purchase orders' } }) %>
<link rel="stylesheet" href="/assets/css/po-dark-mode.css">

<body class="bg-gray-50 dark:bg-gray-900">
  <%- include('../../../../partials/_subnav', { user, section: 'PO', subsection: 'Categories' }) %>

  <div class="min-h-screen pt-16">
      <!-- Header -->
      <div class="bg-white dark:bg-gray-800 shadow">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="py-6">
            <div class="md:flex md:items-center md:justify-between">
              <div class="flex-1 min-w-0">
                <h2 class="mt-2 text-2xl font-bold leading-7 text-gray-900 dark:text-white sm:text-3xl sm:truncate">Category Management</h2>
                <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Manage product categories for procurement items</p>
              </div>
              <div class="mt-4 flex md:mt-0 md:ml-4">
                <button type="button" onclick="openCreateCategoryModal()" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 dark:focus:ring-offset-gray-800">
                  <i data-lucide="plus" class="h-4 w-4 mr-2"></i>
                  Add New Category
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Main Content -->
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 sm:py-8">
        <!-- Stats Cards -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6 mb-6 lg:mb-8">
          <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
            <div class="p-4 lg:p-6">
              <div class="flex items-center">
                <div class="flex-shrink-0">
                  <div class="w-10 h-10 lg:w-12 lg:h-12 bg-blue-100 dark:bg-blue-900/20 rounded-lg flex items-center justify-center">
                    <i data-lucide="folder" class="h-5 w-5 lg:h-6 lg:w-6 text-blue-600 dark:text-blue-400"></i>
                  </div>
                </div>
                <div class="ml-3 lg:ml-4 flex-1">
                  <dl>
                    <dt class="text-xs lg:text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Categories</dt>
                    <dd class="text-lg lg:text-2xl font-bold text-gray-900 dark:text-white" id="totalCategories">-</dd>
                  </dl>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
            <div class="p-4 lg:p-6">
              <div class="flex items-center">
                <div class="flex-shrink-0">
                  <div class="w-10 h-10 lg:w-12 lg:h-12 bg-green-100 dark:bg-green-900/20 rounded-lg flex items-center justify-center">
                    <i data-lucide="check-circle" class="h-5 w-5 lg:h-6 lg:w-6 text-green-600 dark:text-green-400"></i>
                  </div>
                </div>
                <div class="ml-3 lg:ml-4 flex-1">
                  <dl>
                    <dt class="text-xs lg:text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Active Categories</dt>
                    <dd class="text-lg lg:text-2xl font-bold text-gray-900 dark:text-white" id="activeCategories">-</dd>
                  </dl>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
            <div class="p-4 lg:p-6">
              <div class="flex items-center">
                <div class="flex-shrink-0">
                  <div class="w-10 h-10 lg:w-12 lg:h-12 bg-yellow-100 dark:bg-yellow-900/20 rounded-lg flex items-center justify-center">
                    <i data-lucide="package" class="h-5 w-5 lg:h-6 lg:w-6 text-yellow-600 dark:text-yellow-400"></i>
                  </div>
                </div>
                <div class="ml-3 lg:ml-4 flex-1">
                  <dl>
                    <dt class="text-xs lg:text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Products</dt>
                    <dd class="text-lg lg:text-2xl font-bold text-gray-900 dark:text-white" id="totalProducts">-</dd>
                  </dl>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
            <div class="p-4 lg:p-6">
              <div class="flex items-center">
                <div class="flex-shrink-0">
                  <div class="w-10 h-10 lg:w-12 lg:h-12 bg-purple-100 dark:bg-purple-900/20 rounded-lg flex items-center justify-center">
                    <i data-lucide="dollar-sign" class="h-5 w-5 lg:h-6 lg:w-6 text-purple-600 dark:text-purple-400"></i>
                  </div>
                </div>
                <div class="ml-3 lg:ml-4 flex-1">
                  <dl>
                    <dt class="text-xs lg:text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Value</dt>
                    <dd class="text-lg lg:text-2xl font-bold text-gray-900 dark:text-white" id="totalValue">-</dd>
                  </dl>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Categories Table -->
        <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-md">
          <div class="px-4 py-4 lg:px-6 lg:py-6">
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center mb-4 space-y-2 sm:space-y-0">
              <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white">Categories</h3>
              <div class="flex space-x-2">
                <button onclick="refreshCategories()" class="text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 p-2">
                  <i data-lucide="refresh-cw" class="h-5 w-5"></i>
                </button>
                <button onclick="exportCategories()" class="text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 p-2">
                  <i data-lucide="download" class="h-5 w-5"></i>
                </button>
              </div>
            </div>

            <!-- Table View -->
            <div class="overflow-x-auto -mx-4 sm:mx-0">
              <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-600">
                <thead class="bg-gray-50 dark:bg-gray-700">
                  <tr>
                    <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Name</th>
                    <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Description</th>
                    <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Products</th>
                    <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Status</th>
                    <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Created</th>
                    <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Actions</th>
                  </tr>
                </thead>
                <tbody id="categoriesTableBody" class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-600">
                  <!-- Categories will be loaded here -->
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Create/Edit Category Modal -->
    <div id="categoryModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full hidden z-50 backdrop-blur-sm">
      <div class="relative top-4 sm:top-20 mx-auto p-4 sm:p-6 border w-11/12 sm:w-2/3 lg:w-1/3 xl:w-1/4 shadow-2xl rounded-xl bg-white dark:bg-gray-800 border-gray-200 dark:border-gray-700 transform transition-all duration-300 ease-out scale-95 opacity-0">
        <div class="mt-3">
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center space-x-3">
              <div class="w-10 h-10 bg-orange-100 dark:bg-orange-900/20 rounded-lg flex items-center justify-center">
                <i data-lucide="folder" class="h-5 w-5 text-orange-600 dark:text-orange-400"></i>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white" id="categoryModalTitle">Add New Category</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400">Create a new product category</p>
              </div>
            </div>
            <button onclick="closeCategoryModal()" class="text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors">
              <i data-lucide="x" class="h-5 w-5"></i>
            </button>
          </div>

          <form id="categoryForm" class="space-y-6">
            <div>
              <label for="categoryName" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Category Name *</label>
              <input type="text" id="categoryName" name="name" required placeholder="Enter category name" class="block w-full px-3 py-2.5 border-2 border-gray-300 dark:border-gray-600 rounded-lg shadow-sm focus:ring-2 focus:ring-orange-500 focus:border-orange-500 sm:text-sm transition-colors bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400" />
            </div>

            <div>
              <label for="categoryDescription" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Description</label>
              <textarea id="categoryDescription" name="description" rows="3" placeholder="Enter category description (optional)" class="block w-full px-3 py-2.5 border-2 border-gray-300 dark:border-gray-600 rounded-lg shadow-sm focus:ring-2 focus:ring-orange-500 focus:border-orange-500 sm:text-sm transition-colors resize-none bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"></textarea>
            </div>

            <div>
              <label for="categoryStatus" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Status</label>
              <select id="categoryStatus" name="is_active" class="block w-full px-3 py-2.5 border-2 border-gray-300 dark:border-gray-600 rounded-lg shadow-sm focus:ring-2 focus:ring-orange-500 focus:border-orange-500 sm:text-sm transition-colors bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
                <option value="true">Active</option>
                <option value="false">Inactive</option>
              </select>
            </div>

            <div class="flex justify-end space-x-3 pt-6 border-t border-gray-200 dark:border-gray-600">
              <button type="button" onclick="closeCategoryModal()" class="px-6 py-2.5 border-2 border-gray-300 dark:border-gray-600 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 hover:border-gray-400 dark:hover:border-gray-500 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition-colors">Cancel</button>
              <button type="submit" class="px-6 py-2.5 bg-orange-600 border-2 border-orange-600 rounded-lg text-sm font-medium text-white hover:bg-orange-700 hover:border-orange-700 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:ring-offset-2 transition-colors">
                <span id="categorySubmitText">Create Category</span>
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <script>
      let categories = [];
      let currentCategoryId = null;

      // Load data on page load
      document.addEventListener("DOMContentLoaded", function () {
        loadCategories();
      });

      // Load categories
      async function loadCategories() {
        try {
          const response = await fetch("/po/api/v1/categories");
          const result = await response.json();
          if (result.success) {
            categories = result.data;
            updateStats();
            renderCategories();
          }
        } catch (error) {
          console.error("Error loading categories:", error);
        }
      }

      // Update statistics
      function updateStats() {
        const totalCategories = categories.length;
        const activeCategories = categories.filter((category) => category.is_active).length;
        const totalProducts = categories.reduce((sum, category) => sum + (category.product_count || 0), 0);
        const totalValue = categories.reduce((sum, category) => sum + (category.total_value || 0), 0);

        document.getElementById("totalCategories").textContent = totalCategories;
        document.getElementById("activeCategories").textContent = activeCategories;
        document.getElementById("totalProducts").textContent = totalProducts;
        document.getElementById("totalValue").textContent = `₹${totalValue.toLocaleString()}`;
      }

      // Render categories table
      function renderCategories() {
        const tbody = document.getElementById("categoriesTableBody");
        tbody.innerHTML = categories
          .map(
            (category) => `
    <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
      <td class="px-3 sm:px-6 py-4 whitespace-nowrap">
        <div class="flex items-center">
          <div class="flex-shrink-0 h-8 w-8 sm:h-10 sm:w-10">
            <div class="h-8 w-8 sm:h-10 sm:w-10 rounded-lg bg-gray-100 dark:bg-gray-700 flex items-center justify-center">
              <i data-lucide="folder" class="h-4 w-4 sm:h-5 sm:w-5 text-gray-400 dark:text-gray-500"></i>
            </div>
          </div>
          <div class="ml-3 sm:ml-4">
            <div class="text-sm font-medium text-gray-900 dark:text-white">${category.name}</div>
          </div>
        </div>
      </td>
      <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
        ${category.description || "-"}
      </td>
      <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">
        ${category.product_count || 0}
      </td>
      <td class="px-3 sm:px-6 py-4 whitespace-nowrap">
        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium ${category.is_active ? "bg-green-100 dark:bg-green-900/20 text-green-800 dark:text-green-400" : "bg-red-100 dark:bg-red-900/20 text-red-800 dark:text-red-400"}">
          ${category.is_active ? "Active" : "Inactive"}
        </span>
      </td>
      <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
        ${new Date(category.created_at).toLocaleDateString()}
      </td>
      <td class="px-3 sm:px-6 py-4 whitespace-nowrap text-sm font-medium">
        <div class="flex space-x-1 sm:space-x-2">
          <button onclick="editCategory(${category.id})" class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-900 dark:hover:text-indigo-300 p-1">
            <i data-lucide="edit" class="h-4 w-4"></i>
          </button>
          <button onclick="deleteCategory(${category.id})" class="text-red-600 dark:text-red-400 hover:text-red-900 dark:hover:text-red-300 p-1">
            <i data-lucide="trash-2" class="h-4 w-4"></i>
          </button>
        </div>
      </td>
    </tr>
  `,
          )
          .join("");

        // Re-initialize icons
        if (typeof lucide !== "undefined") {
          lucide.createIcons();
        }
      }

      // Modal functions
      function openCreateCategoryModal() {
        currentCategoryId = null;
        document.getElementById("categoryModalTitle").textContent = "Add New Category";
        document.getElementById("categorySubmitText").textContent = "Create Category";
        document.getElementById("categoryForm").reset();
        document.getElementById("categoryStatus").value = "true"; // Default to active

        const modal = document.getElementById("categoryModal");
        modal.classList.remove("hidden");

        // Add animation class
        setTimeout(() => {
          modal.querySelector(".transform").classList.add("scale-100", "opacity-100");
        }, 10);
      }

      function closeCategoryModal() {
        const modal = document.getElementById("categoryModal");
        modal.querySelector(".transform").classList.remove("scale-100", "opacity-100");

        setTimeout(() => {
          modal.classList.add("hidden");
        }, 200);

        currentCategoryId = null;
      }

      function editCategory(id) {
        const category = categories.find((c) => c.id === id);
        if (!category) return;

        currentCategoryId = id;
        document.getElementById("categoryModalTitle").textContent = "Edit Category";
        document.getElementById("categorySubmitText").textContent = "Update Category";

        // Populate form
        document.getElementById("categoryName").value = category.name;
        document.getElementById("categoryDescription").value = category.description || "";
        document.getElementById("categoryStatus").value = category.is_active ? "true" : "false";

        const modal = document.getElementById("categoryModal");
        modal.classList.remove("hidden");

        // Add animation class
        setTimeout(() => {
          modal.querySelector(".transform").classList.add("scale-100", "opacity-100");
        }, 10);
      }

      function deleteCategory(id) {
        if (confirm("Are you sure you want to delete this category?")) {
          fetch(`/po/api/v1/categories/${id}`, {
            method: "DELETE",
          })
            .then((response) => response.json())
            .then((result) => {
              if (result.success) {
                loadCategories();
                if (typeof showSuccessToast !== "undefined") {
                  showSuccessToast("Category deleted successfully");
                } else if (typeof toastManager !== "undefined") {
                  toastManager.success("Category deleted successfully");
                } else {
                  console.log(`SUCCESS: Category deleted successfully`);
                }
              } else {
                if (typeof showErrorToast !== "undefined") {
                  showErrorToast(result.error || "Error deleting category");
                } else if (typeof toastManager !== "undefined") {
                  toastManager.error(result.error || "Error deleting category");
                } else {
                  console.log(`ERROR: ${result.error || "Error deleting category"}`);
                }
              }
            })
            .catch((error) => {
              console.error("Error deleting category:", error);
              if (typeof showErrorToast !== "undefined") {
                showErrorToast("Error deleting category");
              } else if (typeof toastManager !== "undefined") {
                toastManager.error("Error deleting category");
              } else {
                console.log(`ERROR: Error deleting category`);
              }
            });
        }
      }

      // Form submission
      document.getElementById("categoryForm").addEventListener("submit", async function (e) {
        e.preventDefault();

        const formData = new FormData(this);
        const data = Object.fromEntries(formData.entries());

        try {
          const url = currentCategoryId ? `/po/api/v1/categories/${currentCategoryId}` : "/po/api/v1/categories";
          const method = currentCategoryId ? "PUT" : "POST";

          const response = await fetch(url, {
            method: method,
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
          });

          const result = await response.json();
          if (result.success) {
            closeCategoryModal();
            loadCategories();
            if (typeof showSuccessToast !== "undefined") {
              showSuccessToast("Category saved successfully");
            } else if (typeof toastManager !== "undefined") {
              toastManager.success("Category saved successfully");
            } else {
              console.log(`SUCCESS: Category saved successfully`);
            }
          } else {
            if (typeof showErrorToast !== "undefined") {
              showErrorToast(result.error || "Error saving category");
            } else if (typeof toastManager !== "undefined") {
              toastManager.error(result.error || "Error saving category");
            } else {
              console.log(`ERROR: ${result.error || "Error saving category"}`);
            }
          }
        } catch (error) {
          console.error("Error saving category:", error);
          if (typeof showErrorToast !== "undefined") {
            showErrorToast("Error saving category");
          } else if (typeof toastManager !== "undefined") {
            toastManager.error("Error saving category");
          } else {
            console.log(`ERROR: Error saving category`);
          }
        }
      });

      function refreshCategories() {
        loadCategories();
      }

      function exportCategories() {
        // TODO: Implement export functionality
        console.log("Export categories");
      }
    </script>

  <%- include('../../../../partials/_footer') %>
  <%- include('../../../../partials/_toast') %>
</body>
</html>

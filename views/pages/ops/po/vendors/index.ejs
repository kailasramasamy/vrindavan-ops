<!DOCTYPE html>
<html lang="en">
  <%- include('../../../../partials/_head', { seo: { title: 'Vendor Management - PO Management', description: 'Manage vendor profiles, performance, and compliance' } }) %>
  <link rel="stylesheet" href="/assets/css/po-dark-mode.css" />

  <body class="bg-gray-50 dark:bg-gray-900">
    <%- include('../../../../partials/_subnav', { user, section: 'PO', subsection: 'Vendors' }) %>

    <div class="min-h-screen pt-16">
      <!-- Header -->
      <div class="bg-white dark:bg-gray-800 shadow">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="py-6">
            <div class="md:flex md:items-center md:justify-between">
              <div class="flex-1 min-w-0">
                <h2 class="mt-2 text-2xl font-bold leading-7 text-gray-900 dark:text-white sm:text-3xl sm:truncate">Vendor Management</h2>
                <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Manage vendor profiles, performance, and compliance</p>
              </div>
              <div class="mt-4 flex md:mt-0 md:ml-4">
                <button type="button" onclick="openCreateVendorModal()" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                  <i data-lucide="plus" class="h-4 w-4 mr-2"></i>
                  Add New Vendor
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Main Content -->
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Stats Cards -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-10">
          <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
            <div class="p-6">
              <div class="flex items-center">
                <div class="flex-shrink-0">
                  <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/20 rounded-lg flex items-center justify-center">
                    <i data-lucide="building" class="h-6 w-6 text-blue-600 dark:text-blue-400"></i>
                  </div>
                </div>
                <div class="ml-12 flex-1">
                  <dl class="pl-2">
                    <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Vendors</dt>
                    <dd class="text-lg font-medium text-gray-900 dark:text-white" id="totalVendors">-</dd>
                  </dl>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
            <div class="p-6">
              <div class="flex items-center">
                <div class="flex-shrink-0">
                  <div class="w-12 h-12 bg-green-100 dark:bg-green-900/20 rounded-lg flex items-center justify-center">
                    <i data-lucide="check-circle" class="h-6 w-6 text-green-600 dark:text-green-400"></i>
                  </div>
                </div>
                <div class="ml-12 flex-1">
                  <dl class="pl-2">
                    <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Active Vendors</dt>
                    <dd class="text-lg font-medium text-gray-900 dark:text-white" id="activeVendors">-</dd>
                  </dl>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
            <div class="p-6">
              <div class="flex items-center">
                <div class="flex-shrink-0">
                  <div class="w-12 h-12 bg-yellow-100 dark:bg-yellow-900/20 rounded-lg flex items-center justify-center">
                    <i data-lucide="star" class="h-6 w-6 text-yellow-600 dark:text-yellow-400"></i>
                  </div>
                </div>
                <div class="ml-12 flex-1">
                  <dl class="pl-2">
                    <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Avg. Rating</dt>
                    <dd class="text-lg font-medium text-gray-900 dark:text-white" id="avgRating">-</dd>
                  </dl>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
            <div class="p-6">
              <div class="flex items-center">
                <div class="flex-shrink-0">
                  <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/20 rounded-lg flex items-center justify-center">
                    <i data-lucide="dollar-sign" class="h-6 w-6 text-purple-600 dark:text-purple-400"></i>
                  </div>
                </div>
                <div class="ml-12 flex-1">
                  <dl class="pl-2">
                    <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Value</dt>
                    <dd class="text-lg font-medium text-gray-900 dark:text-white" id="totalValue">-</dd>
                  </dl>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Filters and Search -->
        <div class="bg-white dark:bg-gray-800 shadow rounded-lg mb-8">
          <div class="px-6 py-6">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <div>
                <label for="Search" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Search</label>
                <input type="text" id="searchInput" placeholder="Search by name, contact, GSTIN..." class="block w-full bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 px-3 py-2.5 border-2 border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" />
              </div>
              <div>
                <label for="Status" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Status</label>
                <select id="statusFilter" class="block w-full bg-white dark:bg-gray-700 text-gray-900 dark:text-white px-3 py-2.5 border-2 border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                  <option value="">All Status</option>
                  <option value="active">Active</option>
                  <option value="inactive">Inactive</option>
                </select>
              </div>
              <div>
                <label for="Min Rating" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Min Rating</label>
                <select id="ratingFilter" class="block w-full bg-white dark:bg-gray-700 text-gray-900 dark:text-white px-3 py-2.5 border-2 border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                  <option value="">Any Rating</option>
                  <option value="4">4+ Stars</option>
                  <option value="3">3+ Stars</option>
                  <option value="2">2+ Stars</option>
                </select>
              </div>
            </div>
          </div>
        </div>

        <!-- Vendors Table -->
        <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-md">
          <div class="px-6 py-6">
            <div class="flex justify-between items-center mb-6">
              <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white">Vendors</h3>
              <div class="flex space-x-3">
                <button onclick="refreshVendors()" class="text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                  <i data-lucide="refresh-cw" class="h-5 w-5"></i>
                </button>
                <button onclick="exportVendors()" class="text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                  <i data-lucide="download" class="h-5 w-5"></i>
                </button>
              </div>
            </div>

            <div class="overflow-x-auto -mx-6 sm:mx-0">
              <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-600">
                <thead class="bg-gray-50 dark:bg-gray-700">
                  <tr>
                    <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Vendor</th>
                    <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Contact</th>
                    <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">GSTIN</th>
                    <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Location</th>
                    <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Rating</th>
                    <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Status</th>
                    <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Actions</th>
                  </tr>
                </thead>
                <tbody id="vendorsTableBody" class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-600">
                  <!-- Vendors will be loaded here -->
                </tbody>
              </table>
            </div>

            <!-- Pagination -->
            <div class="bg-white dark:bg-gray-800 px-6 py-4 flex items-center justify-between border-t border-gray-200 dark:border-gray-600">
              <div class="flex-1 flex items-center justify-between">
                <div>
                  <p class="text-sm text-gray-700 dark:text-gray-300">
                    Showing
                    <span id="showingStart">1</span>
                    to
                    <span id="showingEnd">10</span>
                    of
                    <span id="totalVendorsCount">0</span>
                    results
                  </p>
                </div>
                <div>
                  <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px">
                    <button onclick="previousPage()" class="relative inline-flex items-center px-3 py-2 rounded-l-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm font-medium text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors">
                      <i data-lucide="chevron-left" class="h-5 w-5"></i>
                    </button>
                    <button onclick="nextPage()" class="relative inline-flex items-center px-3 py-2 rounded-r-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm font-medium text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors">
                      <i data-lucide="chevron-right" class="h-5 w-5"></i>
                    </button>
                  </nav>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Create/Edit Vendor Modal -->
    <div id="vendorModal" class="fixed inset-0 bg-gray-600 dark:bg-gray-900 bg-opacity-50 dark:bg-opacity-75 overflow-y-auto h-full w-full hidden z-50 backdrop-blur-sm">
      <div class="relative top-4 sm:top-20 mx-auto p-4 border w-11/12 max-w-md sm:max-w-lg lg:max-w-xl xl:max-w-2xl shadow-2xl rounded-xl bg-white dark:bg-gray-800 border-gray-200 dark:border-gray-700 transform transition-all duration-300 ease-out scale-95 opacity-0">
        <div class="mt-3">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center space-x-3">
              <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/20 rounded-lg flex items-center justify-center">
                <i data-lucide="building" class="h-5 w-5 text-blue-600 dark:text-blue-400"></i>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white" id="vendorModalTitle">Add New Vendor</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400">Create a new vendor profile</p>
              </div>
            </div>
            <button onclick="closeVendorModal()" class="text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors">
              <i data-lucide="x" class="h-5 w-5"></i>
            </button>
          </div>

          <form id="vendorForm" class="space-y-2">
            <!-- Basic Information -->
            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-3">
              <h4 class="text-sm font-semibold text-gray-800 dark:text-gray-200 mb-3 flex items-center">
                <i data-lucide="building" class="w-4 h-4 mr-2 text-blue-600 dark:text-blue-400"></i>
                Basic Information
              </h4>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                  <label for="vendorName" class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">Vendor Name *</label>
                  <input type="text" id="vendorName" name="name" required placeholder="Enter vendor name" class="block w-full bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-1 focus:ring-blue-500 focus:border-blue-500 text-sm transition-colors" />
                </div>
                <div>
                  <label for="vendorGstin" class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">GSTIN</label>
                  <input type="text" id="vendorGstin" name="gstin" placeholder="Enter GSTIN" class="block w-full bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-1 focus:ring-blue-500 focus:border-blue-500 text-sm transition-colors" />
                </div>
              </div>
            </div>

            <!-- Address Information -->
            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-3">
              <h4 class="text-sm font-semibold text-gray-800 dark:text-gray-200 mb-3 flex items-center">
                <i data-lucide="map-pin" class="w-4 h-4 mr-2 text-green-600 dark:text-green-400"></i>
                Address Information
              </h4>
              <div class="space-y-3">
                <div>
                  <label for="vendorAddress" class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">Address</label>
                  <textarea id="vendorAddress" name="address" rows="2" placeholder="Enter complete address" class="block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-1 focus:ring-blue-500 focus:border-blue-500 text-sm transition-colors resize-none bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"></textarea>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                  <div>
                    <label for="vendorCity" class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">City</label>
                    <input type="text" id="vendorCity" name="city" placeholder="City" class="block w-full bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-1 focus:ring-blue-500 focus:border-blue-500 text-sm transition-colors" />
                  </div>
                  <div>
                    <label for="vendorState" class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">State</label>
                    <input type="text" id="vendorState" name="state" placeholder="State" class="block w-full bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-1 focus:ring-blue-500 focus:border-blue-500 text-sm transition-colors" />
                  </div>
                  <div>
                    <label for="vendorPincode" class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">Pincode</label>
                    <input type="text" id="vendorPincode" name="pincode" placeholder="Pincode" class="block w-full bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-1 focus:ring-blue-500 focus:border-blue-500 text-sm transition-colors" />
                  </div>
                </div>
              </div>
            </div>

            <!-- Contact Information -->
            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-3">
              <h4 class="text-sm font-semibold text-gray-800 dark:text-gray-200 mb-3 flex items-center">
                <i data-lucide="user" class="w-4 h-4 mr-2 text-purple-600 dark:text-purple-400"></i>
                Contact Information
              </h4>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                  <label for="contactPersonName" class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">Contact Person *</label>
                  <input type="text" id="contactPersonName" name="contact_person_name" required placeholder="Contact person name" class="block w-full bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-1 focus:ring-blue-500 focus:border-blue-500 text-sm transition-colors" />
                </div>
                <div>
                  <label for="contactPersonPhone" class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">Phone *</label>
                  <input type="tel" id="contactPersonPhone" name="contact_person_phone" required placeholder="Phone number" class="block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-1 focus:ring-blue-500 focus:border-blue-500 text-sm transition-colors bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400" />
                </div>
                <div>
                  <label for="contactPersonEmail" class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">Email</label>
                  <input type="email" id="contactPersonEmail" name="contact_person_email" placeholder="Email address" class="block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-1 focus:ring-blue-500 focus:border-blue-500 text-sm transition-colors bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400" />
                </div>
                <div>
                  <label for="paymentTerms" class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">Payment Terms</label>
                  <input type="text" id="paymentTerms" name="payment_terms" placeholder="e.g., Net 30" class="block w-full bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-1 focus:ring-blue-500 focus:border-blue-500 text-sm transition-colors" />
                </div>
              </div>
            </div>

            <!-- Additional Information -->
            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-3">
              <h4 class="text-sm font-semibold text-gray-800 dark:text-gray-200 mb-3 flex items-center">
                <i data-lucide="settings" class="w-4 h-4 mr-2 text-orange-600 dark:text-orange-400"></i>
                Additional Information
              </h4>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                  <label for="vendorRating" class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">Rating (1-5)</label>
                  <input type="number" id="vendorRating" name="rating" min="1" max="5" step="0.1" placeholder="4.5" class="block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-1 focus:ring-blue-500 focus:border-blue-500 text-sm transition-colors bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400" />
                </div>
                <div>
                  <label for="vendorStatus" class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">Status</label>
                  <select id="vendorStatus" name="status" class="block w-full bg-white dark:bg-gray-700 text-gray-900 dark:text-white px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-1 focus:ring-blue-500 focus:border-blue-500 text-sm transition-colors">
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                  </select>
                </div>
              </div>
              <div class="mt-3">
                <label for="vendorNotes" class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">Notes</label>
                <textarea id="vendorNotes" name="notes" rows="2" placeholder="Additional notes about the vendor" class="block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-1 focus:ring-blue-500 focus:border-blue-500 text-sm transition-colors resize-none bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"></textarea>
              </div>
            </div>

            <div class="flex justify-end space-x-3 pt-3 border-t border-gray-200 dark:border-gray-600">
              <button type="button" onclick="closeVendorModal()" class="px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 hover:border-gray-400 dark:hover:border-gray-500 focus:outline-none focus:ring-1 focus:ring-gray-500 focus:ring-offset-1 transition-colors">Cancel</button>
              <button type="submit" class="px-4 py-2 bg-blue-600 border border-blue-600 rounded-md text-sm font-medium text-white hover:bg-blue-700 hover:border-blue-700 focus:outline-none focus:ring-1 focus:ring-blue-500 focus:ring-offset-1 transition-colors">
                <span id="vendorSubmitText">Create Vendor</span>
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <script>
      let vendors = [];
      let filteredVendors = [];
      let currentPage = 1;
      let vendorsPerPage = 10;
      let currentVendorId = null;

      // Load data on page load
      document.addEventListener("DOMContentLoaded", function () {
        loadVendors();
      });

      // Load vendors
      async function loadVendors() {
        try {
          const response = await fetch("/po/api/v1/vendors");
          const result = await response.json();
          if (result.success) {
            vendors = result.data;
            filteredVendors = [...vendors]; // Initialize filtered vendors
            updateStats();
            renderVendors();
            setupEventListeners(); // Setup auto-filtering
          }
        } catch (error) {
          console.error("Error loading vendors:", error);
        }
      }

      // Update statistics
      function updateStats() {
        const totalVendors = vendors.length;
        const activeVendors = vendors.filter((vendor) => vendor.status === "active").length;
        // Calculate average rating with proper NaN handling
        const validRatings = vendors.filter((vendor) => vendor.rating && !isNaN(parseFloat(vendor.rating))).map((vendor) => parseFloat(vendor.rating));
        const avgRating = validRatings.length > 0 ? (validRatings.reduce((sum, rating) => sum + rating, 0) / validRatings.length).toFixed(1) : "0.0";

        // Calculate total value with proper formatting
        const totalValue = vendors.reduce((sum, vendor) => {
          const value = parseFloat(vendor.total_purchase_value) || 0;
          return sum + value;
        }, 0);

        document.getElementById("totalVendors").textContent = totalVendors;
        document.getElementById("activeVendors").textContent = activeVendors;
        document.getElementById("avgRating").textContent = avgRating;
        document.getElementById("totalValue").textContent = `₹${totalValue.toFixed(2)}`;
      }

      // Render vendors table
      function renderVendors() {
        const tbody = document.getElementById("vendorsTableBody");
        const startIndex = (currentPage - 1) * vendorsPerPage;
        const endIndex = startIndex + vendorsPerPage;
        const pageVendors = filteredVendors.slice(startIndex, endIndex);

        tbody.innerHTML = pageVendors
          .map(
            (vendor) => `
     <tr class="hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
       <td class="px-6 py-6 whitespace-nowrap">
         <div class="flex items-center">
           <div class="flex-shrink-0 h-10 w-10">
             <div class="h-10 w-10 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center">
               <i data-lucide="building" class="h-5 w-5 text-gray-400 dark:text-gray-500"></i>
             </div>
           </div>
           <div class="ml-4">
             <div class="text-sm font-medium text-gray-900 dark:text-white">${vendor.name}</div>
             <div class="text-sm text-gray-500 dark:text-gray-400">${vendor.gstin || "No GSTIN"}</div>
           </div>
         </div>
       </td>
       <td class="px-6 py-6 whitespace-nowrap text-sm text-gray-900 dark:text-white">
         <div>${vendor.contact_person_name}</div>
         <div class="text-gray-500 dark:text-gray-400">${vendor.contact_person_phone}</div>
       </td>
       <td class="px-6 py-6 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
         ${vendor.gstin || "-"}
       </td>
       <td class="px-6 py-6 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
         <div>${vendor.city || "-"}</div>
         <div class="text-xs">${vendor.state || "-"}</div>
       </td>
       <td class="px-6 py-6 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
         <div class="flex items-center">
           <span class="text-yellow-400">★</span>
           <span class="ml-1">${vendor.rating && !isNaN(parseFloat(vendor.rating)) ? parseFloat(vendor.rating).toFixed(1) : "0.0"}</span>
         </div>
       </td>
       <td class="px-6 py-6 whitespace-nowrap">
         <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${vendor.status === "active" ? "bg-green-100 dark:bg-green-900/20 text-green-800 dark:text-green-400" : "bg-red-100 dark:bg-red-900/20 text-red-800 dark:text-red-400"}">
           ${vendor.status}
         </span>
       </td>
       <td class="px-6 py-6 whitespace-nowrap text-sm font-medium">
         <div class="flex space-x-2">
           <button onclick="editVendor(${vendor.id})" class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-900 dark:hover:text-indigo-300 p-1 rounded hover:bg-indigo-50 dark:hover:bg-indigo-900/20 transition-colors">
             <i data-lucide="edit" class="h-4 w-4"></i>
           </button>
           <button onclick="deleteVendor(${vendor.id})" class="text-red-600 dark:text-red-400 hover:text-red-900 dark:hover:text-red-300 p-1 rounded hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors">
             <i data-lucide="trash-2" class="h-4 w-4"></i>
           </button>
         </div>
       </td>
     </tr>
   `,
          )
          .join("");

        // Update pagination info
        document.getElementById("showingStart").textContent = startIndex + 1;
        document.getElementById("showingEnd").textContent = Math.min(endIndex, filteredVendors.length);
        document.getElementById("totalVendorsCount").textContent = filteredVendors.length;

        // Re-initialize icons
        if (typeof lucide !== "undefined") {
          lucide.createIcons();
        }
      }

      // Modal functions
      function openCreateVendorModal() {
        currentVendorId = null;
        document.getElementById("vendorModalTitle").textContent = "Add New Vendor";
        document.getElementById("vendorSubmitText").textContent = "Create Vendor";
        document.getElementById("vendorForm").reset();

        const modal = document.getElementById("vendorModal");
        modal.classList.remove("hidden");

        // Add animation class
        setTimeout(() => {
          modal.querySelector(".transform").classList.add("scale-100", "opacity-100");
        }, 10);
      }

      function closeVendorModal() {
        const modal = document.getElementById("vendorModal");
        modal.querySelector(".transform").classList.remove("scale-100", "opacity-100");

        setTimeout(() => {
          modal.classList.add("hidden");
        }, 200);

        currentVendorId = null;
      }

      function editVendor(id) {
        const vendor = vendors.find((v) => v.id === id);
        if (!vendor) return;

        currentVendorId = id;
        document.getElementById("vendorModalTitle").textContent = "Edit Vendor";
        document.getElementById("vendorSubmitText").textContent = "Update Vendor";

        // Populate form
        document.getElementById("vendorName").value = vendor.name;
        document.getElementById("vendorGstin").value = vendor.gstin || "";
        document.getElementById("vendorAddress").value = vendor.address || "";
        document.getElementById("vendorCity").value = vendor.city || "";
        document.getElementById("vendorState").value = vendor.state || "";
        document.getElementById("vendorPincode").value = vendor.pincode || "";
        document.getElementById("contactPersonName").value = vendor.contact_person_name;
        document.getElementById("contactPersonPhone").value = vendor.contact_person_phone;
        document.getElementById("contactPersonEmail").value = vendor.contact_person_email || "";
        document.getElementById("paymentTerms").value = vendor.payment_terms || "";
        document.getElementById("vendorRating").value = vendor.rating || "";
        document.getElementById("vendorStatus").value = vendor.status;
        document.getElementById("vendorNotes").value = vendor.notes || "";

        const modal = document.getElementById("vendorModal");
        modal.classList.remove("hidden");

        // Add animation class
        setTimeout(() => {
          modal.querySelector(".transform").classList.add("scale-100", "opacity-100");
        }, 10);
      }

      async function deleteVendor(id) {
        if (confirm("Are you sure you want to delete this vendor?")) {
          try {
            const response = await fetch(`/po/api/v1/vendors/${id}`, {
              method: "DELETE",
            });

            const result = await response.json();
            if (result.success) {
              if (typeof showSuccessToast !== "undefined") {
                showSuccessToast("Vendor deleted successfully");
              } else if (typeof toastManager !== "undefined") {
                toastManager.success("Vendor deleted successfully");
              } else {
                console.log(`SUCCESS: Vendor deleted successfully`);
              }
              loadVendors(); // Reload the vendors list
            } else {
              if (typeof showErrorToast !== "undefined") {
                showErrorToast(result.error || "Error deleting vendor");
              } else if (typeof toastManager !== "undefined") {
                toastManager.error(result.error || "Error deleting vendor");
              } else {
                console.log(`ERROR: ${result.error || "Error deleting vendor"}`);
              }
            }
          } catch (error) {
            console.error("Error deleting vendor:", error);
            if (typeof showErrorToast !== "undefined") {
              showErrorToast("Error deleting vendor");
            } else if (typeof toastManager !== "undefined") {
              toastManager.error("Error deleting vendor");
            } else {
              console.log(`ERROR: Error deleting vendor`);
            }
          }
        }
      }

      // Form submission
      document.getElementById("vendorForm").addEventListener("submit", async function (e) {
        e.preventDefault();

        const formData = new FormData(this);
        const data = Object.fromEntries(formData.entries());

        try {
          const url = currentVendorId ? `/po/api/v1/vendors/${currentVendorId}` : "/po/api/v1/vendors";
          const method = currentVendorId ? "PUT" : "POST";

          const response = await fetch(url, {
            method: method,
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
          });

          const result = await response.json();
          if (result.success) {
            const successMessage = currentVendorId ? "Vendor updated successfully" : "Vendor created successfully";
            closeVendorModal();
            loadVendors();
            if (typeof showSuccessToast !== "undefined") {
              showSuccessToast(successMessage);
            } else if (typeof toastManager !== "undefined") {
              toastManager.success(successMessage);
            } else {
              console.log(`SUCCESS: ${successMessage}`);
            }
          } else {
            const errorMessage = currentVendorId ? "Error updating vendor" : "Error creating vendor";
            if (typeof showErrorToast !== "undefined") {
              showErrorToast(result.error || errorMessage);
            } else if (typeof toastManager !== "undefined") {
              toastManager.error(result.error || errorMessage);
            } else {
              console.log(`ERROR: ${result.error || errorMessage}`);
            }
          }
        } catch (error) {
          console.error("Error saving vendor:", error);
          if (typeof showErrorToast !== "undefined") {
            showErrorToast("Error saving vendor");
          } else if (typeof toastManager !== "undefined") {
            toastManager.error("Error saving vendor");
          } else {
            console.log(`ERROR: Error saving vendor`);
          }
        }
      });

      // Setup event listeners for auto-filtering
      function setupEventListeners() {
        const searchInput = document.getElementById("searchInput");
        const statusFilter = document.getElementById("statusFilter");
        const ratingFilter = document.getElementById("ratingFilter");

        // Debounce function for search input
        function debounce(func, wait) {
          let timeout;
          return function executedFunction(...args) {
            const later = () => {
              clearTimeout(timeout);
              func(...args);
            };
            clearTimeout(timeout);
            timeout = setTimeout(later, wait);
          };
        }

        // Auto-filter on search input
        searchInput.addEventListener("input", debounce(applyFilters, 300));

        // Auto-filter on dropdown changes
        statusFilter.addEventListener("change", applyFilters);
        ratingFilter.addEventListener("change", applyFilters);
      }

      // Filter functions
      function applyFilters() {
        const search = document.getElementById("searchInput").value.toLowerCase();
        const status = document.getElementById("statusFilter").value;
        const rating = document.getElementById("ratingFilter").value;

        filteredVendors = vendors.filter((vendor) => {
          // Search filter
          const matchesSearch = !search || vendor.name.toLowerCase().includes(search) || vendor.contact_person_name.toLowerCase().includes(search) || vendor.gstin?.toLowerCase().includes(search) || vendor.city?.toLowerCase().includes(search);

          // Status filter
          const matchesStatus = !status || vendor.status === status;

          // Rating filter
          const vendorRating = parseFloat(vendor.rating) || 0;
          const matchesRating = !rating || vendorRating >= parseFloat(rating);

          return matchesSearch && matchesStatus && matchesRating;
        });

        // Reset to first page when filtering
        currentPage = 1;
        renderVendors();
      }

      function refreshVendors() {
        loadVendors();
      }

      function exportVendors() {
        // TODO: Implement export functionality
        console.log("Export vendors");
      }

      // Pagination
      function previousPage() {
        if (currentPage > 1) {
          currentPage--;
          renderVendors();
        }
      }

      function nextPage() {
        const totalPages = Math.ceil(filteredVendors.length / vendorsPerPage);
        if (currentPage < totalPages) {
          currentPage++;
          renderVendors();
        }
      }
    </script>

    <style>
      /* Force vendor modal to have a reasonable width */
      #vendorModal .relative {
        max-width: 500px !important;
        width: 90% !important;
      }

      @media (min-width: 640px) {
        #vendorModal .relative {
          max-width: 600px !important;
          width: 75% !important;
        }
      }

      @media (min-width: 1024px) {
        #vendorModal .relative {
          max-width: 650px !important;
          width: 60% !important;
        }
      }

      @media (min-width: 1280px) {
        #vendorModal .relative {
          max-width: 700px !important;
          width: 50% !important;
        }
      }
    </style>

    <%- include('../../../../partials/_footer') %> <%- include('../../../../partials/_toast') %>
  </body>

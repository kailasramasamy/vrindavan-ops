    // Update stats
    function updateStats() {
      document.getElementById('totalCalculations').textContent = pricingData.length;
      document.getElementById('activeVariants').textContent = new Set(pricingData.map(item => item.variant_id)).size;
      
      if (pricingData.length > 0) {
        const avgProfitMargin = pricingData.reduce((sum, item) => sum + parseFloat(item.profit_margin_percentage), 0) / pricingData.length;
        document.getElementById('avgProfitMargin').textContent = avgProfitMargin.toFixed(1) + '%';
        
        const avgMRP = pricingData.reduce((sum, item) => sum + parseFloat(item.final_mrp), 0) / pricingData.length;
        document.getElementById('avgMRP').textContent = '₹' + avgMRP.toLocaleString('en-IN', {minimumFractionDigits: 2, maximumFractionDigits: 2});
      } else {
        document.getElementById('avgProfitMargin').textContent = '-';
        document.getElementById('avgMRP').textContent = '-';
      }
    }



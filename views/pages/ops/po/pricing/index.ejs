    // Edit Profit Margin Modal Functions
    let currentEditProfitMarginData = null;

    async function openEditProfitMarginModal(variantId, procurementItemId, variantName, itemName, currentMRP, currentMargin, useGlobalMargin = false) {
      try {
        currentEditProfitMarginData = { variantId, procurementItemId };
        
        document.getElementById('editProfitMarginVariantName').textContent = variantName;
        document.getElementById('editProfitMarginItemName').textContent = itemName;
        document.getElementById('editProfitMarginCurrentMRP').textContent = parseFloat(currentMRP).toFixed(2);
        
        // Fetch global margin from procurement item
        try {
          const response = await fetch(`/po/api/v1/products/${procurementItemId}`);
          const result = await response.json();
          
          if (result.success) {
            const globalMargin = result.data.default_profit_margin || 20;
            document.getElementById('globalMarginValue').textContent = globalMargin;
            
            // Set radio buttons based on current state
            if (useGlobalMargin) {
              document.getElementById('useGlobalMargin').checked = true;
              document.getElementById('useCustomMargin').checked = false;
              document.getElementById('globalMarginInfo').classList.remove('hidden');
              document.getElementById('customMarginInput').classList.add('hidden');
            } else {
              document.getElementById('useGlobalMargin').checked = false;
              document.getElementById('useCustomMargin').checked = true;
              document.getElementById('globalMarginInfo').classList.add('hidden');
              document.getElementById('customMarginInput').classList.remove('hidden');
            }
            
            // Set calculation mode to default (Adjust Profit Margin)
            document.getElementById('adjustMarginMode').checked = true;
            document.getElementById('keepMRPMode').checked = false;
            document.getElementById('fixedMRPInput').classList.add('hidden');
            document.getElementById('calculatedMarginLabel').classList.add('hidden');
            
            // Set current margin in custom input for reference
            document.getElementById('editProfitMarginValue').value = currentMargin;
          }
        } catch (error) {
          console.error('Error fetching global margin:', error);
          // Fallback to current margin
          document.getElementById('globalMarginValue').textContent = currentMargin;
        }
        
        document.getElementById('editProfitMarginModal').classList.remove('hidden');
        
        // Setup event listeners for this modal instance
        setupEditProfitMarginEventListeners();
        
        // Calculate preview
        calculateProfitMarginPreview();
        
        // Re-initialize icons
        if (typeof lucide !== 'undefined') {
          lucide.createIcons();
        }
      } catch (error) {
        console.error('Error opening edit profit margin modal:', error);
      }
    }

    function closeEditProfitMarginModal() {
      document.getElementById('editProfitMarginModal').classList.add('hidden');
      currentEditProfitMarginData = null;
    }

    function calculateProfitMarginPreview() {
      try {
        if (!currentEditProfitMarginData) {
          return;
        }
        
        // Find the current pricing data for this variant
        const currentData = pricingData.find(item => 
          item.variant_id == currentEditProfitMarginData.variantId && 
          item.procurement_item_id == currentEditProfitMarginData.procurementItemId
        );
        
        if (!currentData) {
          document.getElementById('editProfitMarginNewMRP').textContent = 'Data not found';
          return;
        }
        
        const sourcingCost = parseFloat(currentData.sourcing_cost);
        const gstAmount = parseFloat(currentData.gst_amount || 0);
        const totalExpenses = parseFloat(currentData.total_expenses || 0);
        
        const adjustMarginMode = document.getElementById('adjustMarginMode');
        
        if (adjustMarginMode.checked) {
          // Adjust Profit Margin mode - calculate new MRP based on margin
          let newMargin;
          
          if (document.getElementById('useGlobalMargin').checked) {
            newMargin = parseFloat(document.getElementById('globalMarginValue').textContent) || 0;
          } else {
            newMargin = parseFloat(document.getElementById('editProfitMarginValue').value) || 0;
          }
          
          // If using global margin, calculate new MRP with global margin
          if (document.getElementById('useGlobalMargin').checked) {
            // Calculate total cost (sourcing + GST + operational expenses, excluding payment gateway)
            const variantShippingCost = parseFloat(currentData.variant_shipping_cost || 0);
            const packagingCost = parseFloat(currentData.packaging_cost || 0);
            const deliveryCost = parseFloat(currentData.delivery_cost || 0);
            const softwareCost = parseFloat(currentData.software_cost || 0);
            const operationalExpenses = variantShippingCost + packagingCost + deliveryCost + softwareCost;
            
            const totalCost = sourcingCost + gstAmount + operationalExpenses;
            
            // Calculate final MRP based on global profit margin: Final MRP = Total Cost / (1 - Global Profit Margin % / 100)
            const finalMRP = totalCost / (1 - newMargin / 100);
            
            // Display the calculated MRP
            document.getElementById('editProfitMarginNewMRP').textContent = parseFloat(finalMRP.toFixed(2)).toLocaleString('en-IN', {minimumFractionDigits: 2});
            document.getElementById('calculatedMarginLabel').classList.add('hidden');
            return;
          }
          
          // If using the same margin as current, show current MRP
          const currentMargin = parseFloat(currentData.actual_profit_margin_percentage || currentData.profit_margin_percentage) || 0;
          if (Math.abs(newMargin - currentMargin) < 0.01) {
            document.getElementById('editProfitMarginNewMRP').textContent = parseFloat(currentData.final_mrp).toFixed(2);
            return;
          }
          
          // Calculate total cost (sourcing + GST + operational expenses, excluding payment gateway)
          // Extract individual expense components from totalExpenses
          const variantShippingCost = parseFloat(currentData.variant_shipping_cost || 0);
          const packagingCost = parseFloat(currentData.packaging_cost || 0);
          const deliveryCost = parseFloat(currentData.delivery_cost || 0);
          const softwareCost = parseFloat(currentData.software_cost || 0);
          const operationalExpenses = variantShippingCost + packagingCost + deliveryCost + softwareCost;
          
          const totalCost = sourcingCost + gstAmount + operationalExpenses;
          
          // Calculate final MRP based on profit margin: Final MRP = Total Cost / (1 - Profit Margin % / 100)
          const finalMRP = totalCost / (1 - newMargin / 100);
          
          // Calculate payment gateway charge (2% of final MRP)
          const paymentGatewayCharge = finalMRP * 0.02;
          
          // Display the calculated MRP
          document.getElementById('editProfitMarginNewMRP').textContent = parseFloat(finalMRP.toFixed(2)).toLocaleString('en-IN', {minimumFractionDigits: 2});
          document.getElementById('calculatedMarginLabel').classList.add('hidden');
        } else {
          // Keep MRP Fixed mode - calculate profit margin based on fixed MRP
          const fixedMRP = parseFloat(document.getElementById('editFixedMRPValue').value) || 0;
          
          if (fixedMRP <= 0) {
            document.getElementById('editProfitMarginNewMRP').textContent = 'Enter valid MRP';
            document.getElementById('editCalculatedMargin').textContent = '-';
            return;
          }
          
          // Calculate payment gateway charge from fixed MRP
          const paymentGatewayCharge = fixedMRP * 0.02;
          const baseMRP = fixedMRP - paymentGatewayCharge;
          
          // Calculate profit margin from fixed MRP (including all costs)
          const totalCost = sourcingCost + gstAmount + totalExpenses + paymentGatewayCharge;
          const profitAmount = fixedMRP - totalCost;
          const calculatedMargin = (profitAmount / fixedMRP) * 100;
          
          // Display the fixed MRP and calculated margin
          document.getElementById('editProfitMarginNewMRP').textContent = parseFloat(fixedMRP.toFixed(2)).toLocaleString('en-IN', {minimumFractionDigits: 2});
          document.getElementById('editCalculatedMargin').textContent = parseFloat(calculatedMargin.toFixed(2));
          document.getElementById('calculatedMarginLabel').classList.remove('hidden');
        }
      } catch (error) {
        console.error('Error in calculateProfitMarginPreview:', error);
        document.getElementById('editProfitMarginNewMRP').textContent = 'Error calculating';
      }
    }

    // Setup event listeners for edit profit margin modal
    function setupEditProfitMarginEventListeners() {
      const useGlobalMargin = document.getElementById('useGlobalMargin');
      const useCustomMargin = document.getElementById('useCustomMargin');
      const adjustMarginMode = document.getElementById('adjustMarginMode');
      const keepMRPMode = document.getElementById('keepMRPMode');
      const globalMarginInfo = document.getElementById('globalMarginInfo');
      const customMarginInput = document.getElementById('customMarginInput');
      const fixedMRPInput = document.getElementById('fixedMRPInput');
      const editProfitMarginValue = document.getElementById('editProfitMarginValue');
      const editFixedMRPValue = document.getElementById('editFixedMRPValue');

      if (useGlobalMargin && useCustomMargin) {
        // Remove existing listeners to avoid duplicates
        useGlobalMargin.removeEventListener('change', handleGlobalMarginChange);
        useCustomMargin.removeEventListener('change', handleCustomMarginChange);
        
        // Add new listeners
        useGlobalMargin.addEventListener('change', handleGlobalMarginChange);
        useCustomMargin.addEventListener('change', handleCustomMarginChange);
      }

      if (adjustMarginMode && keepMRPMode) {
        // Remove existing listeners to avoid duplicates
        adjustMarginMode.removeEventListener('change', handleCalculationModeChange);
        keepMRPMode.removeEventListener('change', handleCalculationModeChange);
        
        // Add new listeners
        adjustMarginMode.addEventListener('change', handleCalculationModeChange);
        keepMRPMode.addEventListener('change', handleCalculationModeChange);
      }

      // Add event listener for input field changes
      if (editProfitMarginValue) {
        editProfitMarginValue.removeEventListener('input', handleMarginInputChange);
        editProfitMarginValue.addEventListener('input', handleMarginInputChange);
      }

      if (editFixedMRPValue) {
        editFixedMRPValue.removeEventListener('input', handleFixedMRPInputChange);
        editFixedMRPValue.addEventListener('input', handleFixedMRPInputChange);
      }
    }

    function handleGlobalMarginChange() {
      if (this.checked) {
        document.getElementById('globalMarginInfo').classList.remove('hidden');
        document.getElementById('customMarginInput').classList.add('hidden');
        calculateProfitMarginPreview();
      }
    }

    function handleCustomMarginChange() {
      if (this.checked) {
        document.getElementById('globalMarginInfo').classList.add('hidden');
        document.getElementById('customMarginInput').classList.remove('hidden');
        calculateProfitMarginPreview();
      }
    }

    function handleMarginInputChange() {
      calculateProfitMarginPreview();
    }

    function handleCalculationModeChange() {
      const adjustMarginMode = document.getElementById('adjustMarginMode');
      const keepMRPMode = document.getElementById('keepMRPMode');
      const customMarginInput = document.getElementById('customMarginInput');
      const fixedMRPInput = document.getElementById('fixedMRPInput');
      const calculatedMarginLabel = document.getElementById('calculatedMarginLabel');

      if (adjustMarginMode.checked) {
        // Show custom margin input, hide fixed MRP input
        customMarginInput.classList.remove('hidden');
        fixedMRPInput.classList.add('hidden');
        calculatedMarginLabel.classList.add('hidden');
      } else if (keepMRPMode.checked) {
        // Show fixed MRP input, hide custom margin input
        customMarginInput.classList.add('hidden');
        fixedMRPInput.classList.remove('hidden');
        calculatedMarginLabel.classList.remove('hidden');
        
        // Set current MRP as default value
        const currentMRP = document.getElementById('editProfitMarginCurrentMRP').textContent;
        document.getElementById('editFixedMRPValue').value = currentMRP;
      }
      
      calculateProfitMarginPreview();
    }

    function handleFixedMRPInputChange() {
      calculateProfitMarginPreview();
    }

    async function saveVariantProfitMargin() {
      try {
        if (!currentEditProfitMarginData) {
          window.showErrorToast('No variant selected for editing');
          return;
        }

        const adjustMarginMode = document.getElementById('adjustMarginMode');
        
        if (adjustMarginMode.checked) {
          // Adjust Profit Margin mode - traditional behavior
          let profitMargin;
          let useGlobal = false;

          if (document.getElementById('useGlobalMargin').checked) {
            profitMargin = parseFloat(document.getElementById('globalMarginValue').textContent) || 0;
            useGlobal = true;
          } else {
            profitMargin = parseFloat(document.getElementById('editProfitMarginValue').value);
            useGlobal = false;
          }

          if (profitMargin < 0 || profitMargin > 100) {
            window.showErrorToast('Profit margin must be between 0 and 100');
            return;
          }

          const url = `/po/api/v1/variants/${currentEditProfitMarginData.variantId}/profit-margin/${currentEditProfitMarginData.procurementItemId}`;

          const response = await fetch(url, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 
              profitMargin,
              useGlobal: useGlobal
            })
          });

          const result = await response.json();

          if (result.success) {
            const message = useGlobal ? 
              'Variant profit margin set to use global margin' : 
              'Variant profit margin updated successfully';
            window.showSuccessToast(message);
            closeEditProfitMarginModal();
            loadPricingData(); // Refresh the table
          } else {
            window.showErrorToast('Error updating profit margin: ' + result.error);
          }
        } else {
          // Keep MRP Fixed mode - calculate and save the profit margin based on fixed MRP
          const fixedMRP = parseFloat(document.getElementById('editFixedMRPValue').value);
          
          if (fixedMRP <= 0) {
            window.showErrorToast('Please enter a valid MRP value');
            return;
          }

          // Find the current pricing data for this variant
          const currentData = pricingData.find(item => 
            item.variant_id == currentEditProfitMarginData.variantId && 
            item.procurement_item_id == currentEditProfitMarginData.procurementItemId
          );
          
          if (!currentData) {
            window.showErrorToast('Unable to find variant data');
            return;
          }
          
          const sourcingCost = parseFloat(currentData.sourcing_cost);
          const variantShippingCost = parseFloat(currentData.variant_shipping_cost);
          const packagingCost = parseFloat(currentData.packaging_cost || 0);
          const deliveryCost = parseFloat(currentData.delivery_cost || 0);
          const softwareCost = parseFloat(currentData.software_cost || 0);
          const gstAmount = parseFloat(currentData.gst_amount || 0);
          const totalExpenses = variantShippingCost + packagingCost + deliveryCost + softwareCost;
          
          // Calculate payment gateway charge from fixed MRP
          const paymentGatewayCharge = fixedMRP * 0.02;
          const baseMRP = fixedMRP - paymentGatewayCharge;
          
          // Calculate profit margin from fixed MRP (including all costs)
          const totalCost = sourcingCost + gstAmount + totalExpenses + paymentGatewayCharge;
          const profitAmount = fixedMRP - totalCost;
          const calculatedMargin = (profitAmount / fixedMRP) * 100;
          
          if (calculatedMargin < 0) {
            window.showErrorToast('The fixed MRP results in a negative profit margin. Please increase the MRP.');
            return;
          }

          const url = `/po/api/v1/variants/${currentEditProfitMarginData.variantId}/fixed-mrp/${currentEditProfitMarginData.procurementItemId}`;

          const response = await fetch(url, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 
              fixedMRP: fixedMRP
            })
          });

          const result = await response.json();

          if (result.success) {
            window.showSuccessToast(`Profit margin updated to ${calculatedMargin.toFixed(2)}% based on fixed MRP of ₹${fixedMRP.toFixed(2)}`);
            closeEditProfitMarginModal();
            loadPricingData(); // Refresh the table
          } else {
            window.showErrorToast('Error updating profit margin: ' + result.error);
          }
        }
      } catch (error) {
        console.error('Error updating profit margin:', error);
        window.showErrorToast('Error updating profit margin');
      }
    }

    // Expense Breakdown Modal Functions
    function showExpenseBreakdown(variantId, procurementItemId, variantName, itemName, shippingCost, packagingCost, deliveryCost, softwareCost, totalExpenses, gstAmount, gstPercentage, paymentGatewayCharge) {
      // Set the modal content
      document.getElementById('expenseBreakdownVariantName').textContent = variantName;
      document.getElementById('expenseBreakdownItemName').textContent = itemName;
      document.getElementById('expenseBreakdownShipping').textContent = '₹' + parseFloat(shippingCost || 0).toFixed(2);
      document.getElementById('expenseBreakdownPackaging').textContent = '₹' + parseFloat(packagingCost || 0).toFixed(2);
      document.getElementById('expenseBreakdownDelivery').textContent = '₹' + parseFloat(deliveryCost || 0).toFixed(2);
      document.getElementById('expenseBreakdownSoftware').textContent = '₹' + parseFloat(softwareCost || 0).toFixed(2);
      document.getElementById('expenseBreakdownGateway').textContent = '₹' + parseFloat(paymentGatewayCharge || 0).toFixed(2) + ' (2.0%)';
      
    // Calculate total from individual components to ensure consistency with the breakdown display
    const calculatedTotal = parseFloat(shippingCost || 0) + parseFloat(packagingCost || 0) + parseFloat(deliveryCost || 0) + parseFloat(softwareCost || 0) + parseFloat(paymentGatewayCharge || 0);
    document.getElementById('expenseBreakdownTotal').textContent = '₹' + calculatedTotal.toFixed(2);
      
      // Show the modal
      document.getElementById('expenseBreakdownModal').classList.remove('hidden');
      
      // Re-initialize icons
      if (typeof lucide !== 'undefined') {
        lucide.createIcons();
      }
    }

    function closeExpenseBreakdownModal() {
      document.getElementById('expenseBreakdownModal').classList.add('hidden');
    }

    // Toast functions - use the global toast system directly
    // No local function definitions to avoid conflicts with global ones
  </script>

<!DOCTYPE html>
<html lang="en">
  <%- include('../../../../partials/_head', { seo }) %>
<link rel="stylesheet" href="/assets/css/po-dark-mode.css">

  <body class="bg-gray-50 dark:bg-gray-900">
    <%- include('../../../../partials/_subnav', { user, section: 'PO', subsection: 'Pricing' }) %>

    <div class="min-h-screen pt-16">
      <!-- Header -->
      <div class="bg-white dark:bg-gray-800 shadow">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="py-6">
            <div class="md:flex md:items-center md:justify-between">
              <div class="flex-1 min-w-0">
                <h2 class="mt-2 text-2xl font-bold leading-7 text-gray-900 dark:text-white sm:text-3xl sm:truncate">Variant Pricing Management</h2>
                <p class="mt-1 text-sm text-gray-500 dark:text-gray-400 dark:text-gray-500 dark:text-gray-400">Calculate and manage MRP for product variants</p>
              </div>
              <div class="mt-4 flex md:mt-0 md:ml-4">
                <button onclick="openExpenseSettingsModal()" class="inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 dark:focus:ring-offset-gray-800 focus:ring-blue-500 transition-colors">
                  <i data-lucide="settings" class="h-4 w-4 mr-2"></i>
                  Expense Settings
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Stats Cards -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 bg-blue-100 dark:bg-blue-900/20 flex items-center justify-center">
                <i data-lucide="calculator" class="h-5 w-5 text-blue-600 dark:text-blue-400"></i>
              </div>
            </div>
            <div class="ml-6 w-0 flex-1" style="margin-left: 1.75rem !important;">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Calculations</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white" id="totalCalculations">-</dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 bg-green-100 dark:bg-green-900/20 flex items-center justify-center">
                <i data-lucide="package" class="h-5 w-5 text-green-600 dark:text-green-400"></i>
              </div>
            </div>
            <div class="ml-6 w-0 flex-1" style="margin-left: 1.75rem !important;">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Active Variants</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white" id="activeVariants">-</dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 bg-purple-100 dark:bg-purple-900/20 flex items-center justify-center">
                <i data-lucide="trending-up" class="h-5 w-5 text-purple-600 dark:text-purple-400"></i>
              </div>
            </div>
            <div class="ml-6 w-0 flex-1" style="margin-left: 1.75rem !important;">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Avg Profit Margin</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white" id="avgProfitMargin">-</dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 bg-orange-100 dark:bg-orange-900/20 flex items-center justify-center">
                <i data-lucide="dollar-sign" class="h-5 w-5 text-orange-600 dark:text-orange-400"></i>
              </div>
            </div>
            <div class="ml-6 w-0 flex-1" style="margin-left: 1.75rem !important;">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Avg MRP</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white" id="avgMRP">-</dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Filters -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg p-6 mb-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label for="PO Number" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">PO Number</label>
          <div class="relative">
            <input type="text" id="poFilter" placeholder="Search PO Number..." class="block w-full bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" autocomplete="off">
            <div id="poDropdown" class="absolute z-10 w-full mt-1 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md shadow-lg hidden max-h-60 overflow-auto">
              <div class="py-1">
                <div class="px-3 py-2 text-sm text-gray-500 dark:text-gray-300 cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-600" data-value="">All POs</div>
              </div>
            </div>
          </div>
        </div>
        <div>
          <label for="Product Item" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Product Item</label>
          <div class="relative">
            <input type="text" id="itemFilter" placeholder="Search Product Item..." class="block w-full bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" autocomplete="off">
            <div id="itemDropdown" class="absolute z-10 w-full mt-1 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md shadow-lg hidden max-h-60 overflow-auto">
              <div class="py-1">
                <div class="px-3 py-2 text-sm text-gray-500 dark:text-gray-300 cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-600" data-value="">All Items</div>
              </div>
            </div>
          </div>
        </div>
        <div>
          <label for="Variant" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Variant</label>
          <select id="variantFilter" onchange="applyFilters()" class="block w-full bg-white dark:bg-gray-700 text-gray-900 dark:text-white px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
            <option value="">All Variants</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Pricing Data Table -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
      <div class="px-4 sm:px-6 py-4 border-b border-gray-200 dark:border-gray-600">
        <!-- Mobile Header -->
        <div class="block md:hidden">
          <div class="flex items-center space-x-3">
            <div class="w-8 h-8 bg-blue-100 dark:bg-blue-900/20 flex items-center justify-center">
              <i data-lucide="calculator" class="h-4 w-4 text-blue-600 dark:text-blue-400"></i>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white" id="modalTitle">Pricing Calculations</h3>
              <p class="text-sm text-gray-600 dark:text-gray-300">MRP and profit calculations</p>
            </div>
          </div>
        </div>
        
        <!-- Desktop Header -->
        <div class="hidden md:block">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white">Pricing Calculations</h3>
        </div>
      </div>
      
      <!-- Desktop Table View -->
      <div class="hidden md:block overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-600">
          <thead class="bg-gray-50 dark:bg-gray-700">
            <tr>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">PO / Item / Variant</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Sourcing Cost</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">GST</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Expenses</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Profit Margin</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Final MRP</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Calculated</th>
              <th class="px-3 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody id="pricingTableBody" class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-600">
            <tr>
              <td colspan="8" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400">
                <div class="flex flex-col items-center">
                  <i data-lucide="loader" class="h-8 w-8 text-gray-400 dark:text-gray-500 animate-spin mb-2"></i>
                  <span>Loading pricing data...</span>
                </td>
            </tr>
          </tbody>
        </table>
      </div>
      
      <!-- Mobile Card View -->
      <div class="block md:hidden">
        <div id="pricingMobileBody" class="p-4 space-y-3">
          <div class="text-center py-8">
            <i data-lucide="loader" class="h-8 w-8 text-gray-400 dark:text-gray-500 animate-spin mx-auto mb-2"></i>
            <span class="text-gray-600 dark:text-gray-400">Loading pricing data...</span>
          </div>
        </div>
      </div>
      
    </div>
  </div>

  <!-- Expense Settings Modal -->
  <div id="expenseSettingsModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 dark:bg-gray-900 dark:bg-opacity-75 overflow-y-auto h-full w-full hidden z-50 backdrop-blur-sm">
    <div class="relative top-20 mx-auto p-5 border border-gray-200 dark:border-gray-600 w-11/12 md:w-1/2 lg:w-1/3 shadow-lg rounded-md bg-white dark:bg-gray-800">
      <div class="mt-3">
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-blue-100 dark:bg-blue-900/20 flex items-center justify-center mr-3">
              <i data-lucide="settings" class="h-5 w-5 text-blue-600 dark:text-blue-400"></i>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white" id="modalTitle">Expense Settings</h3>
          </div>
          <button onclick="closeExpenseSettingsModal()" class="text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors">
            <i data-lucide="x" class="h-6 w-6"></i>
          </button>
        </div>

        <div class="space-y-4">
          <div>
            <label for="Packaging Cost (₹)" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Packaging Cost (₹)</label>
            <input type="number" id="packagingCost" step="0.01" min="0" class="block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition-colors bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
          </div>
          <div>
            <label for="Delivery Cost (₹)" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Delivery Cost (₹)</label>
            <input type="number" id="deliveryCost" step="0.01" min="0" class="block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition-colors bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
          </div>
          <div>
            <label for="Software Cost (₹)" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Software Cost (₹)</label>
            <input type="number" id="softwareCost" step="0.01" min="0" class="block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition-colors bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
          </div>
        </div>

        <div class="flex justify-end space-x-3 mt-6">
          <button onclick="closeExpenseSettingsModal()" class="px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 dark:focus:ring-offset-gray-800 focus:ring-gray-500 transition-colors">
            Cancel
          </button>
          <button onclick="saveExpenseSettings()" class="px-4 py-2 border border-transparent rounded-md text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 dark:focus:ring-offset-gray-800 focus:ring-blue-500 transition-colors">
            Save Settings
          </button>
        </div>
      </div>
    </div>
  </div>


  <!-- Edit Variant Expenses Modal -->
  <div id="editExpensesModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 dark:bg-gray-900 dark:bg-opacity-75 overflow-y-auto h-full w-full hidden z-50 backdrop-blur-sm">
    <div class="relative top-20 mx-auto p-5 border border-gray-200 dark:border-gray-600 w-11/12 md:w-1/2 lg:w-1/3 shadow-lg rounded-md bg-white dark:bg-gray-800">
      <div class="mt-3">
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-blue-100 dark:bg-blue-900/20 flex items-center justify-center mr-3">
              <i data-lucide="settings" class="h-5 w-5 text-blue-600 dark:text-blue-400"></i>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white" id="modalTitle">Edit Variant Expenses</h3>
          </div>
          <button onclick="closeEditExpensesModal()" class="text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors">
            <i data-lucide="x" class="h-6 w-6"></i>
          </button>
        </div>

        <div class="mb-4">
          <p class="text-sm text-gray-600 dark:text-gray-300 mb-2">Variant: <span id="editExpensesVariantName" class="font-medium text-gray-900 dark:text-white"></span></p>
          <p class="text-sm text-gray-600 dark:text-gray-300">Item: <span id="editExpensesItemName" class="font-medium text-gray-900 dark:text-white"></span></p>
        </div>

        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Shipping Cost (₹)</label>
            <div class="block w-full px-3 py-2 border border-gray-200 dark:border-gray-600 rounded-md bg-gray-50 dark:bg-gray-700 text-gray-600 dark:text-gray-300 sm:text-sm" id="editShippingCost">
              ₹0.00
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400">Derived from PO shipping cost (read-only)</p>
          </div>

          <div>
            <label for="Packaging Cost (₹)" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Packaging Cost (₹)</label>
            <input type="number" id="editPackagingCost" step="0.01" min="0" class="block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition-colors bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
          </div>

          <div>
            <label for="Delivery Cost (₹)" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Delivery Cost (₹)</label>
            <input type="number" id="editDeliveryCost" step="0.01" min="0" class="block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition-colors bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
          </div>

          <div>
            <label for="Software Cost (₹)" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Software Cost (₹)</label>
            <input type="number" id="editSoftwareCost" step="0.01" min="0" class="block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition-colors bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
          </div>
        </div>

        <div class="flex justify-end space-x-3 mt-6">
          <button onclick="closeEditExpensesModal()" class="px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 dark:focus:ring-offset-gray-800 focus:ring-gray-500 transition-colors">
            Cancel
          </button>
          <button onclick="saveVariantExpenses()" class="px-4 py-2 border border-transparent rounded-md text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 dark:focus:ring-offset-gray-800 focus:ring-blue-500 transition-colors">
            Save Expenses
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Edit Profit Margin Modal -->
  <div id="editProfitMarginModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 dark:bg-gray-900 dark:bg-opacity-75 overflow-y-auto h-full w-full hidden z-50 backdrop-blur-sm">
    <div class="relative top-20 mx-auto p-5 border border-gray-200 dark:border-gray-600 w-11/12 md:w-1/2 lg:w-1/3 shadow-lg rounded-md bg-white dark:bg-gray-800">
      <div class="mt-3">
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-purple-100 dark:bg-purple-900/20 flex items-center justify-center mr-3">
              <i data-lucide="percent" class="h-5 w-5 text-purple-600 dark:text-purple-400"></i>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white" id="modalTitle">Edit Profit Margin</h3>
          </div>
          <button onclick="closeEditProfitMarginModal()" class="text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors">
            <i data-lucide="x" class="h-6 w-6"></i>
          </button>
        </div>

        <div class="mb-4">
          <p class="text-sm text-gray-600 dark:text-gray-300 mb-2">Variant: <span id="editProfitMarginVariantName" class="font-medium text-gray-900 dark:text-white"></span></p>
          <p class="text-sm text-gray-600 dark:text-gray-300">Item: <span id="editProfitMarginItemName" class="font-medium text-gray-900 dark:text-white"></span></p>
          <p class="text-sm text-gray-600 dark:text-gray-300">Current MRP: ₹<span id="editProfitMarginCurrentMRP" class="font-medium text-gray-900 dark:text-white"></span></p>
        </div>

        <div class="mb-4">
          <div class="flex items-center space-x-4 mb-3">
            <label class="flex items-center">
              <input type="radio" id="useGlobalMargin" name="marginType" value="global" class="mr-2" checked>
              <span class="text-sm text-gray-700 dark:text-gray-300">Use Global Margin</span>
            </label>
            <label class="flex items-center">
              <input type="radio" id="useCustomMargin" name="marginType" value="custom" class="mr-2">
              <span class="text-sm text-gray-700 dark:text-gray-300">Custom Margin</span>
            </label>
          </div>
          
          <div class="flex items-center space-x-4 mb-3">
            <label class="flex items-center">
              <input type="radio" id="adjustMarginMode" name="calculationMode" value="adjust-margin" class="mr-2" checked>
              <span class="text-sm text-gray-700 dark:text-gray-300">Adjust Profit Margin</span>
            </label>
            <label class="flex items-center">
              <input type="radio" id="keepMRPMode" name="calculationMode" value="keep-mrp" class="mr-2">
              <span class="text-sm text-gray-700 dark:text-gray-300">Keep MRP Fixed</span>
            </label>
          </div>
          
          <div id="globalMarginInfo" class="p-3 bg-blue-50 dark:bg-blue-900/20 rounded-md mb-3 border border-blue-200 dark:border-blue-700">
            <p class="text-sm text-blue-800 dark:text-blue-300">Global Margin: <span id="globalMarginValue" class="font-medium">-</span>%</p>
            <p class="text-sm text-blue-600 dark:text-blue-400">This margin is inherited from the procurement item settings</p>
          </div>
          
          <div id="customMarginInput" class="hidden">
            <label for="Custom Profit Margin (%)" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Custom Profit Margin (%)</label>
            <input type="number" id="editProfitMarginValue" step="0.01" min="0" max="100" class="block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 sm:text-sm transition-colors bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
          </div>
          
          <div id="fixedMRPInput" class="hidden">
            <label for="Fixed MRP (₹)" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Fixed MRP (₹)</label>
            <input type="number" id="editFixedMRPValue" step="0.01" min="0" class="block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 sm:text-sm transition-colors bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
          </div>
        </div>

        <div class="mt-4 p-3 bg-gray-50 dark:bg-gray-700 rounded-md">
          <p class="text-sm text-gray-600 dark:text-gray-300">New MRP: ₹<span id="editProfitMarginNewMRP" class="font-medium text-purple-600 dark:text-purple-400">-</span></p>
          <p class="text-sm text-gray-600 dark:text-gray-300 hidden" id="calculatedMarginLabel">Calculated Profit Margin: <span id="editCalculatedMargin" class="font-medium text-green-600 dark:text-green-400">-</span>%</p>
        </div>

        <div class="flex justify-end space-x-3 mt-6">
          <button onclick="closeEditProfitMarginModal()" class="px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 dark:focus:ring-offset-gray-800 focus:ring-gray-500 transition-colors">
            Cancel
          </button>
          <button onclick="saveVariantProfitMargin()" class="px-4 py-2 border border-transparent rounded-md text-sm font-medium text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 dark:focus:ring-offset-gray-800 focus:ring-purple-500 transition-colors">
            Save Profit Margin
          </button>

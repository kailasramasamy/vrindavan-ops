  </div>

  <%- include('../../../../partials/_toast') %>

  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <script>
    let pricingData = [];

    // Initialize page
    document.addEventListener('DOMContentLoaded', function() {
      loadPricingData();
      loadExpenseSettings();
      
      // Initialize icons
      if (typeof lucide !== 'undefined') {
        lucide.createIcons();
      }
    });

    // Load pricing data
    async function loadPricingData() {
      try {
        const response = await fetch('/po/api/v1/pricing-data');
        
        if (!response.ok) {
          throw new Error(`API returned ${response.status}: ${response.statusText}`);
        }
        
        const result = await response.json();

        if (result.success) {
          pricingData = result.data || [];
          renderPricingTable();
          updateStats();
          initializePODropdown();
          initializeItemDropdown();
          loadVariants();
        } else {
          console.error('Error loading pricing data:', result.error);
          if (typeof window.showErrorToast !== 'undefined') {
            window.showErrorToast('Error loading pricing data: ' + (result.error || 'Unknown error'));
          }
          // Still render empty state
          pricingData = [];
          renderPricingTable();
        }
      } catch (error) {
        console.error('Error loading pricing data:', error);
        if (typeof window.showErrorToast !== 'undefined') {
          window.showErrorToast('Error loading pricing data. Please check the console for details.');
        }
        // Render empty state on error
        pricingData = [];
        renderPricingTable();
      }
    }

    // Render pricing table
    function renderPricingTable() {
      const tbody = document.getElementById('pricingTableBody');
      
      if (!tbody) {
        console.error('tbody element not found');
        return;
      }
      
      if (pricingData.length === 0) {
        tbody.innerHTML = `
            <tr>
              <td colspan="8" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400">
              <div class="flex flex-col items-center space-y-3">
                <i data-lucide="calculator" class="h-12 w-12 text-gray-400 dark:text-gray-500"></i>
                <div>
                  <p class="text-lg font-medium text-gray-900 dark:text-white mb-2">No pricing data found</p>
                  <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">To see pricing data here, you need to:</p>
                  <ol class="text-sm text-gray-600 dark:text-gray-400 text-left space-y-2 max-w-md">
                    <li>1. Create a Product PO and mark it as <span class="font-medium">Received</span></li>
                    <li>2. Go to the PO detail page and click <span class="font-medium">"Calculate MRP"</span> button</li>
                    <li>3. The calculated pricing will appear here</li>
                  </ol>
                  <p class="text-xs text-gray-500 dark:text-gray-400 mt-4">
                    <strong>Note:</strong> Variants are added in the <a href="/po/products" class="text-blue-600 dark:text-blue-400 hover:underline">Products Management</a> page, not here.
                  </p>
                </div>
              </div>
            </td>
          </tr>
        `;
        
        // Update mobile empty state
        const mobileBody = document.getElementById('pricingMobileBody');
        if (mobileBody) {
          mobileBody.innerHTML = `
            <div class="text-center py-12 text-gray-500 dark:text-gray-400">
              <div class="flex flex-col items-center space-y-3">
                <i data-lucide="calculator" class="h-12 w-12 text-gray-400 dark:text-gray-500"></i>
                <div>
                  <p class="text-lg font-medium text-gray-900 dark:text-white mb-2">No pricing data found</p>
                  <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">To see pricing data here, you need to:</p>
                  <ol class="text-sm text-gray-600 dark:text-gray-400 text-left space-y-2 px-4">
                    <li>1. Create a Product PO and mark it as <span class="font-medium">Received</span></li>
                    <li>2. Go to the PO detail page and click <span class="font-medium">"Calculate MRP"</span> button</li>
                    <li>3. The calculated pricing will appear here</li>
                  </ol>
                  <p class="text-xs text-gray-500 dark:text-gray-400 mt-4 px-4">
                    <strong>Note:</strong> Variants are added in the <a href="/po/products" class="text-blue-600 dark:text-blue-400 hover:underline">Products Management</a> page, not here.
                  </p>
                </div>
              </div>
            </div>
          `;
        }
        return;
      }

      // Create mobile cards
      const mobileCards = pricingData.map(item => `
        <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-600 p-4">
          <!-- Header -->
          <div class="flex justify-between items-start mb-3">
            <div class="flex-1">
              <h3 class="font-semibold text-gray-900 dark:text-white">${item.po_number}</h3>
              <p class="text-sm text-gray-600 dark:text-gray-300">${item.item_name}</p>
              <p class="text-sm text-gray-500 dark:text-gray-400">${item.variant_name} (${parseFloat(item.size || item.unit_size).toFixed(3)} ${item.base_unit})</p>
              ${item.inherited_settings ? '<div class="text-xs text-blue-600 dark:text-blue-400 mt-1">📋 Inherited settings</div>' : ''}
            </div>
            <div class="text-right">
              <div class="text-lg font-bold text-gray-900 dark:text-white">₹${parseFloat(item.final_mrp).toLocaleString('en-IN', {minimumFractionDigits: 2})}</div>
              <div class="text-xs text-gray-500 dark:text-gray-400">Final MRP</div>
            </div>
          </div>
          
          <!-- Cost Breakdown -->
          <div class="grid grid-cols-2 gap-4 mb-3">
            <div>
              <p class="text-xs text-gray-500 dark:text-gray-400">Sourcing Cost</p>
              <p class="text-sm font-medium text-gray-900 dark:text-white">₹${parseFloat(item.sourcing_cost).toLocaleString('en-IN', {minimumFractionDigits: 2})}</p>
            </div>
            <div>
              <p class="text-xs text-gray-500 dark:text-gray-400">GST</p>
              <p class="text-sm font-medium text-gray-900 dark:text-white">₹${parseFloat(item.gst_amount || 0).toFixed(2)}</p>
              <p class="text-xs text-gray-500 dark:text-gray-400">${parseFloat(item.gst_percentage_calc || item.gst_percentage || 0).toFixed(1)}%</p>
            </div>
          </div>
          
          <div class="grid grid-cols-2 gap-4 mb-3">
            <div>
              <p class="text-xs text-gray-500 dark:text-gray-400">Expenses</p>
              <p class="text-sm font-medium text-gray-900 dark:text-white">₹${parseFloat(item.total_expenses || 0).toFixed(2)}</p>
            </div>
            <div>
              <p class="text-xs text-gray-500 dark:text-gray-400">Profit Margin</p>
              <div class="flex items-center space-x-1">
                <div class="flex flex-col items-start">
                  <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium ${item.use_global_margin ? 'bg-green-100 dark:bg-green-900/20 text-green-800 dark:text-green-400' : 'bg-blue-100 dark:bg-blue-900/20 text-blue-800 dark:text-blue-400'}">
                    ${item.actual_profit_margin_percentage || item.profit_margin_percentage}%
                  </span>
                  <span class="text-xs text-gray-600 dark:text-gray-300 mt-1">₹${(parseFloat(item.final_mrp || 0) * parseFloat(item.actual_profit_margin_percentage || item.profit_margin_percentage || 0) / 100).toFixed(2)}</span>
                </div>
                ${item.use_global_margin ? 
                  '<span class="text-xs text-green-600 dark:text-green-400" title="Using Global Margin">🌐</span>' : 
                  '<span class="text-xs text-blue-600 dark:text-blue-400" title="Custom Margin">⚙️</span>'
                }
              </div>
            </div>
          </div>
          
          <!-- Date and Actions -->
          <div class="flex justify-between items-center pt-3 border-t border-gray-100">
            <div class="text-xs text-gray-500 dark:text-gray-400">
              Calculated: ${new Date(item.calculation_date).toLocaleDateString('en-IN')}
            </div>
            <div class="flex space-x-2">
              <button onclick='showExpenseBreakdown(${item.variant_id}, ${item.procurement_item_id}, "${item.variant_name.replace(/"/g, "&quot;")}", "${item.item_name.replace(/"/g, "&quot;")}", ${item.variant_shipping_cost || 0}, ${item.packaging_cost || 0}, ${item.delivery_cost || 0}, ${item.software_cost || 0}, ${item.total_expenses}, ${item.gst_amount || 0}, ${item.gst_percentage_calc || item.gst_percentage || 0}, ${item.payment_gateway_charge || 0})' class="text-blue-600 dark:text-blue-400 hover:text-blue-900 dark:hover:text-blue-300 text-xs" title="View Expense Breakdown">
                <i data-lucide="info" class="h-4 w-4"></i>
              </button>
              <button onclick='openEditExpensesModal(${item.variant_id}, ${item.procurement_item_id}, "${item.variant_name.replace(/"/g, "&quot;")}", "${item.item_name.replace(/"/g, "&quot;")}", {shipping_cost: ${item.variant_shipping_cost || 0}, packaging_cost: ${item.packaging_cost || 0}, delivery_cost: ${item.delivery_cost || 0}, software_cost: ${item.software_cost || 0}})' class="text-green-600 dark:text-green-400 hover:text-green-900 dark:hover:text-green-300 text-xs" title="Edit Expenses">
                <i data-lucide="settings" class="h-4 w-4"></i>
              </button>
              <button onclick='openEditProfitMarginModal(${item.variant_id}, ${item.procurement_item_id}, "${item.variant_name.replace(/"/g, "&quot;")}", "${item.item_name.replace(/"/g, "&quot;")}", ${item.final_mrp}, ${item.profit_margin_percentage}, ${item.use_global_margin})' class="text-purple-600 hover:text-purple-900 text-xs" title="Edit Profit Margin">
                <i data-lucide="percent" class="h-4 w-4"></i>
              </button>
            </div>
          </div>
        </div>
      `).join('');

      // Create desktop table
      const desktopTable = pricingData.map(item => `
        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="text-sm font-medium text-gray-900 dark:text-white">${item.po_number}</div>
            <div class="text-sm text-gray-500 dark:text-gray-400">${item.item_name}</div>
            <div class="text-sm text-gray-600 dark:text-gray-300">${item.variant_name}</div>
            <div class="text-xs text-gray-400">(${parseFloat(item.size || item.unit_size).toFixed(3)} ${item.base_unit})</div>
            ${item.inherited_settings ? '<div class="text-xs text-blue-600 dark:text-blue-400 mt-1">📋 Inherited settings</div>' : ''}
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">
            ₹${parseFloat(item.sourcing_cost).toLocaleString('en-IN', {minimumFractionDigits: 2})}
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">
            <div class="text-center">
              <div class="font-medium">₹${parseFloat(item.gst_amount || 0).toFixed(2)}</div>
              <div class="text-sm text-gray-500 dark:text-gray-400">${parseFloat(item.gst_percentage_calc || item.gst_percentage || 0).toFixed(1)}%</div>
            </div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">
            <div class="flex items-center space-x-1">
                <span class="font-medium">₹${parseFloat(item.total_expenses || 0).toFixed(2)}</span>
              <button onclick='showExpenseBreakdown(${item.variant_id}, ${item.procurement_item_id}, "${item.variant_name.replace(/"/g, "&quot;")}", "${item.item_name.replace(/"/g, "&quot;")}", ${item.variant_shipping_cost || 0}, ${item.packaging_cost || 0}, ${item.delivery_cost || 0}, ${item.software_cost || 0}, ${item.total_expenses}, ${item.gst_amount || 0}, ${item.gst_percentage_calc || item.gst_percentage || 0}, ${item.payment_gateway_charge || 0})' class="text-gray-400 hover:text-gray-600 transition-colors" title="View Expense Breakdown">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </button>
            </div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="flex items-center space-x-2">
              <div class="relative group">
                <div class="flex flex-col items-center">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-sm font-medium ${item.use_global_margin ? 'bg-green-100 dark:bg-green-900/20 text-green-800 dark:text-green-400' : 'bg-blue-100 dark:bg-blue-900/20 text-blue-800 dark:text-blue-400'} cursor-help">
                    ${item.actual_profit_margin_percentage || item.profit_margin_percentage}%
                  </span>
                  <span class="text-xs text-gray-600 dark:text-gray-300 mt-1">₹${(parseFloat(item.final_mrp || 0) * parseFloat(item.actual_profit_margin_percentage || item.profit_margin_percentage || 0) / 100).toFixed(2)}</span>
                </div>
                <!-- Profit Margin Breakdown Tooltip -->
                <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 w-80 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-600 rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                  <div class="p-4">
                    <h4 class="font-semibold text-gray-900 dark:text-white mb-3">Profit Margin Breakdown</h4>
                    
                    <!-- Current Margin (Based on Sourcing Cost) -->
                    <div class="mb-3">
                      <div class="flex justify-between items-center mb-1">
                        <span class="text-sm text-gray-600 dark:text-gray-300">Current Margin (on Sourcing Cost)</span>
                        <span class="text-sm font-medium text-blue-600 dark:text-blue-400">${item.profit_margin_percentage}%</span>
                      </div>
                      <div class="text-xs text-gray-500 dark:text-gray-400">
                        Profit: ₹${((parseFloat(item.sourcing_cost) * parseFloat(item.profit_margin_percentage)) / 100).toFixed(2)}
                      </div>
                    </div>
                    
                    <!-- Net Profit Margin (After All Expenses) -->
                    <div class="mb-3">
                      <div class="flex justify-between items-center mb-1">
                        <span class="text-sm text-gray-600 dark:text-gray-300">Net Profit Margin (on Final MRP)</span>
                        <span class="text-sm font-medium text-green-600 dark:text-green-400">${((parseFloat(item.final_mrp) - parseFloat(item.sourcing_cost) - parseFloat(item.total_expenses || 0) - parseFloat(item.gst_amount || 0)) / parseFloat(item.final_mrp) * 100).toFixed(1)}%</span>
                      </div>
                      <div class="text-xs text-gray-500 dark:text-gray-400">
                        Net Profit: ₹${(parseFloat(item.final_mrp) - parseFloat(item.sourcing_cost) - parseFloat(item.total_expenses || 0) - parseFloat(item.gst_amount || 0)).toFixed(2)}
                      </div>
                    </div>
                    
                    <!-- Cost Breakdown -->
                    <div class="border-t border-gray-200 dark:border-gray-600 pt-2">
                      <div class="text-xs text-gray-500 dark:text-gray-400 space-y-1">
                        <div class="flex justify-between">
                          <span class="text-gray-700 dark:text-gray-300">Sourcing Cost:</span>
                          <span class="text-gray-900 dark:text-white">₹${parseFloat(item.sourcing_cost).toFixed(2)}</span>
                        </div>
                        <div class="flex justify-between">
                          <span class="text-gray-700 dark:text-gray-300">GST (${item.gst_percentage_calc || item.gst_percentage || 0}%):</span>
                          <span class="text-gray-900 dark:text-white">₹${parseFloat(item.gst_amount || 0).toFixed(2)}</span>
                        </div>
                        <div class="flex justify-between">
                          <span class="text-gray-700 dark:text-gray-300">Expenses:</span>
                          <span class="text-gray-900 dark:text-white">₹${parseFloat(item.total_expenses || 0).toFixed(2)}</span>
                        </div>
                        <div class="flex justify-between">
                          <span class="text-gray-700 dark:text-gray-300">Payment Gateway:</span>
                          <span class="text-gray-900 dark:text-white">₹${parseFloat(item.payment_gateway_charge || 0).toFixed(2)}</span>
                        </div>
                        <div class="flex justify-between font-medium border-t border-gray-200 dark:border-gray-600 pt-1">
                          <span class="text-gray-900 dark:text-white">Final MRP:</span>
                          <span class="text-gray-900 dark:text-white">₹${parseFloat(item.final_mrp).toFixed(2)}</span>
                        </div>
                      </div>
                    </div>
                  </div>
                  <!-- Tooltip arrow -->
                  <div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-4 border-r-4 border-t-4 border-transparent border-t-gray-200 dark:border-t-gray-600"></div>
                </div>
              </div>
              ${item.use_global_margin ? 
                '<span class="inline-flex items-center px-1.5 py-0.5 rounded text-sm font-medium bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400" title="Using Global Margin">🌐</span>' : 
                '<span class="inline-flex items-center px-1.5 py-0.5 rounded text-sm font-medium bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-400" title="Custom Margin">⚙️</span>'
              }
            </div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white">
            ₹${parseFloat(item.final_mrp).toLocaleString('en-IN', {minimumFractionDigits: 2})}
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
            ${new Date(item.calculation_date).toLocaleDateString('en-IN')}
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
            <button onclick='openEditExpensesModal(${item.variant_id}, ${item.procurement_item_id}, "${item.variant_name.replace(/"/g, "&quot;")}", "${item.item_name.replace(/"/g, "&quot;")}", {shipping_cost: ${item.variant_shipping_cost || 0}, packaging_cost: ${item.packaging_cost || 0}, delivery_cost: ${item.delivery_cost || 0}, software_cost: ${item.software_cost || 0}})' class="text-green-600 dark:text-green-400 hover:text-green-900 dark:hover:text-green-300 mr-2" title="Edit Expenses">
              <i data-lucide="settings" class="h-4 w-4"></i>
            </button>

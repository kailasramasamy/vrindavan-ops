    // Apply filters
    function applyFilters() {
      const poFilter = selectedPOValue || document.getElementById('poFilter').value;
      const itemFilter = selectedItemValue || document.getElementById('itemFilter').value;
      const variantFilter = document.getElementById('variantFilter').value;

      let filteredData = pricingData;

      if (poFilter) {
        filteredData = filteredData.filter(item => item.po_number.toLowerCase().includes(poFilter.toLowerCase()));
      }
      if (itemFilter) {
        filteredData = filteredData.filter(item => item.procurement_item_id == itemFilter);
      }
      if (variantFilter) {
        filteredData = filteredData.filter(item => item.variant_id == variantFilter);
      }

      const originalData = pricingData;
      pricingData = filteredData;
      renderPricingTable();
      updateStats();
      pricingData = originalData;
    }


    async function loadExpenseSettings() {
      try {
        const response = await fetch('/po/api/v1/expense-settings');
        const result = await response.json();

        if (result.success) {
          result.data.forEach(setting => {
            if (setting.expense_type === 'packaging') {
              document.getElementById('packagingCost').value = setting.default_amount;
            } else if (setting.expense_type === 'delivery') {
              document.getElementById('deliveryCost').value = setting.default_amount;
            } else if (setting.expense_type === 'software') {
              document.getElementById('softwareCost').value = setting.default_amount;
            }
          });
        }
      } catch (error) {
        console.error('Error loading expense settings:', error);
      }
    }

    async function saveExpenseSettings() {
      const packagingCost = document.getElementById('packagingCost').value;
      const deliveryCost = document.getElementById('deliveryCost').value;
      const softwareCost = document.getElementById('softwareCost').value;

      try {
        const promises = [
          fetch('/po/api/v1/expense-settings', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ expenseType: 'packaging', amount: packagingCost })
          }),
          fetch('/po/api/v1/expense-settings', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ expenseType: 'delivery', amount: deliveryCost })
          }),
          fetch('/po/api/v1/expense-settings', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ expenseType: 'software', amount: softwareCost })
          })
        ];

        await Promise.all(promises);
        window.showSuccessToast('Expense settings updated successfully');
        closeExpenseSettingsModal();
      } catch (error) {
        console.error('Error saving expense settings:', error);
        window.showErrorToast('Error saving expense settings');
      }
    }



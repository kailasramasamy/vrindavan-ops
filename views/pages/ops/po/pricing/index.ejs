    </div>
  </div>

  <!-- Expense Breakdown Modal -->
  <div id="expenseBreakdownModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 dark:bg-gray-900 dark:bg-opacity-75 overflow-y-auto h-full w-full hidden z-50 backdrop-blur-sm">
    <div class="relative top-20 mx-auto p-5 border border-gray-200 dark:border-gray-600 w-11/12 md:w-1/2 lg:w-1/3 shadow-lg rounded-md bg-white dark:bg-gray-800">
      <div class="mt-3">
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-blue-100 dark:bg-blue-900/20 flex items-center justify-center mr-3">
              <i data-lucide="receipt" class="h-5 w-5 text-blue-600 dark:text-blue-400"></i>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white" id="modalTitle">Expense Breakdown</h3>
          </div>
          <button onclick="closeExpenseBreakdownModal()" class="text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors">
            <i data-lucide="x" class="h-6 w-6"></i>
          </button>
        </div>

        <div class="mb-4">
          <p class="text-sm text-gray-600 dark:text-gray-300 mb-2">Variant: <span id="expenseBreakdownVariantName" class="font-medium text-gray-900 dark:text-white"></span></p>
          <p class="text-sm text-gray-600 dark:text-gray-300">Item: <span id="expenseBreakdownItemName" class="font-medium text-gray-900 dark:text-white"></span></p>
        </div>

        <div class="space-y-3">
          <div class="flex justify-between items-center py-2 border-b border-gray-100 dark:border-gray-600">
            <span class="text-sm text-gray-600 dark:text-gray-300">Shipping Cost</span>
            <span class="text-sm font-medium text-gray-900 dark:text-white" id="expenseBreakdownShipping">₹0.00</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-gray-100 dark:border-gray-600">
            <span class="text-sm text-gray-600 dark:text-gray-300">Packaging Cost</span>
            <span class="text-sm font-medium text-gray-900 dark:text-white" id="expenseBreakdownPackaging">₹0.00</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-gray-100 dark:border-gray-600">
            <span class="text-sm text-gray-600 dark:text-gray-300">Delivery Cost</span>
            <span class="text-sm font-medium text-gray-900 dark:text-white" id="expenseBreakdownDelivery">₹0.00</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-gray-100 dark:border-gray-600">
            <span class="text-sm text-gray-600 dark:text-gray-300">Software Cost</span>
            <span class="text-sm font-medium text-gray-900 dark:text-white" id="expenseBreakdownSoftware">₹0.00</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-gray-100 dark:border-gray-600">
            <span class="text-sm text-gray-600 dark:text-gray-300">Payment Gateway Charges</span>
            <span class="text-sm font-medium text-gray-900 dark:text-white" id="expenseBreakdownGateway">₹0.00 (2.0%)</span>
          </div>
          <div class="flex justify-between items-center py-3 bg-gray-50 dark:bg-gray-700 rounded-md px-3">
            <span class="text-sm font-semibold text-gray-900 dark:text-white">Total Expenses (Including Payment Gateway)</span>
            <span class="text-sm font-bold text-blue-600 dark:text-blue-400" id="expenseBreakdownTotal">₹0.00</span>
          </div>
        </div>

        <div class="flex justify-end space-x-3 mt-6">
          <button onclick="closeExpenseBreakdownModal()" class="px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 dark:focus:ring-offset-gray-800 focus:ring-gray-500 transition-colors">
            Close
          </button>

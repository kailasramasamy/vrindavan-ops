<%- include('../../../partials/_head', { seo }) %>

<body class="bg-slate-50 dark:bg-gray-900">
  <%- include('../../../partials/_header', { user: (typeof user !== 'undefined' ? user : null) }) %>

  <div class="min-h-screen">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Header -->
      <div class="mb-6">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">Inward Purchase Orders</h1>
            <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">POs received from WMS — auto-invoiced after GRN</p>
          </div>
        </div>
      </div>

      <!-- Stats Cards -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 mb-6">
        <a href="/inward-po" class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4 shadow-sm hover:shadow-md transition-shadow">
          <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Total</p>
          <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= (stats.total) || 0 %></p>
        </a>
        <a href="/inward-po?status=received" class="bg-white dark:bg-gray-800 border-2 <%= (typeof filters !== 'undefined' && filters.status === 'received') ? 'border-blue-500' : 'border-gray-200 dark:border-gray-700' %> rounded-xl p-4 shadow-sm hover:shadow-md transition-shadow">
          <p class="text-xs font-medium text-blue-600 dark:text-blue-400 uppercase">Received</p>
          <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= stats.received_count || 0 %></p>
        </a>
        <a href="/inward-po?status=processing" class="bg-white dark:bg-gray-800 border-2 <%= (typeof filters !== 'undefined' && filters.status === 'processing') ? 'border-yellow-500' : 'border-gray-200 dark:border-gray-700' %> rounded-xl p-4 shadow-sm hover:shadow-md transition-shadow">
          <p class="text-xs font-medium text-yellow-600 dark:text-yellow-400 uppercase">Processing</p>
          <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= stats.processing_count || 0 %></p>
        </a>
        <a href="/inward-po?status=invoiced" class="bg-white dark:bg-gray-800 border-2 <%= (typeof filters !== 'undefined' && filters.status === 'invoiced') ? 'border-indigo-500' : 'border-gray-200 dark:border-gray-700' %> rounded-xl p-4 shadow-sm hover:shadow-md transition-shadow">
          <p class="text-xs font-medium text-indigo-600 dark:text-indigo-400 uppercase">Invoiced</p>
          <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= stats.invoiced_count || 0 %></p>
        </a>
        <a href="/inward-po?status=paid" class="bg-white dark:bg-gray-800 border-2 <%= (typeof filters !== 'undefined' && filters.status === 'paid') ? 'border-green-500' : 'border-gray-200 dark:border-gray-700' %> rounded-xl p-4 shadow-sm hover:shadow-md transition-shadow">
          <p class="text-xs font-medium text-green-600 dark:text-green-400 uppercase">Paid</p>
          <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= stats.paid_count || 0 %></p>
        </a>
        <a href="/inward-po?status=disputed" class="bg-white dark:bg-gray-800 border-2 <%= (typeof filters !== 'undefined' && filters.status === 'disputed') ? 'border-red-500' : 'border-gray-200 dark:border-gray-700' %> rounded-xl p-4 shadow-sm hover:shadow-md transition-shadow">
          <p class="text-xs font-medium text-red-600 dark:text-red-400 uppercase">Disputed</p>
          <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= stats.disputed_count || 0 %></p>
        </a>
      </div>

      <!-- Value Summary -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-6">
        <div class="bg-gradient-to-r from-blue-600 to-indigo-600 rounded-xl p-4 text-white">
          <p class="text-xs opacity-80 uppercase">Total PO Value</p>
          <p class="text-xl font-bold mt-1">₹<%= stats.total_value ? Number(stats.total_value).toLocaleString('en-IN', { minimumFractionDigits: 2 }) : '0.00' %></p>
        </div>
        <div class="bg-gradient-to-r from-orange-500 to-amber-500 rounded-xl p-4 text-white">
          <p class="text-xs opacity-80 uppercase">Pending Invoice</p>
          <p class="text-xl font-bold mt-1">₹<%= stats.pending_invoice_value ? Number(stats.pending_invoice_value).toLocaleString('en-IN', { minimumFractionDigits: 2 }) : '0.00' %></p>
        </div>
        <div class="bg-gradient-to-r from-green-500 to-emerald-500 rounded-xl p-4 text-white">
          <p class="text-xs opacity-80 uppercase">Paid</p>
          <p class="text-xl font-bold mt-1">₹<%= stats.paid_value ? Number(stats.paid_value).toLocaleString('en-IN', { minimumFractionDigits: 2 }) : '0.00' %></p>
        </div>
      </div>

      <!-- Filters -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 mb-6">
        <form method="GET" action="/inward-po" class="p-4">
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
            <div>
              <label class="text-xs font-medium text-gray-500 dark:text-gray-400 block mb-1">Search</label>
              <input type="text" name="search" value="<%= (typeof filters !== 'undefined' && filters.search) || '' %>" placeholder="PO number..." class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
            </div>
            <div>
              <label class="text-xs font-medium text-gray-500 dark:text-gray-400 block mb-1">Status</label>
              <select name="status" class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg text-gray-900 dark:text-white">
                <option value="">All</option>
                <% ['received','grn_received','invoiced','paid','disputed','cancelled'].forEach(function(s) { %>
                  <option value="<%= s %>" <%= (typeof filters !== 'undefined' && filters.status === s) ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
                <% }); %>
              </select>
            </div>
            <div>
              <label class="text-xs font-medium text-gray-500 dark:text-gray-400 block mb-1">GRN</label>
              <select name="has_grn" class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg text-gray-900 dark:text-white">
                <option value="">All</option>
                <option value="yes" <%= (typeof filters !== 'undefined' && filters.has_grn === 'yes') ? 'selected' : '' %>>GRN Done</option>
                <option value="no" <%= (typeof filters !== 'undefined' && filters.has_grn === 'no') ? 'selected' : '' %>>Awaiting GRN</option>
              </select>
            </div>
            <div>
              <label class="text-xs font-medium text-gray-500 dark:text-gray-400 block mb-1">From Date</label>
              <input type="date" name="from_date" value="<%= (typeof filters !== 'undefined' && filters.from_date) || '' %>" class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg text-gray-900 dark:text-white" />
            </div>
            <div>
              <label class="text-xs font-medium text-gray-500 dark:text-gray-400 block mb-1">To Date</label>
              <input type="date" name="to_date" value="<%= (typeof filters !== 'undefined' && filters.to_date) || '' %>" class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg text-gray-900 dark:text-white" />
            </div>
            <div class="flex items-end gap-2">
              <button type="submit" class="px-4 py-2 text-sm font-medium bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">Filter</button>
              <a href="/inward-po" class="px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors">Clear</a>
            </div>
          </div>
        </form>
      </div>

      <!-- PO Table -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
        <div class="px-4 py-3 border-b border-gray-200 dark:border-gray-700">
          <h2 class="text-sm font-semibold text-gray-900 dark:text-white">Purchase Orders (<%= recentPOs.length %>)</h2>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gray-50 dark:bg-gray-700/50">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">PO #</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Warehouse</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">PO Amount</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">GRN</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Invoice</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Status</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Received</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
              <% if (typeof recentPOs !== 'undefined' && recentPOs.length > 0) { %>
                <% const statusColors = { received: 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300', grn_received: 'bg-cyan-100 text-cyan-800 dark:bg-cyan-900/30 dark:text-cyan-300', processing: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300', invoiced: 'bg-indigo-100 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-300', paid: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300', disputed: 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300', cancelled: 'bg-gray-100 text-gray-800 dark:bg-gray-900/30 dark:text-gray-300' }; %>
                <% recentPOs.forEach(function(po) { %>
                  <tr class="hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                    <td class="px-4 py-3">
                      <a href="/inward-po/<%= po.id %>" class="text-blue-600 dark:text-blue-400 font-medium hover:underline text-sm"><%= po.wms_po_number %></a>
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300"><%= po.warehouse_name || '-' %></td>
                    <td class="px-4 py-3 text-sm text-gray-900 dark:text-white text-right font-medium">₹<%= Number(po.total_amount || 0).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
                    <td class="px-4 py-3 text-center">
                      <% if (po.grn_number) { %>
                        <span class="inline-flex items-center gap-1 text-xs font-medium text-green-700 dark:text-green-400">
                          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                          <%= po.grn_number %>
                        </span>
                      <% } else { %>
                        <span class="text-xs text-gray-400 dark:text-gray-500">Awaiting</span>
                      <% } %>
                    </td>
                    <td class="px-4 py-3">
                      <% if (po.invoice_number) { %>
                        <div class="text-xs">
                          <span class="font-medium text-gray-900 dark:text-white"><%= po.invoice_number %></span>
                          <% if (po.invoice_amount) { %>
                            <span class="text-gray-500 dark:text-gray-400 ml-1">₹<%= Number(po.invoice_amount).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></span>
                          <% } %>
                          <% if (po.sent_to_wms_at) { %>
                            <span class="ml-1 text-green-600 dark:text-green-400" title="Sent to WMS">✓</span>
                          <% } %>
                        </div>
                      <% } else { %>
                        <span class="text-xs text-gray-400 dark:text-gray-500">—</span>
                      <% } %>
                    </td>
                    <td class="px-4 py-3 text-center">
                      <span class="px-2 py-1 text-xs font-medium rounded-full <%= statusColors[po.status] || 'bg-gray-100 text-gray-800' %>"><%= po.status %></span>
                    </td>
                    <td class="px-4 py-3 text-xs text-gray-500 dark:text-gray-400"><%= new Date(po.created_at).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: '2-digit' }) %></td>
                    <td class="px-4 py-3 text-center">
                      <a href="/inward-po/<%= po.id %>" class="text-xs text-blue-600 dark:text-blue-400 hover:underline font-medium">View</a>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="8" class="px-4 py-12 text-center text-gray-500 dark:text-gray-400">
                    <svg class="w-12 h-12 mx-auto text-gray-300 dark:text-gray-600 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    <p class="text-sm font-medium">No purchase orders found</p>
                    <p class="text-xs mt-1">POs will appear here when received from WMS via webhook</p>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>

  <%- include('../../../partials/_footer') %>
</body>
</html>

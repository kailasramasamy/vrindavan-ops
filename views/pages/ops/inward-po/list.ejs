<%- include('../../../partials/_head', { seo }) %>

<body class="bg-slate-50 dark:bg-gray-900">
  <%- include('../../../partials/_header', { user: (typeof user !== 'undefined' ? user : null) }) %>

  <div class="min-h-screen">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Header -->
      <div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white">All Inward Purchase Orders</h1>
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Filter and manage all inward POs</p>
        </div>
        <a href="/inward-po" class="inline-flex items-center px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition-colors text-sm font-medium">
          Back to Dashboard
        </a>
      </div>

      <!-- Filters -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4 mb-6">
        <form method="GET" action="/inward-po/list" class="flex flex-wrap items-end gap-4">
          <div class="flex-1 min-w-[180px]">
            <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Search</label>
            <input type="text" name="search" value="<%= (typeof filters !== 'undefined' && filters.search) || '' %>"
              placeholder="PO number or warehouse..."
              class="w-full px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-blue-500">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Status</label>
            <select name="status" class="px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-blue-500">
              <option value="">All</option>
              <% ['received','processing','invoiced','paid','disputed','cancelled'].forEach(function(s) { %>
                <option value="<%= s %>" <%= (typeof filters !== 'undefined' && filters.status === s) ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
              <% }); %>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">From</label>
            <input type="date" name="from_date" value="<%= (typeof filters !== 'undefined' && filters.from_date) || '' %>"
              class="px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white text-sm">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">To</label>
            <input type="date" name="to_date" value="<%= (typeof filters !== 'undefined' && filters.to_date) || '' %>"
              class="px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white text-sm">
          </div>
          <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-sm font-medium">
            Filter
          </button>
          <a href="/inward-po/list" class="px-4 py-2 bg-gray-200 dark:bg-gray-600 text-gray-700 dark:text-gray-200 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-500 transition-colors text-sm">
            Clear
          </a>
        </form>
      </div>

      <!-- Status Tabs -->
      <div class="flex flex-wrap gap-2 mb-6">
        <% const statuses = [{ key: '', label: 'All' }, { key: 'received', label: 'Received' }, { key: 'processing', label: 'Processing' }, { key: 'invoiced', label: 'Invoiced' }, { key: 'paid', label: 'Paid' }, { key: 'disputed', label: 'Disputed' }]; %>
        <% statuses.forEach(function(s) { %>
          <% const isActive = (typeof filters !== 'undefined' && (filters.status || '') === s.key); %>
          <a href="/inward-po/list?status=<%= s.key %>"
            class="px-3 py-1.5 rounded-full text-sm font-medium transition-colors
              <%= isActive ? 'bg-blue-600 text-white' : 'bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-gray-600' %>">
            <%= s.label %>
          </a>
        <% }); %>
      </div>

      <!-- PO Table -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gray-50 dark:bg-gray-700/50">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">PO Number</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Warehouse</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Subtotal</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">GST</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Total</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Status</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Invoices</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Received</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
              <% if (typeof pos !== 'undefined' && pos.length > 0) { %>
                <% pos.forEach(function(po) { %>
                  <tr class="hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                    <td class="px-4 py-3">
                      <a href="/inward-po/<%= po.id %>" class="text-blue-600 dark:text-blue-400 font-medium hover:underline"><%= po.wms_po_number %></a>
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300"><%= po.warehouse_name || '-' %></td>
                    <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300 text-right">Rs. <%= Number(po.subtotal || 0).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
                    <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400 text-right">Rs. <%= Number(po.gst_amount || 0).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
                    <td class="px-4 py-3 text-sm text-gray-900 dark:text-white text-right font-medium">Rs. <%= Number(po.total_amount || 0).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
                    <td class="px-4 py-3 text-center">
                      <% const statusColors = { received: 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300', grn_received: 'bg-cyan-100 text-cyan-800 dark:bg-cyan-900/30 dark:text-cyan-300', processing: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300', invoiced: 'bg-indigo-100 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-300', paid: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300', disputed: 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300', cancelled: 'bg-gray-100 text-gray-800 dark:bg-gray-900/30 dark:text-gray-300' }; %>
                      <span class="px-2 py-1 text-xs font-medium rounded-full <%= statusColors[po.status] || 'bg-gray-100 text-gray-800' %>"><%= po.status %></span>
                    </td>
                    <td class="px-4 py-3 text-center text-sm text-gray-700 dark:text-gray-300"><%= po.invoice_count || 0 %></td>
                    <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400"><%= new Date(po.created_at).toLocaleDateString('en-IN') %></td>
                    <td class="px-4 py-3 text-center">
                      <a href="/inward-po/<%= po.id %>" class="text-sm text-blue-600 dark:text-blue-400 hover:underline">View</a>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="9" class="px-4 py-8 text-center text-gray-500 dark:text-gray-400">No purchase orders found matching your filters.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>

  <%- include('../../../partials/_footer') %>
</body>
</html>

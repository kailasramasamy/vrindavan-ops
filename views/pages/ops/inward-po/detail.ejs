<%- include('../../../partials/_head', { seo }) %>

<body class="bg-slate-50 dark:bg-gray-900">
  <%- include('../../../partials/_header', { user: (typeof user !== 'undefined' ? user : null) }) %>

  <div class="min-h-screen">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Header -->
      <div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <div class="flex items-center gap-3">
            <a href="/inward-po/list" class="text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
            </a>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">PO: <%= po.wms_po_number %></h1>
            <% const statusColors = { received: 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300', grn_received: 'bg-cyan-100 text-cyan-800 dark:bg-cyan-900/30 dark:text-cyan-300', processing: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300', invoiced: 'bg-indigo-100 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-300', paid: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300', disputed: 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300', cancelled: 'bg-gray-100 text-gray-800 dark:bg-gray-900/30 dark:text-gray-300' }; %>
            <span class="px-3 py-1 text-sm font-medium rounded-full <%= statusColors[po.status] || 'bg-gray-100 text-gray-800' %>"><%= po.status %></span>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Warehouse: <%= po.warehouse_name || 'N/A' %> | Received: <%= new Date(po.created_at).toLocaleDateString('en-IN') %></p>
        </div>
        <div class="flex gap-2">
          <% if (po.status === 'received' || po.status === 'grn_received') { %>
            <button onclick="showInvoiceModal()" class="px-3 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 text-sm font-medium">Create Invoice</button>
          <% } %>
          <% if (po.status !== 'cancelled' && po.status !== 'paid') { %>
            <button onclick="updateStatus('disputed')" class="px-3 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600 text-sm font-medium">Dispute</button>
          <% } %>
        </div>
      </div>

      <!-- PO Summary -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
        <div class="lg:col-span-2">
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">PO Details</h2>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <p class="text-xs text-gray-500 dark:text-gray-400 uppercase">WMS PO ID</p>
                <p class="text-sm font-medium text-gray-900 dark:text-white"><%= po.wms_po_id %></p>
              </div>
              <div>
                <p class="text-xs text-gray-500 dark:text-gray-400 uppercase">PO Number</p>
                <p class="text-sm font-medium text-gray-900 dark:text-white"><%= po.wms_po_number %></p>
              </div>
              <div>
                <p class="text-xs text-gray-500 dark:text-gray-400 uppercase">Expected Delivery</p>
                <p class="text-sm font-medium text-gray-900 dark:text-white"><%= po.expected_delivery_date ? new Date(po.expected_delivery_date).toLocaleDateString('en-IN') : 'N/A' %></p>
              </div>
              <div>
                <p class="text-xs text-gray-500 dark:text-gray-400 uppercase">Warehouse</p>
                <p class="text-sm font-medium text-gray-900 dark:text-white"><%= po.warehouse_name || 'N/A' %></p>
              </div>
              <div>
                <p class="text-xs text-gray-500 dark:text-gray-400 uppercase">GRN</p>
                <%
                  let grnData = null;
                  try {
                    const poDataObj = typeof po.po_data === 'string' ? JSON.parse(po.po_data) : po.po_data;
                    grnData = poDataObj?.grn || null;
                  } catch(e) {}
                %>
                <% if (grnData) { %>
                  <div class="mt-0.5">
                    <div class="flex items-center gap-1.5">
                      <svg class="w-3.5 h-3.5 text-green-600 dark:text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                      <span class="text-sm font-medium text-green-700 dark:text-green-400"><%= grnData.grnNumber || 'Completed' %></span>
                    </div>
                    <% if (grnData.completedAt) { %>
                      <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5"><%= new Date(grnData.completedAt).toLocaleString('en-IN', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
                    <% } %>
                  </div>
                <% } else { %>
                  <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400 mt-0.5">Awaiting</span>
                <% } %>
              </div>
            </div>
            <% if (po.notes) { %>
              <div class="mt-4 pt-4 border-t border-gray-200 dark:border-gray-700">
                <p class="text-xs text-gray-500 dark:text-gray-400 uppercase mb-1">Notes</p>
                <p class="text-sm text-gray-700 dark:text-gray-300"><%= po.notes %></p>
              </div>
            <% } %>
          </div>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Amount Summary</h2>
          <div class="space-y-3">
            <div class="flex justify-between">
              <span class="text-sm text-gray-500 dark:text-gray-400">Subtotal</span>
              <span class="text-sm font-medium text-gray-900 dark:text-white">Rs. <%= Number(po.subtotal || 0).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm text-gray-500 dark:text-gray-400">GST</span>
              <span class="text-sm font-medium text-gray-900 dark:text-white">Rs. <%= Number(po.gst_amount || 0).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></span>
            </div>
            <div class="flex justify-between pt-3 border-t border-gray-200 dark:border-gray-700">
              <span class="text-base font-semibold text-gray-900 dark:text-white">Total</span>
              <span class="text-base font-bold text-gray-900 dark:text-white">Rs. <%= Number(po.total_amount || 0).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Items Table -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 mb-8">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Line Items (<%= po.items ? po.items.length : 0 %>)</h2>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gray-50 dark:bg-gray-700/50">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">#</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Product</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">SKU</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Unit</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Ordered</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Received</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Accepted</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Unit Cost (incl GST)</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">GST %</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Line Total</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
              <% if (po.items && po.items.length > 0) { %>
                <% po.items.forEach(function(item, idx) { %>
                  <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                    <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400"><%= idx + 1 %></td>
                    <td class="px-4 py-3 text-sm font-medium text-gray-900 dark:text-white"><%= item.product_name || '-' %></td>
                    <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400"><%= item.sku || '-' %></td>
                    <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400"><%= item.unit_of_measure || '-' %></td>
                    <td class="px-4 py-3 text-sm text-gray-900 dark:text-white text-right"><%= item.ordered_qty %></td>
                    <td class="px-4 py-3 text-sm text-right <%= item.received_qty != null && item.received_qty < item.ordered_qty ? 'text-amber-600 dark:text-amber-400 font-medium' : 'text-gray-500 dark:text-gray-400' %>"><%= item.received_qty != null ? item.received_qty : '—' %></td>
                    <td class="px-4 py-3 text-sm text-right <%= item.accepted_qty != null && item.accepted_qty < (item.received_qty || item.ordered_qty) ? 'text-red-600 dark:text-red-400 font-medium' : 'text-gray-500 dark:text-gray-400' %>"><%= item.accepted_qty != null ? item.accepted_qty : '—' %></td>
                    <td class="px-4 py-3 text-sm text-gray-900 dark:text-white text-right">Rs. <%= Number(item.unit_cost || 0).toFixed(2) %></td>
                    <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400 text-right"><%= Number(item.gst_pct || 0).toFixed(1) %>%</td>
                    <td class="px-4 py-3 text-sm font-medium text-gray-900 dark:text-white text-right">Rs. <%= Number(item.line_total || 0).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr><td colspan="10" class="px-4 py-6 text-center text-gray-500 dark:text-gray-400">No items found</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Invoices Section -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 mb-8">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Invoices</h2>
          <% if (po.status === 'received' || po.status === 'grn_received') { %>
            <button onclick="showInvoiceModal()" class="text-sm text-blue-600 dark:text-blue-400 hover:underline font-medium">+ Create Invoice</button>
          <% } %>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gray-50 dark:bg-gray-700/50">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Invoice #</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Date</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Amount</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Status</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Payment</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
              <% if (po.invoices && po.invoices.length > 0) { %>
                <% po.invoices.forEach(function(inv) { %>
                  <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                    <td class="px-4 py-3">
                      <p class="text-sm font-medium text-gray-900 dark:text-white"><%= inv.invoice_number %></p>
                      <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
                        Subtotal: ₹<%= Number(inv.subtotal || 0).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %>
                        + GST: ₹<%= Number(inv.gst_amount || 0).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %>
                      </p>
                      <% if (inv.notes) { %>
                        <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5"><%= inv.notes %></p>
                      <% } %>
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400"><%= inv.invoice_date ? new Date(inv.invoice_date).toLocaleDateString('en-IN') : '-' %></td>
                    <td class="px-4 py-3 text-sm font-semibold text-gray-900 dark:text-white text-right">₹<%= Number(inv.total_amount || 0).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
                    <td class="px-4 py-3 text-center">
                      <% const invStatusColors = { draft: 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300', sent: 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300', acknowledged: 'bg-indigo-100 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-300', paid: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300' }; %>
                      <span class="px-2 py-1 text-xs font-medium rounded-full <%= invStatusColors[inv.status] || 'bg-gray-100 text-gray-800' %>"><%= inv.status %></span>
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400">
                      <% if (inv.payment_date) { %>
                        <%= new Date(inv.payment_date).toLocaleDateString('en-IN') %> | <%= inv.payment_reference || '' %>
                      <% } else { %>
                        -
                      <% } %>
                    </td>
                    <td class="px-4 py-3 text-center">
                      <div class="flex items-center justify-center gap-2 flex-wrap">
                        <a href="/inward-po/<%= po.id %>/invoice-pdf" class="inline-flex items-center gap-1 px-2 py-1 text-xs font-medium text-blue-700 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/20 hover:bg-blue-100 dark:hover:bg-blue-900/40 rounded transition-colors">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                          Download PDF
                        </a>
                        <% if (inv.sent_to_wms_at) { %>
                          <span class="inline-flex items-center gap-1 text-xs text-green-600 dark:text-green-400">
                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                            Sent
                          </span>
                        <% } else if (!inv.sent_to_wms_at) { %>
                          <button onclick="sendInvoice(<%= inv.id %>)" class="text-xs text-amber-600 dark:text-amber-400 hover:underline font-medium">Retry Send</button>
                        <% } %>
                        <% if (inv.status !== 'paid') { %>
                          <button onclick="showPaymentModal(<%= inv.id %>)" class="text-xs text-green-600 dark:text-green-400 hover:underline">Mark Paid</button>
                        <% } %>
                      </div>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr><td colspan="6" class="px-4 py-6 text-center text-gray-500 dark:text-gray-400">No invoices created yet</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Status Timeline -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Status History</h2>
        </div>
        <div class="p-6">
          <% if (po.status_history && po.status_history.length > 0) { %>
            <div class="space-y-4">
              <% po.status_history.forEach(function(h) { %>
                <div class="flex items-start gap-3">
                  <div class="w-2 h-2 mt-2 rounded-full bg-blue-500 flex-shrink-0"></div>
                  <div>
                    <p class="text-sm text-gray-900 dark:text-white">
                      <% if (h.from_status) { %>
                        <span class="font-medium"><%= h.from_status %></span> &rarr;
                      <% } %>
                      <span class="font-semibold"><%= h.to_status %></span>
                    </p>
                    <% if (h.notes) { %>
                      <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5"><%= h.notes %></p>
                    <% } %>
                    <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5"><%= new Date(h.created_at).toLocaleString('en-IN') %></p>
                  </div>
                </div>
              <% }); %>
            </div>
          <% } else { %>
            <p class="text-sm text-gray-500 dark:text-gray-400">No status changes recorded</p>
          <% } %>
        </div>
      </div>
    </main>
  </div>

  <!-- Invoice Modal -->
  <div id="invoiceModal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center overflow-y-auto">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl max-w-2xl w-full mx-4 my-8 p-6">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Create Invoice</h3>
      <form id="invoiceForm" class="space-y-4">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Invoice Number *</label>
            <input type="text" name="invoice_number" required class="w-full px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white text-sm">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Invoice Date</label>
            <input type="date" name="invoice_date" value="<%= new Date().toISOString().slice(0, 10) %>" class="w-full px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white text-sm">
          </div>
        </div>

        <!-- Line Items -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Supply Quantities</label>
          <div class="border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden">
            <table class="w-full text-sm">
              <thead class="bg-gray-50 dark:bg-gray-700/50">
                <tr>
                  <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400">Product</th>
                  <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-400">Ordered</th>
                  <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-400">Supply Qty</th>
                  <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-400">Rate</th>
                  <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-400">GST %</th>
                  <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-400">Line Total</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                <% if (po.items && po.items.length > 0) { %>
                  <% po.items.forEach(function(item, idx) { %>
                    <tr>
                      <td class="px-3 py-2 text-gray-900 dark:text-white"><%= item.product_name %></td>
                      <td class="px-3 py-2 text-right text-gray-500 dark:text-gray-400"><%= item.ordered_qty %></td>
                      <td class="px-3 py-2 text-right">
                        <input type="number" min="0" max="<%= item.ordered_qty %>"
                          value="<%= item.ordered_qty %>"
                          data-unit-cost="<%= item.unit_cost %>"
                          data-gst-pct="<%= item.gst_pct || 0 %>"
                          class="inv-qty-input w-20 px-2 py-1 text-right rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white text-sm"
                        >
                      </td>
                      <td class="px-3 py-2 text-right text-gray-500 dark:text-gray-400">₹<%= Number(item.unit_cost || 0).toFixed(2) %></td>
                      <td class="px-3 py-2 text-right text-gray-500 dark:text-gray-400"><%= Number(item.gst_pct || 0).toFixed(1) %>%</td>
                      <td class="px-3 py-2 text-right font-medium text-gray-900 dark:text-white inv-line-total">₹<%= Number(item.line_total || 0).toFixed(2) %></td>
                    </tr>
                  <% }); %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Totals (auto-calculated) -->
        <div class="bg-gray-50 dark:bg-gray-700/30 rounded-lg p-3">
          <div class="grid grid-cols-3 gap-3 text-sm">
            <div class="flex justify-between">
              <span class="text-gray-500 dark:text-gray-400">Subtotal:</span>
              <span id="invCalcSubtotal" class="font-medium text-gray-900 dark:text-white">₹0.00</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-500 dark:text-gray-400">GST:</span>
              <span id="invCalcGst" class="font-medium text-gray-900 dark:text-white">₹0.00</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-500 dark:text-gray-400">Total:</span>
              <span id="invCalcTotal" class="font-bold text-gray-900 dark:text-white">₹0.00</span>
            </div>
          </div>
        </div>

        <input type="hidden" name="subtotal" id="invSubtotalHidden">
        <input type="hidden" name="gst_amount" id="invGstHidden">
        <input type="hidden" name="total_amount" id="invTotalHidden">

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Notes</label>
          <textarea name="notes" rows="2" class="w-full px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white text-sm" placeholder="Optional"></textarea>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="submit" class="flex-1 px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 text-sm font-medium">Create Invoice</button>
          <button type="button" onclick="hideInvoiceModal()" class="px-4 py-2 bg-gray-200 dark:bg-gray-600 text-gray-700 dark:text-gray-200 rounded-lg hover:bg-gray-300 text-sm">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Payment Modal -->
  <div id="paymentModal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl max-w-md w-full mx-4 p-6">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Mark as Paid</h3>
      <form id="paymentForm" class="space-y-4">
        <input type="hidden" name="invoice_id" id="paymentInvoiceId">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Payment Date</label>
          <input type="date" name="payment_date" value="<%= new Date().toISOString().slice(0, 10) %>" class="w-full px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Payment Reference</label>
          <input type="text" name="payment_reference" placeholder="UTR / cheque number" class="w-full px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white text-sm">
        </div>
        <div class="flex gap-3 pt-2">
          <button type="submit" class="flex-1 px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 text-sm font-medium">Confirm Payment</button>
          <button type="button" onclick="hidePaymentModal()" class="px-4 py-2 bg-gray-200 dark:bg-gray-600 text-gray-700 dark:text-gray-200 rounded-lg hover:bg-gray-300 text-sm">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    const poId = <%= po.id %>;

    function recalcInvoice() {
      let totalAmount = 0, gstAmount = 0;
      document.querySelectorAll('.inv-qty-input').forEach(function(input, idx) {
        const qty = Number(input.value) || 0;
        const unitCost = Number(input.dataset.unitCost) || 0;
        const gstPct = Number(input.dataset.gstPct) || 0;
        const lineTotal = qty * unitCost;
        const baseRate = gstPct > 0 ? lineTotal / (1 + gstPct / 100) : lineTotal;
        const lineGst = lineTotal - baseRate;
        totalAmount += lineTotal;
        gstAmount += lineGst;
        // Update line total cell
        const cells = document.querySelectorAll('.inv-line-total');
        if (cells[idx]) cells[idx].textContent = '₹' + lineTotal.toFixed(2);
      });
      const subtotal = totalAmount - gstAmount;
      document.getElementById('invCalcSubtotal').textContent = '₹' + subtotal.toFixed(2);
      document.getElementById('invCalcGst').textContent = '₹' + gstAmount.toFixed(2);
      document.getElementById('invCalcTotal').textContent = '₹' + totalAmount.toFixed(2);
      document.getElementById('invSubtotalHidden').value = subtotal.toFixed(2);
      document.getElementById('invGstHidden').value = gstAmount.toFixed(2);
      document.getElementById('invTotalHidden').value = totalAmount.toFixed(2);
    }

    function showInvoiceModal() {
      document.getElementById('invoiceModal').classList.remove('hidden');
      document.getElementById('invoiceModal').classList.add('flex');
      recalcInvoice();
    }

    // Recalc on qty change
    document.querySelectorAll('.inv-qty-input').forEach(function(input) {
      input.addEventListener('input', recalcInvoice);
    });
    function hideInvoiceModal() {
      document.getElementById('invoiceModal').classList.add('hidden');
      document.getElementById('invoiceModal').classList.remove('flex');
    }
    function showPaymentModal(invoiceId) {
      document.getElementById('paymentInvoiceId').value = invoiceId;
      document.getElementById('paymentModal').classList.remove('hidden');
      document.getElementById('paymentModal').classList.add('flex');
    }
    function hidePaymentModal() {
      document.getElementById('paymentModal').classList.add('hidden');
      document.getElementById('paymentModal').classList.remove('flex');
    }

    async function updateStatus(status) {
      const notes = prompt('Add a note (optional):');
      try {
        const res = await fetch(`/inward-po/${poId}/status`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status, notes }),
        });
        const data = await res.json();
        if (data.success) {
          location.reload();
        } else {
          alert('Error: ' + (data.error || 'Unknown error'));
        }
      } catch (err) {
        alert('Failed to update status');
      }
    }

    async function sendInvoice(invoiceId) {
      if (!confirm('Send this invoice to WMS?')) return;
      try {
        const res = await fetch(`/inward-po/${poId}/invoice/send`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ invoice_id: invoiceId }),
        });
        const data = await res.json();
        if (data.success) {
          alert('Invoice sent to WMS');
          location.reload();
        } else {
          alert('Error: ' + (data.error || 'Failed to send'));
        }
      } catch (err) {
        alert('Failed to send invoice to WMS');
      }
    }

    document.getElementById('invoiceForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      const formData = new FormData(this);
      const body = Object.fromEntries(formData.entries());
      try {
        const res = await fetch(`/inward-po/${poId}/invoice`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        const data = await res.json();
        if (data.success) {
          hideInvoiceModal();
          alert('Invoice created successfully and sent to receiver.');
          location.reload();
        } else {
          alert('Error: ' + (data.error || 'Unknown error'));
        }
      } catch (err) {
        alert('Failed to create invoice');
      }
    });

    document.getElementById('paymentForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      const formData = new FormData(this);
      const body = Object.fromEntries(formData.entries());
      try {
        const res = await fetch(`/inward-po/${poId}/mark-paid`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        const data = await res.json();
        if (data.success) {
          location.reload();
        } else {
          alert('Error: ' + (data.error || 'Unknown error'));
        }
      } catch (err) {
        alert('Failed to mark as paid');
      }
    });
  </script>

  <%- include('../../../partials/_footer') %>
</body>
</html>

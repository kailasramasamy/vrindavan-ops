<!DOCTYPE html>
<html lang="en">
  <%- include('../../../partials/_head', { seo, pageKey, promo }) %>
  <body class="bg-slate-50 dark:bg-gray-900">
    <div class="min-h-dvh flex flex-col">
      <%- include('../../../partials/_header', { user: user }) %> <%- include('../../../partials/_subnav', { section: 'Admin', page: 'Rate Charts', user }) %>

      <main class="flex-1">
        <section class="max-w-7xl mx-auto px-4 py-10">
          <!-- Header -->
          <header class="mb-8">
            <div class="flex items-center justify-between">
              <div class="flex items-center space-x-4">
                <button onclick="window.history.back()" class="inline-flex items-center px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors duration-200">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                  </svg>
                  Back
                </button>
                <div>
                  <h1 class="text-3xl font-extrabold tracking-tight text-gray-900 dark:text-white"><%= chart?.name || 'Rate Chart' %></h1>
                  <p class="text-slate-600 dark:text-gray-400 mt-2">Manage pricing slabs and rates</p>
                </div>
              </div>
              <div class="flex items-center space-x-3">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium <%= chart?.status === 'active' ? 'bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-400' : 'bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-300' %>"><%= chart?.status === 'active' ? 'Active' : 'Inactive' %></span>
                <button type="button" id="btnEditChart" class="inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors duration-200">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                  </svg>
                  Edit Chart
                </button>
              </div>
            </div>
          </header>

          <!-- Chart Info -->
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700 p-6 mb-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <div class="text-center">
                <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Total Slabs</p>
                <p class="text-3xl font-bold text-blue-600 dark:text-blue-400"><%= (slabs || []).length %></p>
              </div>
              <div class="text-center">
                <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Min Rate</p>
                <p class="text-3xl font-bold text-green-600 dark:text-green-400">₹<%= Math.min(...(slabs || []).map(s => s.rate_per_litre)) || 0 %></p>
              </div>
              <div class="text-center">
                <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Max Rate</p>
                <p class="text-3xl font-bold text-purple-600 dark:text-purple-400">₹<%= Math.max(...(slabs || []).map(s => s.rate_per_litre)) || 0 %></p>
              </div>
            </div>
            <% if (chart?.description) { %>
            <div class="mt-6 pt-6 border-t border-gray-100 dark:border-gray-700">
              <h3 class="text-sm font-medium text-gray-600 dark:text-gray-400 mb-2">Description</h3>
              <p class="text-gray-900 dark:text-white"><%= chart.description %></p>
            </div>
            <% } %>
          </div>

          <!-- Main Content Grid -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <!-- Add Slab Form -->
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700 p-6">
              <div class="flex items-center justify-between mb-6">
                <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Add New Slab</h2>
                <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                  </svg>
                </div>
              </div>

              <form method="post" action="/admin/rate-charts/<%= chart.id %>/slabs" class="space-y-4">
                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Fat Min (%)</label>
                    <input name="fat_min" type="number" step="0.1" min="0" max="10" placeholder="e.g., 3.0" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-slate-900 dark:text-white bg-white dark:bg-gray-700 placeholder:text-gray-500 dark:placeholder:text-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" required />
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Fat Max (%)</label>
                    <input name="fat_max" type="number" step="0.1" min="0" max="10" placeholder="e.g., 3.5" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-slate-900 dark:text-white bg-white dark:bg-gray-700 placeholder:text-gray-500 dark:placeholder:text-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" required />
                  </div>
                </div>

                <div>
                  <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Rate per Litre (₹)</label>
                  <input name="rate_per_litre" type="number" step="0.1" min="0" placeholder="e.g., 45.50" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-slate-900 dark:text-white bg-white dark:bg-gray-700 placeholder:text-gray-500 dark:placeholder:text-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" required />
                </div>

                <button type="submit" class="w-full inline-flex items-center justify-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors duration-200">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                  </svg>
                  Add Slab
                </button>
              </form>
            </div>

            <!-- Slabs Table -->
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700 p-6">
              <div class="flex items-center justify-between mb-6">
                <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Pricing Slabs</h2>
                <div class="flex items-center space-x-2">
                  <span class="text-sm text-gray-500 dark:text-gray-400"><%= (slabs || []).length %> slabs</span>
                </div>
              </div>

              <% if ((slabs || []).length === 0) { %>
              <!-- Empty State -->
              <div class="text-center py-12">
                <div class="w-16 h-16 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center mx-auto mb-4">
                  <svg class="w-8 h-8 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                  </svg>
                </div>
                <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">No slabs found</h3>
                <p class="text-gray-500 dark:text-gray-400">Add your first pricing slab to get started</p>
              </div>
              <% } else { %>
              <!-- Slabs Table -->
              <div class="overflow-hidden">
                <table class="w-full">
                  <thead>
                    <tr class="border-b border-gray-200 dark:border-gray-700">
                      <th class="text-left py-3 px-4 text-sm font-medium text-gray-600 dark:text-gray-400">Fat Range (%)</th>
                      <th class="text-left py-3 px-4 text-sm font-medium text-gray-600 dark:text-gray-400">Rate per Litre</th>
                      <th class="text-right py-3 px-4 text-sm font-medium text-gray-600 dark:text-gray-400">Actions</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                    <% (slabs || []).forEach((s, index) => { %>
                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors duration-150">
                      <td class="py-4 px-4">
                        <div class="flex items-center space-x-2">
                          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-400"><%= s.fat_min %>% - <%= s.fat_max %>%</span>
                        </div>
                      </td>
                      <td class="py-4 px-4">
                        <span class="text-lg font-semibold text-green-600 dark:text-green-400">₹<%= s.rate_per_litre %></span>
                      </td>
                      <td class="py-4 px-4 text-right">
                        <div class="flex items-center justify-end space-x-2">
                          <button type="button" class="text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 transition-colors duration-200" onclick="editSlab(<%= s.id %>, <%= s.fat_min %>, <%= s.fat_max %>, <%= s.rate_per_litre %>)">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                            </svg>
                          </button>
                          <button type="button" class="text-gray-400 dark:text-gray-500 hover:text-red-600 dark:hover:text-red-400 transition-colors duration-200" onclick="deleteSlab(<%= s.id %>)">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                            </svg>
                          </button>
                        </div>
                      </td>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
              <% } %>
            </div>
          </div>
        </section>
      </main>

      <%- include('../../../partials/_footer') %>
    </div>

    <!-- Edit Chart Modal -->
    <div id="editChartModal" class="fixed inset-0 hidden items-center justify-center z-50">
      <div class="ops-overlay bg-black dark:bg-gray-900 bg-opacity-50 dark:bg-opacity-75" data-close="modal"></div>
      <div class="ops-panel bg-white dark:bg-gray-800 rounded-xl shadow-2xl border dark:border-gray-700 max-w-md w-full mx-4">
        <div class="p-6">
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Edit Chart</h3>
            <button type="button" class="text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 transition-colors duration-200" data-close="modal">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>

          <form method="post" action="/admin/rate-charts/<%= chart.id %>/edit" class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Chart Name</label>
              <input name="name" type="text" value="<%= chart?.name || '' %>" placeholder="Enter chart name..." class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-slate-900 dark:text-white bg-white dark:bg-gray-700 placeholder:text-gray-500 dark:placeholder:text-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" required />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Description</label>
              <textarea name="description" rows="3" placeholder="Enter chart description..." class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-slate-900 dark:text-white bg-white dark:bg-gray-700 placeholder:text-gray-500 dark:placeholder:text-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors resize-none"><%= chart?.description || '' %></textarea>
            </div>

            <div class="flex justify-end space-x-3 pt-4">
              <button type="button" class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 rounded-lg transition-colors duration-200" data-close="modal">Cancel</button>
              <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors duration-200">Update Chart</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Edit Slab Modal -->
    <div id="editSlabModal" class="fixed inset-0 hidden items-center justify-center z-50">
      <div class="ops-overlay bg-black dark:bg-gray-900 bg-opacity-50 dark:bg-opacity-75" data-close="modal"></div>
      <div class="ops-panel bg-white dark:bg-gray-800 rounded-xl shadow-2xl border dark:border-gray-700 max-w-md w-full mx-4">
        <div class="p-6">
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Edit Pricing Slab</h3>
            <button type="button" class="text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 transition-colors duration-200" data-close="modal">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>

          <form id="editSlabForm" method="post" class="space-y-4">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Fat Min (%)</label>
                <input id="editFatMin" name="fat_min" type="number" step="0.1" min="0" max="10" placeholder="e.g., 3.0" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-slate-900 dark:text-white bg-white dark:bg-gray-700 placeholder:text-gray-500 dark:placeholder:text-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" required />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Fat Max (%)</label>
                <input id="editFatMax" name="fat_max" type="number" step="0.1" min="0" max="10" placeholder="e.g., 3.5" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-slate-900 dark:text-white bg-white dark:bg-gray-700 placeholder:text-gray-500 dark:placeholder:text-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" required />
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Rate per Litre (₹)</label>
              <input id="editRatePerLitre" name="rate_per_litre" type="number" step="0.1" min="0" placeholder="e.g., 45.50" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-slate-900 dark:text-white bg-white dark:bg-gray-700 placeholder:text-gray-500 dark:placeholder:text-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" required />
            </div>

            <div class="flex justify-end space-x-3 pt-4">
              <button type="button" class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 rounded-lg transition-colors duration-200" data-close="modal">Cancel</button>
              <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors duration-200">Update Slab</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
    <script>
      // Initialize Lucide icons
      lucide.createIcons();

      // Modal functionality
      const chartModal = document.getElementById("editChartModal");
      const slabModal = document.getElementById("editSlabModal");
      const openChartButton = document.getElementById("btnEditChart");
      const closeButtons = document.querySelectorAll('[data-close="modal"]');

      // Chart modal functionality
      openChartButton?.addEventListener("click", () => {
        chartModal.classList.remove("hidden");
        chartModal.classList.add("flex");
      });

      // Close modal functionality
      closeButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          chartModal.classList.add("hidden");
          chartModal.classList.remove("flex");
          slabModal.classList.add("hidden");
          slabModal.classList.remove("flex");
        });
      });

      // Close modal on overlay click
      [chartModal, slabModal].forEach((modal) => {
        modal.addEventListener("click", (e) => {
          if (e.target === modal || e.target.classList.contains("ops-overlay")) {
            modal.classList.add("hidden");
            modal.classList.remove("flex");
          }
        });
      });

      // Close modal on Escape key
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
          if (chartModal.classList.contains("flex")) {
            chartModal.classList.add("hidden");
            chartModal.classList.remove("flex");
          }
          if (slabModal.classList.contains("flex")) {
            slabModal.classList.add("hidden");
            slabModal.classList.remove("flex");
          }
        }
      });

      // Edit slab function
      function editSlab(id, fatMin, fatMax, rate) {
        // Set form action URL
        const form = document.getElementById("editSlabForm");
        form.action = `/admin/rate-charts/<%= chart.id %>/slabs/${id}/edit`;

        // Populate form fields
        document.getElementById("editFatMin").value = fatMin;
        document.getElementById("editFatMax").value = fatMax;
        document.getElementById("editRatePerLitre").value = rate;

        // Show modal
        slabModal.classList.remove("hidden");
        slabModal.classList.add("flex");
      }

      // Delete slab function
      function deleteSlab(id) {
        if (confirm("Are you sure you want to delete this slab?")) {
          // Create a form and submit it
          const form = document.createElement("form");
          form.method = "POST";
          form.action = `/admin/rate-charts/<%= chart.id %>/slabs/${id}/delete`;
          document.body.appendChild(form);
          form.submit();
        }
      }

      // Form validation
      document.querySelector('form[action*="/slabs"]')?.addEventListener("submit", function (e) {
        const fatMin = parseFloat(this.querySelector('input[name="fat_min"]').value);
        const fatMax = parseFloat(this.querySelector('input[name="fat_max"]').value);

        if (fatMin >= fatMax) {
          e.preventDefault();
          alert("Fat Min must be less than Fat Max");
          return false;
        }

        if (fatMin < 0 || fatMax < 0) {
          e.preventDefault();
          alert("Fat values must be positive");
          return false;
        }
      });
    </script>
  </body>
</html>

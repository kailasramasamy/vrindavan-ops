            // Load material stock data
            async function loadMaterialStock(materialId) {
              try {
                const response = await fetch(`/api/v1/material/materials/${materialId}`);
                const result = await response.json();

                if (result.success && result.data) {
                  const material = result.data;

                  // Display current total stock
                  const totalStock = material.stock ? material.stock.reduce((sum, s) => sum + parseFloat(s.on_hand_qty || 0), 0) : 0;
                  document.getElementById('currentStockDisplay').textContent = `${totalStock.toFixed(2)} ${material.default_uom_symbol || ''}`;

                  // Display stock by location with proper line breaks
                  if (material.stock && material.stock.length > 0) {
                    const stockByLocation = material.stock.map(s => `${s.location_name}: ${parseFloat(s.on_hand_qty || 0).toFixed(2)} ${material.default_uom_symbol || ''}`).join('\n');
                    document.getElementById('stockByLocationDisplay').textContent = stockByLocation;
                    // Add CSS to preserve line breaks
                    document.getElementById('stockByLocationDisplay').style.whiteSpace = 'pre-line';
                  } else {
                    document.getElementById('stockByLocationDisplay').textContent = 'No stock recorded';
                  }
                }
              } catch (error) {
                console.error('Error loading material stock:', error);
                document.getElementById('currentStockDisplay').textContent = 'Error loading stock';
                document.getElementById('stockByLocationDisplay').textContent = 'Error loading stock';
              }
            }

            // Apply stock adjustment
            async function applyStockAdjustment() {
              const materialId = currentStockMaterialId;
              const locationId = document.getElementById('stockLocation').value;
              const adjustmentType = document.getElementById('stockAdjustmentType').value;
              const quantity = parseFloat(document.getElementById('stockAdjustmentQty').value);
              const reason = document.getElementById('stockAdjustmentReason').value;
              const reasonError = document.getElementById('reasonError');

              // Clear previous errors
              reasonError.classList.add('hidden');
              document.getElementById('stockAdjustmentReason').classList.remove('border-red-500');

              // Validation
              if (!materialId) {
                showErrorToast('Material ID is required');
                return;
              }
              if (!locationId) {
                showErrorToast('Please select a location');
                return;
              }
              if (isNaN(quantity) || quantity <= 0) {
                showErrorToast('Please enter a valid quantity');
                return;
              }
              if (!reason.trim()) {
                reasonError.classList.remove('hidden');
                document.getElementById('stockAdjustmentReason').classList.add('border-red-500');
                document.getElementById('stockAdjustmentReason').focus();
                return;
              }

              try {
                // Determine transaction type based on adjustment
                let transactionTypeId;
                let finalQuantity = quantity;
                let notes = `Stock adjustment: ${adjustmentType} ${quantity} units`;

                // For 'set' type, we need to get current stock first and calculate the difference
                if (adjustmentType === 'set') {
                  const response = await fetch(`/api/v1/material/materials/${materialId}`);
                  const result = await response.json();

                  if (result.success && result.data.stock) {
                    const currentStock = result.data.stock.find(s => s.location_id == locationId);
                    const currentQty = currentStock ? currentStock.on_hand_qty : 0;
                    finalQuantity = Math.abs(quantity - currentQty);

                    if (quantity > currentQty) {
                      transactionTypeId = 6; // ADJUST_POS (Positive Adjustment)
                      notes = `Stock set to ${quantity} (was ${currentQty}, added ${finalQuantity})`;
                    } else if (quantity < currentQty) {
                      transactionTypeId = 7; // ADJUST_NEG (Negative Adjustment)
                      notes = `Stock set to ${quantity} (was ${currentQty}, removed ${finalQuantity})`;
                    } else {
                      showInfoToast('Stock quantity is already at the specified amount');
                      return;
                    }
                  }
                } else if (adjustmentType === 'add') {
                  transactionTypeId = 6; // ADJUST_POS (Positive Adjustment)
                } else if (adjustmentType === 'subtract') {
                  transactionTypeId = 7; // ADJUST_NEG (Negative Adjustment)
                }

                // Create a stock adjustment transaction
                const transactionData = {
                  transaction_type_id: transactionTypeId,
                  material_id: parseInt(materialId),
                  location_id: parseInt(locationId),
                  quantity: finalQuantity,
                  reason: reason,
                  notes: notes,
                  user_id: 1 // You might want to get this from the session
                };

                const response = await fetch('/api/v1/material/transactions', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify(transactionData)
                });

                const result = await response.json();

                if (result.success) {
                  showSuccessToast('Stock adjustment applied successfully!');

                  // Close the modal
                  closeStockManagementModal();

                  // Reload materials list to update the display
                  loadMaterials();
                } else {
                  showErrorToast('Error: ' + (result.error || 'Failed to apply stock adjustment'));
                }
              } catch (error) {
                console.error('Error applying stock adjustment:', error);
                showErrorToast('Failed to apply stock adjustment');
              }
            }

            // Load category attributes
            async function loadCategoryAttributes(categoryId, existingCustomAttributes = null) {
              if (!categoryId) {
                document.getElementById('customAttributesSection').classList.add('hidden');
                return;
              }

              try {
                const response = await fetch(`/api/v1/material/categories/${categoryId}`);
                const result = await response.json();

                if (result.success && result.data.templates && result.data.templates.length > 0) {
                  const container = document.getElementById('customAttributesContainer');

                  // Parse existing custom attributes if provided
                  let parsedAttributes = {};
                  if (existingCustomAttributes) {
                    try {
                      parsedAttributes = typeof existingCustomAttributes === 'string'
                        ? JSON.parse(existingCustomAttributes)
                        : existingCustomAttributes;
                    } catch (e) {
                      parsedAttributes = {};
                    }
                  }

                  container.innerHTML = result.data.templates.map(template => {
                    let input = '';
                    const fieldName = `custom_attributes[${template.field_key}]`;
                    const existingValue = parsedAttributes[template.field_key] || '';

                    switch (template.data_type) {
                      case 'string':
                      case 'number':
                        input = `<input type="${template.data_type === 'number' ? 'number' : 'text'}" name="${fieldName}"
                                       class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                       placeholder="Enter ${template.field_label.toLowerCase()}"
                                       value="${existingValue}" />`;
                        break;
                      case 'boolean':
                        input = `<select name="${fieldName}"
                                         class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                     <option value="">Select</option>
                                     <option value="true" ${existingValue === 'true' || existingValue === true ? 'selected' : ''}>Yes</option>
                                     <option value="false" ${existingValue === 'false' || existingValue === false ? 'selected' : ''}>No</option>
                                   </select>`;
                        break;
                      case 'date':
                        input = `<input type="date" name="${fieldName}"
                                       class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                       value="${existingValue}" />`;
                        break;
                      case 'enum':
                        const options = template.enum_options ? (Array.isArray(template.enum_options) ? template.enum_options : template.enum_options.split(',').map(opt => opt.trim()).filter(opt => opt)) : [];
                        input = `<select name="${fieldName}"
                                         class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                     <option value="">Select</option>
                                     ${options.map(opt => `<option value="${opt}" ${existingValue === opt ? 'selected' : ''}>${opt}</option>`).join('')}
                                   </select>`;
                        break;
                    }

                    return `
                      <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                          ${template.field_label}${template.is_required ? ' *' : ''}
                        </label>
                        ${input}
                      </div>
                    `;
                  }).join('');

                  document.getElementById('customAttributesSection').classList.remove('hidden');
                } else {
                  document.getElementById('customAttributesSection').classList.add('hidden');
                }
              } catch (error) {
                console.error('Error loading category attributes:', error);
                document.getElementById('customAttributesSection').classList.add('hidden');
              }
            }


                                      // Process custom attributes
                                      const customAttributes = {};
                                      Object.entries(data).forEach(([key, value]) => {
                                        if (key.startsWith('custom_attributes[') && value) {
                                          const attrKey = key.match(/custom_attributes\[(.+)\]/)[1];
                                          customAttributes[attrKey] = value;
                                        }
                                      });

                                      data.custom_attributes = Object.keys(customAttributes).length > 0 ? customAttributes : null;

                                      const isEdit = data.id !== '';

                                      try {
                                        const url = isEdit ? `/api/v1/material/materials/${data.id}` : '/api/v1/material/materials';
                                        const method = isEdit ? 'PUT' : 'POST';

                                        const response = await fetch(url, {
                                          method,
                                          headers: { 'Content-Type': 'application/json' },
                                          body: JSON.stringify(data)
                                        });

                                        const result = await response.json();

                                        if (result.success) {
                                          closeMaterialModal();
                                          loadMaterials();
                                        } else {
                                          alert('Error: ' + result.error);
                                        }

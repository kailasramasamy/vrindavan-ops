<script>
  (function(){
    const modal = document.getElementById('editModal');
    const form = document.getElementById('editForm');
    const f = {
      rcc: document.getElementById('f_rcc'),
      milk: document.getElementById('f_milk_type'),
      name: document.getElementById('f_name'),
      person: document.getElementById('f_person_name'),
      village: document.getElementById('f_village'),
      phone: document.getElementById('f_phone'),
      status: document.getElementById('f_status'),
      salaryType: document.getElementById('f_salary_type'),
      salaryAmount: document.getElementById('f_salary_amount'),
      salaryLabel: document.getElementById('f_salary_label'),
      salaryInfo: document.getElementById('f_salary_info'),
      rateType: document.getElementById('f_rate_type'),
      flatRate: document.getElementById('f_flat_rate'),
      rateChartId: document.getElementById('f_rate_chart_id'),
      rateField: document.getElementById('f_rate_field'),
      rateLabel: document.getElementById('f_rate_label'),
      rateInfo: document.getElementById('f_rate_info'),
    };
    
    function openModal(){ modal.classList.remove('hidden'); modal.classList.add('flex'); }
    function closeModal(){ modal.classList.add('hidden'); modal.classList.remove('flex'); }
    document.querySelectorAll('[data-close="modal"]').forEach(el=>el.addEventListener('click', closeModal));
    
    // Add CPP modal
    const addModal = document.getElementById('addCppModal');
    const openAdd = document.getElementById('btnOpenAddCpp');
    function openAddModal(){ addModal.classList.remove('hidden'); addModal.classList.add('flex'); }
    function closeAddModal(){ addModal.classList.add('hidden'); addModal.classList.remove('flex'); }
    openAdd?.addEventListener('click', openAddModal);
    addModal?.querySelectorAll('[data-close="modal"]').forEach(el=>el.addEventListener('click', closeAddModal));

    // Salary type change handlers
    function updateSalaryFields(type, isAdd = false) {
      const prefix = isAdd ? 'add' : 'f_';
      const label = document.getElementById(prefix + 'salary_label');
      const info = document.getElementById(prefix + 'salary_info');
      
      if (type === 'fixed') {
        label.textContent = 'Fixed Amount (₹)';
        info.textContent = 'Fixed salary: Enter the monthly fixed amount for this CPP.';
      } else {
        label.textContent = 'Commission Rate (₹/L)';
        info.textContent = 'Commission: Enter the rate per litre of milk collected. Total salary = Volume × Rate.';
      }
    }

    // Rate type change handlers
    function updateRateFields(type, isAdd = false) {
      const prefix = isAdd ? 'add' : 'f_';
      const label = document.getElementById(prefix + 'rate_label');
      const info = document.getElementById(prefix + 'rate_info');
      const field = document.getElementById(prefix + 'rate_field');
      
      if (type === 'flat') {
        label.textContent = 'Flat Rate (₹)';
        info.textContent = 'Flat rate: Enter the fixed rate per litre of milk collected.';
        field.innerHTML = `
          <label class="block text-sm font-semibold text-slate-700 dark:text-gray-300" id="${prefix}rate_label">Flat Rate (₹)</label>
          <input name="flat_rate" id="${prefix}flat_rate" type="number" step="0.01" min="0" placeholder="Enter flat rate" 
                 class="w-full border border-slate-300 dark:border-gray-600 rounded-lg p-3 text-slate-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors duration-200 bg-white dark:bg-gray-700 placeholder:text-gray-500 dark:placeholder:text-gray-400" />
        `;
      } else {
        label.textContent = 'Rate Chart';
        info.textContent = 'Rate chart: Select a predefined rate chart for variable pricing.';
        field.innerHTML = `
          <label class="block text-sm font-semibold text-slate-700 dark:text-gray-300" id="${prefix}rate_label">Rate Chart</label>
          <select name="rate_chart_id" id="${prefix}rate_chart_id" class="w-full border border-slate-300 dark:border-gray-600 rounded-lg p-3 text-slate-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors duration-200 bg-white dark:bg-gray-700">
            <option value="">Select Rate Chart</option>
            <% (rateCharts||[]).forEach(rc => { %>
              <option value="<%= rc.id %>"><%= rc.name %></option>
            <% }) %>
          </select>
        `;
      }
    }

    // Add modal salary type handler
    const addSalaryType = document.getElementById('addSalaryType');
    addSalaryType?.addEventListener('change', (e) => {
      updateSalaryFields(e.target.value, true);
    });

    // Add modal rate type handler
    const addRateType = document.getElementById('addRateType');
    addRateType?.addEventListener('change', (e) => {
      updateRateFields(e.target.value, true);
    });

    // Edit modal salary type handler
    f.salaryType?.addEventListener('change', (e) => {
      updateSalaryFields(e.target.value, false);
    });

    // Edit modal rate type handler
    f.rateType?.addEventListener('change', (e) => {
      updateRateFields(e.target.value, false);
    });

    // Search filter
    const search = document.getElementById('cppSearch');
    const cards = Array.from(document.querySelectorAll('.cpp-card'));
    function norm(s){ return (s||'').toString().toLowerCase(); }
    function matches(card, q){
      const txt = [
        card.dataset.name, 
        card.dataset.rcc, 
        card.dataset.village, 
        card.dataset.phone, 
        card.dataset.milk, 
        card.dataset.status,
        card.dataset.salaryType,
        card.dataset.rateType,
        card.dataset.flatRate,
        card.dataset.rateChartName
      ].map(norm).join(' ');
      return txt.includes(q);
    }
    search?.addEventListener('input', () => {
      const q = norm(search.value);
      cards.forEach(c => { c.style.display = q ? (matches(c, q) ? '' : 'none') : ''; });
    });

    // Edit button handlers
    document.querySelectorAll('.btn-edit').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-id');
        const rccId = btn.getAttribute('data-rcc-id') || '';
        const name = btn.getAttribute('data-name') || '';
        const person = btn.getAttribute('data-person') || '';
        const village = btn.getAttribute('data-village') || '';
        const phone = btn.getAttribute('data-phone') || '';
        const milk = btn.getAttribute('data-milk-type') || 'A2';
        const status = btn.getAttribute('data-status') || 'active';
        const salaryType = btn.getAttribute('data-salary-type') || 'fixed';
        const salaryAmount = btn.getAttribute('data-salary-amount') || '0';
        const rateType = btn.getAttribute('data-rate-type') || 'flat';
        const flatRate = btn.getAttribute('data-flat-rate') || '';
        const rateChartId = btn.getAttribute('data-rate-chart-id') || '';
        
        form.setAttribute('action', `/admin/cpp/${id}`);
        f.rcc.value = rccId;
        f.milk.value = milk;
        f.name.value = name;
        f.person.value = person;
        f.village.value = village;
        f.phone.value = phone;
        f.status.value = status;
        f.salaryType.value = salaryType;
        f.salaryAmount.value = salaryAmount;
        f.rateType.value = rateType;
        
        // Update salary field labels
        updateSalaryFields(salaryType, false);
        
        // Update rate field labels and populate values
        updateRateFields(rateType, false);
        
        // Set rate values after field is updated
        setTimeout(() => {
          if (rateType === 'flat') {
            const flatRateField = document.getElementById('f_flat_rate');
            if (flatRateField) flatRateField.value = flatRate;
          } else {
            const rateChartField = document.getElementById('f_rate_chart_id');
            if (rateChartField) rateChartField.value = rateChartId;
          }
        }, 100);
        
        openModal();
      });
    });

    // Initialize salary and rate fields on page load
    updateSalaryFields('fixed', true);
    updateSalaryFields('fixed', false);
    updateRateFields('flat', true);
    updateRateFields('flat', false);
  })();
  </script>
  <script src="/assets/js/main.js" defer></script>
</body>
</html>

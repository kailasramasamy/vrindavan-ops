                <span class="text-sm text-gray-900 dark:text-white">Show only active products</span>
              </label>
              <button onclick="exportSellerOverridesToExcel()" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors">

<%- include('../../../partials/_head', { seo }) %>

<body class="bg-slate-50 dark:bg-gray-900">
  <%- include('../../../partials/_subnav', { user, section: 'Product Margin', subsection: 'Product Details' }) %>

  <div class="min-h-screen pt-16">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Header -->
      <div class="mb-6">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            <div class="flex items-center gap-3 mb-2">
              <a href="/product-margin" class="text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
              </a>
              <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">Product Details</h1>
            </div>
            <p class="text-sm sm:text-base text-gray-600 dark:text-gray-400">View complete product information</p>
          </div>
          <div class="flex gap-2">
            <button id="editBtn" onclick="window.location.href='/product-margin/products/<%= productId %>/edit'" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
              <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
              </svg>
              Edit Product
            </button>
          </div>
        </div>
      </div>

      <!-- Loading State -->
      <div id="loadingState" class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-8">
        <div class="text-center">
          <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
          <p class="mt-4 text-gray-600 dark:text-gray-400">Loading product details...</p>
        </div>
      </div>

      <!-- Error State -->
      <div id="errorState" class="hidden bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-8">
        <div class="text-center">
          <div class="text-red-500 mb-4">
            <svg class="w-12 h-12 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Failed to Load Product</h3>
          <p class="text-gray-600 dark:text-gray-400 mb-4" id="errorMessage"></p>
          <button onclick="window.location.reload()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Retry</button>
        </div>
      </div>

      <!-- Product Details Content -->
      <div id="productContent" class="hidden">
        <!-- Product Header -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-6">
          <h2 id="productName" class="text-2xl font-bold text-gray-900 dark:text-white mb-2"></h2>
          <div class="flex items-center gap-4 text-sm text-gray-600 dark:text-gray-400">
            <span id="productBrand"></span>
            <span id="productCategory"></span>
            <span id="productStatus" class="px-2 py-1 rounded-full text-xs font-medium"></span>
          </div>
        </div>

        <!-- Product Information Sections -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <!-- Left Column -->
          <div class="space-y-6">
            <!-- Basic Information -->
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 pb-3 border-b border-gray-200 dark:border-gray-700">Basic Information</h3>
              <div id="basicInfo" class="grid grid-cols-2 gap-4 text-sm"></div>
            </div>

            <!-- Physical Properties -->
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 pb-3 border-b border-gray-200 dark:border-gray-700">Physical Properties</h3>
              <div id="physicalProps" class="grid grid-cols-2 gap-4 text-sm"></div>
            </div>

            <!-- Codes & Identification -->
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 pb-3 border-b border-gray-200 dark:border-gray-700">Codes & Identification</h3>
              <div id="codesInfo" class="grid grid-cols-2 gap-4 text-sm"></div>
            </div>
          </div>

          <!-- Right Column -->
          <div class="space-y-6">
            <!-- Pricing Information -->
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 pb-3 border-b border-gray-200 dark:border-gray-700">Pricing Information</h3>
              <div id="pricingInfo" class="grid grid-cols-2 gap-4 text-sm"></div>
            </div>

            <!-- Packaging & Logistics -->
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 pb-3 border-b border-gray-200 dark:border-gray-700">Packaging & Logistics</h3>
              <div id="packagingInfo" class="grid grid-cols-2 gap-4 text-sm"></div>
            </div>

            <!-- Product Lifecycle -->
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 pb-3 border-b border-gray-200 dark:border-gray-700">Product Lifecycle</h3>
              <div id="lifecycleInfo" class="grid grid-cols-2 gap-4 text-sm"></div>
            </div>
          </div>
        </div>

        <!-- Description -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 mt-6">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 pb-3 border-b border-gray-200 dark:border-gray-700">Description</h3>
          <p id="productDescription" class="text-gray-600 dark:text-gray-400"></p>
        </div>
      </div>
    </main>
  </div>

  <%- include('../../../partials/_toast') %>

  <script>
    const API_BASE = '/product-margin/api/v1';
    const productId = <%= productId %>;

    // Helper functions
    const displayValue = (value) => value !== null && value !== undefined && value !== '' ? value : '-';
    const formatCurrency = (value) => value ? `₹${parseFloat(value).toFixed(2)}` : '-';
    const formatPercent = (value) => value ? `${parseFloat(value).toFixed(2)}%` : '-';
    const formatDate = (dateString) => {
      if (!dateString) return '-';
      const date = new Date(dateString);
      return date.toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' });
    };

    // Load product details
    async function loadProductDetails() {
      try {
        const response = await fetch(`${API_BASE}/products/${productId}`);
        const result = await response.json();

        if (!result.success || !result.product) {
          throw new Error(result.error || 'Product not found');
        }

        const product = result.product;
        const category = product.category_name || '-';
        const subcategory = product.subcategory_name || '-';

        // Hide loading, show content
        document.getElementById('loadingState').classList.add('hidden');
        document.getElementById('productContent').classList.remove('hidden');

        // Update header
        document.getElementById('productName').textContent = product.name || 'Unknown Product';
        document.getElementById('productBrand').textContent = product.brand_name ? `Brand: ${product.brand_name}` : '';
        document.getElementById('productCategory').textContent = category !== '-' ? `Category: ${category}` : '';
        document.getElementById('productStatus').textContent = product.is_active ? 'Active' : 'Inactive';
        document.getElementById('productStatus').className = `px-2 py-1 rounded-full text-xs font-medium ${product.is_active ? 'bg-green-100 text-green-800 dark:bg-green-900/20 dark:text-green-300' : 'bg-red-100 text-red-800 dark:bg-red-900/20 dark:text-red-300'}`;

        // Basic Information
        document.getElementById('basicInfo').innerHTML = `
          <div><span class="text-gray-500 dark:text-gray-400">Product Name:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${displayValue(product.name)}</span></div>
          <div><span class="text-gray-500 dark:text-gray-400">Name Alias:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${displayValue(product.name_alias)}</span></div>
          <div><span class="text-gray-500 dark:text-gray-400">Brand Name:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${displayValue(product.brand_name)}</span></div>
          <div><span class="text-gray-500 dark:text-gray-400">Product Type:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${displayValue(product.product_type)}</span></div>
          <div><span class="text-gray-500 dark:text-gray-400">Category:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${displayValue(category)}</span></div>
          <div><span class="text-gray-500 dark:text-gray-400">Subcategory:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${displayValue(subcategory)}</span></div>
        `;

        // Physical Properties
        document.getElementById('physicalProps').innerHTML = `
          <div><span class="text-gray-500 dark:text-gray-400">Grammage:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${displayValue(product.grammage || product.unit_size)}</span></div>
          <div><span class="text-gray-500 dark:text-gray-400">Packing Type:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${displayValue(product.packing_type)}</span></div>
          <div><span class="text-gray-500 dark:text-gray-400">Milk Type:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${displayValue(product.milk_type)}</span></div>
          <div><span class="text-gray-500 dark:text-gray-400">Storage Type:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${displayValue(product.storage_type)}</span></div>
        `;

        // Codes & Identification
        document.getElementById('codesInfo').innerHTML = `
          <div><span class="text-gray-500 dark:text-gray-400">EAN Code:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${displayValue(product.ean_code)}</span></div>
          <div><span class="text-gray-500 dark:text-gray-400">HSN Code:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${displayValue(product.hsn_code)}</span></div>
        `;

        // Pricing Information
        const costPrice = parseFloat(product.cost_price) || 0;
        const mrp = parseFloat(product.mrp) || 0;
        const marginPercentage = parseFloat(product.margin_percentage) || 0;
        const gstPercentage = parseFloat(product.gst_percentage) || 0;
        
        // Calculate seller commission from MRP and Seller Margin %
        const sellerCommission = mrp > 0 && marginPercentage >= 0 ? mrp * (marginPercentage / 100) : (parseFloat(product.seller_commission) || 0);
        const sellerCommissionRounded = Math.round(sellerCommission * 100) / 100;
        
        // Landing Price = MRP - Seller Margin Value
        const landingPrice = mrp - sellerCommissionRounded;
        const landingPriceRounded = Math.round(landingPrice * 100) / 100;
        
        // Basic Price = Landing Price / (1 + GST%/100)
        let basicPrice = 0;
        if (landingPriceRounded > 0 && gstPercentage >= 0) {
          basicPrice = landingPriceRounded / (1 + gstPercentage / 100);
          basicPrice = Math.round(basicPrice * 100) / 100;
        }
        
        // GST Value = Basic Price * GST%
        const gstValue = Math.round((basicPrice * gstPercentage / 100) * 100) / 100;
        
        // Net Profit = MRP - Cost Price - Seller Commission
        const netProfit = mrp - costPrice - sellerCommissionRounded;
        const profitAmount = netProfit.toFixed(2);
        
        // Determine profit indicator styling
        let profitClass = '';
        if (netProfit > 0) {
          profitClass = 'border-green-300 dark:border-green-600 bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300';
        } else if (netProfit < 0) {
          profitClass = 'border-red-300 dark:border-red-600 bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-300';
        } else {
          profitClass = 'border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-600 text-gray-700 dark:text-gray-300';
        }
        
        document.getElementById('pricingInfo').innerHTML = `
          <div><span class="text-gray-500 dark:text-gray-400">Cost Price:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${formatCurrency(product.cost_price)}</span></div>
          <div><span class="text-gray-500 dark:text-gray-400">Basic Price:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${formatCurrency(basicPrice)}</span></div>
          <div><span class="text-gray-500 dark:text-gray-400">GST %:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${formatPercent(product.gst_percentage)}</span></div>
          <div><span class="text-gray-500 dark:text-gray-400">GST Value:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${formatCurrency(gstValue)}</span></div>
          <div><span class="text-gray-500 dark:text-gray-400">Landing Price:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${formatCurrency(landingPriceRounded)}</span></div>
          <div><span class="text-gray-500 dark:text-gray-400">MRP:</span> <span class="text-gray-900 dark:text-white font-semibold text-lg ml-2">${formatCurrency(product.mrp)}</span></div>
          <div><span class="text-gray-500 dark:text-gray-400">Seller Margin %:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${formatPercent(product.margin_percentage)}</span></div>
          <div><span class="text-gray-500 dark:text-gray-400">Seller Commission (₹):</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${formatCurrency(sellerCommissionRounded)}</span></div>
          <div class="col-span-2 mt-2">
            <div class="px-4 py-3 border rounded-lg font-semibold text-xl ${profitClass}">
              <div class="flex items-center justify-between">
                <span>Net Profit:</span>
                <span>₹${profitAmount}</span>
              </div>
            </div>
          </div>
        `;

        // Packaging & Logistics
        document.getElementById('packagingInfo').innerHTML = `
          <div><span class="text-gray-500 dark:text-gray-400">Vendor Pack Size:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${displayValue(product.vendor_pack_size)}</span></div>
          <div><span class="text-gray-500 dark:text-gray-400">Packaging Dimensions:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${displayValue(product.packaging_dimensions)}</span></div>
          <div><span class="text-gray-500 dark:text-gray-400">Temperature:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${displayValue(product.temperature)}</span></div>
          <div><span class="text-gray-500 dark:text-gray-400">Cut-off Time:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${displayValue(product.cutoff_time)}</span></div>
        `;

        // Product Lifecycle
        document.getElementById('lifecycleInfo').innerHTML = `
          <div><span class="text-gray-500 dark:text-gray-400">Shelf Life:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${product.shelf_life_days ? product.shelf_life_days + ' days' : '-'}</span></div>
          <div><span class="text-gray-500 dark:text-gray-400">RTV Status:</span> <span class="text-gray-900 dark:text-white font-medium ml-2">${displayValue(product.rtv_status)}</span></div>
        `;

        // Description
        document.getElementById('productDescription').textContent = displayValue(product.description);

      } catch (error) {
        console.error('Error loading product:', error);
        document.getElementById('loadingState').classList.add('hidden');
        document.getElementById('errorState').classList.remove('hidden');
        document.getElementById('errorMessage').textContent = error.message || 'Failed to load product details';
      }
    }

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', () => {
      // Check for stored toast message from previous page load
      const storedToast = sessionStorage.getItem('productEditToast');
      if (storedToast) {
        try {
          const toastData = JSON.parse(storedToast);
          // Wait a bit for toast manager to be initialized
          setTimeout(() => {
            if (toastData.type === 'success') {
              showSuccessToast(toastData.message);
            } else if (toastData.type === 'error') {
              showErrorToast(toastData.message);
            } else if (toastData.type === 'warning') {
              showWarningToast(toastData.message);
            } else {
              showInfoToast(toastData.message);
            }
            // Clear the stored message
            sessionStorage.removeItem('productEditToast');
          }, 100);
        } catch (e) {
          console.error('Error displaying stored toast:', e);
          sessionStorage.removeItem('productEditToast');
        }
      }

      loadProductDetails();
    });
  </script>
</body>
</html>


    // Load campaign expenses
    async function loadCampaignExpenses() {
      try {
        showExpensesLoading();
        const response = await fetch(`/marketing/api/campaigns/${campaignId}/expenses`);
        const result = await response.json();

        if (result.success) {
          expenses = result.data;
          renderExpenses();
          updateExpenseSummary();
        } else {
          showExpensesError('Failed to load expenses');
        }
      } catch (error) {
        console.error('Error loading expenses:', error);
        showExpensesError('Error loading expenses');
      }
    }

    // Show expenses loading state
    function showExpensesLoading() {
      document.getElementById('expensesLoadingState').classList.remove('hidden');
      document.getElementById('expensesEmptyState').classList.add('hidden');
      document.getElementById('expensesTableBody').innerHTML = '';
    }

    // Show expenses empty state
    function showExpensesEmpty() {
      document.getElementById('expensesLoadingState').classList.add('hidden');
      document.getElementById('expensesEmptyState').classList.remove('hidden');
      document.getElementById('expensesTableBody').innerHTML = '';
    }

    // Show expenses error
    function showExpensesError(message) {
      document.getElementById('expensesLoadingState').classList.add('hidden');
      document.getElementById('expensesEmptyState').classList.remove('hidden');
      document.getElementById('expensesEmptyState').innerHTML = `
        <svg class="mx-auto h-12 w-12 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <p class="mt-2 text-red-500">${message}</p>
      `;
    }

    // Render expenses table
    function renderExpenses() {
      const tbody = document.getElementById('expensesTableBody');
      
      document.getElementById('expensesLoadingState').classList.add('hidden');
      document.getElementById('expensesEmptyState').classList.add('hidden');

      if (expenses.length === 0) {
        showExpensesEmpty();
        return;
      }

      tbody.innerHTML = expenses.map(expense => {
        const categoryColors = {
          'digital_ads': 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200',
          'printing': 'bg-orange-100 text-orange-800 dark:bg-orange-900 dark:text-orange-200',
          'distribution': 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200',
          'vendor': 'bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200',
          'commission': 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200',
          'miscellaneous': 'bg-gray-100 text-gray-800 dark:bg-gray-900 dark:text-gray-200'
        };

        const categoryColor = categoryColors[expense.category] || 'bg-gray-100 text-gray-800 dark:bg-gray-900 dark:text-gray-200';
        const categoryName = expense.category.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());

        return `
          <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">
              ${new Date(expense.expense_date).toLocaleDateString()}
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full ${categoryColor}">
                ${categoryName}
              </span>
            </td>
            <td class="px-6 py-4">
              <div class="text-sm text-gray-900 dark:text-white max-w-xs truncate" title="${expense.description}">
                ${expense.description}
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-gray-900 dark:text-white">
              ₹${parseFloat(expense.amount).toLocaleString()}
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">
              ${expense.vendor_name || 'N/A'}
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
              <div class="flex space-x-2">
                <button onclick="editExpense(${expense.id})" class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-md text-indigo-600 bg-indigo-100 hover:bg-indigo-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors duration-200">
                  Edit
                </button>
                <button onclick="deleteExpense(${expense.id})" class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-md text-red-600 bg-red-100 hover:bg-red-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-colors duration-200">
                  Delete
                </button>
              </div>
            </td>
          </tr>
        `;
      }).join('');
    }

    // Update expense summary
    function updateExpenseSummary() {
      const totalSpent = expenses.reduce((sum, expense) => sum + parseFloat(expense.amount), 0);
      const expenseCount = expenses.length;
      
      // Get budget from campaign
      const budget = campaign.expected_goal_metrics?.budget || 0;
      const budgetRemaining = Math.max(0, parseFloat(budget) - totalSpent);

      document.getElementById('totalSpent').textContent = `₹${totalSpent.toLocaleString()}`;
      document.getElementById('expenseCount').textContent = expenseCount;
      document.getElementById('budgetRemaining').textContent = `₹${budgetRemaining.toLocaleString()}`;

      // Update performance summary with actual expenses
      document.getElementById('totalExpenses').textContent = `₹${totalSpent.toLocaleString()}`;
      
      // Recalculate ROI with actual expenses
      const revenue = parseFloat(campaign.total_revenue || 0);
      const roi = totalSpent > 0 ? ((revenue - totalSpent) / totalSpent * 100).toFixed(1) : '0';
      document.getElementById('roi').textContent = `${roi}%`;
    }

    // Show add expense modal
    function showAddExpenseModal() {
      // Set today's date as default
      document.getElementById('expenseDate').value = new Date().toISOString().split('T')[0];
      document.getElementById('addExpenseModal').classList.remove('hidden');
    }

    // Hide add expense modal
    function hideAddExpenseModal() {
      document.getElementById('addExpenseModal').classList.add('hidden');
      document.getElementById('addExpenseForm').reset();
    }

    // Add expense form submission
    async function handleAddExpense(event) {
      event.preventDefault();
      
      const formData = new FormData(event.target);
      const expenseData = {
        campaign_id: campaignId,
        expense_date: formData.get('expense_date'),
        category: formData.get('category'),
        description: formData.get('description'),
        amount: parseFloat(formData.get('amount')),
        vendor_name: formData.get('vendor_name') || null,
        receipt_path: null // TODO: Handle file upload
      };

      try {
        const response = await fetch('/marketing/api/expenses', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(expenseData)
        });

        const result = await response.json();

        if (result.success) {
          hideAddExpenseModal();
          loadCampaignExpenses(); // Reload expenses
          showSuccessToast('Expense added successfully!');
        } else {
          showErrorToast('Failed to add expense: ' + (result.error || 'Unknown error'));
        }
      } catch (error) {
        console.error('Error adding expense:', error);
        showErrorToast('Error adding expense: ' + error.message);
      }
    }

    // Edit expense (placeholder)
    function editExpense(expenseId) {
      showInfoToast('Edit expense functionality coming soon!');
    }

    // Delete expense
    async function deleteExpense(expenseId) {
      if (!confirm('Are you sure you want to delete this expense?')) {
        return;
      }

      try {
        const response = await fetch(`/marketing/api/expenses/${expenseId}`, {
          method: 'DELETE'
        });

        const result = await response.json();

        if (result.success) {
          loadCampaignExpenses(); // Reload expenses
          showSuccessToast('Expense deleted successfully!');
        } else {
          showErrorToast('Failed to delete expense: ' + (result.error || 'Unknown error'));
        }
      } catch (error) {
        console.error('Error deleting expense:', error);
        showErrorToast('Error deleting expense: ' + error.message);
      }
    }

    // Edit campaign button
    document.getElementById('editCampaign').addEventListener('click', () => {
      window.location.href = `/marketing/campaigns/${campaignId}/edit`;
    });





    // Register Chart.js plugins
    Chart.register(ChartDataLabels);
    
    // Register annotations plugin
    if (typeof ChartAnnotation !== 'undefined') {
      Chart.register(ChartAnnotation);
    }

    // Helper function to get campaign start date label
    function getCampaignStartDateLabel(startDate, chartLabels) {
      if (!startDate) return null;
      
      const campaignDate = new Date(startDate);
      const day = campaignDate.getDate().toString().padStart(2, '0');
      const month = (campaignDate.getMonth() + 1).toString().padStart(2, '0');
      const campaignLabel = `${day}/${month}`;
      
      // Find the closest label in the chart
      const labelIndex = chartLabels.findIndex(label => label === campaignLabel);
      return labelIndex >= 0 ? campaignLabel : null;
    }

    // Performance chart
    let performanceChart = null;

    async function loadPerformanceChart() {
      try {
        // Show loading spinner
        document.getElementById('chartLoading').style.display = 'flex';
        document.getElementById('performanceChart').style.display = 'none';

        // Fetch both chart data and campaign data
        const [chartResponse, campaignResponse] = await Promise.all([
          fetch(`/marketing/api/campaigns/${campaignId}/performance-chart`),
          fetch(`/marketing/api/campaigns/${campaignId}`)
        ]);

        const chartResult = await chartResponse.json();
        const campaignResult = await campaignResponse.json();

        // Hide loading spinner
        document.getElementById('chartLoading').style.display = 'none';
        document.getElementById('performanceChart').style.display = 'block';

        if (chartResult.success && chartResult.data) {
          const campaignStartDate = campaignResult.success ? campaignResult.data.start_date : null;
          renderPerformanceChart(chartResult.data, campaignStartDate);
        } else {
          renderEmptyChart();
        }
      } catch (error) {
        console.error('Error loading performance chart:', error);
        // Hide loading spinner on error
        document.getElementById('chartLoading').style.display = 'none';
        document.getElementById('performanceChart').style.display = 'block';
        renderEmptyChart();
      }
    }

    function renderPerformanceChart(data, campaignStartDate) {
      const ctx = document.getElementById('performanceChart').getContext('2d');
      
      // Destroy existing chart if it exists
      if (performanceChart) {
        performanceChart.destroy();
      }

      // Check if we're in dark mode
      const isDarkMode = document.documentElement.classList.contains('dark');
      
      // Apply dark mode colors to datasets if needed
      const datasets = data.datasets.map(dataset => {
        if (isDarkMode) {
          // Convert light mode colors to dark mode equivalents
          const colorMap = {
            '#3b82f6': '#60a5fa',
            '#10b981': '#34d399',
            '#f59e0b': '#fbbf24',
            '#ef4444': '#f87171',
            '#8b5cf6': '#a78bfa'
          };
          
          const darkBorderColor = colorMap[dataset.borderColor] || dataset.borderColor;
          const darkBackgroundColor = dataset.backgroundColor.replace(/rgba\(([^,]+),([^,]+),([^,]+),([^)]+)\)/, 
            (match, r, g, b, a) => {
              const rgb = darkBorderColor.replace('#', '');
              const darkR = parseInt(rgb.substr(0, 2), 16);
              const darkG = parseInt(rgb.substr(2, 2), 16);
              const darkB = parseInt(rgb.substr(4, 2), 16);
              return `rgba(${darkR}, ${darkG}, ${darkB}, ${a})`;
            }
          );
          
          return {
            ...dataset,
            borderColor: darkBorderColor,
            backgroundColor: darkBackgroundColor
          };
        }
        return dataset;
      });
      
      const chartData = {
        labels: data.labels || [],
        datasets: datasets
      };

      performanceChart = new Chart(ctx, {
        type: 'line',
        data: chartData,
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              labels: {
                color: isDarkMode ? '#ffffff' : '#374151'
              }
            },
            datalabels: {
              display: true,
              color: isDarkMode ? '#ffffff' : '#374151',
              font: {
                size: 10,
                weight: 'bold'
              },
              formatter: function(value, context) {
                // Only show labels for non-zero values to avoid clutter
                return value > 0 ? value : '';
              },
              anchor: 'end',
              align: 'top',
              offset: 4
            },
            annotation: campaignStartDate ? {
              annotations: {
                campaignStartLine: {
                  type: 'line',
                  mode: 'vertical',
                  scaleID: 'x',
                  value: getCampaignStartDateLabel(campaignStartDate, data.labels),
                  borderColor: isDarkMode ? '#ef4444' : '#dc2626',
                  borderWidth: 2,
                  borderDash: [5, 5],
                  label: {
                    content: 'Campaign Start',
                    enabled: true,
                    position: 'top',
                    backgroundColor: isDarkMode ? '#ef4444' : '#dc2626',
                    color: '#ffffff',
                    font: {
                      size: 12,
                      weight: 'bold'
                    },
                    padding: 4,
                    borderRadius: 4
                  }
                }
              }
            } : {}
          },
          scales: {
            x: {
              ticks: {
                color: isDarkMode ? '#ffffff' : '#374151'
              },
              grid: {
                color: isDarkMode ? '#374151' : '#e5e7eb'
              }
            },
            y: {
              type: 'linear',
              display: true,
              position: 'left',
              beginAtZero: true,
              ticks: {
                color: isDarkMode ? '#ffffff' : '#374151',
                callback: function(value) {
                  return value.toLocaleString();
                }
              },
              grid: {
                color: isDarkMode ? '#374151' : '#e5e7eb'
              },
              title: {
                display: true,
                text: 'Number of Products Sold',
                color: isDarkMode ? '#ffffff' : '#374151'
              }
            }
          }
        }
      });
    }

    function renderEmptyChart() {
      const ctx = document.getElementById('performanceChart').getContext('2d');
      
      if (performanceChart) {
        performanceChart.destroy();
      }

      const isDarkMode = document.documentElement.classList.contains('dark');

      performanceChart = new Chart(ctx, {
        type: 'line',
        data: {
          labels: ['No Data'],
          datasets: [{
            label: 'Sales (₹)',
            data: [0],
            borderColor: isDarkMode ? '#60a5fa' : '#3b82f6',
            backgroundColor: isDarkMode ? 'rgba(96, 165, 250, 0.1)' : 'rgba(59, 130, 246, 0.1)',
            borderWidth: 2
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              labels: {
                color: isDarkMode ? '#ffffff' : '#374151'
              }
            },
            datalabels: {
              display: false
            }
          },
          scales: {
            x: {
              ticks: {
                color: isDarkMode ? '#ffffff' : '#374151'
              },
              grid: {
                color: isDarkMode ? '#374151' : '#e5e7eb'
              }
            },
            y: {
              beginAtZero: true,
              ticks: {
                color: isDarkMode ? '#ffffff' : '#374151'
              },
              grid: {
                color: isDarkMode ? '#374151' : '#e5e7eb'
              }
            }
          }
        }
      });
    }

    // Delete campaign functionality
    function showDeleteModal() {
      document.getElementById('deleteModal').classList.remove('hidden');
    }

    function hideDeleteModal() {
      document.getElementById('deleteModal').classList.add('hidden');
    }

    async function deleteCampaign() {
      try {
        const campaignId = window.location.pathname.split('/').pop();
        const response = await fetch(`/marketing/api/campaigns/${campaignId}`, {
          method: 'DELETE'
        });
        
        const result = await response.json();
        
        if (result.success) {
          // Show success message
          showSuccessToast('Campaign deleted successfully!');
          
          // Redirect to campaigns list after a short delay
          setTimeout(() => {
            window.location.href = '/marketing/campaigns';
          }, 1500);
        } else {
          // Show error message
          showErrorToast('Failed to delete campaign: ' + (result.error || 'Unknown error'));
        }
      } catch (error) {
        console.error('Error deleting campaign:', error);
        showErrorToast('Error deleting campaign: ' + error.message);
      }
    }

    // Load campaign details on page load
    document.addEventListener('DOMContentLoaded', () => {
      loadCampaignDetails();
      loadPerformanceChart();
      
      // Add event listeners for delete functionality
      document.getElementById('deleteCampaign').addEventListener('click', showDeleteModal);
      document.getElementById('confirmDelete').addEventListener('click', deleteCampaign);
      document.getElementById('cancelDelete').addEventListener('click', hideDeleteModal);
      
      // Add event listeners for expense functionality
      document.getElementById('addExpenseBtn').addEventListener('click', showAddExpenseModal);
      document.getElementById('closeAddExpenseModal').addEventListener('click', hideAddExpenseModal);
      document.getElementById('cancelAddExpense').addEventListener('click', hideAddExpenseModal);
      document.getElementById('addExpenseForm').addEventListener('submit', handleAddExpense);
      
      // Close modals when clicking outside
      document.getElementById('deleteModal').addEventListener('click', (e) => {
        if (e.target === document.getElementById('deleteModal')) {
          hideDeleteModal();
        }
      });
      
      document.getElementById('addExpenseModal').addEventListener('click', (e) => {
        if (e.target === document.getElementById('addExpenseModal')) {
          hideAddExpenseModal();
        }
      });
    });
  </script>


                  <p class="text-xs text-gray-500 dark:text-gray-400">File</p>
                </div>
              </div>
            </div>`;
          }
        }).join('');
      } else {
        creativeAssets.innerHTML = '<div class="text-center py-6"><span class="text-gray-500 dark:text-gray-400">No creative assets uploaded</span></div>';
      }

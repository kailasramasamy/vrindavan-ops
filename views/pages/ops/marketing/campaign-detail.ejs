          <button id="confirmDelete" class="px-4 py-2 bg-red-600 text-white text-base font-medium rounded-md w-24 mr-2 hover:bg-red-700">
            Delete
          </button>
          <button id="cancelDelete" class="px-4 py-2 bg-gray-600 text-white text-base font-medium rounded-md w-24 hover:bg-gray-700">
            Cancel
          </button>
        </div>
      </div>
    </div>
  </div>
</body>
</html>

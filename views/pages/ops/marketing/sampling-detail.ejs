    function toggleBatch(batchId) {
      const batch = document.getElementById(batchId);
      const icon = document.getElementById(`${batchId}-icon`);
      if (batch.classList.contains('hidden')) {
        batch.classList.remove('hidden');
        icon.style.transform = 'rotate(0deg)';
      } else {
        batch.classList.add('hidden');
        icon.style.transform = 'rotate(-90deg)';
      }
    }

    function renderOrders() {
      const container = document.getElementById('orderBatchesContainer');
      container.innerHTML = '';

      if (campaign.tracking.length === 0) {
        container.innerHTML = '<div class="text-center py-8 text-gray-500 dark:text-gray-400">No orders tracked yet.</div>';
        return;
      }

      // Group orders by customer's sampling_date (only for tracked customers)
      const ordersByDate = {};
      campaign.tracking.forEach(order => {
        const customer = campaign.customers.find(c => c.customer_id === order.customer_id);
        
        // Skip orders from customers who are not in the tracking list
        if (!customer) {
          return;
        }
        
        // Normalize sampling_date to YYYY-MM-DD format
        let samplingDate = 'No Date';
        if (customer.sampling_date) {
          if (customer.sampling_date instanceof Date) {
            const year = customer.sampling_date.getFullYear();
            const month = String(customer.sampling_date.getMonth() + 1).padStart(2, '0');
            const day = String(customer.sampling_date.getDate()).padStart(2, '0');
            samplingDate = `${year}-${month}-${day}`;
          } else if (typeof customer.sampling_date === 'string') {
            // Extract YYYY-MM-DD from string (handles ISO strings and date strings)
            samplingDate = customer.sampling_date.split('T')[0].split(' ')[0].trim();
          }
        }
        
        // Normalize order_date for comparison
        let normalizedOrderDate = '';
        if (order.order_date) {
          if (order.order_date instanceof Date) {
            const year = order.order_date.getFullYear();
            const month = String(order.order_date.getMonth() + 1).padStart(2, '0');
            const day = String(order.order_date.getDate()).padStart(2, '0');
            normalizedOrderDate = `${year}-${month}-${day}`;
          } else if (typeof order.order_date === 'string') {
            normalizedOrderDate = order.order_date.split('T')[0].split(' ')[0].trim();
          }
        }
        
        if (!ordersByDate[samplingDate]) {
          ordersByDate[samplingDate] = [];
        }
        
        ordersByDate[samplingDate].push({
          ...order,
          customer: customer,
          isSampleOrder: normalizedOrderDate === samplingDate
        });
      });

      // Check if we have any orders from tracked customers
      if (Object.keys(ordersByDate).length === 0) {
        container.innerHTML = '<div class="text-center py-8 text-gray-500 dark:text-gray-400">No orders from tracked customers yet.</div>';
        return;
      }

      // Create a map: sampling_date -> batch_number from database (marketing_sampling_customers.batch_number)
      // All customers with the same sampling_date should have the same batch_number
      const samplingDateToBatchNumber = {};
      Object.keys(ordersByDate).forEach(samplingDate => {
        const ordersForDate = ordersByDate[samplingDate];
        // Get batch_number from the first order's customer (all customers with same sampling_date have same batch_number)
        if (ordersForDate.length > 0 && ordersForDate[0].customer) {
          const customer = ordersForDate[0].customer;
          // Use batch_number from marketing_sampling_customers.batch_number
          if (customer.batch_number !== null && customer.batch_number !== undefined) {
            samplingDateToBatchNumber[samplingDate] = customer.batch_number;
          }
        }
      });
      
      // Now sort dates in descending order (newest first) for display
      // Sort by batch_number descending (newest batch first)
      const sortedDates = Object.keys(ordersByDate).sort((a, b) => {
        if (a === 'No Date') return 1;
        if (b === 'No Date') return -1;
        const batchA = samplingDateToBatchNumber[a] || 999;
        const batchB = samplingDateToBatchNumber[b] || 999;
        return batchB - batchA; // Descending order (newest batch first)
      });

      // Render each batch (grouped by sampling_date)
      sortedDates.forEach((samplingDate, index) => {
        const orders = ordersByDate[samplingDate];
        // Get batch_number from database (marketing_sampling_customers.batch_number)
        // All customers with the same sampling_date have the same batch_number
        const batchNumber = samplingDateToBatchNumber[samplingDate] || null;
        if (batchNumber === null && orders.length > 0 && orders[0].customer && orders[0].customer.batch_number) {
          // Fallback: use batch_number from first customer if not in map
          const fallbackBatchNumber = orders[0].customer.batch_number;
          if (fallbackBatchNumber !== null && fallbackBatchNumber !== undefined) {
            samplingDateToBatchNumber[samplingDate] = fallbackBatchNumber;
          }
        }
        const finalBatchNumber = samplingDateToBatchNumber[samplingDate] || (index + 1);
        // Format date display safely (avoid timezone issues by parsing YYYY-MM-DD directly)
        let dateDisplay = 'No Date Assigned';
        if (samplingDate !== 'No Date') {
          const [year, month, day] = samplingDate.split('-');
          if (year && month && day) {
            const dateObj = new Date(parseInt(year), parseInt(month) - 1, parseInt(day));
            dateDisplay = dateObj.toLocaleDateString('en-US', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' });
          }
        }
        const batchId = `order-batch-${samplingDate.replace(/\s/g, '-')}`;
        
        // Count sample orders vs regular orders
        const sampleOrdersCount = orders.filter(o => o.isSampleOrder).length;
        const regularOrdersCount = orders.length - sampleOrdersCount;
        const totalAmount = orders.reduce((sum, o) => sum + parseFloat(o.order_amount || 0), 0);
        
        const batchDiv = document.createElement('div');
        batchDiv.className = 'bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden';
        batchDiv.innerHTML = `
          <div class="bg-gray-50 dark:bg-gray-900 px-4 py-3 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-800" onclick="toggleBatch('${batchId}')">
            <div class="flex items-center space-x-4">
              <svg class="w-5 h-5 text-gray-500 dark:text-gray-400 transition-transform" id="${batchId}-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
              <div>
                <h4 class="text-sm font-medium text-gray-900 dark:text-white">📅 ${dateDisplay}</h4>
                <p class="text-xs text-gray-500 dark:text-gray-400">${orders.length} order${orders.length !== 1 ? 's' : ''} • ${sampleOrdersCount} sample, ${regularOrdersCount} regular • ₹${totalAmount.toFixed(2)}</p>
              </div>
            </div>
            <div class="flex items-center space-x-2">
              <span class="px-2 py-1 text-xs font-medium rounded-full ${samplingDate === 'No Date' ? 'bg-gray-200 text-gray-700 dark:bg-gray-700 dark:text-gray-300' : 'bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-300'}">
                Batch ${finalBatchNumber}
              </span>
            </div>
          </div>
          <div id="${batchId}" class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
              <thead class="bg-gray-50 dark:bg-gray-900">
                <tr>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Order Date</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Customer</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Phone</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Quantity</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Amount</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Type</th>
                </tr>
              </thead>
              <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                ${orders.map(order => {
                  return `
                    <tr>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">${new Date(order.order_date).toLocaleDateString()}</td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">${order.customer ? order.customer.customer_name : order.customer_id}</td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">${order.customer ? (order.customer.customer_phone || 'N/A') : 'N/A'}</td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">${order.quantity}</td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">₹${parseFloat(order.order_amount || 0).toFixed(2)}</td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm">
                        ${order.isSampleOrder ? 
                          '<span class="px-2 py-1 text-xs font-medium rounded-full bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300">📦 Sample Order</span>' : 
                          '<span class="px-2 py-1 text-xs font-medium rounded-full bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300">Regular Order</span>'
                        }
                      </td>
                    </tr>
                  `;
                }).join('')}
              </tbody>
            </table>
          </div>
        `;
        container.appendChild(batchDiv);
      });
    }

    function switchTab(tab) {
      document.querySelectorAll('.tab-button').forEach(btn => {
        btn.classList.remove('active', 'text-blue-600', 'border-blue-600', 'dark:text-blue-400');
        btn.classList.add('text-gray-500', 'border-transparent');
      });

      document.querySelectorAll('.tab-content').forEach(content => {
        content.classList.add('hidden');
      });

      document.getElementById(`tab-${tab}`).classList.remove('text-gray-500', 'border-transparent');
      document.getElementById(`tab-${tab}`).classList.add('active', 'text-blue-600', 'border-blue-600', 'dark:text-blue-400');
      document.getElementById(`content-${tab}`).classList.remove('hidden');
    }

    async function updateStatus(status) {
      try {
        const response = await fetch(`/marketing/api/sampling/campaigns/${campaignId}/status`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ status })
        });

        const result = await response.json();

        if (result.success) {
          campaign.status = status;
          const trackButton = document.getElementById('trackButton');
          const refreshOrdersButton = document.getElementById('refreshOrdersButton');
          if (status === 'active') {
            if (trackButton) trackButton.disabled = false;
            if (refreshOrdersButton) refreshOrdersButton.disabled = false;
          } else {
            if (trackButton) trackButton.disabled = true;
            if (refreshOrdersButton) refreshOrdersButton.disabled = true;
          }
        }
      } catch (error) {
        console.error("Error updating status:", error);
      }
    }

    async function runTracking() {
      // Check if campaign is active
      if (campaign && campaign.status !== 'active') {
        showErrorToast('Tracking can only be run for active campaigns');
        return;
      }

      const confirmed = await showConfirmDialog(
        'Run Tracking?',
        'This will scan for new sample orders from tracked customers. Continue?',
        'Run Tracking',
        'Cancel'
      );
      
      if (!confirmed) return;

      // Disable buttons during tracking
      const trackButton = document.getElementById('trackButton');
      const refreshOrdersButton = document.getElementById('refreshOrdersButton');
      const originalTrackText = trackButton ? trackButton.textContent : '';
      const originalRefreshHTML = refreshOrdersButton ? refreshOrdersButton.innerHTML : '';
      
      if (trackButton) {
        trackButton.disabled = true;
        trackButton.textContent = 'Tracking...';
      }
      if (refreshOrdersButton) {
        refreshOrdersButton.disabled = true;
        refreshOrdersButton.innerHTML = '<svg class="animate-spin h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>Refreshing...';
      }

      try {
        const response = await fetch(`/marketing/api/sampling/campaigns/${campaignId}/track`, {
          method: 'POST'
        });

        const result = await response.json();

        if (result.success) {
          showSuccessToast(`Tracking completed. Found ${result.new_orders} new order${result.new_orders !== 1 ? 's' : ''}.`);
          loadCampaignDetails();
        } else {
          showErrorToast('Failed to run tracking: ' + (result.error || 'Unknown error'));
        }
      } catch (error) {
        console.error("Error running tracking:", error);
        showErrorToast('Failed to run tracking');
      } finally {
        // Re-enable buttons
        if (trackButton) {
          trackButton.disabled = campaign && campaign.status === 'active' ? false : true;
          trackButton.textContent = originalTrackText;
        }
        if (refreshOrdersButton) {
          refreshOrdersButton.disabled = campaign && campaign.status === 'active' ? false : true;
          refreshOrdersButton.innerHTML = originalRefreshHTML;
        }
      }
    }

    async function addSampleToBatch(samplingDate, event) {
      // Stop propagation to prevent batch collapse/expand
      event.stopPropagation();
      
      // Normalize the date to YYYY-MM-DD format (remove any time component)
      // This ensures we match customers correctly and send the correct date to API
      let normalizedDateStr = samplingDate;
      if (samplingDate && samplingDate !== 'No Date') {
        // If it's a Date object, format it
        if (samplingDate instanceof Date) {
          const year = samplingDate.getFullYear();
          const month = String(samplingDate.getMonth() + 1).padStart(2, '0');
          const day = String(samplingDate.getDate()).padStart(2, '0');
          normalizedDateStr = `${year}-${month}-${day}`;
        } else if (typeof samplingDate === 'string') {
          // Extract YYYY-MM-DD from string (handles ISO strings and date strings)
          normalizedDateStr = samplingDate.split('T')[0].split(' ')[0].trim();
        }
      }
      
      // Filter customers by normalized date (compare date strings)
      const batchCustomers = campaign.customers
        .filter(c => {
          if (!c.sampling_date) return false;
          // Normalize customer's sampling_date for comparison
          const customerDate = c.sampling_date instanceof Date 
            ? `${c.sampling_date.getFullYear()}-${String(c.sampling_date.getMonth() + 1).padStart(2, '0')}-${String(c.sampling_date.getDate()).padStart(2, '0')}`
            : String(c.sampling_date).split('T')[0].split(' ')[0].trim();
          return customerDate === normalizedDateStr;
        })
        .sort((a, b) => a.customer_id - b.customer_id);
      
      if (batchCustomers.length === 0) {
        showErrorToast(`No customers found for sampling date ${normalizedDateStr}`);
        return;
      }
      
      // Get credit amount
      const creditAmount = campaign.product_discount_price ? parseFloat(campaign.product_discount_price) : 0;
      const creditAmountDisplay = `₹${creditAmount.toFixed(2)}`;
      const totalCredit = `₹${(creditAmount * batchCustomers.length).toFixed(2)}`;
      
      // Show progress modal with confirmation
      // The modal will show Step 1 confirmation first, then Step 1 summary + Step 2 confirmation, then final summary
      showAddSampleProgressModal(
        batchCustomers, 
        normalizedDateStr, 
        creditAmount,
        campaign.product_name || 'N/A',
        campaignId
      );
    }

    async function removeCustomer(customerId) {
      const confirmed = await showConfirmDialog(
        'Remove Customer?',
        'Remove this customer from tracking?',
        'Remove',
        'Cancel'
      );
      
      if (!confirmed) return;

      try {
        const response = await fetch(`/marketing/api/sampling/campaigns/${campaignId}/customers/${customerId}`, {
          method: 'DELETE'
        });

        const result = await response.json();

        if (result.success) {
          showSuccessToast('Customer removed successfully');
          loadCampaignDetails();
        } else {
          showErrorToast('Failed to remove customer: ' + (result.error || 'Unknown error'));
        }
      } catch (error) {
        console.error("Error removing customer:", error);
        showErrorToast('Failed to remove customer');
      }
    }

    // Export customers to CSV
    function exportCustomersToCSV() {
      if (!campaign || !campaign.customers || campaign.customers.length === 0) {
        showErrorToast('No customers to export');
        return;
      }

      // Map customers with additional fields
      const customersData = campaign.customers.map(customer => {
        return {
          customer_id: customer.customer_id,
          customer_name: customer.customer_name || '',
          customer_phone: customer.customer_phone || '',
          locality: customer.locality_name || '',
          house_no: customer.house_no || '',
          complete_address: customer.complete_address || '',
          sample_product_name: campaign.product_name || '',
          added_at: customer.added_at ? new Date(customer.added_at).toLocaleString() : ''
        };
      });

      // Create CSV headers
      const headers = [
        'Customer ID',
        'Customer Name',
        'Phone',
        'Locality',
        'House Number',
        'Complete Address',
        'Sample Product Name',
        'Added At'
      ];

      // Create CSV rows
      const rows = customersData.map(customer => [
        customer.customer_id,
        `"${customer.customer_name.replace(/"/g, '""')}"`, // Escape quotes in name
        customer.customer_phone,
        `"${customer.locality.replace(/"/g, '""')}"`,
        `"${customer.house_no.replace(/"/g, '""')}"`,
        `"${customer.complete_address.replace(/"/g, '""')}"`,
        `"${customer.sample_product_name.replace(/"/g, '""')}"`,
        `"${customer.added_at}"`
      ]);

      // Combine headers and rows
      const csvContent = [headers.join(','), ...rows.map(row => row.join(','))].join('\n');

      // Create a blob and download
      const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
      const link = document.createElement('a');
      const url = URL.createObjectURL(blob);
      
      // Generate filename with campaign name and date
      const campaignName = campaign.campaign_name.replace(/[^a-z0-9]/gi, '_').toLowerCase();
      const dateStr = new Date().toISOString().split('T')[0];
      const filename = `${campaignName}_customers_${dateStr}.csv`;
      
      link.setAttribute('href', url);
      link.setAttribute('download', filename);
      link.style.visibility = 'hidden';
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      
      showSuccessToast(`Exported ${customersData.length} customers to CSV`);
    }

    // Export batch-specific customers to CSV
    function exportBatchToCSV(samplingDate, batchNumber, event) {
      // Stop propagation to prevent batch collapse/expand
      if (event) {
        event.stopPropagation();
      }

      if (!campaign || !campaign.customers || campaign.customers.length === 0) {
        showErrorToast('No customers to export');
        return;
      }

      // Normalize sampling_date for comparison
      let normalizedDateStr = samplingDate;
      if (samplingDate && samplingDate !== 'No Date') {
        if (samplingDate instanceof Date) {
          const year = samplingDate.getFullYear();
          const month = String(samplingDate.getMonth() + 1).padStart(2, '0');
          const day = String(samplingDate.getDate()).padStart(2, '0');
          normalizedDateStr = `${year}-${month}-${day}`;
        } else if (typeof samplingDate === 'string') {
          normalizedDateStr = samplingDate.split('T')[0].split(' ')[0].trim();
        }
      }

      // Filter customers by sampling_date
      const batchCustomers = campaign.customers.filter(c => {
        if (!c.sampling_date) return false;
        // Normalize customer's sampling_date for comparison
        const customerDate = c.sampling_date instanceof Date 
          ? `${c.sampling_date.getFullYear()}-${String(c.sampling_date.getMonth() + 1).padStart(2, '0')}-${String(c.sampling_date.getDate()).padStart(2, '0')}`
          : String(c.sampling_date).split('T')[0].split(' ')[0].trim();
        return customerDate === normalizedDateStr;
      });

      if (batchCustomers.length === 0) {
        showErrorToast('No customers found for this batch');
        return;
      }

      // Map customers with additional fields (same format as global export)
      const customersData = batchCustomers.map(customer => {
        return {
          customer_id: customer.customer_id,
          customer_name: customer.customer_name || '',
          customer_phone: customer.customer_phone || '',
          locality: customer.locality_name || '',
          house_no: customer.house_no || '',
          complete_address: customer.complete_address || '',
          sample_product_name: campaign.product_name || '',
          added_at: customer.added_at ? new Date(customer.added_at).toLocaleString() : ''
        };
      });

      // Create CSV headers (same as global export)
      const headers = [
        'Customer ID',
        'Customer Name',
        'Phone',
        'Locality',
        'House Number',
        'Complete Address',
        'Sample Product Name',
        'Added At'
      ];

      // Create CSV rows (same format as global export)
      const rows = customersData.map(customer => [
        customer.customer_id,
        `"${(customer.customer_name || '').replace(/"/g, '""')}"`, // Escape quotes in name
        customer.customer_phone,
        `"${(customer.locality || '').replace(/"/g, '""')}"`,
        `"${(customer.house_no || '').replace(/"/g, '""')}"`,
        `"${(customer.complete_address || '').replace(/"/g, '""')}"`,
        `"${(customer.sample_product_name || '').replace(/"/g, '""')}"`,
        `"${customer.added_at}"`
      ]);

      // Combine headers and rows
      const csvContent = [headers.join(','), ...rows.map(row => row.join(','))].join('\n');

      // Create a blob and download
      const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
      const link = document.createElement('a');
      const url = URL.createObjectURL(blob);
      
      // Generate filename with campaign name, batch number, and date
      const campaignName = campaign.campaign_name.replace(/[^a-z0-9]/gi, '_').toLowerCase();
      const dateStr = new Date().toISOString().split('T')[0];
      const batchDateStr = normalizedDateStr.replace(/-/g, '');
      const filename = `${campaignName}_batch_${batchNumber}_${batchDateStr}_${dateStr}.csv`;
      
      link.setAttribute('href', url);
      link.setAttribute('download', filename);
      link.style.visibility = 'hidden';
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      
      showSuccessToast(`Exported ${customersData.length} customers from Batch ${batchNumber} to CSV`);
    }

    // Confirmation dialog helper
    function showConfirmDialog(title, message, confirmText = "Confirm", cancelText = "Cancel") {
      return new Promise((resolve) => {
        const modal = document.createElement("div");
        modal.className = "fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50 flex items-center justify-center";
        modal.innerHTML = `
          <div class="relative bg-white dark:bg-gray-800 rounded-lg shadow-xl max-w-md w-full mx-4">
            <div class="p-6">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">${title}</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400 whitespace-pre-line mb-6">${message}</p>
              <div class="flex justify-end space-x-3">
                <button id="confirmCancel" class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:hover:bg-gray-600">
                  ${cancelText}
                </button>
                <button id="confirmOk" class="px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-md">
                  ${confirmText}
                </button>
              </div>
            </div>
          </div>
        `;
        
        document.body.appendChild(modal);
        
        modal.querySelector("#confirmOk").onclick = () => {
          document.body.removeChild(modal);
          resolve(true);
        };
        
        modal.querySelector("#confirmCancel").onclick = () => {
          document.body.removeChild(modal);
          resolve(false);
        };
        
        modal.onclick = (e) => {
          if (e.target === modal) {
            document.body.removeChild(modal);
            resolve(false);
          }
        };
      });
    }


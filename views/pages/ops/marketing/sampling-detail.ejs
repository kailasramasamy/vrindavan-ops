<%- include('../../../partials/_head', { title: title, seo: seo }) %>
<link rel="stylesheet" href="/assets/css/marketing-dark-mode.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>

<body class="bg-gray-50 dark:bg-gray-900">
  <%- include('../../../partials/_subnav', { currentPage: currentPage, section: 'Marketing', subsection: 'Product Sampling', user: user }) %>
  <%- include('../../../partials/_toast') %>

  <div class="min-h-screen">
    <!-- Header -->
    <div class="bg-white dark:bg-gray-800 shadow">
      <div class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center">
          <div>
            <div class="flex items-center space-x-3">
              <a href="/marketing/sampling" class="text-gray-500 hover:text-gray-700 dark:text-gray-400">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
              </a>
              <h1 class="text-3xl font-bold text-gray-900 dark:text-white" id="campaignTitle">Loading...</h1>
            </div>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400" id="campaignDescription"></p>
          </div>
          <div class="flex space-x-3 items-center">
            <button onclick="runTracking()" id="trackButton" class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-md text-sm font-medium" disabled>
              Track Orders
            </button>
            <div class="relative" id="statusDropdown">
              <select id="statusSelect" class="appearance-none bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 px-4 py-2 pr-8 rounded-md focus:outline-none focus:ring-blue-500" onchange="updateStatus(this.value)" disabled>
                <option value="draft">Draft</option>
                <option value="active">Active</option>
                <option value="paused">Paused</option>
                <option value="completed">Completed</option>
              </select>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8 mt-8">
      <!-- Product Information -->
        <div class="bg-white dark:bg-gray-800 shadow rounded-lg p-6 mb-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0">
                <img id="sampleProductImage" src="" alt="Sample Product" class="hidden w-20 h-20 object-cover rounded-lg border border-gray-200 dark:border-gray-700">
                <div id="sampleProductImagePlaceholder" class="w-20 h-20 bg-gray-200 dark:bg-gray-700 rounded-lg flex items-center justify-center">
                  <svg class="w-10 h-10 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                </div>
              </div>
              <div class="flex-1">
                <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Sample Product</h3>
                <p class="text-lg font-semibold text-gray-900 dark:text-white" id="sampleProductName">Not set</p>
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Product being sampled to customers</p>
              </div>
            </div>
            <div>
              <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Reference Product</h3>
              <p class="text-lg font-semibold text-gray-900 dark:text-white" id="referenceProductName">Not set</p>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Customers order this product regularly</p>
            </div>
          </div>
        </div>

      <!-- Statistics Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-6 gap-6 mb-8">
        <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
          <div class="p-5">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <div class="w-8 h-8 bg-blue-500 rounded-md flex items-center justify-center">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                  </svg>
                </div>
              </div>
              <div class="ml-5 w-0 flex-1">
                <dl>
                  <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Tracked Customers</dt>
                  <dd class="text-lg font-medium text-gray-900 dark:text-white" id="customerCount">0</dd>
                </dl>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
          <div class="p-5">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <div class="w-8 h-8 bg-green-500 rounded-md flex items-center justify-center">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                  </svg>
                </div>
              </div>
              <div class="ml-5 w-0 flex-1">
                <dl>
                  <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Orders</dt>
                  <dd class="text-lg font-medium text-gray-900 dark:text-white" id="orderCount">0</dd>
                </dl>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
          <div class="p-5">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <div class="w-8 h-8 bg-yellow-500 rounded-md flex items-center justify-center">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                  </svg>
                </div>
              </div>
              <div class="ml-5 w-0 flex-1">
                <dl>
                  <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Revenue</dt>
                  <dd class="text-lg font-medium text-gray-900 dark:text-white" id="totalRevenue">₹0</dd>
                </dl>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
          <div class="p-5">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <div class="w-8 h-8 bg-purple-500 rounded-md flex items-center justify-center">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                </div>
              </div>
              <div class="ml-5 w-0 flex-1">
                <dl>
                  <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Last Tracked</dt>
                  <dd class="text-lg font-medium text-gray-900 dark:text-white" id="lastTracked">Never</dd>
                </dl>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
          <div class="p-5">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <div class="w-8 h-8 bg-orange-500 rounded-md flex items-center justify-center">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10m-8 4h6m-9 6V9a2 2 0 012-2h8a2 2 0 012 2v12a2 2 0 01-2 2H7a2 2 0 01-2-2z"></path>
                  </svg>
                </div>
              </div>
              <div class="ml-5 w-0 flex-1">
                <dl>
                  <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Batches Sent</dt>
                  <dd class="text-lg font-medium text-gray-900 dark:text-white" id="batchCount">0</dd>
                </dl>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
          <div class="p-5">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <div class="w-8 h-8 bg-teal-500 rounded-md flex items-center justify-center">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                </div>
              </div>
              <div class="ml-5 w-0 flex-1">
                <dl>
                  <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Product Cost</dt>
                  <dd class="text-lg font-medium text-gray-900 dark:text-white" id="totalProductCost">₹0.00</dd>
                </dl>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Daily Orders Chart -->
      <div class="bg-white dark:bg-gray-800 shadow rounded-lg p-6 mb-8">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white">Daily Order Trend (Last 30 Days)</h3>
          <button onclick="runTracking()" id="refreshOrdersButton" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium flex items-center">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
            </svg>
            Refresh Orders
          </button>
        </div>
        <div class="h-64 relative">
          <canvas id="dailyChart"></canvas>
          <div id="noOrdersMessage" class="hidden absolute inset-0 flex items-center justify-center">
            <div class="text-center">
              <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              </svg>
              <p class="mt-4 text-sm text-gray-500 dark:text-gray-400">No orders found in the last 30 days</p>
              <p class="mt-2 text-xs text-gray-400 dark:text-gray-500">Orders will appear here once customers start placing orders for the sample product</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Tabs -->
      <div class="bg-white dark:bg-gray-800 shadow rounded-lg mb-8">
        <div class="border-b border-gray-200 dark:border-gray-700">
          <nav class="flex -mb-px">
            <button onclick="switchTab('customers')" id="tab-customers" class="tab-button active px-6 py-4 text-sm font-medium text-blue-600 border-b-2 border-blue-600 dark:text-blue-400">
              Tracked Customers
            </button>
            <button onclick="switchTab('orders')" id="tab-orders" class="tab-button px-6 py-4 text-sm font-medium text-gray-500 hover:text-gray-700 dark:text-gray-400 border-b-2 border-transparent">
              Sample Orders
            </button>
          </nav>
        </div>

        <!-- Customers Tab -->
        <div id="content-customers" class="tab-content p-6">
          <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-medium text-gray-900 dark:text-white">Tracked Customers by Sampling Date</h3>
            <div class="flex space-x-3">
              <button onclick="exportCustomersToCSV()" class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-md text-sm font-medium flex items-center">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                Export CSV
              </button>
              <a href="/marketing/sampling/<%= campaignId %>/add-customers" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium">
                Add Customers
              </a>
            </div>
          </div>
          
          <!-- Batches Container -->
          <div id="customerBatchesContainer" class="space-y-6">
            <!-- Dynamic batches will be inserted here -->
          </div>
        </div>

        <!-- Orders Tab -->
        <div id="content-orders" class="tab-content hidden p-6">
          <div class="flex items-center mb-4">
            <h3 class="text-lg font-medium text-gray-900 dark:text-white">Sample Orders by Sampling Date</h3>
          </div>
          
          <!-- Orders Batches Container -->
          <div id="orderBatchesContainer" class="space-y-6">
            <!-- Dynamic batches will be inserted here -->
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('../../../partials/_footer') %>

  <script>
    let campaignId = '<%= campaignId %>';
    let campaign = null;
    let dailyChart = null;

    // Register Chart.js datalabels plugin
    if (typeof ChartDataLabels !== 'undefined') {
      Chart.register(ChartDataLabels);
    }

    // Load initial data
    document.addEventListener("DOMContentLoaded", function() {
      loadCampaignDetails();
      initChart();
    });

    function initChart() {
      const ctx = document.getElementById('dailyChart').getContext('2d');
      dailyChart = new Chart(ctx, {
        type: 'line',
        data: {
          labels: [],
          datasets: [{
            label: 'Orders',
            data: [],
            borderColor: 'rgb(59, 130, 246)',
            backgroundColor: 'rgba(59, 130, 246, 0.1)',
            tension: 0.4,
            datalabels: {
              display: true,
              align: 'top',
              anchor: 'end',
              color: 'rgb(59, 130, 246)',
              font: {
                weight: 'bold',
                size: 12
              }
            }
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: true,
              position: 'top'
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              ticks: {
                stepSize: 1
              }
            }
          }
        }
      });
    }

    async function loadCampaignDetails() {
      try {
        const response = await fetch(`/marketing/api/sampling/campaigns/${campaignId}`);
        const result = await response.json();

        if (result.success) {
          campaign = result.data;
          updateUI();
        }
      } catch (error) {
        console.error("Error loading campaign details:", error);
      }
    }


    function updateUI() {
      document.getElementById('campaignTitle').textContent = campaign.campaign_name;
      document.getElementById('campaignDescription').textContent = campaign.description || 'No description';
      document.getElementById('statusSelect').value = campaign.status;
      document.getElementById('statusSelect').disabled = false;
      
      // Update product names
      document.getElementById('sampleProductName').textContent = campaign.product_name || 'Not set';
      document.getElementById('referenceProductName').textContent = campaign.reference_product_name || 'Not set';
      
      // Update sample product image
      const sampleProductImage = document.getElementById('sampleProductImage');
      const sampleProductImagePlaceholder = document.getElementById('sampleProductImagePlaceholder');
      if (campaign.product_image) {
        sampleProductImage.src = campaign.product_image;
        sampleProductImage.classList.remove('hidden');
        if (sampleProductImagePlaceholder) {
          sampleProductImagePlaceholder.classList.add('hidden');
        }
      } else {
        sampleProductImage.classList.add('hidden');
        if (sampleProductImagePlaceholder) {
          sampleProductImagePlaceholder.classList.remove('hidden');
        }
      }
      
      // Filter tracking orders to only include tracked customers
      const trackedCustomerIds = new Set(campaign.customers.map(c => c.customer_id));
      const trackedOrders = campaign.tracking.filter(t => trackedCustomerIds.has(t.customer_id));
      
      document.getElementById('customerCount').textContent = campaign.customers.length;
      document.getElementById('orderCount').textContent = trackedOrders.length;
      document.getElementById('totalRevenue').textContent = `₹${trackedOrders.reduce((sum, t) => sum + (parseFloat(t.order_amount) || 0), 0).toLocaleString('en-IN', {minimumFractionDigits: 2})}`;
      const uniqueBatchCount = campaign.customers.reduce((set, customer) => {
        const batchNumber = customer.batch_number;
        if (batchNumber !== null && batchNumber !== undefined) {
          set.add(`batch-${batchNumber}`);
        } else {
          const date = customer.sampling_date;
          if (date && typeof date === 'string' && date.trim() !== '') {
            set.add(date.trim());
          }
        }
        return set;
      }, new Set()).size;
      const batchCountEl = document.getElementById('batchCount');
      if (batchCountEl) {
        batchCountEl.textContent = uniqueBatchCount;
      }
      const perCustomerCost = (() => {
        const discountPrice = parseFloat(campaign.product_discount_price || 0);
        if (!isNaN(discountPrice) && discountPrice > 0) {
          return discountPrice;
        }
        const fallbackPrice = parseFloat(campaign.product_price || 0);
        return !isNaN(fallbackPrice) && fallbackPrice > 0 ? fallbackPrice : 0;
      })();
      const totalProductCostValue = perCustomerCost * (campaign.customers.length || 0);
      const totalProductCostEl = document.getElementById('totalProductCost');
      if (totalProductCostEl) {
        totalProductCostEl.textContent = perCustomerCost > 0
          ? `₹${totalProductCostValue.toLocaleString('en-IN', { minimumFractionDigits: 2 })}`
          : '₹0.00';
      }

      if (trackedOrders.length > 0) {
        const lastTracked = trackedOrders[trackedOrders.length - 1].tracked_at;
        if (lastTracked) {
          const trackedDate = new Date(lastTracked);
          document.getElementById('lastTracked').textContent = trackedDate.toLocaleDateString('en-IN', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          });
        }
      }

      renderCustomers();
      renderOrders();
      updateChart();

      // Enable track button if campaign is active
      const trackButton = document.getElementById('trackButton');
      const refreshOrdersButton = document.getElementById('refreshOrdersButton');
      if (campaign.status === 'active') {
        if (trackButton) trackButton.disabled = false;
        if (refreshOrdersButton) refreshOrdersButton.disabled = false;
      } else {
        if (trackButton) trackButton.disabled = true;
        if (refreshOrdersButton) refreshOrdersButton.disabled = true;
      }
    }

    function updateChart() {
      if (!dailyChart || !campaign.daily_summary) {
        // Show informative message if no chart or no daily_summary
        const noOrdersMessage = document.getElementById('noOrdersMessage');
        const chartCanvas = document.getElementById('dailyChart');
        if (noOrdersMessage && chartCanvas) {
          noOrdersMessage.classList.remove('hidden');
          chartCanvas.style.display = 'none';
        }
        return;
      }

      const sortedData = campaign.daily_summary.sort((a, b) => new Date(a.order_date) - new Date(b.order_date));
      const hasData = sortedData.length > 0 && sortedData.some(d => d.order_count > 0);
      
      const noOrdersMessage = document.getElementById('noOrdersMessage');
      const chartCanvas = document.getElementById('dailyChart');
      
      if (!hasData) {
        // Show informative message if no orders
        if (noOrdersMessage && chartCanvas) {
          noOrdersMessage.classList.remove('hidden');
          chartCanvas.style.display = 'none';
        }
      } else {
        // Show chart if there's data
        if (noOrdersMessage && chartCanvas) {
          noOrdersMessage.classList.add('hidden');
          chartCanvas.style.display = 'block';
        }
        // Format dates as DD-MM
        dailyChart.data.labels = sortedData.map(d => {
          const date = new Date(d.order_date);
          const day = String(date.getDate()).padStart(2, '0');
          const month = String(date.getMonth() + 1).padStart(2, '0');
          return `${day}-${month}`;
        });
        dailyChart.data.datasets[0].data = sortedData.map(d => d.order_count);
        dailyChart.update();
      }
    }

    function renderCustomers() {
      const container = document.getElementById('customerBatchesContainer');
      container.innerHTML = '';

      if (campaign.customers.length === 0) {
        container.innerHTML = '<div class="text-center py-8 text-gray-500 dark:text-gray-400">No customers tracked yet.</div>';
        return;
      }

      // Group customers by sampling_date (normalize dates to YYYY-MM-DD format)
      const customersByDate = {};
      campaign.customers.forEach(customer => {
        let date = 'No Date';
        if (customer.sampling_date) {
          // Normalize the date to YYYY-MM-DD format to avoid timezone issues
          if (customer.sampling_date instanceof Date) {
            // Use UTC methods to avoid timezone conversion issues
            const year = customer.sampling_date.getUTCFullYear();
            const month = String(customer.sampling_date.getUTCMonth() + 1).padStart(2, '0');
            const day = String(customer.sampling_date.getUTCDate()).padStart(2, '0');
            date = `${year}-${month}-${day}`;
          } else {
            // Extract YYYY-MM-DD from string (handles ISO strings and date strings)
            const dateStr = String(customer.sampling_date);
            // If it's already in YYYY-MM-DD format, use it directly
            if (/^\d{4}-\d{2}-\d{2}$/.test(dateStr)) {
              date = dateStr;
            } else {
              // Extract date part from ISO string or other formats
              date = dateStr.split('T')[0].split(' ')[0].trim();
            }
          }
        }
        if (!customersByDate[date]) {
          customersByDate[date] = [];
        }
        customersByDate[date].push(customer);
      });

      // Create a map: sampling_date -> batch_number from database (marketing_sampling_customers.batch_number)
      // All customers with the same sampling_date should have the same batch_number
      const samplingDateToBatchNumber = {};
      Object.keys(customersByDate).forEach(samplingDate => {

          confirmStep1Btn.onclick = () => {
            if (confirmStep1Callback) {
              confirmStep1Callback();
            }
          };
        }
        
        if (confirmStep2Btn) {
          confirmStep2Btn.onclick = () => {
            if (confirmStep2Callback) {
              confirmStep2Callback();
            }
          };
        }
        
        if (closeBtn) {
          closeBtn.onclick = () => {
            document.body.removeChild(modal);
            if (resolvePromise) resolvePromise({ cancelled: false, creditResult, orderResult });
          };
        }
        
        modal.onclick = (e) => {
          if (e.target === modal && currentStep >= 3) {
            document.body.removeChild(modal);
            if (resolvePromise) resolvePromise({ cancelled: false, creditResult, orderResult });
          }
        };
      };
      
      // Initial render
      updateModal();
      document.body.appendChild(modal);
      
      // Expose update functions
      modal.updateStep = (step, result) => {
        currentStep = step;
        if (step === 1) creditResult = result;
        if (step === 3) orderResult = result;
        updateModal();
      };
      
      modal.setStep = (step) => {
        currentStep = step;
        updateModal();
      };
      
      // Execute Step 1: Add Credit
      const executeStep1 = async () => {
        // Move to step 1 in progress
        modal.setStep(0);
        
        try {
          const creditResponse = await fetch(`/marketing/api/sampling/campaigns/${campaignId}/add-credit`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ 
              sampling_date: normalizedDateStr,
              test_mode: false,
              dry_run: false  // Call actual API
            })
          });

          const result = await creditResponse.json();

          if (!result.success) {
            showErrorToast('Failed to add credit: ' + (result.error || 'Unknown error'));
            // Reset to confirmation
            modal.setStep(-1);
            return;
          }

          // Update modal with Step 1 results and show Step 2 confirmation
          modal.updateStep(1, result);
          
        } catch (error) {
          console.error("Error in step 1:", error);
          showErrorToast('Failed to add credit');
          // Reset to confirmation
          modal.setStep(-1);
        }
      };
      
      // Execute Step 2: Place Orders
      const executeStep2 = async () => {
        // Move to step 2 in progress
        modal.setStep(2);
        
        try {
          const orderResponse = await fetch(`/marketing/api/sampling/campaigns/${campaignId}/place-order`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ 
              sampling_date: normalizedDateStr,
              test_mode: false,
              dry_run: false  // Call actual API
            })
          });

          const result = await orderResponse.json();

          if (!result.success) {
            showErrorToast('Failed to place orders: ' + (result.error || 'Unknown error'));
            // Keep modal open to show Step 1 results and Step 2 confirmation
            modal.setStep(1);
            return;
          }

          // Update modal with Step 2 results and show final summary
          modal.updateStep(3, result);
          
          // Show success toast
          const creditSummary = creditResult.summary;
          const orderSummary = result.summary;
          if (creditSummary.succeeded > 0 || orderSummary.succeeded > 0) {
            showSuccessToast(`Process completed! ${creditSummary.succeeded} credit${creditSummary.succeeded !== 1 ? 's' : ''} added, ${orderSummary.succeeded} order${orderSummary.succeeded !== 1 ? 's' : ''} placed.`);
            // Reload campaign details to refresh data
            setTimeout(() => {
              loadCampaignDetails();
            }, 2000);
          }
          
        } catch (error) {
          console.error("Error in step 2:", error);
          showErrorToast('Failed to place orders');
          // Keep modal open to show Step 1 results and Step 2 confirmation
          modal.setStep(1);
        }
      };
      
      // Store the callbacks so Confirm buttons can call them
      confirmStep1Callback = executeStep1;
      confirmStep2Callback = executeStep2;
      
      // Return modal and promise
      return { modal, promise };
    }

    // Results modal helper (with Continue button)
    function showResultsDialog(title, htmlContent, continueText = "Continue") {
      return new Promise((resolve) => {
        const modal = document.createElement("div");
        modal.className = "fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50 flex items-center justify-center";
        modal.innerHTML = `
          <div class="relative bg-white dark:bg-gray-800 rounded-lg shadow-xl max-w-2xl w-full mx-4">
            <div class="p-6">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">${title}</h3>
              <div class="text-sm text-gray-700 dark:text-gray-300 mb-6">${htmlContent}</div>
              <div class="flex justify-end space-x-3">
                <button id="resultsClose" class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:hover:bg-gray-600">
                  Close
                </button>
                <button id="resultsContinue" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-md">
                  ${continueText}
                </button>
              </div>
            </div>
          </div>
        `;
        
        document.body.appendChild(modal);
        
        modal.querySelector("#resultsContinue").onclick = () => {
          document.body.removeChild(modal);
          resolve(true);
        };
        
        modal.querySelector("#resultsClose").onclick = () => {
          document.body.removeChild(modal);
          resolve(false);
        };
        
        modal.onclick = (e) => {
          if (e.target === modal) {
            document.body.removeChild(modal);
            resolve(false);
          }
        };
      });
    }

    // Results modal helper (close only)
    function showResultsModal(title, htmlContent) {
      const modal = document.createElement("div");
      modal.className = "fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50 flex items-center justify-center";
      modal.innerHTML = `
        <div class="relative bg-white dark:bg-gray-800 rounded-lg shadow-xl max-w-2xl w-full mx-4">
          <div class="p-6">
            <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">${title}</h3>
            <div class="text-sm text-gray-700 dark:text-gray-300 mb-6">${htmlContent}</div>
            <div class="flex justify-end">
              <button id="resultsClose" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-md">
                Close
              </button>
            </div>
          </div>
        </div>
      `;
      
      document.body.appendChild(modal);
      
      modal.querySelector("#resultsClose").onclick = () => {
        document.body.removeChild(modal);
      };
      
      modal.onclick = (e) => {
        if (e.target === modal) {
          document.body.removeChild(modal);
        }
      };
    }
  </script>
</body>
</html>


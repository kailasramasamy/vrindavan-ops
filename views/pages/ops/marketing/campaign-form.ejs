    // Close dropdowns when clicking outside
    document.addEventListener('click', function(event) {
      if (!event.target.closest('.relative')) {
        document.getElementById('referenceProductResults').classList.add('hidden');
        document.getElementById('sampleProductResults').classList.add('hidden');
      }
    });

    // Initialize form
    document.addEventListener('DOMContentLoaded', function() {
      // Initialize product/category selection first
      initializeProductCategorySelection();
      
      // Then load campaign data for editing
      loadCampaignData();
      
      // Set up campaign type change handler
      handleCampaignTypeChange();
    });

    // Theme toggle functionality
    document.getElementById('themeToggle').addEventListener('click', function() {
      const html = document.documentElement;
      const isCurrentlyDark = html.classList.contains('dark');
      const newTheme = isCurrentlyDark ? 'light' : 'dark';

      // Apply explicitly to avoid toggle inconsistencies
      if (newTheme === 'dark') {
        html.classList.add('dark');
      } else {
        html.classList.remove('dark');
      }

      localStorage.setItem('theme', newTheme);
      
      // Reload the page to reinitialize with correct theme
      window.location.reload();
    });

    // Dark mode toggle functionality
    function initDarkMode() {
      const savedTheme = localStorage.getItem('theme') || 'dark';
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const shouldUseDark = savedTheme === 'dark' || (savedTheme === 'system' && prefersDark);
      
      if (shouldUseDark) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    }

    initDarkMode();

    // Set default start date to today
    function setDefaultStartDate() {
      const startDateInput = document.getElementById('start_date');
      if (startDateInput && !startDateInput.value) {
        const today = new Date();
        const year = today.getFullYear();
        const month = String(today.getMonth() + 1).padStart(2, '0');
        const day = String(today.getDate()).padStart(2, '0');
        const todayString = `${year}-${month}-${day}`;
        startDateInput.value = todayString;
      }
    }

    setDefaultStartDate();

    // Initialize Rich Text Editor
    function initializeRichEditor() {
      const toolbarOptions = [
        [{ 'header': [1, 2, 3, false] }],
        ['bold', 'italic', 'underline', 'strike'],
        [{ 'color': [] }, { 'background': [] }],
        [{ 'list': 'ordered'}, { 'list': 'bullet' }],
        [{ 'align': [] }],
        ['link', 'image'],
        ['clean']
      ];

      const quill = new Quill('#rich-editor', {
        theme: 'snow',
        modules: {
          toolbar: toolbarOptions
        },
        placeholder: 'Write your campaign content here...'
      });

      // Apply dark mode styling after initialization
      function applyDarkModeStyling() {
        const isDark = document.documentElement.classList.contains('dark');
        const editor = document.querySelector('.ql-editor');
        const toolbar = document.querySelector('.ql-toolbar');
        
        if (isDark) {
          if (editor) {
            editor.style.backgroundColor = '#1f2937';
            editor.style.color = '#f9fafb';
          }
          if (toolbar) {
            toolbar.style.backgroundColor = '#111827';
            toolbar.style.borderBottomColor = '#374151';
          }
        } else {
          if (editor) {
            editor.style.backgroundColor = '#ffffff';
            editor.style.color = '#111827';
          }
          if (toolbar) {
            toolbar.style.backgroundColor = '#f9fafb';
            toolbar.style.borderBottomColor = '#e5e7eb';
          }
        }
      }

      // Apply initial styling
      applyDarkModeStyling();

      // Update hidden input when content changes
      quill.on('text-change', function() {
        const content = quill.root.innerHTML;
        document.getElementById('campaign_content').value = content;
      });


      // Update dark mode on theme toggle
      const themeToggle = document.getElementById('themeToggle');
      if (themeToggle) {
        themeToggle.addEventListener('click', function() {
          setTimeout(applyDarkModeStyling, 100);
        });
      }
    }

    initializeRichEditor();
    
    // Force editor height after initialization
    setTimeout(() => {
      const editor = document.querySelector('#rich-editor .ql-editor');
      const container = document.querySelector('#rich-editor .ql-container');
      if (editor) {
        editor.style.height = '350px !important';
        editor.style.minHeight = '350px !important';
        editor.style.maxHeight = '350px !important';
        editor.style.overflow = 'auto';
      }
      if (container) {
        container.style.height = '350px !important';
        container.style.minHeight = '350px !important';
        container.style.maxHeight = '350px !important';
      }
    }, 100);

    // Product/Category Selection Functionality
    function initializeProductCategorySelection() {
    const targetTypeRadios = document.querySelectorAll('input[name="target_type"]');
    const productSelection = document.getElementById('product-selection');
    const categorySelection = document.getElementById('category-selection');
    const productSearch = document.getElementById('product-search');
    const productSearchResults = document.getElementById('product-search-results');
    const selectedProducts = document.getElementById('selected-products');
    const categorySelect = document.getElementById('category-select');
    const subcategorySelect = document.getElementById('subcategory-select');
    const selectedCategories = document.getElementById('selected-categories');
    const targetProductsInput = document.getElementById('target_products');

    let allProducts = [];
    let allCategories = [];
    let allSubcategories = [];
    window.selectedProductsList = [];
    window.selectedCategoriesList = [];

    // Load initial data
    loadProducts();
    loadCategories();

    // Handle target type change
    targetTypeRadios.forEach(radio => {
      radio.addEventListener('change', (e) => {
        if (e.target.value === 'product') {
          productSelection.classList.remove('hidden');
          categorySelection.classList.add('hidden');
        } else {
          productSelection.classList.add('hidden');
          categorySelection.classList.remove('hidden');
        }
        updateTargetProductsInput();
      });
    });

    // Product search functionality
    productSearch.addEventListener('input', (e) => {
      const query = e.target.value.trim();
      if (query.length >= 2) {
        searchProducts(query);
      } else {
        productSearchResults.classList.add('hidden');
      }
    });

    // Hide search results when clicking outside
    document.addEventListener('click', (e) => {
      if (!productSearch.contains(e.target) && !productSearchResults.contains(e.target)) {
        productSearchResults.classList.add('hidden');
      }
    });

    // Category selection change
    categorySelect.addEventListener('change', (e) => {
      const categoryId = e.target.value;
      if (categoryId) {
        loadSubcategories(categoryId);
        subcategorySelect.disabled = false;
        
        // Add category to selection
        if (!window.selectedCategoriesList.find(cat => cat.id === categoryId)) {
          const category = allCategories.find(cat => cat.id == categoryId);
          if (category) {
            // Add parent_category_id as null to indicate this is a main category
            window.selectedCategoriesList.push({
              ...category,
              parent_category_id: null
            });
            renderSelectedCategories();
            updateTargetProductsInput();
          }
        }
      } else {
        subcategorySelect.innerHTML = '<option value="">Choose a subcategory...</option>';
        subcategorySelect.disabled = true;
      }
    });

    // Add subcategory to selection
    subcategorySelect.addEventListener('change', (e) => {
      const subcategoryId = e.target.value;
      if (subcategoryId && !window.selectedCategoriesList.find(cat => cat.id === subcategoryId)) {
        const subcategory = allSubcategories.find(sub => sub.id == subcategoryId);
        if (subcategory) {
          // Add parent_category_id to indicate this is a subcategory
          window.selectedCategoriesList.push({
            ...subcategory,
            parent_category_id: subcategory.category_id
          });
          renderSelectedCategories();
          updateTargetProductsInput();
        }
      }
    });

    // Load products
    async function loadProducts() {
      try {
        const response = await fetch('/marketing/api/product-data/products');
        const result = await response.json();
        if (result.success) {
          allProducts = result.data;
        }
      } catch (error) {
        console.error('Error loading products:', error);
      }
    }

    // Search products
    async function searchProducts(query) {
      try {
        const response = await fetch(`/marketing/api/product-data/products/search?q=${encodeURIComponent(query)}`);
        const result = await response.json();
        if (result.success) {
          renderProductSearchResults(result.data);
        }
      } catch (error) {
        console.error('Error searching products:', error);
      }
    }

    // Render product search results with multi-select checkboxes
    function renderProductSearchResults(products) {
      if (products.length === 0) {
        productSearchResults.innerHTML = '<div class="p-3 text-gray-500 dark:text-gray-400">No products found</div>';
      } else {
        productSearchResults.innerHTML = products.map(product => {
          const isSelected = window.selectedProductsList.find(p => p.id === product.id);
          return `<div class="p-3 hover:bg-gray-100 dark:hover:bg-gray-600 border-b border-gray-200 dark:border-gray-600 last:border-b-0">
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" 
                     value="${product.id}" 
                     data-name="${product.name.replace(/'/g, "\\'")}"
                     class="rounded border-gray-300 dark:border-gray-600 dark:bg-gray-700 text-blue-600 shadow-sm focus:border-blue-300 focus:ring focus:ring-blue-200 focus:ring-opacity-50 mr-3"
                     ${isSelected ? 'checked' : ''}
                     onchange="toggleProduct(${product.id}, '${product.name.replace(/'/g, "\\'")}')">
              <div class="flex-1">
                <div class="font-medium text-gray-900 dark:text-white">${product.name}</div>
                <div class="text-sm text-gray-500 dark:text-gray-400">
                  ₹${product.price}${product.unit ? ' - ' + product.unit : ''}
                </div>
              </div>
            </label>
          </div>`;
        }).join('');
      }
      productSearchResults.classList.remove('hidden');
    }

    // Load categories
    async function loadCategories() {
      try {
        const response = await fetch('/marketing/api/product-data/categories');
        const result = await response.json();
        if (result.success) {
          allCategories = result.data; // All categories (no parent_id column in current schema)
          renderCategorySelect();
        }
      } catch (error) {
        console.error('Error loading categories:', error);
      }
    }


    // Load subcategories
    async function loadSubcategories(categoryId) {
      try {
        const response = await fetch(`/marketing/api/product-data/categories/${categoryId}/subcategories`);
        const result = await response.json();
        if (result.success) {
          allSubcategories = result.data;
          renderSubcategorySelect();
        }
      } catch (error) {
        console.error('Error loading subcategories:', error);
      }
    }

    // Render category select
    function renderCategorySelect() {
      categorySelect.innerHTML = '<option value="">Choose a category...</option>' +
        allCategories.map(category => 
          `<option value="${category.id}">${category.name}</option>`
        ).join('');
    }

    // Render subcategory select
    function renderSubcategorySelect() {
      if (allSubcategories.length === 0) {
        subcategorySelect.innerHTML = '<option value="">No subcategories available</option>';
      } else {
        subcategorySelect.innerHTML = '<option value="">Choose a subcategory...</option>' +
          allSubcategories.map(subcategory => 
            `<option value="${subcategory.id}">${subcategory.name}</option>`
          ).join('');
      }
    }


    // Toggle product selection
    window.toggleProduct = function(productId, productName) {
      const existingIndex = window.selectedProductsList.findIndex(p => p.id === productId);
      
      if (existingIndex > -1) {
        // Remove product
        window.selectedProductsList.splice(existingIndex, 1);
      } else {
        // Add product
        window.selectedProductsList.push({ id: productId, name: productName });
      }
      
      renderSelectedProducts();
      updateTargetProductsInput();
    };

    // Remove product from selection
    window.removeProduct = function(productId) {
      window.selectedProductsList = window.selectedProductsList.filter(p => p.id !== productId);
      
      // Update the checkbox in search results if visible
      const checkbox = productSearchResults.querySelector(`input[value="${productId}"]`);
      if (checkbox) {
        checkbox.checked = false;
      }
      
      renderSelectedProducts();
      updateTargetProductsInput();
    };

    // Add category to selection
    window.addCategory = function(categoryId, categoryName) {
      if (!window.selectedCategoriesList.find(c => c.id === categoryId)) {
        window.selectedCategoriesList.push({ 
          id: categoryId, 
          name: categoryName,
          parent_category_id: null
        });
        renderSelectedCategories();
        updateTargetProductsInput();
      }
    };

    // Remove category from selection
    window.removeCategory = function(categoryId) {
      window.selectedCategoriesList = window.selectedCategoriesList.filter(c => c.id !== categoryId);
      renderSelectedCategories();
      updateTargetProductsInput();
    };

    // Render selected products
    function renderSelectedProducts() {
      selectedProducts.innerHTML = window.selectedProductsList.map(product => 
        `<span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
          ${product.name}
          <button type="button" onclick="removeProduct(${product.id})" class="ml-2 text-blue-600 hover:text-blue-800 dark:text-blue-200 dark:hover:text-blue-100">
            ×
          </button>
        </span>`
      ).join('');
    }

    // Render selected categories
    function renderSelectedCategories() {
      selectedCategories.innerHTML = window.selectedCategoriesList.map(category => 
        `<span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
          ${category.name}
          <button type="button" onclick="removeCategory(${category.id})" class="ml-2 text-green-600 hover:text-green-800 dark:text-green-200 dark:hover:text-green-100">
            ×
          </button>
        </span>`
      ).join('');
    }

    // Update hidden input with selected values
    function updateTargetProductsInput() {
      const targetType = document.querySelector('input[name="target_type"]:checked').value;
      let selectedItems = [];
      
      if (targetType === 'product') {
        selectedItems = window.selectedProductsList.map(p => ({ type: 'product', id: p.id, name: p.name }));
      } else {
        // Smart logic: if both category and its subcategory are selected, only store subcategory
        const categoriesToStore = [];
        const subcategoriesToStore = [];
        
        // Separate categories and subcategories
        for (const item of window.selectedCategoriesList) {
          // Check if this is a subcategory by looking at the database
          // For now, we'll use a simple heuristic: if it has a parent_category_id, it's a subcategory
          if (item.parent_category_id) {
            subcategoriesToStore.push(item);
          } else {
            categoriesToStore.push(item);
          }
        }
        
        // Check for conflicts and apply smart logic
        const finalCategories = [];
        const finalSubcategories = [...subcategoriesToStore];
        
        for (const category of categoriesToStore) {
          // Check if any subcategory belongs to this category
          const hasSubcategoryFromThisCategory = subcategoriesToStore.some(sub => {
            return sub.parent_category_id === category.id;
          });
          
          if (!hasSubcategoryFromThisCategory) {
            // Only store category if no subcategory from this category is selected
            finalCategories.push(category);
          }
        }
        
        // Combine final results
        selectedItems = [
          ...finalCategories.map(c => ({ type: 'category', id: c.id, name: c.name })),
          ...finalSubcategories.map(s => ({ type: 'sub-category', id: s.id, name: s.name }))
        ];
      }
      
      targetProductsInput.value = JSON.stringify(selectedItems);
    }

    // Initialize product/category selection
    }
    // end initializeProductCategorySelection
  </script>

  <%- include('../../../partials/_footer') %>
  
  <!-- Toast Notification System -->
  <%- include('../../../partials/_toast') %>
</body>
</html>

<%- include('../../../partials/_head', { title: title, seo: seo }) %>
<link rel="stylesheet" href="/assets/css/marketing-dark-mode.css">

<body class="bg-gray-50 dark:bg-gray-900">
  <%- include('../../../partials/_subnav', { currentPage: currentPage, section: 'Marketing', subsection: 'Ad Content' }) %>

  <div class="min-h-screen">
    <!-- Header -->
    <div class="bg-white dark:bg-gray-800 shadow">
      <div class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center">
          <div>
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Ad Content Management</h1>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">Manage ad creatives and content library</p>
          </div>
          <div class="flex space-x-3 items-center">
            <a href="/marketing/assets" class="bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-md text-sm font-medium">
              Asset Library
            </a>
            <a href="/marketing/ads/new" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium">
              Create Ad
            </a>
            <a href="/marketing/dashboard" class="bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-md text-sm font-medium">
              Dashboard
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Filters -->
    <div class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8">
      <div class="bg-white dark:bg-gray-800 shadow rounded-lg p-6 mb-6">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div>
            <label for="statusFilter" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Status</label>
            <select id="statusFilter" class="mt-1 block w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500">
              <option value="">All Status</option>
              <option value="draft">Draft</option>
              <option value="in_review">In Review</option>
              <option value="approved">Approved</option>
              <option value="published">Published</option>
              <option value="archived">Archived</option>
            </select>
          </div>
          <div>
            <label for="campaignFilter" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Campaign</label>
            <select id="campaignFilter" class="mt-1 block w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500">
              <option value="">All Campaigns</option>
            </select>
          </div>
          <div>
            <label for="platformFilter" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Platform</label>
            <select id="platformFilter" class="mt-1 block w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500">
              <option value="">All Platforms</option>
            </select>
          </div>
          <div>
            <label for="searchFilter" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Search</label>
            <input type="text" id="searchFilter" placeholder="Search ads..." class="mt-1 block w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500">
          </div>
        </div>
      </div>

      <!-- Ads Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        <div id="adsContainer">
          <!-- Ads will be loaded here -->
        </div>
      </div>

      <!-- Loading State -->
      <div id="loadingState" class="text-center py-12">
        <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
        <p class="mt-2 text-gray-500 dark:text-gray-400">Loading ads...</p>
      </div>

      <!-- Empty State -->
      <div id="emptyState" class="hidden text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
        </svg>
        <p class="mt-2 text-gray-500 dark:text-gray-400">No ads found</p>
      </div>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div id="deleteModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full hidden z-50">
    <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white dark:bg-gray-800 dark:border-gray-700">
      <div class="mt-3 text-center">
        <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-red-100 dark:bg-red-900">
          <svg class="h-6 w-6 text-red-600 dark:text-red-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-medium text-gray-900 dark:text-white mt-2">Delete Ad</h3>
        <div class="mt-2 px-7 py-3">
          <p class="text-sm text-gray-500 dark:text-gray-400">Are you sure you want to delete this ad? This action cannot be undone.</p>
        </div>
        <div class="items-center px-4 py-3">
          <button id="confirmDelete" class="px-4 py-2 bg-red-600 text-white text-base font-medium rounded-md w-24 mr-2 hover:bg-red-700">
            Delete
          </button>
          <button id="cancelDelete" class="px-4 py-2 bg-gray-600 text-white text-base font-medium rounded-md w-24 hover:bg-gray-700">
            Cancel
          </button>
        </div>
      </div>
    </div>
  </div>

  <script>
    const API_BASE = '/marketing/api/ad-content';
    let currentFilters = {};
    let adToDelete = null;

    // Load campaigns and platforms for filters
    async function loadFilterOptions() {
      try {
        // Load campaigns
        const campaignsRes = await fetch('/marketing/api/campaigns');
        const campaignsData = await campaignsRes.json();
        if (campaignsData.success && campaignsData.data) {
          const campaignSelect = document.getElementById('campaignFilter');
          campaignsData.data.forEach(campaign => {
            const option = document.createElement('option');
            option.value = campaign.id;
            option.textContent = campaign.name;
            campaignSelect.appendChild(option);
          });
        }

        // Load platforms
        const platformsRes = await fetch(`${API_BASE}/platforms`);
        const platformsData = await platformsRes.json();
        if (platformsData.success && platformsData.data) {
          const platformSelect = document.getElementById('platformFilter');
          platformsData.data.forEach(platform => {
            const option = document.createElement('option');
            option.value = platform.id;
            option.textContent = platform.name;
            platformSelect.appendChild(option);
          });
        }
      } catch (error) {
        console.error('Error loading filter options:', error);
      }
    }

    // Format date
    function formatDate(dateString) {
      if (!dateString) return '-';
      const date = new Date(dateString);
      return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
    }

    // Get status badge class
    function getStatusBadgeClass(status) {
      const classes = {
        'approved': 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200',
        'in_review': 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200',
        'published': 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200',
        'archived': 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300',
        'draft': 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300'
      };
      return classes[status] || classes['draft'];
    }

    // Get approval badge class
    function getApprovalBadgeClass(approvalStatus) {
      const classes = {
        'approved': 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200',
        'rejected': 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200',
        'pending': 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200'
      };
      return classes[approvalStatus] || classes['pending'];
    }

    // Load ads with assets
    async function loadAds() {
      const loadingState = document.getElementById('loadingState');
      const adsContainer = document.getElementById('adsContainer');
      const emptyState = document.getElementById('emptyState');

      loadingState.classList.remove('hidden');
      adsContainer.innerHTML = '';
      emptyState.classList.add('hidden');

      try {
        const params = new URLSearchParams(currentFilters);
        const response = await fetch(`${API_BASE}/ads?${params}`);
        const data = await response.json();

        if (data.success && data.data && data.data.length > 0) {
          // Load assets for each ad
          const adsWithAssets = await Promise.all(data.data.map(async (ad) => {
            try {
              const adDetailResponse = await fetch(`${API_BASE}/ads/${ad.id}`);
              const adDetailData = await adDetailResponse.json();
              if (adDetailData.success && adDetailData.data) {
                return { ...ad, assets: adDetailData.data.assets || [] };
              }
            } catch (err) {
              console.error(`Error loading assets for ad ${ad.id}:`, err);
            }
            return { ...ad, assets: [] };
          }));

          adsContainer.innerHTML = adsWithAssets.map(ad => {
            const primaryAsset = ad.assets && ad.assets.length > 0 
              ? ad.assets.find(a => a.is_primary) || ad.assets[0]
              : null;
            
            return `
              <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow relative group">
                <!-- Asset Preview -->
                <div class="relative h-48 bg-gray-100 dark:bg-gray-700 overflow-hidden">
                  ${primaryAsset ? (
                    primaryAsset.file_type === 'image' ? `
                      <img src="${primaryAsset.file_path}" alt="${primaryAsset.original_filename}" class="w-full h-full object-cover">
                    ` : `
                      <div class="w-full h-full flex items-center justify-center bg-gray-200 dark:bg-gray-700">
                        <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                        </svg>
                      </div>
                    `
                  ) : (
                    `<div class="w-full h-full flex items-center justify-center">
                      <svg class="w-16 h-16 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                      </svg>
                    </div>`
                  )}
                  
                  <!-- Overlay Actions -->
                  <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-40 transition-all duration-200 flex items-center justify-center gap-3 opacity-0 group-hover:opacity-100">
                    <a href="/marketing/ads/${ad.id}" class="bg-white dark:bg-gray-800 text-gray-900 dark:text-white rounded-full p-3 shadow-lg hover:bg-blue-50 dark:hover:bg-blue-900 transition-colors" title="View">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                      </svg>
                    </a>
                    <button onclick="showDeleteModal(${ad.id}, ${JSON.stringify(ad.name || 'Untitled Ad')})" class="bg-white dark:bg-gray-800 text-red-600 dark:text-red-400 rounded-full p-3 shadow-lg hover:bg-red-50 dark:hover:bg-red-900 transition-colors" title="Delete">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                      </svg>
                    </button>
                  </div>
                  
                  <!-- Status Badge -->
                  <div class="absolute top-2 right-2">
                    <span class="px-2 py-1 text-xs font-semibold rounded-full ${getStatusBadgeClass(ad.status)}">
                      ${ad.status || 'draft'}
                    </span>
                  </div>
                </div>
                
                <!-- Card Content -->
                <div class="p-4">
                  <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1 truncate" title="${ad.name || 'Untitled Ad'}">
                    ${ad.name || 'Untitled Ad'}
                  </h3>
                  ${ad.description ? `
                    <p class="text-sm text-gray-600 dark:text-gray-400 mb-2 line-clamp-2">
                      ${ad.description}
                    </p>
                  ` : ''}
                  
                  <div class="flex items-center justify-between mt-3 pt-3 border-t border-gray-200 dark:border-gray-700">
                    <div class="flex items-center space-x-3 text-xs text-gray-500 dark:text-gray-400">
                      ${ad.campaign_name ? `
                        <span class="flex items-center">
                          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"></path>
                          </svg>
                          ${ad.campaign_name}
                        </span>
                      ` : ''}
                      <span class="flex items-center">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                        ${ad.asset_count || 0} assets
                      </span>
                    </div>
                    <span class="px-2 py-1 text-xs font-semibold rounded-full ${getApprovalBadgeClass(ad.approval_status)}">
                      ${ad.approval_status || 'pending'}
                    </span>
                  </div>
                </div>
              </div>
            `;
          }).join('');
        } else {
          emptyState.classList.remove('hidden');
        }
      } catch (error) {
        console.error('Error loading ads:', error);
        emptyState.classList.remove('hidden');
      } finally {
        loadingState.classList.add('hidden');
      }
    }

    // Show delete modal (global function for onclick)
    window.showDeleteModal = function(adId, adName) {
      adToDelete = adId;
      const modal = document.getElementById('deleteModal');
      modal.classList.remove('hidden');
    };

    // Hide delete modal
    function hideDeleteModal() {
      const modal = document.getElementById('deleteModal');
      modal.classList.add('hidden');
      adToDelete = null;
    }

    // Delete ad
    async function deleteAd() {
      if (!adToDelete) return;

      try {
        const response = await fetch(`${API_BASE}/ads/${adToDelete}`, {
          method: 'DELETE'
        });
        const data = await response.json();

        if (data.success) {
          hideDeleteModal();
          loadAds();
        } else {
          alert('Error deleting ad: ' + (data.error || 'Unknown error'));
        }
      } catch (error) {
        console.error('Error deleting ad:', error);
        alert('Failed to delete ad');
      }
    }

    // Function to apply filters
    function applyFilters() {
      currentFilters = {
        status: document.getElementById('statusFilter').value,
        campaign_id: document.getElementById('campaignFilter').value,
        platform_id: document.getElementById('platformFilter').value,
        search: document.getElementById('searchFilter').value,
      };
      // Remove empty filters
      Object.keys(currentFilters).forEach(key => {
        if (currentFilters[key] === '' || currentFilters[key] === null) {
          delete currentFilters[key];
        }
      });
      loadAds();
    }

    // Function to clear filters
    function clearFilters() {
      document.getElementById('statusFilter').value = '';
      document.getElementById('campaignFilter').value = '';
      document.getElementById('platformFilter').value = '';
      document.getElementById('searchFilter').value = '';
      currentFilters = {};
      loadAds();
    }

    // Auto-apply filters on dropdown change
    document.getElementById('statusFilter').addEventListener('change', applyFilters);
    document.getElementById('campaignFilter').addEventListener('change', applyFilters);
    document.getElementById('platformFilter').addEventListener('change', applyFilters);
    
    // Auto-apply search filter with debounce (wait for user to stop typing)
    let searchTimeout;
    document.getElementById('searchFilter').addEventListener('input', () => {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        applyFilters();
      }, 500); // Wait 500ms after user stops typing
    });

    // Clear filters on Escape key in search field
    document.getElementById('searchFilter').addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.getElementById('searchFilter').value = '';
        applyFilters();
      }
    });

    // Delete modal handlers
    document.getElementById('confirmDelete').addEventListener('click', deleteAd);
    document.getElementById('cancelDelete').addEventListener('click', hideDeleteModal);

    // Close modal on background click
    document.getElementById('deleteModal').addEventListener('click', (e) => {
      if (e.target.id === 'deleteModal') {
        hideDeleteModal();
      }
    });

    // Initialize
    loadFilterOptions();
    loadAds();
  </script>
</body>
</html>

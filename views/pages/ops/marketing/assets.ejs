<%- include('../../../partials/_head', { title: title, seo: seo }) %>
<link rel="stylesheet" href="/assets/css/marketing-dark-mode.css">

<body class="bg-gray-50 dark:bg-gray-900">
  <%- include('../../../partials/_subnav', { currentPage: currentPage, section: 'Marketing', subsection: 'Asset Library' }) %>
  <%- include('../../../partials/_toast') %>

  <div class="min-h-screen">
    <!-- Header -->
    <div class="bg-white dark:bg-gray-800 shadow">
      <div class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center">
          <div>
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Asset Library</h1>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">Browse and manage ad assets (images and videos)</p>
          </div>
          <div class="flex space-x-3 items-center">
            <button id="uploadBtn" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium">
              Upload Assets
            </button>
            <a href="/marketing/ads" class="bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-md text-sm font-medium">
              Back to Ads
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Upload Modal -->
    <div id="uploadModal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50">
      <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white dark:bg-gray-800">
        <div class="mt-3">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Upload Assets</h3>
          <form id="uploadForm" enctype="multipart/form-data">
            <input type="file" id="fileInput" multiple accept="image/*,video/*" class="mb-4">
            <div class="flex justify-end space-x-2">
              <button type="button" id="cancelUpload" class="bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-md text-sm">
                Cancel
              </button>
              <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm">
                Upload
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div id="deleteModal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50">
      <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white dark:bg-gray-800">
        <div class="mt-3">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Delete Asset</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4" id="deleteModalMessage">
            Are you sure you want to delete this asset? This action cannot be undone.
          </p>
          <div class="flex justify-end space-x-2">
            <button type="button" id="cancelDelete" class="bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-md text-sm">
              Cancel
            </button>
            <button type="button" id="confirmDelete" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-md text-sm">
              Delete
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Filters -->
    <div class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8">
      <div class="bg-white dark:bg-gray-800 shadow rounded-lg p-6 mb-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <label for="typeFilter" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Type</label>
            <select id="typeFilter" class="mt-1 block w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-md shadow-sm">
              <option value="">All Types</option>
              <option value="image">Images</option>
              <option value="video">Videos</option>
            </select>
          </div>
          <div>
            <label for="searchFilter" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Search</label>
            <input type="text" id="searchFilter" placeholder="Search assets..." class="mt-1 block w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-md shadow-sm">
          </div>
        </div>
      </div>

      <!-- Assets Grid -->
      <div id="assetsContainer" class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
        <!-- Assets will be loaded here -->
      </div>

      <!-- Loading State -->
      <div id="loadingState" class="text-center py-12">
        <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
        <p class="mt-2 text-gray-500 dark:text-gray-400">Loading assets...</p>
      </div>
    </div>
  </div>

  <script>
    const API_BASE = '/marketing/api/ad-content';
    let currentFilters = {};

    async function loadAssets() {
      const loadingState = document.getElementById('loadingState');
      const assetsContainer = document.getElementById('assetsContainer');

      loadingState.classList.remove('hidden');
      assetsContainer.innerHTML = '';

      try {
        const params = new URLSearchParams(currentFilters);
        const response = await fetch(`${API_BASE}/assets?${params}`);
        const data = await response.json();

        if (data.success && data.data && data.data.length > 0) {
          assetsContainer.innerHTML = data.data.map(asset => {
            const usageWarning = asset.usage_count > 0 ? `This asset is used in ${asset.usage_count} ad(s). Deleting it will remove it from those ads.` : '';
            return `
            <div class="bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden group relative">
              <div class="relative">
                ${asset.file_type === 'image' ? `
                  <img src="${asset.file_path}" alt="${asset.original_filename}" class="w-full h-32 object-cover">
                ` : `
                  <div class="w-full h-32 bg-gray-200 dark:bg-gray-700 flex items-center justify-center">
                    <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                    </svg>
                  </div>
                `}
                <!-- Delete button overlay -->
                <button 
                  onclick="confirmDeleteAsset(${asset.id}, '${asset.original_filename.replace(/'/g, "\\'")}', ${asset.usage_count || 0})"
                  class="absolute top-2 right-2 bg-red-600 hover:bg-red-700 text-white rounded-full p-2 opacity-0 group-hover:opacity-100 transition-opacity shadow-lg"
                  title="Delete asset">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                  </svg>
                </button>
              </div>
              <div class="p-2">
                <p class="text-xs text-gray-600 dark:text-gray-400 truncate" title="${asset.original_filename}">${asset.original_filename}</p>
                ${asset.file_type === 'image' && asset.width && asset.height ? `
                  <p class="text-xs text-gray-500 dark:text-gray-500 mt-1">${asset.width}×${asset.height}</p>
                ` : ''}
                <p class="text-xs text-gray-500 dark:text-gray-500 mt-1">${asset.usage_count || 0} ads</p>
              </div>
            </div>
          `;
          }).join('');
        } else {
          assetsContainer.innerHTML = `
            <div class="col-span-full text-center py-12">
              <p class="text-gray-500 dark:text-gray-400">No assets found</p>
            </div>
          `;
        }
      } catch (error) {
        console.error('Error loading assets:', error);
      } finally {
        loadingState.classList.add('hidden');
      }
    }

    // Upload functionality
    document.getElementById('uploadBtn').addEventListener('click', () => {
      document.getElementById('uploadModal').classList.remove('hidden');
    });

    document.getElementById('cancelUpload').addEventListener('click', () => {
      document.getElementById('uploadModal').classList.add('hidden');
    });

    document.getElementById('uploadForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData();
      const files = document.getElementById('fileInput').files;
      
      for (let i = 0; i < files.length; i++) {
        formData.append('files', files[i]);
      }

      try {
        const response = await fetch(`${API_BASE}/assets/upload`, {
          method: 'POST',
          headers: {
            'Accept': 'application/json'
          },
          body: formData
        });
        
        const contentType = response.headers.get('content-type');
        if (!contentType || !contentType.includes('application/json')) {
          const text = await response.text();
          console.error('Non-JSON response:', text);
          throw new Error(`Server error: ${response.status} ${response.statusText}`);
        }
        
        const data = await response.json();
        
        if (data.success) {
          document.getElementById('uploadModal').classList.add('hidden');
          document.getElementById('fileInput').value = '';
          if (window.toastManager) {
            window.toastManager.success(`Successfully uploaded ${files.length} asset(s)`);
          }
          loadAssets();
        } else {
          const errorMsg = data.error || 'Unknown error';
          if (window.toastManager) {
            window.toastManager.error('Upload failed: ' + errorMsg);
          } else {
            alert('Upload failed: ' + errorMsg);
          }
        }
      } catch (error) {
        console.error('Upload error:', error);
        const errorMsg = error.message || 'Upload failed. Please try again.';
        if (window.toastManager) {
          window.toastManager.error(errorMsg);
        } else {
          alert(errorMsg);
        }
      }
    });

    // Filters
    document.getElementById('typeFilter').addEventListener('change', () => {
      currentFilters = {
        file_type: document.getElementById('typeFilter').value,
        search: document.getElementById('searchFilter').value,
      };
      loadAssets();
    });

    document.getElementById('searchFilter').addEventListener('input', () => {
      currentFilters = {
        file_type: document.getElementById('typeFilter').value,
        search: document.getElementById('searchFilter').value,
      };
      loadAssets();
    });

    // Helper function to escape HTML
    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    // Delete asset functionality
    let assetToDelete = null;

    window.confirmDeleteAsset = function(assetId, assetName, usageCount) {
      assetToDelete = { id: assetId, name: assetName, usageCount };
      const modal = document.getElementById('deleteModal');
      const message = document.getElementById('deleteModalMessage');
      
      if (usageCount > 0) {
        message.innerHTML = `Are you sure you want to delete <strong>${escapeHtml(assetName)}</strong>?<br><br>This asset is used in <strong>${usageCount}</strong> ad(s). Deleting it will remove it from those ads. This action cannot be undone.`;
      } else {
        message.innerHTML = `Are you sure you want to delete <strong>${escapeHtml(assetName)}</strong>?<br><br>This action cannot be undone.`;
      }
      
      modal.classList.remove('hidden');
    };

    document.getElementById('cancelDelete').addEventListener('click', () => {
      document.getElementById('deleteModal').classList.add('hidden');
      assetToDelete = null;
    });

    document.getElementById('confirmDelete').addEventListener('click', async () => {
      if (!assetToDelete) return;

      const deleteBtn = document.getElementById('confirmDelete');
      const originalText = deleteBtn.textContent;
      deleteBtn.disabled = true;
      deleteBtn.textContent = 'Deleting...';

      try {
        const response = await fetch(`${API_BASE}/assets/${assetToDelete.id}`, {
          method: 'DELETE',
          headers: {
            'Accept': 'application/json'
          }
        });

        const contentType = response.headers.get('content-type');
        if (!contentType || !contentType.includes('application/json')) {
          const text = await response.text();
          console.error('Non-JSON response:', text);
          throw new Error(`Server error: ${response.status} ${response.statusText}`);
        }

        const data = await response.json();

        if (data.success) {
          document.getElementById('deleteModal').classList.add('hidden');
          if (window.toastManager) {
            window.toastManager.success(`Asset "${assetToDelete.name}" deleted successfully`);
          } else {
            alert('Asset deleted successfully');
          }
          assetToDelete = null;
          loadAssets();
        } else {
          const errorMsg = data.error || 'Failed to delete asset';
          if (window.toastManager) {
            window.toastManager.error(errorMsg);
          } else {
            alert(errorMsg);
          }
        }
      } catch (error) {
        console.error('Delete error:', error);
        const errorMsg = error.message || 'Failed to delete asset. Please try again.';
        if (window.toastManager) {
          window.toastManager.error(errorMsg);
        } else {
          alert(errorMsg);
        }
      } finally {
        deleteBtn.disabled = false;
        deleteBtn.textContent = originalText;
      }
    });

    loadAssets();
  </script>
</body>
</html>


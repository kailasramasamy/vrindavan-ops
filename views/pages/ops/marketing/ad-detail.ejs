<%- include('../../../partials/_head', { title: title, seo: seo }) %>
<link rel="stylesheet" href="/assets/css/marketing-dark-mode.css">

<body class="bg-gray-50 dark:bg-gray-900">
  <%- include('../../../partials/_subnav', { currentPage: currentPage, section: 'Marketing', subsection: 'Ad Details' }) %>

  <div class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="bg-gradient-to-r from-blue-600 to-purple-600 dark:from-blue-700 dark:to-purple-700 rounded-xl p-6 text-white shadow-lg">
        <div class="flex items-center justify-between">
          <div class="flex-1">
            <h1 id="adTitle" class="text-3xl font-bold mb-2">Ad Details</h1>
            <p class="text-blue-100 dark:text-blue-200">View and manage ad creative details</p>
            <div class="mt-4 flex items-center space-x-4">
              <span id="adStatusBadge" class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-white bg-opacity-20 text-white"></span>
            </div>
          </div>
          <div class="flex items-center space-x-4">
            <a href="/marketing/ads" class="inline-flex items-center px-4 py-2 border border-white border-opacity-30 rounded-lg text-sm font-medium text-white bg-white bg-opacity-10 hover:bg-opacity-20">
              ← Back to Ads
            </a>
            <button id="editAd" class="inline-flex items-center px-4 py-2 border border-transparent rounded-lg text-sm font-medium text-blue-600 bg-white hover:bg-gray-50">
              Edit Ad
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Loading State -->
    <div id="loadingState" class="text-center py-12">
      <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
      <p class="mt-2 text-gray-500 dark:text-gray-400">Loading ad details...</p>
    </div>

    <!-- Error State -->
    <div id="errorState" class="hidden text-center py-12">
      <p class="text-red-500">Failed to load ad details</p>
    </div>

    <!-- Ad Details -->
    <div id="adDetails" class="hidden">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
          <!-- Assets Section -->
          <div class="bg-white dark:bg-gray-800 shadow rounded-lg p-6">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Assets</h2>
              <button id="addAssetsBtn" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium">
                Add Assets
              </button>
            </div>
            <div id="assetsContainer" class="grid grid-cols-2 gap-4 mb-4">
              <!-- Assets will be loaded here -->
            </div>
            <div id="noAssetsMessage" class="text-center py-8 text-gray-500 dark:text-gray-400 hidden">
              <p>No assets assigned. Click "Add Assets" to assign assets to this ad.</p>
            </div>
          </div>

          <!-- Texts Section -->
          <div class="bg-white dark:bg-gray-800 shadow rounded-lg p-6">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Text Versions</h2>
              <button id="addTextBtn" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium">
                Add Text Version
              </button>
            </div>
            <div id="textsContainer" class="space-y-4 mb-4">
              <!-- Texts will be loaded here -->
            </div>
            <div id="noTextsMessage" class="text-center py-8 text-gray-500 dark:text-gray-400 hidden">
              <p>No text versions added. Click "Add Text Version" to add platform-specific text.</p>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <!-- Overview -->
          <div class="bg-white dark:bg-gray-800 shadow rounded-lg p-6">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Overview</h2>
            <div id="overviewContent" class="space-y-4">
              <!-- Overview content -->
            </div>
          </div>

          <!-- Approval Section -->
          <div id="approvalSection" class="bg-white dark:bg-gray-800 shadow rounded-lg p-6">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Approval</h2>
            <div id="approvalContent" class="space-y-4">
              <!-- Approval content -->
            </div>
          </div>

          <!-- Publishing Section -->
          <div class="bg-white dark:bg-gray-800 shadow rounded-lg p-6">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Publishing</h2>
            <button id="publishBtn" class="w-full bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium mb-4">
              Record Publication
            </button>
            <div id="publishingsContainer" class="space-y-2">
              <!-- Publishing records -->
            </div>
            <div id="noPublishingsMessage" class="text-center py-4 text-gray-500 dark:text-gray-400 text-sm hidden">
              No publishing records yet
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Add Assets Modal -->
  <div id="addAssetsModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full hidden z-50">
    <div class="relative top-20 mx-auto p-5 border w-full max-w-4xl shadow-lg rounded-md bg-white dark:bg-gray-800 dark:border-gray-700">
      <div class="mt-3">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Add Assets to Ad</h3>
        
        <!-- Upload New Assets -->
        <div class="mb-6">
          <h4 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Upload New Assets</h4>
          <form id="uploadAssetsForm" enctype="multipart/form-data" class="mb-4">
            <input type="file" id="assetFiles" multiple accept="image/*,video/*" class="mb-2 w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-md">
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium">
              Upload
            </button>
          </form>
        </div>

        <!-- Select Existing Assets -->
        <div>
          <h4 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Select Existing Assets</h4>
          <div id="availableAssetsContainer" class="grid grid-cols-4 gap-4 max-h-96 overflow-y-auto mb-4">
            <!-- Available assets will be loaded here -->
          </div>
          <div class="flex justify-end space-x-2">
            <button id="cancelAddAssets" class="bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-md text-sm font-medium">
              Cancel
            </button>
            <button id="saveAssets" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium">
              Save Assets
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Add Text Version Modal -->
  <div id="addTextModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full hidden z-50">
    <div class="relative top-10 mx-auto p-6 border w-full max-w-2xl shadow-lg rounded-lg bg-white dark:bg-gray-800 dark:border-gray-700 mb-10">
      <div class="mb-4">
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">Add Text Version</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400">Create platform-specific text content for your ad</p>
      </div>
      <form id="addTextForm" class="space-y-5">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="textPlatform" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Platform</label>
            <select id="textPlatform" required class="block w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 py-2 px-3">
              <option value="">Select Platform</option>
            </select>
          </div>
          <div>
            <label for="textType" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Text Type</label>
            <select id="textType" required class="block w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 py-2 px-3">
              <option value="">Select Type</option>
              <option value="caption">Caption</option>
              <option value="headline">Headline</option>
              <option value="description">Description</option>
              <option value="cta">CTA (Call to Action)</option>
              <option value="whatsapp_message">WhatsApp Message</option>
            </select>
          </div>
        </div>
        <div>
          <label for="textContent" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Content</label>
          <textarea id="textContent" rows="10" required class="block w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 p-3 resize-y" placeholder="Enter your text content here..."></textarea>
          <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">You can add multiple lines and format your text as needed</p>
        </div>
        <div class="flex justify-end space-x-3 pt-4 border-t border-gray-200 dark:border-gray-700">
          <button type="button" id="cancelAddText" class="bg-gray-600 hover:bg-gray-700 text-white px-6 py-2 rounded-md text-sm font-medium transition-colors">
            Cancel
          </button>
          <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-md text-sm font-medium transition-colors">
            Save Text Version
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Record Publication Modal -->
  <div id="publishModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full hidden z-50">
    <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white dark:bg-gray-800 dark:border-gray-700">
      <div class="mt-3">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Record Publication</h3>
        <form id="publishForm" class="space-y-4">
          <div>
            <label for="publishPlatform" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Platform</label>
            <select id="publishPlatform" required class="mt-1 block w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-md shadow-sm">
              <option value="">Select Platform</option>
            </select>
          </div>
          <div>
            <label for="publishPlacement" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Placement</label>
            <select id="publishPlacement" required class="mt-1 block w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-md shadow-sm">
              <option value="feed">Feed</option>
              <option value="story">Story</option>
              <option value="reels">Reels</option>
              <option value="broadcast">Broadcast</option>
              <option value="post">Post</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label for="publishDate" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Published Date & Time</label>
            <input type="datetime-local" id="publishDate" required class="mt-1 block w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-md shadow-sm">
          </div>
          <div>
            <label for="externalCampaignId" class="block text-sm font-medium text-gray-700 dark:text-gray-300">External Campaign ID (optional)</label>
            <input type="text" id="externalCampaignId" class="mt-1 block w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-md shadow-sm" placeholder="e.g., Meta Campaign ID">
          </div>
          <div>
            <label for="externalAdId" class="block text-sm font-medium text-gray-700 dark:text-gray-300">External Ad ID (optional)</label>
            <input type="text" id="externalAdId" class="mt-1 block w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-md shadow-sm" placeholder="e.g., Meta Ad ID">
          </div>
          <div>
            <label for="linkUsed" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Link Used (optional)</label>
            <input type="url" id="linkUsed" class="mt-1 block w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-md shadow-sm" placeholder="https://...">
          </div>
          <div>
            <label for="publishNotes" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Notes (optional)</label>
            <textarea id="publishNotes" rows="3" class="mt-1 block w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-md shadow-sm" placeholder="Additional notes..."></textarea>
          </div>
          <div class="flex justify-end space-x-2">
            <button type="button" id="cancelPublish" class="bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-md text-sm font-medium">
              Cancel
            </button>
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium">
              Record Publication
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    const API_BASE = '/marketing/api/ad-content';
    const adId = '<%= adId %>';
    let selectedAssetIds = [];
    let availableAssets = [];
    let platforms = [];

    // Load platforms
    async function loadPlatforms() {
      try {
        const response = await fetch(`${API_BASE}/platforms`);
        const data = await response.json();
        if (data.success && data.data) {
          platforms = data.data;
          
          // Populate text platform select
          const textPlatformSelect = document.getElementById('textPlatform');
          platforms.forEach(platform => {
            const option = document.createElement('option');
            option.value = platform.id;
            option.textContent = platform.name;
            textPlatformSelect.appendChild(option);
          });
          
          // Populate publish platform select
          const publishPlatformSelect = document.getElementById('publishPlatform');
          platforms.forEach(platform => {
            const option = document.createElement('option');
            option.value = platform.id;
            option.textContent = platform.name;
            publishPlatformSelect.appendChild(option);
          });
        }
      } catch (error) {
        console.error('Error loading platforms:', error);
      }
    }

    // Load available assets
    async function loadAvailableAssets() {
      try {
        const response = await fetch(`${API_BASE}/assets`);
        const data = await response.json();
        if (data.success && data.data) {
          availableAssets = data.data;
          renderAvailableAssets();
        }
      } catch (error) {
        console.error('Error loading available assets:', error);
      }
    }

    // Render available assets in modal
    function renderAvailableAssets() {
      const container = document.getElementById('availableAssetsContainer');
      
      // Get existing asset IDs for this ad
      let existingAssetIds = [];
      try {
        if (window.currentAdData && window.currentAdData.assets) {
          existingAssetIds = window.currentAdData.assets.map(a => a.id);
        }
      } catch (e) {
        console.error('Error getting existing assets:', e);
      }
      
      container.innerHTML = availableAssets.map(asset => {
        const isSelected = selectedAssetIds.includes(asset.id);
        const isExisting = existingAssetIds.includes(asset.id);
        return `
          <div class="border rounded-lg overflow-hidden cursor-pointer ${isSelected ? 'ring-2 ring-blue-500' : ''} ${isExisting ? 'border-green-500 border-2' : ''}" onclick="toggleAsset(${asset.id})">
            ${asset.file_type === 'image' ? `
              <img src="${asset.file_path}" alt="${asset.original_filename}" class="w-full h-24 object-cover">
            ` : `
              <div class="w-full h-24 bg-gray-200 dark:bg-gray-700 flex items-center justify-center">
                <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                </svg>
              </div>
            `}
            <div class="p-2">
              <p class="text-xs text-gray-600 dark:text-gray-400 truncate" title="${asset.original_filename}">${asset.original_filename}</p>
              ${isSelected ? '<p class="text-xs text-blue-600 dark:text-blue-400 mt-1 font-medium">Selected</p>' : ''}
              ${isExisting && !isSelected ? '<p class="text-xs text-green-600 dark:text-green-400 mt-1">Currently assigned</p>' : ''}
              ${isExisting && isSelected ? '<p class="text-xs text-green-600 dark:text-green-400 mt-1">Assigned & Selected</p>' : ''}
            </div>
          </div>
        `;
      }).join('');
    }

    // Toggle asset selection (global function for onclick)
    window.toggleAsset = function(assetId) {
      const index = selectedAssetIds.indexOf(assetId);
      if (index > -1) {
        selectedAssetIds.splice(index, 1);
      } else {
        selectedAssetIds.push(assetId);
      }
      renderAvailableAssets();
    };

    // Copy image to clipboard (global function for onclick)
    window.copyImageToClipboard = async function(imagePath, buttonElement) {
      try {
        // Fetch the original image file
        const response = await fetch(imagePath);
        if (!response.ok) {
          throw new Error('Failed to fetch image');
        }
        
        const blob = await response.blob();
        
        // Check if Clipboard API supports images
        if (navigator.clipboard && navigator.clipboard.write && window.ClipboardItem) {
          try {
            // Create ClipboardItem with the image blob
            const clipboardItem = new ClipboardItem({
              [blob.type]: blob
            });
            
            await navigator.clipboard.write([clipboardItem]);
            showImageCopyFeedback(buttonElement);
          } catch (clipboardError) {
            // If clipboard write fails, try fallback method
            console.warn('Clipboard API failed, trying fallback:', clipboardError);
            fallbackCopyImageToClipboard(imagePath, buttonElement);
          }
        } else {
          // Fallback for browsers that don't support ClipboardItem
          fallbackCopyImageToClipboard(imagePath, buttonElement);
        }
      } catch (error) {
        console.error('Error copying image:', error);
        alert('Failed to copy image. Your browser may not support this feature, or the image may be too large.');
      }
    };

    // Fallback method for copying images (creates a temporary canvas)
    function fallbackCopyImageToClipboard(imagePath, buttonElement) {
      const img = new Image();
      img.crossOrigin = 'anonymous';
      
      img.onload = function() {
        try {
          // Create a canvas with the image
          const canvas = document.createElement('canvas');
          canvas.width = img.naturalWidth;
          canvas.height = img.naturalHeight;
          const ctx = canvas.getContext('2d');
          ctx.drawImage(img, 0, 0);
          
          // Convert canvas to blob
          canvas.toBlob(async (blob) => {
            try {
              if (navigator.clipboard && navigator.clipboard.write && window.ClipboardItem) {
                const clipboardItem = new ClipboardItem({
                  [blob.type]: blob
                });
                await navigator.clipboard.write([clipboardItem]);
                showImageCopyFeedback(buttonElement);
              } else {
                // Last resort: download the image
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = imagePath.split('/').pop();
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(url);
                alert('Image downloaded. Please paste it manually into WhatsApp.');
              }
            } catch (err) {
              console.error('Fallback copy failed:', err);
              alert('Unable to copy image. Please right-click and save the image, then paste it manually.');
            }
          }, 'image/png');
        } catch (error) {
          console.error('Canvas copy failed:', error);
          alert('Unable to copy image. Please right-click and save the image, then paste it manually.');
        }
      };
      
      img.onerror = function() {
        alert('Failed to load image. Please check if the image is accessible.');
      };
      
      img.src = imagePath;
    }

    // Show visual feedback when image is copied
    function showImageCopyFeedback(buttonElement) {
      const copyIcon = buttonElement.querySelector('.copy-icon');
      const checkIcon = buttonElement.querySelector('.check-icon');
      
      // Hide copy icon, show check icon
      if (copyIcon) copyIcon.classList.add('hidden');
      if (checkIcon) checkIcon.classList.remove('hidden');
      
      // Change button color to green
      buttonElement.classList.remove('bg-blue-600', 'hover:bg-blue-700');
      buttonElement.classList.add('bg-green-600', 'hover:bg-green-700');
      
      // Reset after 2 seconds
      setTimeout(() => {
        if (copyIcon) copyIcon.classList.remove('hidden');
        if (checkIcon) checkIcon.classList.add('hidden');
        buttonElement.classList.remove('bg-green-600', 'hover:bg-green-700');
        buttonElement.classList.add('bg-blue-600', 'hover:bg-blue-700');
      }, 2000);
    }

    // Remove asset from ad (global function for onclick)
    window.removeAsset = function(assetId) {
      if (confirm('Remove this asset from the ad?')) {
        fetch(`${API_BASE}/ads/${adId}/assets/${assetId}`, {
          method: 'DELETE'
        })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            loadAdDetails();
          } else {
            alert('Failed to remove asset');
          }
        })
        .catch(error => {
          console.error('Error removing asset:', error);
          alert('Failed to remove asset');
        });
      }
    };

    // Copy text to clipboard
    function copyTextToClipboard(text, buttonElement) {
      // Use the modern Clipboard API
      if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(text).then(() => {
          showCopyFeedback(buttonElement);
        }).catch(err => {
          console.error('Failed to copy text:', err);
          fallbackCopyTextToClipboard(text, buttonElement);
        });
      } else {
        // Fallback for older browsers
        fallbackCopyTextToClipboard(text, buttonElement);
      }
    }

    // Fallback copy method for older browsers
    function fallbackCopyTextToClipboard(text, buttonElement) {
      const textArea = document.createElement('textarea');
      textArea.value = text;
      textArea.style.position = 'fixed';
      textArea.style.left = '-999999px';
      textArea.style.top = '-999999px';
      document.body.appendChild(textArea);
      textArea.focus();
      textArea.select();
      
      try {
        const successful = document.execCommand('copy');
        if (successful) {
          showCopyFeedback(buttonElement);
        } else {
          alert('Failed to copy text. Please select and copy manually.');
        }
      } catch (err) {
        console.error('Fallback copy failed:', err);
        alert('Failed to copy text. Please select and copy manually.');
      }
      
      document.body.removeChild(textArea);
    }

    // Show visual feedback when text is copied
    function showCopyFeedback(buttonElement) {
      const copyIcon = buttonElement.querySelector('.copy-icon');
      const checkIcon = buttonElement.querySelector('.check-icon');
      
      // Hide copy icon, show check icon
      if (copyIcon) copyIcon.classList.add('hidden');
      if (checkIcon) checkIcon.classList.remove('hidden');
      
      // Change button color to green
      buttonElement.classList.remove('text-gray-600', 'hover:text-gray-800', 'dark:text-gray-400', 'dark:hover:text-gray-300');
      buttonElement.classList.add('text-green-600', 'dark:text-green-400');
      
      // Reset after 2 seconds
      setTimeout(() => {
        if (copyIcon) copyIcon.classList.remove('hidden');
        if (checkIcon) checkIcon.classList.add('hidden');
        buttonElement.classList.remove('text-green-600', 'dark:text-green-400');
        buttonElement.classList.add('text-gray-600', 'hover:text-gray-800', 'dark:text-gray-400', 'dark:hover:text-gray-300');
      }, 2000);
    }

    // Edit text version (global function)
    window.editText = function(textId, platformId, textType, content) {
      // Populate the form with existing data
      if (platformId && platformId !== '' && platformId !== 'null') {
        document.getElementById('textPlatform').value = platformId;
      } else {
        document.getElementById('textPlatform').value = '';
      }
      document.getElementById('textType').value = textType || '';
      document.getElementById('textContent').value = content || '';
      
      // Store the text ID for update
      document.getElementById('addTextForm').dataset.textId = textId;
      
      // Change modal title and button
      document.querySelector('#addTextModal h3').textContent = 'Edit Text Version';
      document.querySelector('#addTextForm button[type="submit"]').textContent = 'Update Text Version';
      
      // Show modal
      document.getElementById('addTextModal').classList.remove('hidden');
    };

    // Delete text version (global function for onclick)
    window.deleteText = function(textId) {
      if (confirm('Delete this text version?')) {
        fetch(`${API_BASE}/texts/${textId}`, {
          method: 'DELETE'
        })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            loadAdDetails();
          } else {
            alert('Failed to delete text');
          }
        })
        .catch(error => {
          console.error('Error deleting text:', error);
          alert('Failed to delete text');
        });
      }
    };

    // Show add assets modal
    document.getElementById('addAssetsBtn').addEventListener('click', async () => {
      selectedAssetIds = [];
      
      // Load existing assets for this ad to show which are already assigned
      try {
        const adResponse = await fetch(`${API_BASE}/ads/${adId}`);
        const adData = await adResponse.json();
        if (adData.success && adData.data && adData.data.assets) {
          // Pre-select existing assets in the modal
          const existingAssetIds = adData.data.assets.map(a => a.id);
          selectedAssetIds = [...existingAssetIds];
        }
      } catch (error) {
        console.error('Error loading existing assets:', error);
      }
      
      loadAvailableAssets();
      document.getElementById('addAssetsModal').classList.remove('hidden');
    });

    // Hide add assets modal
    document.getElementById('cancelAddAssets').addEventListener('click', () => {
      document.getElementById('addAssetsModal').classList.add('hidden');
      selectedAssetIds = [];
    });

    // Upload new assets
    document.getElementById('uploadAssetsForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData();
      const files = document.getElementById('assetFiles').files;
      
      for (let i = 0; i < files.length; i++) {
        formData.append('files', files[i]);
      }

      try {
        const response = await fetch(`${API_BASE}/assets/upload`, {
          method: 'POST',
          headers: {
            'Accept': 'application/json'
          },
          body: formData
        });
        
        // Check if response is JSON
        const contentType = response.headers.get('content-type');
        if (!contentType || !contentType.includes('application/json')) {
          const text = await response.text();
          console.error('Non-JSON response:', text);
          throw new Error(`Server error: ${response.status} ${response.statusText}`);
        }
        
        const data = await response.json();
        
        if (data.success && data.data) {
          // Add uploaded assets to selected list
          data.data.forEach(asset => {
            if (!selectedAssetIds.includes(asset.id)) {
              selectedAssetIds.push(asset.id);
            }
          });
          loadAvailableAssets();
          document.getElementById('assetFiles').value = '';
          
          if (window.toastManager) {
            window.toastManager.success(`Successfully uploaded ${data.data.length} asset(s)`);
          }
        } else {
          const errorMsg = data.error || 'Unknown error';
          if (window.toastManager) {
            window.toastManager.error('Upload failed: ' + errorMsg);
          } else {
            alert('Upload failed: ' + errorMsg);
          }
        }
      } catch (error) {
        console.error('Upload error:', error);
        const errorMsg = error.message || 'Upload failed. Please try again.';
        if (window.toastManager) {
          window.toastManager.error(errorMsg);
        } else {
          alert(errorMsg);
        }
      }
    });

    // Save assets to ad
    document.getElementById('saveAssets').addEventListener('click', async () => {
      if (selectedAssetIds.length === 0) {
        alert('Please select at least one asset');
        return;
      }

      try {
        // Get existing assets to determine if we're appending or replacing
        const adResponse = await fetch(`${API_BASE}/ads/${adId}`);
        const adData = await adResponse.json();
        const existingAssetIds = adData.success && adData.data && adData.data.assets 
          ? adData.data.assets.map(a => a.id) 
          : [];
        
        // Check if user wants to replace or append
        // If all selected assets are new, append. If user unselected existing ones, replace.
        const hasUnselectedExisting = existingAssetIds.some(id => !selectedAssetIds.includes(id));
        const replaceExisting = hasUnselectedExisting;
        
        const response = await fetch(`${API_BASE}/ads/${adId}/assets`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            asset_ids: selectedAssetIds,
            display_orders: selectedAssetIds.map((_, i) => i),
            primary_asset_id: selectedAssetIds[0],
            replace_existing: replaceExisting
          })
        });
        const data = await response.json();
        
        if (data.success) {
          document.getElementById('addAssetsModal').classList.add('hidden');
          selectedAssetIds = [];
          loadAdDetails();
        } else {
          alert('Failed to save assets: ' + (data.error || 'Unknown error'));
        }
      } catch (error) {
        console.error('Error saving assets:', error);
        alert('Failed to save assets');
      }
    });

    // Show add text modal
    document.getElementById('addTextBtn').addEventListener('click', () => {
      document.getElementById('addTextForm').reset();
      delete document.getElementById('addTextForm').dataset.textId;
      document.querySelector('#addTextModal h3').textContent = 'Add Text Version';
      document.querySelector('#addTextForm button[type="submit"]').textContent = 'Save Text Version';
      document.getElementById('addTextModal').classList.remove('hidden');
    });

    // Hide add text modal
    document.getElementById('cancelAddText').addEventListener('click', () => {
      document.getElementById('addTextModal').classList.add('hidden');
    });

    // Save or update text version
    document.getElementById('addTextForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const textId = document.getElementById('addTextForm').dataset.textId;
      const textData = {
        platform_id: document.getElementById('textPlatform').value,
        text_type: document.getElementById('textType').value,
        content: document.getElementById('textContent').value
      };

      try {
        let response;
        if (textId) {
          // Update existing text
          response = await fetch(`${API_BASE}/ads/${adId}/texts/${textId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              platform_id: textData.platform_id,
              text_type: textData.text_type,
              content: textData.content
            })
          });
        } else {
          // Create new text
          response = await fetch(`${API_BASE}/ads/${adId}/texts`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              texts: [textData]
            })
          });
        }
        
        const data = await response.json();
        
        if (data.success) {
          document.getElementById('addTextModal').classList.add('hidden');
          document.getElementById('addTextForm').reset();
          delete document.getElementById('addTextForm').dataset.textId;
          loadAdDetails();
        } else {
          alert('Failed to save text: ' + (data.error || 'Unknown error'));
        }
      } catch (error) {
        console.error('Error saving text:', error);
        alert('Failed to save text');
      }
    });


    async function loadAdDetails() {
      const loadingState = document.getElementById('loadingState');
      const errorState = document.getElementById('errorState');
      const adDetails = document.getElementById('adDetails');

      try {
        const response = await fetch(`${API_BASE}/ads/${adId}`);
        const data = await response.json();

        if (data.success && data.data) {
          const ad = data.data;
          
          // Store ad data globally for asset modal
          window.currentAdData = ad;
          
          // Update header
          document.getElementById('adTitle').textContent = ad.name || 'Untitled Ad';
          const statusBadge = document.getElementById('adStatusBadge');
          statusBadge.textContent = ad.status || 'draft';
          statusBadge.className = `inline-flex items-center px-3 py-1 rounded-full text-sm font-medium ${
            ad.status === 'approved' ? 'bg-green-500' :
            ad.status === 'in_review' ? 'bg-yellow-500' :
            ad.status === 'published' ? 'bg-blue-500' :
            'bg-gray-500'
          } text-white`;

          // Update overview
          const overviewContent = document.getElementById('overviewContent');
          overviewContent.innerHTML = `
            <div>
              <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Description</label>
              <p class="text-sm text-gray-900 dark:text-white">${ad.description || 'No description'}</p>
            </div>
            ${ad.campaign_name ? `
            <div>
              <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Campaign</label>
              <p class="text-sm text-gray-900 dark:text-white font-medium">${ad.campaign_name}</p>
            </div>
            ` : ''}
            <div>
              <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Created By</label>
              <p class="text-sm text-gray-900 dark:text-white font-medium">${ad.created_by_name || 'Unknown'}</p>
            </div>
          `;

          // Load assets with aspect ratio handling
          const assetsContainer = document.getElementById('assetsContainer');
          const noAssetsMessage = document.getElementById('noAssetsMessage');
          if (ad.assets && ad.assets.length > 0) {
            assetsContainer.innerHTML = ad.assets.map(asset => {
              // Calculate aspect ratio
              let aspectRatio = 'aspect-square'; // default
              if (asset.width && asset.height) {
                const ratio = asset.width / asset.height;
                if (ratio > 1.3) {
                  aspectRatio = 'aspect-video'; // landscape (16:9)
                } else if (ratio < 0.7) {
                  aspectRatio = 'aspect-[9/16]'; // portrait (9:16)
                } else {
                  aspectRatio = 'aspect-square'; // square (1:1)
                }
              }
              
              return `
              <div class="border rounded-lg overflow-hidden relative group bg-gray-100 dark:bg-gray-700">
                <div class="${aspectRatio} w-full">
                  ${asset.file_type === 'image' ? `
                    <img src="${asset.file_path}" alt="${asset.original_filename}" class="w-full h-full object-contain" data-asset-path="${asset.file_path}" data-asset-id="${asset.id}">
                  ` : `
                    <div class="w-full h-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center">
                      <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                      </svg>
                    </div>
                  `}
                </div>
                <div class="p-2 bg-white dark:bg-gray-800">
                  <p class="text-xs text-gray-600 dark:text-gray-400 truncate" title="${asset.original_filename}">${asset.original_filename}</p>
                  ${asset.is_primary ? '<span class="text-xs text-blue-600 dark:text-blue-400">Primary</span>' : ''}
                </div>
                ${asset.file_type === 'image' ? `
                <button onclick="copyImageToClipboard('${asset.file_path}', this)" class="absolute top-2 left-2 bg-blue-600 hover:bg-blue-700 text-white rounded-full p-2 opacity-0 group-hover:opacity-100 transition-opacity shadow-lg copy-image-btn" title="Copy image">
                  <svg class="w-4 h-4 copy-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>

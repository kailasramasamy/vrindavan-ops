                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </button>
                ` : ''}
                <button onclick="removeAsset(${asset.id})" class="absolute top-2 right-2 bg-red-600 hover:bg-red-700 text-white rounded-full p-1 opacity-0 group-hover:opacity-100 transition-opacity shadow-lg">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                  </svg>
                </button>
              </div>
            `;
            }).join('');
            noAssetsMessage.classList.add('hidden');
          } else {
            assetsContainer.innerHTML = '';
            noAssetsMessage.classList.remove('hidden');
          }

          // Load texts
          const textsContainer = document.getElementById('textsContainer');
          const noTextsMessage = document.getElementById('noTextsMessage');
          if (ad.texts && ad.texts.length > 0) {
            // Store text data in a way that avoids HTML attribute issues
            const textsData = {};
            
            textsContainer.innerHTML = ad.texts.map((text, index) => {
              // Store data in a global object to avoid attribute escaping issues
              const dataKey = `text_${text.id}_${index}`;
              textsData[dataKey] = {
                id: text.id,
                platformId: text.platform_id || '',
                textType: text.text_type || '',
                content: text.content || ''
              };
              
              return `

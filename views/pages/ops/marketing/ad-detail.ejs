            // Default icon
            return `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342c0 .576.373 1.084.95 1.26l3.196.99c.5.155.99-.155.99-.65v-1.5c0-.495-.49-.805-.99-.65l-3.196.99c-.577.176-.95.684-.95 1.26zm-2.5-2.5c0 .576.373 1.084.95 1.26l3.196.99c.5.155.99-.155.99-.65v-1.5c0-.495-.49-.805-.99-.65l-3.196.99c-.577.176-.95.684-.95 1.26zM12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2z"/>
            </svg>`;
          }
          
          // Load publishings
          const publishingsContainer = document.getElementById('publishingsContainer');
          const noPublishingsMessage = document.getElementById('noPublishingsMessage');
          if (ad.publishings && ad.publishings.length > 0) {
            publishingsContainer.innerHTML = ad.publishings.map(pub => {
              const platformIcon = getPlatformIcon(pub.platform_code, pub.platform_name);
              const placementLabels = {
                'feed': 'Feed',
                'story': 'Story',
                'reels': 'Reels',
                'broadcast': 'Broadcast',
                'post': 'Post',
                'other': 'Other'
              };
              
              return `
              <div class="border rounded-lg p-3 bg-white dark:bg-gray-800 hover:shadow-sm transition-shadow">
                <div class="flex items-center justify-between mb-2">
                  <div class="flex items-center gap-2">
                    <div class="text-blue-600 dark:text-blue-400">
                      ${platformIcon}
                    </div>
                    <span class="text-sm font-medium text-gray-900 dark:text-white">${pub.platform_name}</span>
                  </div>
                  <span class="text-xs text-gray-500 dark:text-gray-400">${new Date(pub.published_at).toLocaleDateString()}</span>
                </div>
                <div class="flex items-center gap-2 mt-1">
                  <span class="text-xs px-2 py-1 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 rounded">${placementLabels[pub.placement] || pub.placement}</span>
                </div>
                ${pub.external_campaign_id ? `<p class="text-xs text-gray-500 dark:text-gray-500 mt-2">Campaign ID: <span class="font-mono">${pub.external_campaign_id}</span></p>` : ''}
                ${pub.external_ad_id ? `<p class="text-xs text-gray-500 dark:text-gray-500 mt-1">Ad ID: <span class="font-mono">${pub.external_ad_id}</span></p>` : ''}
                ${pub.link_used ? `<p class="text-xs text-gray-500 dark:text-gray-500 mt-1 truncate" title="${pub.link_used}">Link: <a href="${pub.link_used}" target="_blank" class="text-blue-600 dark:text-blue-400 hover:underline">${pub.link_used}</a></p>` : ''}
              </div>
            `;
            }).join('');
            noPublishingsMessage.classList.add('hidden');
          } else {
            publishingsContainer.innerHTML = '';
            noPublishingsMessage.classList.remove('hidden');
          }

          // Show approval section if needed
          const approvalSection = document.getElementById('approvalSection');
          if (ad.status === 'in_review' || ad.status === 'draft') {
            approvalSection.innerHTML = `
              <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Approval</h2>
              <div class="space-y-2">
                <button id="approveBtn" class="w-full bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-md text-sm font-medium">
                  Approve
                </button>
                <button id="rejectBtn" class="w-full bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-md text-sm font-medium">
                  Reject
                </button>
              </div>
            `;
            
            // Add approval handlers
            setTimeout(() => {
              const approveBtn = document.getElementById('approveBtn');
              const rejectBtn = document.getElementById('rejectBtn');
              
              if (approveBtn) {
                approveBtn.addEventListener('click', async () => {
                  try {
                    const response = await fetch(`${API_BASE}/ads/${adId}/approve`, {
                      method: 'POST'
                    });
                    const data = await response.json();
                    if (data.success) {
                      loadAdDetails();
                    } else {
                      alert('Failed to approve ad: ' + (data.error || 'Unknown error'));
                    }
                  } catch (error) {
                    console.error('Error approving ad:', error);
                    alert('Failed to approve ad');
                  }
                });
              }
              
              if (rejectBtn) {
                rejectBtn.addEventListener('click', () => {
                  const reason = prompt('Please provide a reason for rejection:');
                  if (reason) {
                    fetch(`${API_BASE}/ads/${adId}/reject`, {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify({ rejection_reason: reason })
                    })
                    .then(res => res.json())
                    .then(data => {
                      if (data.success) {
                        loadAdDetails();
                      } else {
                        alert('Failed to reject ad: ' + (data.error || 'Unknown error'));
                      }
                    })
                    .catch(error => {
                      console.error('Error rejecting ad:', error);
                      alert('Failed to reject ad');
                    });
                  }
                });
              }
            }, 100);
          } else {
            // Get approval status badge class
            const getApprovalBadgeClass = (status) => {
              const classes = {
                'approved': 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200',
                'rejected': 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200',
                'pending': 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200'
              };
              return classes[status] || classes['pending'];
            };
            
            const approvalStatus = ad.approval_status || 'pending';
            const statusLabel = approvalStatus.charAt(0).toUpperCase() + approvalStatus.slice(1);
            
            approvalSection.innerHTML = `
              <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Approval Status</h2>
              <div class="space-y-3">
                <div class="flex items-center gap-2">
                  <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Status:</span>
                  <span class="px-3 py-1 text-xs font-semibold rounded-full ${getApprovalBadgeClass(approvalStatus)}">
                    ${statusLabel}
                  </span>
                </div>
                ${ad.approved_by_name ? `
                <div>
                  <span class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Approved by</span>
                  <p class="text-sm text-gray-900 dark:text-white font-medium mt-1">${ad.approved_by_name}</p>
                </div>
                ` : ''}
                ${ad.approved_at ? `
                <div>
                  <span class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Date</span>
                  <p class="text-sm text-gray-900 dark:text-white font-medium mt-1">${new Date(ad.approved_at).toLocaleDateString()}</p>
                </div>
                ` : ''}
                ${ad.rejection_reason ? `
                <div>
                  <span class="text-xs font-medium text-red-600 dark:text-red-400 uppercase tracking-wide">Rejection Reason</span>
                  <p class="text-sm text-red-700 dark:text-red-300 mt-1">${ad.rejection_reason}</p>
                </div>
                ` : ''}
              </div>
            `;
          }

          adDetails.classList.remove('hidden');
        } else {
          errorState.classList.remove('hidden');
        }
      } catch (error) {
        console.error('Error loading ad details:', error);
        errorState.classList.remove('hidden');
      } finally {
        loadingState.classList.add('hidden');
      }
    }

    document.getElementById('editAd').addEventListener('click', () => {
      window.location.href = `/marketing/ads/${adId}/edit`;
    });

    // Show publish modal
    document.getElementById('publishBtn').addEventListener('click', () => {
      // Set default date/time to now
      const now = new Date();
      const year = now.getFullYear();
      const month = String(now.getMonth() + 1).padStart(2, '0');
      const day = String(now.getDate()).padStart(2, '0');
      const hours = String(now.getHours()).padStart(2, '0');
      const minutes = String(now.getMinutes()).padStart(2, '0');
      document.getElementById('publishDate').value = `${year}-${month}-${day}T${hours}:${minutes}`;
      
      document.getElementById('publishForm').reset();
      document.getElementById('publishDate').value = `${year}-${month}-${day}T${hours}:${minutes}`;
      document.getElementById('publishModal').classList.remove('hidden');
    });

    // Hide publish modal
    document.getElementById('cancelPublish').addEventListener('click', () => {
      document.getElementById('publishModal').classList.add('hidden');
    });

    // Save publishing record
    document.getElementById('publishForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const publishDate = document.getElementById('publishDate').value;
      const publishingData = {
        ad_id: parseInt(adId),
        platform_id: parseInt(document.getElementById('publishPlatform').value),
        placement: document.getElementById('publishPlacement').value,
        published_at: new Date(publishDate).toISOString(),
        external_campaign_id: document.getElementById('externalCampaignId').value || null,
        external_ad_id: document.getElementById('externalAdId').value || null,
        link_used: document.getElementById('linkUsed').value || null,
        notes: document.getElementById('publishNotes').value || null
      };
      
      try {
        const response = await fetch(`${API_BASE}/publishings`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(publishingData)
        });
        const data = await response.json();
        
        if (data.success) {
          document.getElementById('publishModal').classList.add('hidden');
          loadAdDetails();
        } else {
          alert('Failed to record publishing: ' + (data.error || 'Unknown error'));
        }
      } catch (error) {
        console.error('Error recording publishing:', error);
        alert('Failed to record publishing');
      }
    });

    // Close modals on background click
    document.getElementById('addAssetsModal').addEventListener('click', (e) => {
      if (e.target.id === 'addAssetsModal') {
        document.getElementById('addAssetsModal').classList.add('hidden');
      }
    });

    document.getElementById('addTextModal').addEventListener('click', (e) => {
      if (e.target.id === 'addTextModal') {
        document.getElementById('addTextModal').classList.add('hidden');
      }
    });

    document.getElementById('publishModal').addEventListener('click', (e) => {
      if (e.target.id === 'publishModal') {
        document.getElementById('publishModal').classList.add('hidden');
      }
    });

    // Initialize
    loadPlatforms();
    loadAdDetails();
  </script>
</body>
</html>


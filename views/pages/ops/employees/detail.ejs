<%- include('../../../partials/_head', { seo, pageKey }) %>

<script>
  (function () {
    const theme = localStorage.getItem("theme") || "dark";
    if (theme === "dark") {
      document.documentElement.classList.add("dark");
    } else {
      document.documentElement.classList.remove("dark");
    }
  })();
</script>

<body class="bg-slate-50 dark:bg-gray-900">
  <%- include('../../../partials/_subnav', { user, section: 'Employees', subsection: 'Employee Management' }) %>

  <div class="min-h-screen pt-16">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">
      <div class="flex items-center justify-between gap-4">
        <a href="/employees" class="inline-flex items-center gap-2 text-sm text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          Back to Employees
        </a>
        <div class="flex items-center gap-3">
          <button id="editEmployeeBtn" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition-colors">
            Edit Employee
          </button>
        </div>
      </div>

      <!-- Employee Header -->
      <header class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-6 shadow-sm">
        <div class="flex flex-col md:flex-row gap-6">
          <div class="flex-shrink-0">
            <% if (employee.profile_photo) { %>
            <img src="<%= employee.profile_photo %>" alt="<%= employee.name %>" class="w-24 h-24 rounded-full object-cover border-2 border-gray-200 dark:border-gray-700">
            <% } else { %>
            <div class="w-24 h-24 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center border-2 border-gray-300 dark:border-gray-600">
              <span class="text-3xl font-semibold text-gray-500 dark:text-gray-400"><%= (employee.name || "E").charAt(0).toUpperCase() %></span>
            </div>
            <% } %>
          </div>
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-2">
              <h1 class="text-2xl font-semibold text-gray-900 dark:text-white" data-field="employee-name"><%= employee.name || "Employee" %></h1>
              <span class="px-2 py-1 text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400 rounded">ID: <%= employee.id %></span>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400" data-field="employee-role">
              <%= employee.role_name || "No role assigned" %>
            </p>
            <div class="flex flex-wrap gap-4 mt-4 text-sm text-gray-600 dark:text-gray-400">
              <% if (employee.phone) { %>
              <span class="flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
                <%= employee.phone %>
              </span>
              <% } %>
              <% if (employee.email) { %>
              <span class="flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                <%= employee.email %>
              </span>
              <% } %>
              <% if (employee.start_date) { %>
              <span class="flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                Started: <%= new Date(employee.start_date).toLocaleDateString("en-IN") %>
              </span>
              <% } %>
            </div>
            <div class="mt-4">
              <% const statusClass = employee.status === "active" 
                ? "bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300 border border-emerald-200 dark:border-emerald-800"
                : "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300 border border-gray-200 dark:border-gray-600";
              %>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold <%= statusClass %>">
                <%= (employee.status || "active").charAt(0).toUpperCase() + (employee.status || "active").slice(1) %>
              </span>
            </div>
          </div>
        </div>
      </header>

      <!-- Employee Details & Salary Package -->
      <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Employee Details -->
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-6 shadow-sm">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Employee Details</h2>
          <div class="space-y-4">
            <!-- Personal Information -->
            <div>
              <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">Personal Information</h3>
              <dl class="grid grid-cols-2 gap-3">
                <% if (employee.age) { %>
                <div class="flex flex-col">
                  <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Age</dt>
                  <dd class="text-sm font-medium text-gray-900 dark:text-white"><%= employee.age %> years</dd>
                </div>
                <% } %>
                <% if (employee.gender) { %>
                <div class="flex flex-col">
                  <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Gender</dt>
                  <dd class="text-sm font-medium text-gray-900 dark:text-white capitalize"><%= employee.gender %></dd>
                </div>
                <% } %>
                <% if (employee.dob) { %>
                <div class="flex flex-col">
                  <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Date of Birth</dt>
                  <dd class="text-sm font-medium text-gray-900 dark:text-white"><%= new Date(employee.dob).toLocaleDateString("en-IN") %></dd>
                </div>
                <% } %>
              </dl>
              <% if (employee.address) { %>
              <div class="mt-3 pt-3 border-t border-gray-100 dark:border-gray-700">
                <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Address</dt>
                <dd class="text-sm text-gray-900 dark:text-white"><%= employee.address %></dd>
              </div>
              <% } %>
            </div>

            <!-- Employment Information -->
            <% if (employee.job_location || employee.job_description) { %>
            <div class="pt-4 border-t border-gray-200 dark:border-gray-700">
              <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">Employment Information</h3>
              <dl class="space-y-3">
                <% if (employee.job_location) { %>
                <div class="flex flex-col">
                  <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Job Location</dt>
                  <dd class="text-sm font-medium text-gray-900 dark:text-white"><%= employee.job_location %></dd>
                </div>
                <% } %>
                <% if (employee.job_description) { %>
                <div class="flex flex-col">
                  <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Job Description</dt>
                  <dd class="text-sm text-gray-900 dark:text-white whitespace-pre-wrap"><%= employee.job_description %></dd>
                </div>
                <% } %>
              </dl>
            </div>
            <% } %>

            <!-- Emergency Contact -->
            <% if (employee.emergency_contact_name) { %>
            <div class="pt-4 border-t border-gray-200 dark:border-gray-700">
              <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">Emergency Contact</h3>
              <dl>
                <div class="flex flex-col">
                  <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Name</dt>
                  <dd class="text-sm font-medium text-gray-900 dark:text-white"><%= employee.emergency_contact_name %></dd>
                </div>
                <% if (employee.emergency_contact_phone) { %>
                <div class="flex flex-col mt-2">
                  <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Phone</dt>
                  <dd class="text-sm font-medium text-gray-900 dark:text-white"><%= employee.emergency_contact_phone %></dd>
                </div>
                <% } %>
              </dl>
            </div>
            <% } %>
          </div>
        </div>

        <!-- Salary Package Section -->
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-6 shadow-sm">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Salary Package</h2>
            <button id="editSalaryBtn" class="px-3 py-1.5 text-sm bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors">
              <%= salaryPackage ? "Edit" : "Add" %> Salary Package
            </button>
          </div>
          <div id="salaryPackageContent">
            <% if (salaryPackage) { 
              var baseSalary = Number(salaryPackage.base_salary || 0);
              var foodAllowance = Number(salaryPackage.food_allowance || 0);
              var fuelAllowance = Number(salaryPackage.fuel_allowance || 0);
              var totalSalary = baseSalary + foodAllowance + fuelAllowance;
            %>
            <div class="space-y-3">
              <div class="flex items-center justify-between py-2 border-b border-gray-100 dark:border-gray-700">
                <span class="text-xs font-medium text-gray-500 dark:text-gray-400">Base Salary</span>
                <span class="text-lg font-semibold text-gray-900 dark:text-white">₹<%= baseSalary.toLocaleString("en-IN") %></span>
              </div>
              <div class="flex items-center justify-between py-2 border-b border-gray-100 dark:border-gray-700">
                <span class="text-xs font-medium text-gray-500 dark:text-gray-400">Food Allowance</span>
                <span class="text-lg font-semibold text-gray-900 dark:text-white">₹<%= foodAllowance.toLocaleString("en-IN") %></span>
              </div>
              <div class="flex items-center justify-between py-2 border-b border-gray-100 dark:border-gray-700">
                <span class="text-xs font-medium text-gray-500 dark:text-gray-400">Fuel Allowance</span>
                <span class="text-lg font-semibold text-gray-900 dark:text-white">₹<%= fuelAllowance.toLocaleString("en-IN") %></span>
              </div>
              <div class="flex items-center justify-between py-3 mt-3">
                <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">Total Salary</span>
                <span class="text-2xl font-bold text-blue-600 dark:text-blue-400">₹<%= totalSalary.toLocaleString("en-IN") %></span>
              </div>
              <% if (salaryPackage.effective_from) { %>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-3">Effective from: <%= new Date(salaryPackage.effective_from).toLocaleDateString("en-IN") %></p>
              <% } %>
            </div>
            <% } else { %>
            <p class="text-sm text-gray-500 dark:text-gray-400">No salary package configured.</p>
            <% } %>
          </div>
        </div>
      </section>

      <!-- Supporting Documents Section -->
      <section class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-6 shadow-sm">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Supporting Documents</h2>
          <button id="addDocumentBtn" class="px-3 py-1.5 text-sm bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors">
            Add Document
          </button>
        </div>
        <div id="documentsContent">
          <% if (documents && documents.length > 0) { %>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <% documents.forEach(doc => { %>
            <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4" data-document-id="<%= doc.id %>">
              <div class="flex items-start justify-between mb-2">
                <div class="flex-1">
                  <h3 class="font-semibold text-gray-900 dark:text-white text-sm"><%= doc.document_name %></h3>
                  <p class="text-xs text-gray-500 dark:text-gray-400 mt-1 capitalize"><%= doc.document_type %></p>
                </div>
                <button class="document-delete-btn px-2 py-1 text-xs bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300 rounded hover:bg-red-200 dark:hover:bg-red-900/50" data-document-id="<%= doc.id %>">
                  Delete
                </button>
              </div>
              <div class="flex items-center gap-2 mt-3">
                <a href="<%= doc.file_path %>" target="_blank" class="px-3 py-1.5 text-xs bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded hover:bg-blue-200 dark:hover:bg-blue-900/50 flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                  </svg>
                  View
                </a>
                <% if (doc.expiry_date) { %>
                <span class="text-xs text-gray-500 dark:text-gray-400">
                  Expires: <%= new Date(doc.expiry_date).toLocaleDateString("en-IN") %>
                </span>
                <% } %>
              </div>
              <% if (doc.notes) { %>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-2"><%= doc.notes %></p>
              <% } %>
            </div>
            <% }); %>
          </div>
          <% } else { %>
          <p class="text-sm text-gray-500 dark:text-gray-400">No documents uploaded.</p>
          <% } %>
        </div>
      </section>

      <!-- Loans Section -->
      <section class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-6 shadow-sm">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Loans</h2>
          <button id="addLoanBtn" class="px-3 py-1.5 text-sm bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors">
            Add Loan
          </button>
        </div>
        <div id="loansContent">
          <% if (loans && loans.length > 0) { %>
          <div class="space-y-4">
            <% loans.forEach(loan => { %>
            <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4" data-loan-id="<%= loan.id %>">
              <div class="flex items-start justify-between mb-4">
                <div class="flex-1">
                  <div class="flex items-center gap-3 mb-2">
                    <h3 class="font-semibold text-gray-900 dark:text-white">₹<%= Number(loan.loan_amount || 0).toLocaleString("en-IN") %></h3>
                    <% if (loan.interest_rate) { %>
                    <span class="text-xs text-gray-500 dark:text-gray-400">@ <%= loan.interest_rate %>% interest</span>
                    <% } %>
                  </div>
                  <% if (loan.purpose) { %>
                  <p class="text-sm text-gray-600 dark:text-gray-400 mb-2"><%= loan.purpose %></p>
                  <% } %>
                  <div class="flex flex-wrap gap-4 text-xs text-gray-500 dark:text-gray-400">
                    <span>Loan Date: <%= new Date(loan.loan_date).toLocaleDateString("en-IN") %></span>
                    <% if (loan.due_date) { %>
                    <span>Due: <%= new Date(loan.due_date).toLocaleDateString("en-IN") %></span>
                    <% } %>
                    <span>Repaid: ₹<%= Number(loan.total_repaid || 0).toLocaleString("en-IN") %></span>
                    <span class="font-semibold">Remaining: ₹<%= Number(loan.remaining_balance || loan.loan_amount || 0).toLocaleString("en-IN") %></span>
                  </div>
                </div>
                <div class="flex items-center gap-2">
                  <button class="loan-repayments-btn px-2 py-1 text-xs bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded hover:bg-gray-200 dark:hover:bg-gray-600" data-loan-id="<%= loan.id %>">
                    View Repayments
                  </button>
                  <button class="loan-edit-btn px-2 py-1 text-xs bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded hover:bg-blue-200 dark:hover:bg-blue-900/50" data-loan-id="<%= loan.id %>">
                    Edit
                  </button>
                </div>
              </div>
              
              <!-- Repayment History -->
              <% if (loan.repayments && loan.repayments.length > 0) { %>
              <div class="mt-4 pt-4 border-t border-gray-200 dark:border-gray-700">
                <h4 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">Repayment History</h4>
                <div class="space-y-2">
                  <% loan.repayments.forEach(repayment => { %>
                  <% const isSalaryDeduction = repayment.payment_method === 'salary_deduction'; %>
                  <div class="flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-900 rounded-lg border border-gray-200 dark:border-gray-700 <%= isSalaryDeduction ? 'border-blue-300 dark:border-blue-700 bg-blue-50/30 dark:bg-blue-900/10' : '' %>">
                    <div class="flex-1">
                      <div class="flex items-center gap-3 flex-wrap">
                        <span class="text-sm font-medium text-gray-900 dark:text-white">₹<%= Number(repayment.amount || 0).toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span>
                        <span class="text-xs text-gray-500 dark:text-gray-400">
                          <%= new Date(repayment.repayment_date).toLocaleDateString("en-IN") %>
                        </span>
                        <% if (repayment.payment_method) { %>
                        <span class="text-xs <%= isSalaryDeduction ? 'text-blue-600 dark:text-blue-400 font-medium' : 'text-gray-500 dark:text-gray-400' %>">
                          · <%= repayment.payment_method.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) %>
                        </span>
                        <% } %>
                        <% if (isSalaryDeduction) { %>
                        <span class="px-2 py-0.5 text-xs bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded-full font-medium">
                          Salary Deduction
                        </span>
                        <% } %>
                      </div>
                      <% if (repayment.notes) { %>
                      <p class="text-xs text-gray-500 dark:text-gray-400 mt-1"><%= repayment.notes %></p>
                      <% } %>
                    </div>
                  </div>
                  <% }); %>
                </div>
              </div>
              <% } else { %>
              <div class="mt-4 pt-4 border-t border-gray-200 dark:border-gray-700">
                <p class="text-xs text-gray-500 dark:text-gray-400 text-center py-2">No repayments recorded yet</p>
              </div>
              <% } %>
            </div>
            <% }); %>
          </div>
          <% } else { %>
          <p class="text-sm text-gray-500 dark:text-gray-400">No loans recorded.</p>
          <% } %>
        </div>
      </section>
    </main>
  </div>

  <%- include('../../../partials/_toast') %>

  <script>
    window.EMPLOYEE_ID = <%= employee.id %>;
    window.EMPLOYEE_DATA = <%- JSON.stringify(employee) %>;
    window.ROLES = <%- JSON.stringify(roles) %>;
  </script>
  <script src="/assets/js/employees-detail.js?v=<%= Date.now() %>"></script>
</body>
</html>


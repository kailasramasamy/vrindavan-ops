    });

    // Test email connection
    function testEmailConnection() {
      const formData = new FormData(document.getElementById('emailConfigForm'));
      const config = Object.fromEntries(formData);
      
      fetch('/email-settings/test-connection', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(config)
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          toastManager.success('Email connection test successful');
        } else {
          toastManager.error('Email connection test failed: ' + data.error);
        }
      })
      .catch(error => {
        console.error('Error:', error);
        toastManager.error('Email connection test failed');
      });
    }

    // Load existing settings on page load
    document.addEventListener('DOMContentLoaded', function() {
      loadEmailSettings();
    });

    function loadEmailSettings() {
      fetch('/email-settings/load')
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            // Populate email config
            if (data.config) {
              Object.keys(data.config).forEach(key => {
                const element = document.getElementById(key);
                if (element) {
                  if (element.type === 'checkbox') {
                    element.checked = data.config[key];
                  } else {
                    element.value = data.config[key];
                  }
                }
              });
            }
            
            // Populate alert settings
            if (data.reminders) {
              Object.keys(data.reminders).forEach(key => {
                const element = document.getElementById(key);
                if (element) {
                  if (element.type === 'checkbox') {
                    element.checked = data.reminders[key];
                  } else {
                    element.value = data.reminders[key];
                  }
                }
              });
            }
            
            // Populate templates
            if (data.templates) {
              // Service reminder template
              if (data.templates.service_reminder) {
                document.getElementById('service_reminder_subject').value = data.templates.service_reminder.subject || '';
                document.getElementById('service_reminder_template').value = data.templates.service_reminder.template || '';
              }
              
              // Issue alert template
              if (data.templates.issue_alert) {
                document.getElementById('issue_alert_subject').value = data.templates.issue_alert.subject || '';
                document.getElementById('issue_alert_template').value = data.templates.issue_alert.template || '';
              }
              
              // Status change template
              if (data.templates.status_change) {
                document.getElementById('status_change_subject').value = data.templates.status_change.subject || '';
                document.getElementById('status_change_template').value = data.templates.status_change.template || '';
              }
            }
          }
        })
        .catch(error => {
          console.error('Error loading settings:', error);
        });
    }
  </script>

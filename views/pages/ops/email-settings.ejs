<%- include('../../partials/_head', { title: 'Email Settings - Operations Management' }) %>

<body class="bg-gray-50 dark:bg-gray-900">
  <%- include('../../partials/_header', { user: user }) %>

  <div class="min-h-screen">
    <%- include('../../partials/_subnav', { user: user }) %>

    <div>
      <div class="px-4 sm:px-6 lg:px-8 py-8">
        <!-- Main Content Container -->
        <div class="max-w-5xl mx-auto">
          
          <!-- Page Header -->
          <div class="mb-6">
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Email Settings</h1>
            <p class="text-gray-600 dark:text-gray-300">Configure email alerts and notification preferences</p>
          </div>

          <!-- Horizontal Navigation Menu -->
          <div class="mb-8">
            <nav class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-2">
              <div class="flex flex-wrap gap-2">
                <a href="#email-config" onclick="scrollToSection('email-config', event)" class="nav-link flex items-center px-4 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors">
                  <svg class="w-4 h-4 mr-2 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                  <span class="hidden sm:inline">Email Configuration</span>
                  <span class="sm:hidden">Email Config</span>
                </a>
                <a href="#alert-settings" onclick="scrollToSection('alert-settings', event)" class="nav-link flex items-center px-4 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors">
                  <svg class="w-4 h-4 mr-2 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                  </svg>
                  <span class="hidden sm:inline">Alert Settings</span>
                  <span class="sm:hidden">Alerts</span>
                </a>
                <a href="#email-templates" onclick="scrollToSection('email-templates', event)" class="nav-link flex items-center px-4 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors">
                  <svg class="w-4 h-4 mr-2 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                  </svg>
                  <span class="hidden sm:inline">Email Templates</span>
                  <span class="sm:hidden">Templates</span>
                </a>
                <a href="#test-email" onclick="scrollToSection('test-email', event)" class="nav-link flex items-center px-4 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors">
                  <svg class="w-4 h-4 mr-2 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <span class="hidden sm:inline">Test Email</span>
                  <span class="sm:hidden">Test</span>
                </a>
              </div>
            </nav>
          </div>

          <!-- Settings Sections -->
          <div class="space-y-6">
          
          <!-- Email Configuration -->
          <div id="email-config" class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 scroll-mt-8">
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white flex items-center">
                <svg class="w-5 h-5 mr-2 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                Email Configuration
              </h2>
              <p class="text-sm text-gray-600 dark:text-gray-300 mt-1">Configure Zoho mail SMTP settings</p>
            </div>
            <div class="p-6">
              <form id="emailConfigForm" class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div>
                    <label for="smtp_host" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                      SMTP Host
                    </label>
                    <input type="text" id="smtp_host" name="smtp_host" value="smtp.zoho.com" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="smtp.zoho.com">
                  </div>
                  <div>
                    <label for="smtp_port" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                      SMTP Port
                    </label>
                    <input type="number" id="smtp_port" name="smtp_port" value="587" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="587">
                  </div>
                  <div>
                    <label for="smtp_user" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                      Email Address
                    </label>
                    <input type="email" id="smtp_user" name="smtp_user" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="your-email@yourdomain.com">
                  </div>
                  <div>
                    <label for="smtp_pass" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                      App Password
                    </label>
                    <input type="password" id="smtp_pass" name="smtp_pass" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Your Zoho app password">
                  </div>
                </div>
                <div class="flex items-center">
                  <input type="checkbox" id="smtp_secure" name="smtp_secure" class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 dark:border-gray-600 rounded">
                  <label for="smtp_secure" class="ml-2 block text-sm text-gray-900 dark:text-white">
                    Use TLS/SSL encryption
                  </label>
                </div>
                <div class="flex justify-end">
                  <button type="button" onclick="testEmailConnection()" class="px-4 py-2 bg-gray-600 text-white text-sm font-medium rounded-lg hover:bg-gray-700 transition-colors mr-3">
                    Test Connection
                  </button>
                  <button type="submit" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
                    Save Configuration
                  </button>
                </div>
              </form>
            </div>
          </div>

          <!-- Alert Settings -->
          <div id="alert-settings" class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 scroll-mt-8">
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white flex items-center">
                <svg class="w-5 h-5 mr-2 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                </svg>
                Alert Settings
              </h2>
              <p class="text-sm text-gray-600 dark:text-gray-300 mt-1">Configure recipients and frequencies for different alert types</p>
            </div>
            <div class="p-6">
              <form id="alertSettingsForm" class="space-y-6">
                
                <!-- Service Reminder Settings -->
                <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
                  <h3 class="text-md font-medium text-gray-900 dark:text-white mb-4 flex items-center">
                    <svg class="w-4 h-4 mr-2 text-blue-500 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    Service Reminders
                  </h3>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                      <label for="reminder_enabled" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                        Enable Service Reminders
                      </label>
                      <div class="flex items-center">
                        <input type="checkbox" id="reminder_enabled" name="reminder_enabled" class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 dark:border-gray-600 rounded">
                        <label for="reminder_enabled" class="ml-2 block text-sm text-gray-900 dark:text-white">
                          Send automatic service reminder emails
                        </label>
                      </div>
                    </div>
                    <div>
                      <label for="reminder_frequency" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                        Reminder Frequency
                      </label>
                      <select id="reminder_frequency" name="reminder_frequency" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <option value="daily">Daily</option>
                        <option value="weekly">Weekly</option>
                        <option value="biweekly">Bi-weekly</option>
                        <option value="monthly">Monthly</option>
                      </select>
                    </div>
                    <div>
                      <label for="reminder_days_before" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                        Days Before Deadline
                      </label>
                      <input type="number" id="reminder_days_before" name="reminder_days_before" min="1" max="30" value="7" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="7">
                    </div>
                    <div>
                      <label for="reminder_recipients" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                        Service Reminder Recipients
                      </label>
                      <textarea id="reminder_recipients" name="reminder_recipients" rows="2" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Enter email addresses separated by commas"></textarea>
                    </div>
                  </div>
                </div>

                <!-- Issue Alert Settings -->
                <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
                  <h3 class="text-md font-medium text-gray-900 dark:text-white mb-4 flex items-center">
                    <svg class="w-4 h-4 mr-2 text-red-500 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                    </svg>
                    Issue Alerts
                  </h3>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                      <label for="issue_alert_enabled" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                        Issue Report Alerts
                      </label>
                      <div class="flex items-center">
                        <input type="checkbox" id="issue_alert_enabled" name="issue_alert_enabled" class="h-4 w-4 text-red-600 focus:ring-red-500 border-gray-300 dark:border-gray-600 rounded">
                        <label for="issue_alert_enabled" class="ml-2 block text-sm text-gray-900 dark:text-white">
                          Send immediate alerts for reported issues
                        </label>
                      </div>
                    </div>
                    <div>
                      <label for="issue_status_change_enabled" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                        Status Change Alerts
                      </label>
                      <div class="flex items-center">
                        <input type="checkbox" id="issue_status_change_enabled" name="issue_status_change_enabled" class="h-4 w-4 text-orange-600 focus:ring-orange-500 border-gray-300 dark:border-gray-600 rounded">
                        <label for="issue_status_change_enabled" class="ml-2 block text-sm text-gray-900 dark:text-white">
                          Send alerts when issue status changes
                        </label>
                      </div>
                    </div>
                    <div class="md:col-span-2">
                      <label for="issue_alert_recipients" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                        Issue Alert Recipients
                      </label>
                      <textarea id="issue_alert_recipients" name="issue_alert_recipients" rows="2" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-red-500 focus:border-red-500" placeholder="Enter email addresses separated by commas"></textarea>
                      <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">These recipients will receive both issue report alerts and status change alerts</p>
                    </div>
                  </div>
                </div>

                <!-- Material Management Alerts -->
                <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
                  <h3 class="text-md font-medium text-gray-900 dark:text-white mb-4 flex items-center">
                    <svg class="w-4 h-4 mr-2 text-green-500 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                    </svg>
                    Material Management Alerts
                  </h3>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                      <label for="material_transaction_alerts" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                        Material Transaction Alerts
                      </label>
                      <div class="flex items-center">
                        <input type="checkbox" id="material_transaction_alerts" name="material_transaction_alerts" class="h-4 w-4 text-green-600 focus:ring-green-500 border-gray-300 dark:border-gray-600 rounded">
                        <label for="material_transaction_alerts" class="ml-2 block text-sm text-gray-900 dark:text-white">
                          Send alerts for all material transactions
                        </label>
                      </div>
                    </div>
                    <div>
                      <label for="low_stock_alerts" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                        Low Stock Alerts
                      </label>
                      <div class="flex items-center">
                        <input type="checkbox" id="low_stock_alerts" name="low_stock_alerts" class="h-4 w-4 text-yellow-600 focus:ring-yellow-500 border-gray-300 dark:border-gray-600 rounded">
                        <label for="low_stock_alerts" class="ml-2 block text-sm text-gray-900 dark:text-white">
                          Send alerts when materials reach low stock threshold
                        </label>
                      </div>
                    </div>
                    <div class="md:col-span-2">
                      <label for="material_alert_recipients" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                        Material Alert Recipients
                      </label>
                      <textarea id="material_alert_recipients" name="material_alert_recipients" rows="2" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-green-500 focus:border-green-500" placeholder="Enter email addresses separated by commas"></textarea>
                      <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">These recipients will receive material transaction and low stock alerts</p>
                    </div>
                  </div>
                </div>

                <div class="flex justify-end">
                  <button type="submit" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
                    Save Alert Settings
                  </button>
                </div>
              </form>
            </div>
          </div>

          <!-- Email Templates -->
          <div id="email-templates" class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 scroll-mt-8">
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white flex items-center">
                <svg class="w-5 h-5 mr-2 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                Email Templates
              </h2>
              <p class="text-sm text-gray-600 dark:text-gray-300 mt-1">Customize email templates for different alert types</p>
            </div>
            <div class="p-6">
              
              <!-- Template Tabs -->
              <div class="mb-6">
                <div class="bg-gray-100 dark:bg-gray-700 rounded-lg p-1 flex">
                  <button onclick="showTemplate('service_reminder')" id="tab-service_reminder" class="template-tab flex-1 flex items-center justify-center py-3 px-4 rounded-md font-medium text-sm transition-all duration-200 bg-white dark:bg-gray-800 text-blue-600 dark:text-blue-400 shadow-sm">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    Service Reminder
                  </button>
                  <button onclick="showTemplate('issue_alert')" id="tab-issue_alert" class="template-tab flex-1 flex items-center justify-center py-3 px-4 rounded-md font-medium text-sm transition-all duration-200 text-gray-600 dark:text-gray-300 hover:text-gray-800 dark:hover:text-white hover:bg-gray-50 dark:hover:bg-gray-700/50">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                    </svg>
                    Issue Alert
                  </button>
                  <button onclick="showTemplate('status_change')" id="tab-status_change" class="template-tab flex-1 flex items-center justify-center py-3 px-4 rounded-md font-medium text-sm transition-all duration-200 text-gray-600 dark:text-gray-300 hover:text-gray-800 dark:hover:text-white hover:bg-gray-50 dark:hover:bg-gray-700/50">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    Status Change
                  </button>
                  <button onclick="showTemplate('material_transaction')" id="tab-material_transaction" class="template-tab flex-1 flex items-center justify-center py-3 px-4 rounded-md font-medium text-sm transition-all duration-200 text-gray-600 dark:text-gray-300 hover:text-gray-800 dark:hover:text-white hover:bg-gray-50 dark:hover:bg-gray-700/50">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                    </svg>
                    Material Transaction
                  </button>
                  <button onclick="showTemplate('low_stock_alert')" id="tab-low_stock_alert" class="template-tab flex-1 flex items-center justify-center py-3 px-4 rounded-md font-medium text-sm transition-all duration-200 text-gray-600 dark:text-gray-300 hover:text-gray-800 dark:hover:text-white hover:bg-gray-50 dark:hover:bg-gray-700/50">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                    </svg>
                    Low Stock Alert
                  </button>
                </div>
              </div>

              <!-- Service Reminder Template -->
              <div id="template-service_reminder" class="template-content">
                <form id="serviceReminderTemplateForm" class="space-y-4">
                  <div>
                    <label for="service_reminder_subject" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                      Email Subject
                    </label>
                    <input type="text" id="service_reminder_subject" name="subject" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Service Reminder: {service_type} due for {machine_name}">
                  </div>
                  <div>
                    <label for="service_reminder_template" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                      Email Template
                    </label>
                    <textarea id="service_reminder_template" name="template" rows="8" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Enter your email template here..."></textarea>
                  </div>
                  <div class="flex justify-end">
                    <button type="submit" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
                      Save Service Reminder Template
                    </button>
                  </div>
                </form>
              </div>

              <!-- Issue Alert Template -->
              <div id="template-issue_alert" class="template-content hidden">
                <form id="issueAlertTemplateForm" class="space-y-4">
                  <div>
                    <label for="issue_alert_subject" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                      Email Subject
                    </label>

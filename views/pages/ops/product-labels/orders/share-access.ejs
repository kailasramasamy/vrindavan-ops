<%- include('../../../../partials/_head', { seo, pageKey }) %>

<!-- Initialize theme immediately to prevent flash -->
<script>
  (function () {
    const theme = localStorage.getItem("theme") || "dark";
    if (theme === "dark") {
      document.documentElement.classList.add("dark");
    } else {
      document.documentElement.classList.remove("dark");
    }
  })();
</script>

<body class="bg-slate-50 dark:bg-gray-900">
  <div class="min-h-screen flex items-center justify-center px-4 py-12">
    <div class="max-w-md w-full">
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-lg p-8">
        <div class="text-center mb-6">
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Access Order</h1>
          <p class="text-sm text-gray-600 dark:text-gray-400">Enter the 6-digit passcode to view the order</p>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
        <div class="mb-4 p-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg">
          <p class="text-sm text-red-800 dark:text-red-300"><%= error %></p>
        </div>
        <% } %>

        <form method="POST" action="/product-labels/orders/share/<%= shareCode %>" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Passcode</label>
            <input
              type="text"
              name="passcode"
              maxlength="6"
              pattern="[0-9]{6}"
              required
              autocomplete="off"
              class="w-full px-4 py-3 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg text-center text-2xl font-mono tracking-widest text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              placeholder="000000"
              autofocus
            />
            <p class="mt-2 text-xs text-gray-500 dark:text-gray-400 text-center">Enter the 6-digit passcode provided by the order creator</p>
          </div>

          <button
            type="submit"
            class="w-full px-4 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition-colors"
          >
            Access Order
          </button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>


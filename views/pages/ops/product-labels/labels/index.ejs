<%- include('../../../../partials/_head', { seo, pageKey }) %>

<!-- Initialize theme immediately to prevent flash -->
<script>
  (function () {
    const theme = localStorage.getItem("theme") || "dark";
    if (theme === "dark") {
      document.documentElement.classList.add("dark");
    } else {
      document.documentElement.classList.remove("dark");
    }
  })();
</script>

<style>
  .dark input[type="text"],
  .dark input[type="number"],
  .dark textarea,
  .dark select {
    color-scheme: dark;
  }
</style>

<body class="bg-slate-50 dark:bg-gray-900">
  <%- include('../../../../partials/_subnav', { user, section: 'Product Labels', subsection: 'Label Management' }) %>

  <div class="min-h-screen pt-16">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
        <div>
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">Product Labels Management</h1>
          <p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 mt-1">
            Setup and manage product label profiles with design files.
          </p>
        </div>
        <div class="flex items-center gap-3">
          <button id="createLabelBtn" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition-colors">
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
              </svg>
              Add Label
            </span>
          </button>
        </div>
      </div>

      <!-- Filters and Search -->
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4 mb-6">
        <div class="flex flex-col sm:flex-row gap-4">
          <div class="flex-1">
            <input
              type="text"
              id="searchInput"
              placeholder="Search by label name or product name..."
              class="w-full px-4 py-2 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            />
          </div>
          <div class="sm:w-48">
            <select
              id="productFilter"
              class="w-full px-4 py-2 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            >
              <option value="">All Products</option>
              <% if (products && products.length > 0) { %>
                <% products.forEach(product => { %>
                  <option value="<%= product.id %>"><%= product.name %></option>
                <% }); %>
              <% } %>
            </select>
          </div>
          <div class="sm:w-40">
            <select
              id="activeFilter"
              class="w-full px-4 py-2 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            >
              <option value="">All Status</option>
              <option value="true">Active</option>
              <option value="false">Inactive</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Labels Table -->
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-900">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Design</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Label Name</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Unit Size</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Label Type</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Label Material</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Cutting</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Design File</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody id="labelsTableBody" class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
              <tr id="labelsLoadingRow">
                <td colspan="9" class="px-6 py-12 text-center">
                  <div class="flex flex-col items-center justify-center gap-3">
                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
                    <p class="text-sm text-gray-500 dark:text-gray-400">Loading labels...</p>
                  </div>
                </td>
              </tr>
              <tr id="labelsEmptyRow" class="hidden">
                <td colspan="9" class="px-6 py-6 text-center text-gray-500 dark:text-gray-400 text-sm">
                  No labels found. Click "Add Label" to create one.
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>

  <!-- Create/Edit Label Modal -->
  <div id="labelModal" class="hidden fixed inset-0 z-50 overflow-y-auto">
    <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
      <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" onclick="closeLabelModal()"></div>
      <div class="inline-block align-bottom bg-white dark:bg-gray-800 rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-2xl sm:w-full">
        <form id="labelForm" enctype="multipart/form-data">
          <div class="bg-white dark:bg-gray-800 px-6 py-4 border-b border-gray-200 dark:border-gray-700">
            <div class="flex items-center justify-between">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white" id="modalTitle">Add Product Label</h3>
              <button type="button" onclick="closeLabelModal()" class="text-gray-400 hover:text-gray-500 dark:hover:text-gray-300">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </button>
            </div>
          </div>
          <div class="bg-white dark:bg-gray-800 px-6 py-4 space-y-4">
            <input type="hidden" id="labelId" name="labelId" />
            
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Product *</label>
              <div class="relative">
                <input
                  type="text"
                  id="productSearch"
                  autocomplete="off"
                  class="w-full px-4 py-2 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                  placeholder="Search and select product..."
                />
                <input type="hidden" id="productId" name="product_id" required />
                <input type="hidden" id="productName" name="name" />
                <div id="productDropdown" class="hidden absolute z-[100] w-full mt-1 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-600 rounded-lg shadow-lg max-h-60 overflow-auto">
                  <!-- Product options will be populated here -->
                </div>
              </div>
              <p class="mt-1 text-xs text-gray-500 dark:text-gray-400" id="selectedProductInfo"></p>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Label Type *</label>
                <select
                  id="labelType"
                  name="label_type"
                  required
                  class="w-full px-4 py-2 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                >
                  <option value="sticker">Sticker</option>
                  <option value="sheet">Sheet</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Label Material *</label>
                <select
                  id="labelMaterial"
                  name="label_material"
                  required
                  class="w-full px-4 py-2 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                >
                  <option value="transparent pvc">Transparent PVC</option>
                  <option value="white pvc" selected>White PVC</option>
                  <option value="regular sheet">Regular Sheet</option>
                  <option value="regular 78mm cut sheet">Regular 78mm Cut Sheet</option>
                </select>
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Cutting *</label>
              <select
                id="cutting"
                name="cutting"
                required
                class="w-full px-4 py-2 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              >
                <option value="Full">Full</option>
                <option value="Half">Half</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Design File (PDF)</label>
              <input
                type="file"
                id="designFile"
                name="design_file"
                accept=".pdf"
                class="w-full px-4 py-2 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              />
              <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Upload PDF design file (max 10MB)</p>
              <div id="existingFile" class="hidden mt-2">
                <p class="text-sm text-gray-600 dark:text-gray-400">Current file: <span id="currentFileName" class="font-medium"></span></p>
                <a id="currentFileLink" href="#" target="_blank" class="text-blue-600 dark:text-blue-400 hover:underline text-sm">View/Download</a>
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Notes</label>
              <textarea
                id="notes"
                name="notes"
                rows="3"
                class="w-full px-4 py-2 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                placeholder="Additional notes..."
              ></textarea>
            </div>

            <div>
              <label class="flex items-center gap-2">
                <input
                  type="checkbox"
                  id="active"
                  name="active"
                  checked
                  class="w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500"
                />
                <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Active</span>
              </label>
            </div>
          </div>
          <div class="bg-gray-50 dark:bg-gray-700 px-6 py-4 flex justify-end gap-3">
            <button
              type="button"
              onclick="closeLabelModal()"
              class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-600 border border-gray-300 dark:border-gray-500 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-500 transition-colors"
            >
              Cancel
            </button>
            <button
              type="submit"
              class="px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors"
            >
              Save Label
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    // Pass products data to frontend (must be before the script loads)
    window.PRODUCTS_DATA = <%- JSON.stringify(products || []) %>;
  </script>
  <script src="/assets/js/product-labels.js?v=<%= Date.now() %>" defer></script>
  <%- include('../../../../partials/_toast') %>
</body>
</html>



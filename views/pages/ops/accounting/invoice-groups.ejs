    // Remove transaction from invoice group
    async function removeTransactionFromInvoice(transactionId) {
      if (!currentInvoiceId) return;
      
      if (!confirm('Are you sure you want to remove this transaction from the invoice group?')) {
        return;
      }
      
      try {
        const response = await fetch('/accounting/invoice-groups/remove-transaction', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          credentials: 'same-origin',
          body: JSON.stringify({
            invoiceId: currentInvoiceId,
            transactionId: transactionId
          })
        });
        
        const data = await response.json();
        
        if (data.success) {
          showToast('Transaction removed from invoice group successfully', '', 'success');
          // Reload the invoice details to update the transactions list
          viewInvoiceDetails(currentInvoiceId);
          // Also reload the main invoice groups list
          loadInvoiceGroups();
        } else {
          showToast('Error removing transaction from invoice group', data.error, 'error');
        }
      } catch (error) {
        console.error('Error removing transaction from invoice group:', error);
        showToast('Error removing transaction from invoice group', '', 'error');
      }
    }

    // Upload invoice file for invoice group
    async function uploadInvoiceGroupFile() {
      if (!currentInvoiceId) return;
      
      const fileInput = document.getElementById('invoiceGroupFileInput');
      const uploadBtn = document.getElementById('uploadInvoiceGroupBtn');
      
      const file = fileInput.files[0];
      if (!file) {
        showToast('Please select a file', '', 'error');
        return;
      }

      const formData = new FormData();
      formData.append('invoice', file);

      try {
        uploadBtn.disabled = true;
        uploadBtn.innerHTML = '<span class="inline-block animate-spin mr-1">⏳</span> Uploading...';

        const response = await fetch(`/accounting/invoice-groups/${currentInvoiceId}/upload`, {
          method: 'POST',
          body: formData,
          credentials: 'same-origin'
        });

        const result = await response.json();

        if (result.success) {
          showToast(`Invoice uploaded successfully for ${result.affectedRows} transactions`, '', 'success');
          closeInvoiceDetailsModal();
          loadInvoiceGroups();
        } else {
          showToast(result.error || 'Failed to upload invoice', '', 'error');
        }
      } catch (error) {
        console.error('Error uploading invoice group file:', error);
        showToast('Error uploading invoice', '', 'error');
      } finally {
        uploadBtn.disabled = false;
        uploadBtn.innerHTML = 'Upload Invoice File';
      }
    }

    // Delete invoice file for invoice group
    async function deleteInvoiceGroupFile(invoiceId) {
      if (!confirm('Are you sure you want to delete this invoice? This action cannot be undone.')) {
        return;
      }

      try {
        const response = await fetch(`/accounting/invoice-groups/${invoiceId}/delete-invoice`, {
          method: 'DELETE',
          credentials: 'same-origin'
        });

        const result = await response.json();

        if (result.success) {
          showToast('Invoice deleted successfully', '', 'success');
          // Reload the modal to show the updated state
          viewInvoiceDetails(invoiceId);
          // Also reload the main invoice groups list
          loadInvoiceGroups();
        } else {
          showToast(result.error || 'Failed to delete invoice', '', 'error');
        }
      } catch (error) {
        console.error('Error deleting invoice group file:', error);
        showToast('Error deleting invoice', '', 'error');
      }
    }

    // Open edit invoice modal
    // Edit invoice group from table
    function editInvoiceGroup(invoiceId) {
      currentInvoiceId = invoiceId;
      openEditInvoiceModal();
    }

    function openEditInvoiceModal() {
      if (!currentInvoiceId) {
        showToast('No invoice group selected', '', 'error');
        return;
      }

      // Find the current invoice group data
      const currentInvoice = invoiceGroups.find(ig => ig.id === currentInvoiceId);
      if (!currentInvoice) {
        showToast('Invoice group data not found', '', 'error');
        return;
      }

      // Populate the edit form with current data
      document.getElementById('editInvoiceNumber').value = currentInvoice.invoice_number || '';
      
      // Format dates for HTML date inputs (convert from ISO to yyyy-MM-dd)
      if (currentInvoice.invoice_date) {
        const invoiceDate = new Date(currentInvoice.invoice_date);
        document.getElementById('editInvoiceDate').value = invoiceDate.toISOString().split('T')[0];
      } else {
        document.getElementById('editInvoiceDate').value = '';
      }
      
      if (currentInvoice.due_date) {
        const dueDate = new Date(currentInvoice.due_date);
        document.getElementById('editDueDate').value = dueDate.toISOString().split('T')[0];
      } else {
        document.getElementById('editDueDate').value = '';
      }
      
      document.getElementById('editDescription').value = currentInvoice.description || '';
      document.getElementById('editTotalAmount').value = currentInvoice.total_amount || '';

      // Load beneficiaries and remitters for dropdowns
      loadBeneficiariesAndRemittersForEdit();

      // Show the modal
      document.getElementById('editInvoiceModal').classList.remove('hidden');
    }

    // Close edit invoice modal
    function closeEditInvoiceModal() {
      document.getElementById('editInvoiceModal').classList.add('hidden');
    }

    // Load beneficiaries and remitters for edit form
    async function loadBeneficiariesAndRemittersForEdit() {
      try {
        // Load beneficiaries using the API endpoint
        const beneficiariesResponse = await fetch('/accounting/api/beneficiaries', {
          credentials: 'same-origin'
        });
        
        if (beneficiariesResponse.ok) {
          const beneficiariesData = await beneficiariesResponse.json();
          const beneficiarySelect = document.getElementById('editBeneficiaryId');
          beneficiarySelect.innerHTML = '<option value="">Select Beneficiary</option>';
          
          if (beneficiariesData.success && beneficiariesData.beneficiaries) {
            beneficiariesData.beneficiaries.forEach(beneficiary => {
              const option = document.createElement('option');
              option.value = beneficiary.id;
              option.textContent = beneficiary.beneficiary_name;
              beneficiarySelect.appendChild(option);
            });
          } else {
            console.warn('No beneficiaries data received:', beneficiariesData);
          }
        } else {
          console.warn('Failed to load beneficiaries:', beneficiariesResponse.status);
        }

        // Load remitters using the API endpoint
        const remittersResponse = await fetch('/accounting/api/remitters', {
          credentials: 'same-origin'
        });
        
        if (remittersResponse.ok) {
          const remittersData = await remittersResponse.json();
          const remitterSelect = document.getElementById('editRemitterId');
          remitterSelect.innerHTML = '<option value="">Select Remitter</option>';
          
          if (remittersData.success && remittersData.remitters) {
            remittersData.remitters.forEach(remitter => {
              const option = document.createElement('option');
              option.value = remitter.id;
              option.textContent = remitter.remitter_name;
              remitterSelect.appendChild(option);
            });
          }
        } else {
          console.warn('Failed to load remitters:', remittersResponse.status);
        }

        // Set current values
        const currentInvoice = invoiceGroups.find(ig => ig.id === currentInvoiceId);
        if (currentInvoice) {
          document.getElementById('editBeneficiaryId').value = currentInvoice.beneficiary_id || '';
          document.getElementById('editRemitterId').value = currentInvoice.remitter_id || '';
        }

      } catch (error) {
        console.error('Error loading beneficiaries and remitters:', error);
        showToast('Error loading form data', '', 'error');
      }
    }

    // Handle edit invoice form submission
    document.addEventListener('DOMContentLoaded', function() {
      const editForm = document.getElementById('editInvoiceForm');
      if (editForm) {
        editForm.addEventListener('submit', async function(e) {
          e.preventDefault();
          
          if (!currentInvoiceId) {
            showToast('No invoice group selected', '', 'error');
            return;
          }

          const formData = {
            invoice_number: document.getElementById('editInvoiceNumber').value,
            invoice_date: document.getElementById('editInvoiceDate').value,
            due_date: document.getElementById('editDueDate').value,
            description: document.getElementById('editDescription').value,
            beneficiary_id: document.getElementById('editBeneficiaryId').value || null,
            remitter_id: document.getElementById('editRemitterId').value || null,
            total_amount: parseFloat(document.getElementById('editTotalAmount').value) || 0
          };

          try {
            const response = await fetch(`/accounting/invoice-groups/${currentInvoiceId}/update`, {
              method: 'PUT',
              headers: {
                'Content-Type': 'application/json',
              },
              credentials: 'same-origin',
              body: JSON.stringify(formData)
            });

            const result = await response.json();

            if (result.success) {
              showToast('Invoice group updated successfully', '', 'success');
              closeEditInvoiceModal();
              // Reload the invoice groups list
              loadInvoiceGroups();
              // Reload the current invoice details
              viewInvoiceDetails(currentInvoiceId);
            } else {
              showToast('Error updating invoice group', result.error, 'error');
            }
          } catch (error) {
            console.error('Error updating invoice group:', error);
            showToast('Error updating invoice group', '', 'error');
          }
        });
      }
    });

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', function() {
      loadStatistics();
      loadInvoiceGroups();
      
      // Add event listener for invoice group file input (delegated)
      document.addEventListener('change', function(e) {
        if (e.target && e.target.id === 'invoiceGroupFileInput') {
          const uploadBtn = document.getElementById('uploadInvoiceGroupBtn');
          if (uploadBtn) {
            uploadBtn.classList.toggle('hidden', !e.target.files.length);
          }
        }
      });
    });
  </script>
</body>
</html>

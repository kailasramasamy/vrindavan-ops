    // Load invoice groups
    async function loadInvoiceGroups() {
      try {
        const status = document.getElementById('statusFilter').value;
        const startDate = document.getElementById('startDate').value;
        const endDate = document.getElementById('endDate').value;
        
        let url = '/accounting/invoice-groups/list?';
        const params = new URLSearchParams();
        
        if (status) params.append('status', status);
        if (startDate) params.append('start_date', startDate);
        if (endDate) params.append('end_date', endDate);
        
        url += params.toString();
        
        const response = await fetch(url, {
          credentials: 'same-origin'
        });
        
        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }
        
        const data = await response.json();
        
        if (data.success) {
          invoiceGroups = data.invoices;
          renderInvoiceGroupsTable();
        } else {
          showToast('Error loading invoice groups', data.error, 'error');
        }
      } catch (error) {
        console.error('Error loading invoice groups:', error);
        showToast('Error loading invoice groups', error.message, 'error');
        
        // Show fallback table
        const tbody = document.getElementById('invoiceGroupsTableBody');
        tbody.innerHTML = `
          <tr>
            <td colspan="8" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400">
              Error loading invoice groups. Please refresh the page.
            </td>
          </tr>
        `;
      }
    }

    // Render invoice groups table
    function renderInvoiceGroupsTable() {
      const tbody = document.getElementById('invoiceGroupsTableBody');
      
      if (invoiceGroups.length === 0) {
        tbody.innerHTML = `
          <tr>
            <td colspan="8" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400">
              No invoice groups found
            </td>
          </tr>
        `;
        return;
      }
      
      tbody.innerHTML = invoiceGroups.map(invoice => {
        const statusColors = {
          pending: 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-200',
          partial: 'bg-orange-100 dark:bg-orange-900/30 text-orange-800 dark:text-orange-200',
          paid: 'bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-200',
          overdue: 'bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-200'
        };
        
        return `
          <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
            <td class="px-6 py-4 text-sm font-medium text-gray-900 dark:text-white">
              ${invoice.invoice_number}
            </td>
            <td class="px-6 py-4 text-sm text-gray-900 dark:text-white">
              ${new Date(invoice.invoice_date).toLocaleDateString()}
            </td>
            <td class="px-6 py-4 text-sm text-gray-900 dark:text-white">
              <div class="flex flex-col">
                ${invoice.all_beneficiaries_remitters ? 
                  `<div class="space-y-1" title="${invoice.all_beneficiaries_remitters}">
                    ${invoice.all_beneficiaries_remitters.split(', ').slice(0, 3).map(name => 
                      `<span class="inline-block px-2 py-1 text-xs bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded-md mr-1 mb-1">${name}</span>`
                    ).join('')}
                    ${invoice.all_beneficiaries_remitters.split(', ').length > 3 ? 
                      `<span class="inline-block px-2 py-1 text-xs bg-gray-50 dark:bg-gray-700 text-gray-600 dark:text-gray-400 rounded-md mr-1 mb-1">+${invoice.all_beneficiaries_remitters.split(', ').length - 3} more</span>` : 
                      ''
                    }
                  </div>` : 
                  (invoice.beneficiary_name || invoice.remitter_name ? 
                    `<span class="font-medium text-blue-600 dark:text-blue-400">${invoice.beneficiary_name || invoice.remitter_name}</span>` : 
                    '<span class="text-gray-500 dark:text-gray-400">-</span>'
                  )
                }
                ${invoice.transaction_count > 0 ? 
                  `<span class="text-xs text-gray-500 dark:text-gray-400 mt-1">${invoice.transaction_count} transaction${invoice.transaction_count === 1 ? '' : 's'}</span>` :
                  ''
                }
              </div>
            </td>
            <td class="px-6 py-4 text-right text-sm font-semibold text-gray-900 dark:text-white indian-currency" data-amount="${Math.round(parseFloat(invoice.total_amount))}">
              ₹${Math.round(parseFloat(invoice.total_amount))}
            </td>
            <td class="px-6 py-4 text-right text-sm text-gray-900 dark:text-white indian-currency" data-amount="${Math.round(parseFloat(invoice.paid_amount))}">
              ₹${Math.round(parseFloat(invoice.paid_amount))}
            </td>
            <td class="px-6 py-4 text-right text-sm text-gray-900 dark:text-white indian-currency" data-amount="${Math.round(parseFloat(invoice.remaining_amount))}">
              ₹${Math.round(parseFloat(invoice.remaining_amount))}
            </td>
            <td class="px-6 py-4 text-center">
              <span class="px-2 py-1 text-xs rounded-full ${statusColors[invoice.status]}">
                ${invoice.status.charAt(0).toUpperCase() + invoice.status.slice(1)}
              </span>
            </td>
            <td class="px-6 py-4 text-center">
              <div class="flex items-center justify-center gap-3">
                <button onclick="viewInvoiceDetails('${invoice.id}')" class="text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 text-sm font-medium">
                  View
                </button>
                <button onclick="editInvoiceGroup('${invoice.id}')" class="text-purple-600 dark:text-purple-400 hover:text-purple-800 dark:hover:text-purple-300 text-sm font-medium">
                  Edit
                </button>
              </div>
            </td>
          </tr>
        `;
      }).join('');
      
      // Format currency
      const currencyElements = tbody.querySelectorAll('.indian-currency');
      currencyElements.forEach(element => {
        const amount = element.getAttribute('data-amount');
        if (amount !== null && amount !== undefined) {
          element.textContent = formatIndianCurrency(parseFloat(amount));
        }
      });
    }

    // Modal functions
    function openCreateInvoiceModal() {
      document.getElementById('createInvoiceModal').classList.remove('hidden');
      document.getElementById('invoiceDate').value = new Date().toISOString().split('T')[0];
    }

    function closeCreateInvoiceModal() {
      document.getElementById('createInvoiceModal').classList.add('hidden');
      document.getElementById('createInvoiceForm').reset();
    }

    function closeInvoiceDetailsModal() {
      document.getElementById('invoiceDetailsModal').classList.add('hidden');
      currentInvoiceId = null;
    }

    // Create invoice
    document.getElementById('createInvoiceForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const formData = {
        invoice_number: document.getElementById('invoiceNumber').value,
        invoice_date: document.getElementById('invoiceDate').value,
        total_amount: parseFloat(document.getElementById('totalAmount').value),
        due_date: document.getElementById('dueDate').value || null,
        description: document.getElementById('description').value || null
      };
      
      try {
        const response = await fetch('/accounting/invoice-groups', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          credentials: 'same-origin',
          body: JSON.stringify(formData)
        });
        
        const data = await response.json();
        
        if (data.success) {
          showToast('Invoice group created successfully', '', 'success');
          closeCreateInvoiceModal();
          loadInvoiceGroups();
        } else {
          showToast('Error creating invoice group', data.error, 'error');
        }
      } catch (error) {
        console.error('Error creating invoice group:', error);
        showToast('Error creating invoice group', '', 'error');
      }
    });


    // Close invoice group details modal
    function closeInvoiceGroupDetailsModal() {
      document.getElementById("invoiceGroupDetailsModal").classList.add("hidden");
    }

    // Upload invoice group file
    async function uploadInvoiceGroupFile() {
      if (!window.currentInvoiceGroupId) return;
      
      const fileInput = document.getElementById('invoiceGroupFileInput');
      const uploadBtn = document.getElementById('uploadInvoiceGroupBtn');
      
      const file = fileInput.files[0];
      if (!file) {
        showToast('Please select a file', '', 'error');
        return;
      }

      const formData = new FormData();
      formData.append('invoice', file);

      try {
        uploadBtn.disabled = true;
        uploadBtn.innerHTML = '<span class="inline-block animate-spin mr-1">⏳</span> Uploading...';

        const response = await fetch(`/accounting/invoice-groups/${window.currentInvoiceGroupId}/upload`, {
          method: 'POST',
          body: formData,
          credentials: 'same-origin'
        });

        const result = await response.json();

        if (result.success) {
          showToast(`Invoice uploaded successfully for ${result.affectedRows} transactions`, '', 'success');
          // Reload the modal to show the updated state
          viewInvoiceGroupDetails(window.currentInvoiceGroupId);
        } else {
          showToast(result.error || 'Failed to upload invoice', '', 'error');
        }
      } catch (error) {
        console.error('Error uploading invoice group file:', error);
        showToast('Error uploading invoice', '', 'error');
      } finally {
        uploadBtn.disabled = false;
        uploadBtn.innerHTML = 'Upload Invoice File';
      }
    }

    // Mark invoice group as uploaded from modal
    async function markInvoiceGroupAsUploadedFromModal() {
      if (!window.currentInvoiceGroupId) {
        console.error('No invoice group ID available');
        return;
      }
      
      await markInvoiceGroupAsUploaded(window.currentInvoiceGroupId);
      closeInvoiceGroupDetailsModal();
    }

    // Mark invoice group as uploaded
    async function markInvoiceGroupAsUploaded(invoiceGroupId) {
      try {
        const response = await fetch(`/accounting/invoice-groups/${invoiceGroupId}/mark-uploaded`, {
          method: 'POST',
          credentials: 'same-origin'
        });
        
        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }
        
        const data = await response.json();
        
        if (data.success) {
          showToast(`Marked ${data.affectedRows} transactions as uploaded`, '', 'success');
          closeMissingInvoicesModal();
          // Refresh the missing invoices count
          loadMissingInvoicesCount();
        } else {
          showToast('Error marking invoice group as uploaded', data.error, 'error');
        }
      } catch (error) {
        console.error('Error marking invoice group as uploaded:', error);
        showToast('Error marking invoice group as uploaded', error.message, 'error');
      }
    }

    // ============= Discard Import Functionality =============
    async function openDiscardImportModal() {
      try {
        const response = await fetch('/accounting/api/transactions/recent-imports?limit=10');
        const result = await response.json();

        if (result.success && result.imports && result.imports.length > 0) {
          showDiscardImportModal(result.imports);
        } else {
          showToast("No recent imports found", "", "error");
        }
      } catch (error) {
        console.error("Error loading recent imports:", error);
        showToast("Error loading imports", "", "error");
      }
    }


      if (footer) {
        footer.style.display = 'none';
      }
    }

    // Update progress in modal
    function updateModalProgress(current, total) {
      const progressBar = document.getElementById('progressBar');
      const progressText = document.getElementById('progressText');
      
      if (progressBar) {
        const percentage = (current / total) * 100;
        progressBar.style.width = `${percentage}%`;
      }
      
      if (progressText) {
        progressText.textContent = `Updating transaction ${current} of ${total}...`;
      }
    }

    // Update modal for completion
    function updateModalForCompletion(successCount, failCount) {
      const modal = document.getElementById('similarTransactionsModal');
      if (!modal) return;
      
      const contentDiv = modal.querySelector('.p-6.overflow-y-auto');
      if (!contentDiv) return;
      
      let statusIcon = '';
      let statusText = '';
      let statusColor = '';
      
      if (failCount === 0) {
        statusIcon = '✅';
        statusText = 'All transactions updated successfully!';
        statusColor = 'text-green-600 dark:text-green-400';
      } else if (successCount === 0) {
        statusIcon = '❌';
        statusText = 'Failed to update any transactions.';
        statusColor = 'text-red-600 dark:text-red-400';
      } else {
        statusIcon = '⚠️';
        statusText = `Updated ${successCount} transactions, ${failCount} failed.`;
        statusColor = 'text-yellow-600 dark:text-yellow-400';
      }
      
      contentDiv.innerHTML = `
        <div class="text-center">
          <div class="mb-4">
            <div class="text-4xl mb-4">${statusIcon}</div>
            <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">
              Update Complete
            </h3>
            <p class="text-sm ${statusColor}">
              ${statusText}
            </p>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-2">
              You can close this window when ready
            </p>
          </div>
        </div>
      `;
      
      // Show footer with close button
      const footer = modal.querySelector('.flex.items-center.justify-end');
      if (footer) {
        footer.style.display = 'flex';
        footer.innerHTML = `
          <button onclick="closeSimilarTransactionsModal(); location.reload();" 
                  class="px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
            ✅ Close & Refresh
          </button>
        `;
      }
    }

    // Show upload button when file is selected
    document.addEventListener('DOMContentLoaded', function() {
      const fileInput = document.getElementById('invoiceFileInput');
      if (fileInput) {
        fileInput.addEventListener('change', function() {
          const uploadBtn = document.getElementById('uploadInvoiceBtn');
          if (this.files && this.files.length > 0) {
            uploadBtn.classList.remove('hidden');
          } else {
            uploadBtn.classList.add('hidden');
          }
        });
      }

      // Load counts for Quick Actions buttons
      loadQuickActionsCounts();
    });

    // Load counts for incomplete data and missing invoices
    async function loadQuickActionsCounts() {
      try {
        // Get current filter parameters
        const urlParams = new URLSearchParams(window.location.search);
        const bankAccountId = urlParams.get('bank_account_id') || '';
        const startDate = urlParams.get('start_date') || '';
        const endDate = urlParams.get('end_date') || '';

        // Build query string with filters
        const queryParams = new URLSearchParams();
        if (bankAccountId) queryParams.append('bank_account_id', bankAccountId);
        if (startDate) queryParams.append('start_date', startDate);
        if (endDate) queryParams.append('end_date', endDate);
        queryParams.append('limit', '100'); // Get up to 100 to show accurate count

        // Fetch incomplete transactions count
        const incompleteResponse = await fetch(`/accounting/api/transactions/incomplete?${queryParams.toString()}`);
        const incompleteResult = await incompleteResponse.json();
        
        if (incompleteResult.success) {
          const count = incompleteResult.transactions.length;
          document.getElementById('incompleteCount').textContent = count >= 100 ? '99+' : count;
        }

        // Build fresh query for missing invoices
        const invoiceParams = new URLSearchParams();
        if (bankAccountId) invoiceParams.append('bank_account_id', bankAccountId);
        if (startDate) invoiceParams.append('start_date', startDate);
        if (endDate) invoiceParams.append('end_date', endDate);
        invoiceParams.append('limit', '100'); // Get up to 100 to show accurate count

        // Fetch missing invoices count
        const missingInvoicesResponse = await fetch(`/accounting/api/transactions/missing-invoices/count?${invoiceParams.toString()}`);
        const missingInvoicesResult = await missingInvoicesResponse.json();
        
        if (missingInvoicesResult.success) {
          const count = missingInvoicesResult.count;
          document.getElementById('missingInvoicesCountBadge').textContent = count >= 100 ? '99+' : count;
        }
      } catch (error) {
        console.error('Error loading counts:', error);
        document.getElementById('incompleteCount').textContent = '?';
        document.getElementById('missingInvoicesCountBadge').textContent = '?';
      }
    }

    // Upload Invoice
    async function uploadInvoice() {
      const transactionId = document.getElementById('editTransactionId').value;
      const isViewMode = document.getElementById('isViewMode').value === 'true';
      
      // Check if transaction is assigned to an invoice group
      const transactionInvoiceId = document.getElementById('transactionInvoiceId').value;
      if (transactionInvoiceId && transactionInvoiceId.trim() !== '') {
        showToast('This transaction is already assigned to an invoice group. Please upload invoices at the group level.', '', 'error');
        return;
      }
      
      // Determine which file input to use based on mode
      const fileInput = isViewMode ? 
        document.getElementById('viewInvoiceFileInput') : 
        document.getElementById('invoiceFileInput');
      const uploadBtn = isViewMode ? 
        document.getElementById('viewUploadInvoiceBtn') : 
        document.getElementById('uploadInvoiceBtn');
      const currentInvoiceDisplay = isViewMode ? 
        document.getElementById('viewCurrentInvoiceDisplay') : 
        document.getElementById('currentInvoiceDisplay');
      const currentInvoiceLink = isViewMode ? 
        document.getElementById('viewCurrentInvoiceLink') : 
        document.getElementById('currentInvoiceLink');
      
      const file = fileInput.files[0];

      if (!file) {
        showToast('Please select a file', '', 'error');
        return;
      }

      // Debug: Log file details
      console.log('Uploading file:', {
        name: file.name,
        type: file.type,
        size: file.size,
        lastModified: file.lastModified
      });

      const formData = new FormData();
      formData.append('invoice', file);

      try {
        uploadBtn.disabled = true;
        uploadBtn.innerHTML = '<span class="inline-block animate-spin mr-1">⏳</span> Uploading...';

        const response = await fetch(`/accounting/transactions/${transactionId}/invoice`, {
          method: 'POST',
          body: formData
        });

        console.log('Upload response status:', response.status);
        const result = await response.json();
        console.log('Upload result:', result);

        if (result.success) {
          showToast('Invoice uploaded successfully', '', 'success');
          
          // Show current invoice display
          currentInvoiceDisplay.classList.remove('hidden');
          currentInvoiceLink.href = result.invoice_url;
          uploadBtn.classList.add('hidden');
          fileInput.value = '';
          
          // Also update the view invoice section if in view mode
          if (isViewMode) {
            document.getElementById('viewInvoiceSection').classList.remove('hidden');
            document.getElementById('viewInvoiceLink').href = result.invoice_url;
          }
          
          // Update the invoice indicator in the table row
          updateInvoiceIndicatorInTable(transactionId, result.invoice_url);
          
          // Don't close the modal - just refresh the missing invoices list if we're in the missing invoices modal
          if (window.currentMissingInvoicesModal) {
            // Ensure the Missing Invoices modal stays visible
            const missingModal = document.getElementById('missingInvoicesModal');
            if (missingModal) missingModal.classList.remove('hidden');
            // Refresh the missing invoices modal content
            reviewMissingInvoices();
          }
        } else {
          showToast(result.error || 'Failed to upload invoice', '', 'error');
        }
      } catch (error) {
        console.error('Error uploading invoice:', error);
        showToast('Error uploading invoice', '', 'error');
      } finally {
        uploadBtn.disabled = false;
        uploadBtn.innerHTML = 'Upload Invoice';
      }
    }

    // Update invoice indicator in the table row
    function updateInvoiceIndicatorInTable(transactionId, invoiceUrl) {
      const row = document.getElementById(`txn-row-${transactionId}`);
      if (!row) return;
      
      // Find the actions cell (last td in the row)
      const actionsCells = row.querySelectorAll('td');
      const actionsCell = actionsCells[actionsCells.length - 1];
      if (!actionsCell) return;
      
      // Find the invoice indicator container (first div in the actions cell)
      const indicatorContainer = actionsCell.querySelector('div.flex');
      if (!indicatorContainer) return;
      
      // Check if invoice indicator already exists
      let invoiceIndicator = indicatorContainer.querySelector('a[title="View invoice"]');
      
      if (invoiceIndicator) {
        // Update existing indicator
        invoiceIndicator.href = invoiceUrl;
      } else {
        // Remove any existing missing invoice indicator (red warning icon)
        const missingIndicator = indicatorContainer.querySelector('span[title*="Invoice required but missing"]');
        if (missingIndicator) {
          missingIndicator.remove();
        }
        
        // Create and add new invoice indicator at the beginning
        const newIndicator = document.createElement('a');
        newIndicator.href = invoiceUrl;
        newIndicator.target = '_blank';
        newIndicator.className = 'flex items-center hover:bg-gray-100 dark:hover:bg-gray-700 p-0.5 rounded';
        newIndicator.title = 'View invoice';
        newIndicator.innerHTML = `
          <svg class="w-4 h-4 text-emerald-600 dark:text-emerald-400 hover:text-emerald-700 dark:hover:text-emerald-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        `;
        indicatorContainer.insertBefore(newIndicator, indicatorContainer.firstChild);
      }
    }

    // Remove invoice indicator from the table row
    function removeInvoiceIndicatorFromTable(transactionId) {
      const row = document.getElementById(`txn-row-${transactionId}`);
      if (!row) return;
      
      // Find the actions cell (last td in the row)
      const actionsCells = row.querySelectorAll('td');
      const actionsCell = actionsCells[actionsCells.length - 1];
      if (!actionsCell) return;
      
      // Find the invoice indicator container
      const indicatorContainer = actionsCell.querySelector('div.flex');
      if (!indicatorContainer) return;
      
      // Remove the invoice indicator link
      const invoiceIndicator = indicatorContainer.querySelector('a[title="View invoice"]');
      if (invoiceIndicator) {
        invoiceIndicator.remove();
      }
    }

    // Delete Invoice
    async function deleteInvoice() {
      if (!confirm('Are you sure you want to delete this invoice?')) return;

      const transactionId = document.getElementById('editTransactionId').value;
      const isViewMode = document.getElementById('isViewMode').value === 'true';

      try {
        const response = await fetch(`/accounting/transactions/${transactionId}/invoice`, {
          method: 'DELETE'
        });

        const result = await response.json();

        if (result.success) {
          showToast('Invoice deleted successfully', '', 'success');
          
          if (isViewMode) {
            // Hide current invoice display in view mode, show upload option
            document.getElementById('viewCurrentInvoiceDisplay').classList.add('hidden');
            document.getElementById('viewUploadInvoiceBtn').classList.remove('hidden');
            document.getElementById('viewInvoiceSection').classList.add('hidden');
          } else {
            // Hide current invoice display in edit mode, show upload option
            document.getElementById('currentInvoiceDisplay').classList.add('hidden');
            document.getElementById('uploadInvoiceBtn').classList.remove('hidden');
          }
          
          // Remove the invoice indicator from the table row
          removeInvoiceIndicatorFromTable(transactionId);
        } else {
          showToast(result.error || 'Failed to delete invoice', '', 'error');
        }
      } catch (error) {
        console.error('Error deleting invoice:', error);
        showToast('Error deleting invoice', '', 'error');
      }
    }


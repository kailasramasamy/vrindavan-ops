    async function saveTransaction() {
      const transactionId = document.getElementById('editTransactionId').value;
      
      // Check if remitter field is visible (credit transaction) or beneficiary field (debit transaction)
      const isRemitterFieldVisible = !document.getElementById('editRemitterField').classList.contains('hidden');
      
      const updateData = {
        narration: document.getElementById('editNarration').value.trim() || null,
        category_id: document.getElementById('editCategory').value || null,
        payment_mode: document.getElementById('editPaymentMode').value
      };
      
      // Add beneficiary_id or remitter_id based on transaction type
      if (isRemitterFieldVisible) {
        updateData.remitter_id = document.getElementById('editRemitter').value || null;
        if (updateData.remitter_id) {
          updateData.is_matched = true;
        }
      } else {
        updateData.beneficiary_id = document.getElementById('editBeneficiary').value || null;
        if (updateData.beneficiary_id) {
          updateData.is_matched = true;
        }
      }

      try {
        const response = await fetch(`/accounting/transactions/${transactionId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(updateData)
        });

        const result = await response.json();

        if (result.success) {
          closeEditTransactionModal();
          
          // Check for similar transactions that might need the same update
          await checkSimilarTransactions(transactionId, updateData);
          
          // Only reload if no similar transactions modal was shown
          setTimeout(() => {
            if (!document.getElementById('similarTransactionsModal')) {
              showSuccessToast('Transaction updated successfully');
              setTimeout(() => location.reload(), 1500);
            }
          }, 100);
        } else {
          showToast(result.error || 'Failed to update transaction', '', 'error');
        }
      } catch (error) {
        console.error('Error saving transaction:', error);
        showToast('Error saving transaction', '', 'error');
      }
    }

    // Check for similar transactions and offer to apply same changes
    async function checkSimilarTransactions(updatedTransactionId, updateData) {
      try {
        // Only check if narration, category, or remitter was updated
        if (!updateData.narration && !updateData.category_id && !updateData.remitter_id) {
          return;
        }

        // Get the current transaction to find similar ones
        const response = await fetch(`/accounting/transactions/${updatedTransactionId}`);
        const data = await response.json();
        
        if (!data.success || !data.transaction) {
          return;
        }

        const currentTxn = data.transaction;
        
        // Find similar transactions in the current page
        // (same beneficiary/remitter OR similar description pattern)
        const similarTxns = [];
        
        // Get all transaction data from the page
        <% transactions.forEach(txn => { %>
          <% if (true) { %>
            (function() {
              const txnId = <%= txn.id %>;
              const txnBeneficiaryId = <%= txn.beneficiary_id || 'null' %>;
              const txnRemitterId = <%= txn.remitter_id || 'null' %>;
              const txnNarration = '<%= (txn.narration || '').replace(/'/g, "\\'") %>';
              const txnCategoryId = <%= txn.category_id || 'null' %>;
              const txnBeneficiaryName = '<%= (txn.beneficiary_name || '').replace(/'/g, "\\'") %>';
              const txnRemitterName = '<%= (txn.remitter_name || '').replace(/'/g, "\\'") %>';
              const txnDescription = '<%= (txn.description || '').replace(/'/g, "\\'") %>';
              const txnDate = '<%= new Date(txn.transaction_date).toLocaleDateString('en-GB') %>';
              
              // Skip the current transaction
              if (txnId == updatedTransactionId) return;
              
              // Check if same beneficiary or remitter by ID
              const sameEntityById = 
                (currentTxn.beneficiary_id && txnBeneficiaryId == currentTxn.beneficiary_id) ||
                (currentTxn.remitter_id && txnRemitterId == currentTxn.remitter_id);
              
              // Check if same entity by name
              const currentEntityName = currentTxn.beneficiary_name || currentTxn.remitter_name;
              const txnEntityName = txnBeneficiaryName || txnRemitterName;
              const sameEntityByName = currentEntityName && txnEntityName && 
                (txnEntityName.toLowerCase().includes(currentEntityName.toLowerCase()) ||
                 currentEntityName.toLowerCase().includes(txnEntityName.toLowerCase()));
              
              // Extract company name from description for better matching
              const extractCompanyName = (desc) => {
                if (!desc) return '';
                
                // Split by '/' and analyze segments
                const segments = desc.split('/');
                
                // Look for company names in segments, skipping common payment method prefixes
                const skipPrefixes = ['INF', 'INB', 'NEFT', 'RTGS', 'IMPS', 'UPI'];
                
                for (let i = 0; i < segments.length; i++) {
                  const segment = segments[i].trim();
                  
                  // Skip empty segments and common prefixes
                  if (!segment || skipPrefixes.includes(segment.toUpperCase())) {
                    continue;
                  }
                  
                  // Skip bank codes (usually 9-11 characters, alphanumeric)
                  if (/^[A-Z0-9]{9,11}$/i.test(segment)) {
                    continue;
                  }
                  
                  // Skip transaction IDs (usually long alphanumeric strings)
                  if (/^[A-Z0-9]{15,}$/i.test(segment)) {
                    continue;
                  }
                  
                  // Skip bank names that are too generic
                  if (/^(BANK|OF|IN|LTD|PVT)$/i.test(segment)) {
                    continue;
                  }
                  
                  // If we find a segment that looks like a company name
                  if (segment.length > 3 && /^[A-Z\s&]+$/i.test(segment)) {
                    return segment;
                  }
                  
                  // Check for company name with P/PVT/LTD etc.
                  const companyMatch = segment.match(/^([A-Z\s&]+(?:P|PVT|LTD|LLP|INC)?)$/i);
                  if (companyMatch && companyMatch[1].length > 3) {
                    return companyMatch[1].trim();
                  }
                }
                
                return '';
              };
              
              const currentDesc = currentTxn.description || '';
              const currentCompany = extractCompanyName(currentDesc);
              const txnCompany = extractCompanyName(txnDescription);
              
              // Only match by company name if both have valid company names extracted
              const sameByCompany = currentCompany && txnCompany && 
                currentCompany.length > 3 && txnCompany.length > 3 &&
                (txnCompany.toLowerCase().includes(currentCompany.toLowerCase()) ||
                 currentCompany.toLowerCase().includes(txnCompany.toLowerCase()));
              
              // Remove the overly broad description matching that was causing issues
              const isSimilar = sameEntityById || sameEntityByName || sameByCompany;
              
              if (!isSimilar) return;
              
              // Check if needs update
              const needsNarration = updateData.narration && (!txnNarration || txnNarration.trim() === '');
              const needsCategory = updateData.category_id && !txnCategoryId;
              const needsRemitter = updateData.remitter_id && !txnRemitterId;
              
              if (needsNarration || needsCategory || needsRemitter) {
                similarTxns.push({
                  id: txnId,
                  date: txnDate,
                  description: txnDescription.substring(0, 60),
                  entity_name: txnEntityName || txnCompany || 'Unknown'
                });
              }
            })();
          <% } %>
        <% }) %>

        if (similarTxns.length > 0) {
          showSimilarTransactionsModal(similarTxns, updateData, currentTxn);
        }
      } catch (error) {
        console.error('Error checking similar transactions:', error);
        // Silently fail - this is a convenience feature
      }
    }


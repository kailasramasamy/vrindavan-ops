            <button onclick="closeDiscardImportModal()" class="text-gray-400 hover:text-gray-500 dark:hover:text-gray-300">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>
        </div>

        <!-- Content -->
        <div class="flex-1 overflow-y-auto p-6">
          <div class="mb-4 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-700 rounded-lg p-4">
            <div class="flex items-start">
              <svg class="w-5 h-5 text-yellow-600 dark:text-yellow-400 mt-0.5 mr-3" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M12 2a10 10 0 100 20 10 10 0 000-20zM11 7a1 1 0 112 0v6a1 1 0 11-2 0V7zm1 10a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
              </svg>
              <div class="flex-1">
                <h4 class="text-sm font-medium text-yellow-800 dark:text-yellow-300">Warning: Permanent Deletion</h4>
                <p class="text-sm text-yellow-700 dark:text-yellow-400 mt-1">
                  Deleting an import will permanently remove all transactions from that batch. This action cannot be undone.
                </p>
              </div>
            </div>
          </div>

          <div id="recentImportsList" class="space-y-3">
            <!-- Recent imports will be populated here -->
          </div>
        </div>

        <!-- Footer -->
        <div class="px-6 py-4 border-t border-gray-200 dark:border-gray-700 flex-shrink-0">
          <div class="flex justify-end">
            <button onclick="closeDiscardImportModal()" class="px-6 py-2 bg-gray-500 text-white rounded-lg hover:bg-gray-600 font-medium">
              Cancel
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // ============= Invoice Grouping in Edit Modal =============
    
    function toggleInvoiceGroupForm() {
      const form = document.getElementById('linkToInvoiceGroupForm');
      const toggleBtn = document.getElementById('toggleInvoiceGroupLinkBtn');
      
      if (form.classList.contains('hidden')) {
        // Show form and load invoice groups
        form.classList.remove('hidden');
        toggleBtn.textContent = '- Cancel';
        loadInvoiceGroupsForEdit();
        
        // Set default amount from transaction
        const transactionId = document.getElementById('editTransactionId').value;
        fetch(`/accounting/transactions/${transactionId}`, {
          credentials: 'same-origin'
        })
        .then(response => response.json())
        .then(data => {
          if (data.success && data.transaction) {
            const txn = data.transaction;
            const amount = parseFloat(txn.debit_amount) > 0 ? parseFloat(txn.debit_amount) : parseFloat(txn.credit_amount);
            document.getElementById('editInvoiceAmount').value = amount;
          }
        });
      } else {
        // Hide form
        form.classList.add('hidden');
        toggleBtn.textContent = '+ Link to Invoice Group';
      }
    }
    
    async function loadInvoiceGroupsForEdit() {
      try {
        const response = await fetch('/accounting/invoice-groups/list?limit=100', {
          credentials: 'same-origin'
        });
        
        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }
        
        const data = await response.json();
        
        if (data.success) {
          const select = document.getElementById('editInvoiceGroupSelect');
          select.innerHTML = '<option value="">Select an invoice group...</option>';
          
          data.invoices.forEach(invoice => {
            const option = document.createElement('option');
            option.value = invoice.id;
            const beneficiaryName = invoice.beneficiary_name || 'N/A';
            option.textContent = `${invoice.invoice_number} - ${beneficiaryName} - ${formatIndianCurrency(Math.round(parseFloat(invoice.total_amount)))}`;
            select.appendChild(option);
          });
        } else {
          showToast('Error loading invoice groups', data.error, 'error');
        }
      } catch (error) {
        console.error('Error loading invoice groups:', error);
        showToast('Error loading invoice groups', error.message, 'error');
      }
    }
    
    async function linkTransactionToInvoiceGroup() {
      const transactionId = document.getElementById('editTransactionId').value;
      const invoiceId = document.getElementById('editInvoiceGroupSelect').value;
      const amount = parseFloat(document.getElementById('editInvoiceAmount').value);
      
      if (!invoiceId) {
        showToast('Please select an invoice group', '', 'error');
        return;
      }
      
      if (!amount || amount <= 0) {
        showToast('Please enter a valid amount', '', 'error');
        return;
      }
      
      try {
        const response = await fetch('/accounting/invoice-groups/add-transaction', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          credentials: 'same-origin',
          body: JSON.stringify({
            invoiceId: invoiceId,
            transactionId: transactionId,
            amount: amount
          })
        });
        
        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }
        
        const data = await response.json();
        
        if (data.success) {
          showToast('Transaction linked to invoice group successfully', '', 'success');
          
          // Hide the form and toggle button
          document.getElementById('linkToInvoiceGroupForm').classList.add('hidden');
          document.getElementById('toggleInvoiceGroupLinkBtn').classList.add('hidden');
          
          // Show the current invoice group display
          document.getElementById('currentInvoiceGroupDisplay').classList.remove('hidden');
          
          // Reload transaction to get updated invoice group info
          const txnResponse = await fetch(`/accounting/transactions/${transactionId}`, {
            credentials: 'same-origin'
          });
          const txnData = await txnResponse.json();
          if (txnData.success && txnData.transaction) {
            document.getElementById('currentInvoiceGroupInfo').textContent = `${txnData.transaction.invoice_number || 'Invoice Group'} - Amount: ${formatIndianCurrency(Math.round(parseFloat(txnData.transaction.invoice_amount || 0)))}`;
          }
          
          // Update the row in the table to show the green checkmark indicator
          updateInvoiceGroupIndicatorInTable(transactionId, true);
        } else {
          showToast('Error linking transaction to invoice group', data.error, 'error');
        }
      } catch (error) {
        console.error('Error linking transaction to invoice group:', error);
        showToast('Error linking transaction to invoice group', error.message, 'error');
      }
    }
    
    async function unlinkFromInvoiceGroup() {
      if (!confirm('Are you sure you want to unlink this transaction from the invoice group?')) {
        return;
      }
      
      const transactionId = document.getElementById('editTransactionId').value;
      
      try {
        const response = await fetch('/accounting/invoice-groups/remove-transaction', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          credentials: 'same-origin',
          body: JSON.stringify({
            transactionId: transactionId
          })
        });
        
        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }
        
        const data = await response.json();
        
        if (data.success) {
          showToast('Transaction unlinked from invoice group successfully', '', 'success');
          
          // Show the toggle button, hide current display
          document.getElementById('currentInvoiceGroupDisplay').classList.add('hidden');
          document.getElementById('toggleInvoiceGroupLinkBtn').classList.remove('hidden');
          
          // Update the row in the table to remove the green checkmark indicator
          updateInvoiceGroupIndicatorInTable(transactionId, false);
        } else {
          showToast('Error unlinking transaction from invoice group', data.error, 'error');
        }
      } catch (error) {
        console.error('Error unlinking transaction from invoice group:', error);
        showToast('Error unlinking transaction from invoice group', error.message, 'error');
      }
    }
    
    function viewInvoiceGroupDetailsFromEdit() {
      const transactionId = document.getElementById('editTransactionId').value;
      
      // Get the transaction's invoice_id
      fetch(`/accounting/transactions/${transactionId}`, {
        credentials: 'same-origin'
      })
      .then(response => response.json())
      .then(data => {
        if (data.success && data.transaction && data.transaction.invoice_id) {
          // Close edit modal and open invoice group modal
          closeEditTransactionModal();
          viewInvoiceGroupDetails(data.transaction.invoice_id);
        } else {
          showToast('Error loading invoice group details', '', 'error');
        }
      })
      .catch(error => {
        console.error('Error:', error);
        showToast('Error loading invoice group details', error.message, 'error');
      });
    }
    
    // Update invoice group indicator in the table row
    function updateInvoiceGroupIndicatorInTable(transactionId, isLinked) {
      const row = document.getElementById(`txn-row-${transactionId}`);
      if (!row) return;
      
      // Find the actions cell (last td in the row)
      const actionsCells = row.querySelectorAll('td');
      const actionsCell = actionsCells[actionsCells.length - 1];
      if (!actionsCell) return;
      
      // Find the invoice indicator container
      const indicatorContainer = actionsCell.querySelector('div.flex');
      if (!indicatorContainer) return;
      
      // Find or create the invoice group indicator
      let groupIndicator = indicatorContainer.querySelector('span[title*="Linked to invoice group"]');
      
      if (isLinked) {
        if (!groupIndicator) {
          // Create new indicator
          groupIndicator = document.createElement('span');
          groupIndicator.className = 'text-green-600 dark:text-green-400 p-0.5';
          groupIndicator.title = 'Linked to invoice group';
          groupIndicator.innerHTML = `
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          `;
          // Add it before the view button
          const viewButton = indicatorContainer.querySelector('button[title="View"]');
          if (viewButton) {
            indicatorContainer.insertBefore(groupIndicator, viewButton);
          } else {
            indicatorContainer.appendChild(groupIndicator);
          }
        }
      } else {
        // Remove the indicator if it exists
        if (groupIndicator) {
          groupIndicator.remove();
        }
      }
    }

    // Event listener for invoice group file input
    document.addEventListener('change', function(e) {
      if (e.target && e.target.id === 'invoiceGroupFileInput') {
        const uploadBtn = document.getElementById('uploadInvoiceGroupBtn');
        if (uploadBtn) {
          uploadBtn.classList.toggle('hidden', !e.target.files.length);
        }
      }
    });
  </script>

</body>
</html>


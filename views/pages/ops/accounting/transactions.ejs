<%- include('../../../partials/_head', { seo, pageKey }) %>
<link rel="stylesheet" href="/assets/css/accounting-dark-mode.css">

<!-- Indian Number Formatting -->
<script src="/assets/js/indian-number-format.js"></script>

<!-- Initialize theme immediately to prevent flash -->
<script>
  (function() {
    const theme = localStorage.getItem("accounting_theme") || "dark";
    if (theme === "dark") {
      document.documentElement.classList.add("dark");
    }
  })();
</script>

<body class="bg-gray-50 dark:bg-gray-900 transition-colors duration-200">
  <%- include('../../../partials/_subnav', { user, section: 'Accounting', subsection: 'Transactions' }) %>

  <div class="min-h-screen pt-16">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Header -->
      <div class="mb-6">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">Bank Transactions</h1>
            <p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 mt-1">
              View and manage imported bank statements
              <% if (filters.beneficiary_id) { 
                const ben = beneficiaries.find(b => b.id == filters.beneficiary_id); 
                if (ben) { %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-purple-100 dark:bg-purple-900/30 text-purple-800 dark:text-purple-300 ml-2">
                    <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path>
                    </svg>
                    Filtered by: <%= ben.beneficiary_name %>
                  </span>
                <% } %>
              <% } %>
              <% if (filters.remitter_id) { 
                const rem = remitters.find(r => r.id == filters.remitter_id); 
                if (rem) { %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-purple-100 dark:bg-purple-900/30 text-purple-800 dark:text-purple-300 ml-2">
                    <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path>
                    </svg>
                    Filtered by: <%= rem.remitter_name %>
                  </span>
                <% } %>
              <% } %>
            </p>
          </div>
          
        </div>
      </div>

      <!-- Filters -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4 sm:p-6 mb-6">
        <form method="GET" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-6 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Bank Account</label>
            <select name="bank_account_id" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-lg">
              <option value="">All Accounts</option>
              <% bankAccounts.forEach(acc => { %>
                <option value="<%= acc.id %>" <%= filters.bank_account_id == acc.id ? 'selected' : '' %>><%= acc.account_name %></option>
              <% }) %>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Start Date</label>
            <input type="date" name="start_date" value="<%= filters.start_date %>" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-lg" />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">End Date</label>
            <input type="date" name="end_date" value="<%= filters.end_date %>" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-lg" />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Category</label>
            <select name="category_id" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-lg">
              <option value="">All Categories</option>
              <% categories.forEach(cat => { %>
                <option value="<%= cat.id %>" <%= filters.category_id == cat.id ? 'selected' : '' %>><%= cat.category_name %></option>
              <% }) %>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Status</label>
            <select name="is_matched" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-lg">
              <option value="">All Status</option>
              <option value="true" <%= filters.is_matched === 'true' ? 'selected' : '' %>>Matched</option>
              <option value="false" <%= filters.is_matched === 'false' ? 'selected' : '' %>>Pending</option>
            </select>
          </div>

          <div class="flex items-end">
            <button type="submit" class="w-full px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Filter</button>
          </div>
        </form>
      </div>

      <!-- Summary Cards - Shows data from ALL filtered transactions, not just current page -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <!-- Total Debit -->
        <div class="bg-gradient-to-br from-red-500 to-red-600 dark:from-red-500/30 dark:to-red-600/30 rounded-xl p-4 sm:p-5 text-white dark:text-red-50 shadow-md">
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-sm font-semibold opacity-90">Total Debit</h3>
            <svg class="w-6 h-6 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
          </div>
          <p class="text-2xl sm:text-3xl font-bold indian-currency" data-amount="<%= Math.round(summary.total_debit) %>">₹<%= Math.round(summary.total_debit) %></p>
          <p class="text-xs opacity-80 mt-1">Payments made</p>
        </div>

        <!-- Total Credit -->
        <div class="bg-gradient-to-br from-green-500 to-green-600 dark:from-green-500/30 dark:to-green-600/30 rounded-xl p-4 sm:p-5 text-white dark:text-green-50 shadow-md">
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-sm font-semibold opacity-90">Total Credit</h3>
            <svg class="w-6 h-6 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
            </svg>
          </div>
          <p class="text-2xl sm:text-3xl font-bold indian-currency" data-amount="<%= Math.round(summary.total_credit) %>">₹<%= Math.round(summary.total_credit) %></p>
          <p class="text-xs opacity-80 mt-1">Amount received</p>
        </div>

        <!-- Net Balance -->
        <div class="bg-gradient-to-br from-blue-500 to-blue-600 dark:from-blue-500/30 dark:to-blue-600/30 rounded-xl p-4 sm:p-5 text-white dark:text-blue-50 shadow-md">
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-sm font-semibold opacity-90">Net Balance</h3>
            <svg class="w-6 h-6 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
            </svg>
          </div>
          <p class="text-2xl sm:text-3xl font-bold indian-currency" data-amount="<%= Math.round(summary.net_balance) %>">₹<%= Math.round(summary.net_balance) %></p>
          <p class="text-xs opacity-80 mt-1">Credit - Debit</p>
        </div>

        <!-- Total Transactions -->
        <div class="bg-gradient-to-br from-purple-500 to-purple-600 dark:from-purple-500/30 dark:to-purple-600/30 rounded-xl p-4 sm:p-5 text-white dark:text-purple-50 shadow-md">
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-sm font-semibold opacity-90">Transactions</h3>
            <svg class="w-6 h-6 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
            </svg>
          </div>
          <p class="text-2xl sm:text-3xl font-bold"><%= summary.total_transactions %></p>
          <p class="text-xs opacity-80 mt-1">
            <span class="text-green-200"><%= summary.matched_count %> matched</span> • 
            <span class="text-orange-200"><%= summary.unmatched_count %> pending</span>
          </p>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4 sm:p-6 mb-6">
        <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Quick Actions</h3>
        <div class="flex gap-3 flex-wrap">
          <button onclick="openImportModal()" class="px-4 py-2.5 bg-blue-600 dark:bg-blue-600/20 dark:text-blue-100 text-white text-sm font-medium rounded-lg hover:bg-blue-700 dark:hover:bg-blue-600/30 shadow-sm transition-colors">
            <svg class="w-4 h-4 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
            </svg>
            Import Bank Statement
          </button>
          <button onclick="reviewIncompleteTransactions()" class="relative px-4 py-2.5 bg-amber-500 dark:bg-amber-500/20 dark:text-amber-100 text-white text-sm font-medium rounded-lg hover:bg-amber-600 dark:hover:bg-amber-500/30 shadow-sm transition-colors">
            <svg class="w-4 h-4 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
            </svg>
            Review Incomplete Data
            <span id="incompleteCount" class="ml-2 px-2 py-0.5 bg-amber-700 dark:bg-amber-800 text-white text-xs rounded-full">...</span>
          </button>
          <button onclick="reviewMissingInvoices()" class="relative px-4 py-2.5 bg-rose-500 dark:bg-rose-500/20 dark:text-rose-100 text-white text-sm font-medium rounded-lg hover:bg-rose-600 dark:hover:bg-rose-500/30 shadow-sm transition-colors">
            <svg class="w-4 h-4 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
            </svg>
            Missing Mandatory Invoices
            <span id="missingInvoicesCountBadge" class="ml-2 px-2 py-0.5 bg-rose-700 dark:bg-rose-800 text-white text-xs rounded-full">...</span>
          </button>
          <button onclick="openDiscardImportModal()" class="px-4 py-2.5 bg-gray-600 dark:bg-gray-700 text-white text-sm font-medium rounded-lg hover:bg-gray-700 dark:hover:bg-gray-600 shadow-sm transition-colors">
            <svg class="w-4 h-4 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
            </svg>
            Discard Import
          </button>
        </div>
      </div>

      <!-- Search Field -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4 mb-6">
        <div class="relative">
          <input 
            type="text" 
            id="searchInput"
            placeholder="Search by description, beneficiary, remitter, narration, or amount..."
            class="w-full pl-10 pr-10 py-2.5 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            oninput="searchTransactions()"
          />
          <svg class="absolute left-3 top-3 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <button 
            id="clearSearchBtn"
            onclick="clearSearch()"
            class="hidden absolute right-3 top-2.5 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300"
            title="Clear search"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
      </div>

      <!-- Transactions Table -->
      <style>
        #transactionsTable {
          width: 100% !important;
          table-layout: fixed !important;
        }
        #transactionsTable td,
        #transactionsTable th {
          overflow: hidden !important;
          text-overflow: ellipsis !important;
          max-width: 0 !important;
        }
        #transactionsTable col {
          min-width: 0 !important;
        }

        /* Searchable Dropdown Styles */
        .searchable-dropdown {
          position: relative;
        }
        
        .searchable-option {
          transition: background-color 0.15s ease;
          white-space: nowrap;
          overflow: hidden;
          text-overflow: ellipsis;
        }
        
        .searchable-option:hover {
          background-color: rgba(59, 130, 246, 0.1);
        }
        
        .searchable-option:first-child {
          font-style: italic;
          color: #6b7280;
        }
        
        .dark .searchable-option:first-child {
          color: #9ca3af;
        }

        /* Scrollbar styling for dropdown */
        .searchable-dropdown > div {
          scrollbar-width: thin;
          scrollbar-color: #cbd5e1 #f1f5f9;
        }
        
        .dark .searchable-dropdown > div {
          scrollbar-color: #4b5563 #1f2937;
        }
        
        .searchable-dropdown > div::-webkit-scrollbar {
          width: 6px;
        }
        
        .searchable-dropdown > div::-webkit-scrollbar-track {
          background: #f1f5f9;
          border-radius: 3px;
        }
        
        .dark .searchable-dropdown > div::-webkit-scrollbar-track {
          background: #1f2937;
        }
        
        .searchable-dropdown > div::-webkit-scrollbar-thumb {
          background: #cbd5e1;
          border-radius: 3px;
        }
        
        .dark .searchable-dropdown > div::-webkit-scrollbar-thumb {
          background: #4b5563;
        }
        
        .searchable-dropdown > div::-webkit-scrollbar-thumb:hover {
          background: #94a3b8;
        }
        
        .dark .searchable-dropdown > div::-webkit-scrollbar-thumb:hover {
          background: #6b7280;
        }
      </style>
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center">
          <div>
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Transactions</h2>
            <p id="transactionCount" class="text-sm text-gray-600 dark:text-gray-400"><%= summary.total_transactions %> records found</p>
          </div>
          <div class="flex gap-2 flex-wrap">
            <button onclick="autoMatch()" class="px-4 py-2 bg-green-600 text-white text-sm rounded-lg hover:bg-green-700">
              Auto-Match
            </button>
            <button onclick="downloadTransactionsCSV()" class="px-4 py-2 bg-blue-600 text-white text-sm rounded-lg hover:bg-blue-700">
              <svg class="w-4 h-4 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              Download CSV
            </button>
          </div>
        </div>
        <div class="overflow-x-auto">
          <table id="transactionsTable" class="divide-y divide-gray-200 dark:divide-gray-700">
            <colgroup>
              <col style="width: 7%;"><!-- Date -->
              <col style="width: 16%;"><!-- Description -->
              <col style="width: 15%;"><!-- Narration -->
              <col style="width: 13%;"><!-- Beneficiary -->
              <col style="width: 12%;"><!-- Category -->
              <col style="width: 9%;"><!-- Debit -->
              <col style="width: 9%;"><!-- Credit -->
              <col style="width: 10%;"><!-- Status -->
              <col style="width: 9%;"><!-- Actions -->
            </colgroup>
            <thead class="bg-gray-50 dark:bg-gray-900">
              <tr>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Date</th>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Description</th>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Narration</th>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Beneficiary/Remitter</th>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Category</th>
                <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Debit</th>
                <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Credit</th>
                <th class="px-3 py-2 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Status</th>
                <th class="px-2 py-2 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Invoice / Actions</th>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
              <% if (transactions && transactions.length > 0) { %>
                <% transactions.forEach(txn => { %>
                  <tr class="hover:bg-gray-50 dark:hover:bg-gray-700" id="txn-row-<%= txn.id %>">
                    <td class="px-3 py-2 text-xs text-gray-900 dark:text-white">
                      <div class="flex flex-col gap-1">
                        <div><%= new Date(txn.transaction_date).toLocaleDateString('en-GB') %></div>
                        <% if (txn.bank_account_name) { %>
                          <span class="text-[10px] px-1.5 py-0.5 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400 rounded inline-block w-fit" title="<%= txn.bank_account_name %>">
                            <%= txn.bank_account_name.split(' ')[0] %>
                          </span>
                        <% } %>
                      </div>
                    </td>
                    <td class="px-3 py-2 text-xs text-gray-900 dark:text-white" title="<%= txn.description %>">
                      <div class="truncate"><%= txn.description || '-' %></div>
                      <% if (txn.invoice_id) { %>
                        <div class="mt-1">
                          <button onclick="viewInvoiceGroupDetails('<%= txn.invoice_id %>')" 
                             class="inline-flex items-center text-xs text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 transition-colors cursor-pointer"
                             title="View invoice group details">
                            <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                            </svg>
                            <%= txn.invoice_number || 'Invoice Group' %>
                          </button>
                        </div>
                      <% } %>
                    </td>
                    <td class="px-3 py-2 text-xs" title="<%= txn.narration || 'Click to add narration...' %>">
                      <div class="relative narration-cell group">
                        <div 
                          id="narration-display-<%= txn.id %>" 
                          class="<%= txn.narration ? 'text-gray-900 dark:text-gray-200' : 'text-gray-400 dark:text-gray-500 italic' %> truncate cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-700 px-2 py-1 rounded transition-colors"
                          onclick="enableNarrationEdit('<%= txn.id %>')"
                        >
                          <%= txn.narration || 'Click to add...' %>
                        </div>
                        <input 
                          type="text" 
                          id="narration-input-<%= txn.id %>" 
                          class="hidden w-full px-2 py-1 text-xs border border-blue-500 dark:border-blue-400 rounded focus:outline-none focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-gray-200"
                          value="<%= txn.narration || '' %>"
                          onblur="saveNarration('<%= txn.id %>')"
                          onkeydown="handleNarrationKeydown(event, '<%= txn.id %>')"
                          maxlength="255"
                        />
                      </div>
                    </td>
                    <td class="px-3 py-2 text-xs text-gray-900 dark:text-white" title="<%= parseFloat(txn.credit_amount) > 0 ? (txn.remitter_name || '-') : (txn.beneficiary_name || '-') %>">
                      <div>
                        <% if (parseFloat(txn.credit_amount) > 0) { %>
                          <div class="truncate"><%= txn.remitter_name || '-' %></div>
                          <% if (txn.remitter_alias) { %>
                            <div class="text-xs text-gray-500 dark:text-gray-400 truncate italic">(<%= txn.remitter_alias %>)</div>
                          <% } %>
                        <% } else { %>
                          <div class="truncate"><%= txn.beneficiary_name || '-' %></div>
                          <% if (txn.beneficiary_alias) { %>
                            <div class="text-xs text-gray-500 dark:text-gray-400 truncate italic">(<%= txn.beneficiary_alias %>)</div>
                          <% } %>
                        <% } %>
                      </div>
                    </td>
                    <td class="px-3 py-2 text-xs" title="<%= txn.category_name || '' %>">
                      <% if (txn.category_name) { %>
                        <span class="px-2 py-1 text-xs font-medium rounded-full block truncate" style="background-color: <%= txn.color_code %>20; color: <%= txn.color_code %>">
                          <%= txn.category_name %>
                        </span>
                      <% } else { %>
                        <span class="text-gray-400 dark:text-gray-500">-</span>
                      <% } %>
                    </td>
                    <td class="px-3 py-2 text-right text-xs font-medium text-red-600 dark:text-red-400">
                      <% if (parseFloat(txn.debit_amount) > 0) { %>
                        <span class="indian-currency" data-amount="<%= Math.round(parseFloat(txn.debit_amount)) %>">₹<%= Math.round(parseFloat(txn.debit_amount)) %></span>
                      <% } else { %>
                        -
                      <% } %>
                    </td>
                    <td class="px-3 py-2 text-right text-xs font-medium text-green-600 dark:text-green-400">
                      <% if (parseFloat(txn.credit_amount) > 0) { %>
                        <span class="indian-currency" data-amount="<%= Math.round(parseFloat(txn.credit_amount)) %>">₹<%= Math.round(parseFloat(txn.credit_amount)) %></span>
                      <% } else { %>
                        -
                      <% } %>
                    </td>
                    <td class="px-3 py-2 text-center">
                      <% if (txn.is_matched) { %>
                        <span class="px-2 py-1 text-xs font-medium rounded bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-400 inline-block">Matched</span>
                      <% } else { %>
                        <span class="px-2 py-1 text-xs font-medium rounded bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-400 inline-block">Pending</span>
                      <% } %>
                    </td>
                    <td class="px-2 py-2 text-center">
                      <div class="flex items-center justify-center gap-1">
                        <% if (txn.invoice_id) { %>
                          <!-- Transaction is part of an invoice group -->
                          <% if (txn.invoice_group_has_invoice) { %>
                            <!-- Invoice group has invoice uploaded, show clickable green indicator -->
                            <button onclick="viewInvoiceGroupDetails('<%= txn.invoice_id %>')" 
                              class="flex items-center hover:bg-gray-100 dark:hover:bg-gray-700 p-0.5 rounded" 
                              title="Invoice group with uploaded invoice - click to view group details">
                              <svg class="w-4 h-4 text-green-600 dark:text-green-400 hover:text-green-700 dark:hover:text-green-300" fill="currentColor" viewBox="0 0 24 24">
                                <path fill-rule="evenodd" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" clip-rule="evenodd"/>
                              </svg>
                            </button>
                          <% } else { %>
                            <!-- Invoice group but no invoice uploaded yet, show clickable orange indicator -->
                            <button onclick="viewInvoiceGroupDetails('<%= txn.invoice_id %>')" 
                              class="flex items-center hover:bg-gray-100 dark:hover:bg-gray-700 p-0.5 rounded" 
                              title="Invoice group - invoice required - click to view group details">
                              <svg class="w-4 h-4 text-orange-600 dark:text-orange-400 hover:text-orange-700 dark:hover:text-orange-300" fill="currentColor" viewBox="0 0 24 24">
                                <path fill-rule="evenodd" d="M12 2a10 10 0 100 20 10 10 0 000-20zM11 7a1 1 0 112 0v6a1 1 0 11-2 0V7zm1 10a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
                              </svg>
                            </button>
                          <% } %>
                        <% } else if (txn.invoice_url) { %>
                          <!-- Individual transaction with invoice uploaded -->
                          <a href="<%= txn.invoice_url %>" target="_blank" class="flex items-center hover:bg-gray-100 dark:hover:bg-gray-700 p-0.5 rounded" title="View invoice">
                            <svg class="w-4 h-4 text-emerald-600 dark:text-emerald-400 hover:text-emerald-700 dark:hover:text-emerald-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                            </svg>
                          </a>
                        <% } else if (txn.beneficiary_invoice_required && parseFloat(txn.debit_amount) > 0) { %>
                          <!-- Individual transaction requiring invoice but missing -->
                          <span class="flex items-center p-0.5" title="Invoice required but missing!">
                            <svg class="w-4 h-4 text-red-600 dark:text-red-400" fill="currentColor" viewBox="0 0 24 24">
                              <path fill-rule="evenodd" d="M12 2a10 10 0 100 20 10 10 0 000-20zM11 7a1 1 0 112 0v6a1 1 0 11-2 0V7zm1 10a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
                            </svg>
                          </span>
                        <% } %>
                        <% if (txn.invoice_id) { %>
                          <span class="text-green-600 dark:text-green-400 p-0.5" title="Linked to invoice group">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                          </span>
                        <% } %>
                        <button onclick="viewTransaction(<%= txn.id %>)" 
                          class="text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200 p-0.5" title="View">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                          </svg>
                        </button>
                        <button onclick="editTransaction(<%= txn.id %>)" 
                          class="text-blue-600 dark:text-blue-400 hover:text-blue-900 dark:hover:text-blue-300 p-0.5" title="Edit">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                          </svg>
                        </button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="9" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400">
                    No transactions found for the selected filters
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
        
        <!-- Pagination Controls -->
        <div class="bg-white dark:bg-gray-800 px-6 py-4 border-t border-gray-200 dark:border-gray-700">
          <div class="flex items-center justify-between">
            <!-- Entries per page selector -->
            <div class="flex items-center gap-2">
              <span class="text-sm text-gray-700 dark:text-gray-300">Show</span>
              <select id="entriesPerPage" onchange="changeEntriesPerPage()" 
                      class="px-3 py-1 text-sm border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                <option value="25" <%= (filters.limit || 25) == 25 ? 'selected' : '' %>>25</option>
                <option value="50" <%= (filters.limit || 25) == 50 ? 'selected' : '' %>>50</option>
                <option value="100" <%= (filters.limit || 25) == 100 ? 'selected' : '' %>>100</option>
                <option value="200" <%= (filters.limit || 25) == 200 ? 'selected' : '' %>>200</option>
              </select>
              <span class="text-sm text-gray-700 dark:text-gray-300">entries</span>
            </div>

            <!-- Pagination info and controls -->
            <div class="flex items-center gap-4">
              <!-- Page info -->
              <div class="text-sm text-gray-700 dark:text-gray-300">
                Showing 
                <span class="font-medium">
                  <%= pagination.startRecord || 0 %> 
                  to 
                  <%= pagination.endRecord || 0 %>
                </span>
                of 
                <span class="font-medium"><%= pagination.totalRecords || 0 %></span>
                entries
              </div>

              <!-- Pagination buttons -->
              <div class="flex items-center gap-2">
                <!-- Previous button -->
                <button onclick="goToPage(<%= pagination.currentPage - 1 %>)" 
                        <%= pagination.currentPage <= 1 ? 'disabled' : '' %>
                        class="px-3 py-1 text-sm border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-md hover:bg-gray-50 dark:hover:bg-gray-600 disabled:opacity-50 disabled:cursor-not-allowed">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                  </svg>
                </button>

                <!-- Page numbers -->
                <div class="flex items-center gap-1">
                  <% if (pagination.currentPage > 3) { %>
                    <button onclick="goToPage(1)" class="px-3 py-1 text-sm border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-md hover:bg-gray-50 dark:hover:bg-gray-600">1</button>
                    <% if (pagination.currentPage > 4) { %>
                      <span class="px-2 text-gray-500 dark:text-gray-400">...</span>
                    <% } %>
                  <% } %>

                  <% for (let i = Math.max(1, pagination.currentPage - 2); i <= Math.min(pagination.totalPages, pagination.currentPage + 2); i++) { %>
                    <button onclick="goToPage(<%= i %>)" 
                            class="px-3 py-1 text-sm border rounded-md <%= i === pagination.currentPage ? 'bg-blue-600 text-white border-blue-600' : 'border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-600' %>">
                      <%= i %>
                    </button>
                  <% } %>

                  <% if (pagination.currentPage < pagination.totalPages - 2) { %>
                    <% if (pagination.currentPage < pagination.totalPages - 3) { %>
                      <span class="px-2 text-gray-500 dark:text-gray-400">...</span>
                    <% } %>
                    <button onclick="goToPage(<%= pagination.totalPages %>)" class="px-3 py-1 text-sm border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-md hover:bg-gray-50 dark:hover:bg-gray-600"><%= pagination.totalPages %></button>
                  <% } %>
                </div>

                <!-- Next button -->
                <button onclick="goToPage(<%= pagination.currentPage + 1 %>)" 
                        <%= pagination.currentPage >= pagination.totalPages ? 'disabled' : '' %>
                        class="px-3 py-1 text-sm border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-md hover:bg-gray-50 dark:hover:bg-gray-600 disabled:opacity-50 disabled:cursor-not-allowed">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Invoice Group Details Modal -->
  <div id="invoiceGroupDetailsModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center p-4">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl w-full max-w-4xl max-h-[90vh] overflow-y-auto">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 bg-gradient-to-r from-indigo-500 to-purple-600">
        <h2 id="invoiceGroupDetailsTitle" class="text-xl font-semibold text-white">Invoice Group Details</h2>

    // Helper function to extract company name from description
    function extractCompanyName(desc) {
      if (!desc) return '';
      
      // Split by '/' and analyze segments
      const segments = desc.split('/');
      
      // Look for company names in segments, skipping common payment method prefixes
      const skipPrefixes = ['INF', 'INB', 'NEFT', 'RTGS', 'IMPS', 'UPI'];
      
      for (let i = 0; i < segments.length; i++) {
        const segment = segments[i].trim();
        
        // Skip empty segments and common prefixes
        if (!segment || skipPrefixes.includes(segment.toUpperCase())) {
          continue;
        }
        
        // Skip bank codes (usually 9-11 characters, alphanumeric)
        if (/^[A-Z0-9]{9,11}$/i.test(segment)) {
          continue;
        }
        
        // Skip transaction IDs (usually long alphanumeric strings)
        if (/^[A-Z0-9]{15,}$/i.test(segment)) {
          continue;
        }
        
        // Skip bank names that are too generic
        if (/^(BANK|OF|IN|LTD|PVT)$/i.test(segment)) {
          continue;
        }
        
        // If we find a segment that looks like a company name
        if (segment.length > 3 && /^[A-Z\s&]+$/i.test(segment)) {
          return segment;
        }
        
        // Check for company name with P/PVT/LTD etc.
        const companyMatch = segment.match(/^([A-Z\s&]+(?:P|PVT|LTD|LLP|INC)?)$/i);
        if (companyMatch && companyMatch[1].length > 3) {
          return companyMatch[1].trim();
        }
      }
      
      return '';
    }

    // Apply updates to similar transactions
    async function applySimilarUpdates(transactions, updateData) {
      let successCount = 0;
      let failCount = 0;
      
      // Update modal to show progress
      updateModalForProgress(transactions.length);

      for (let i = 0; i < transactions.length; i++) {
        const txn = transactions[i];
        try {
          // Update progress in modal
          updateModalProgress(i + 1, transactions.length);
          
          // Add is_matched: true to the update data for successful bulk updates
          const bulkUpdateData = {
            ...updateData,
            is_matched: true
          };
          
          const response = await fetch(`/accounting/transactions/${txn.id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(bulkUpdateData)
          });

          const result = await response.json();
          if (result.success) {
            successCount++;
          } else {
            failCount++;
          }
        } catch (error) {
          console.error(`Error updating transaction ${txn.id}:`, error);
          failCount++;
        }
      }

      // Show completion message
      updateModalForCompletion(successCount, failCount);
      
      // Show appropriate toast messages immediately
      if (successCount > 0) {
        showSuccessToast(`✅ Applied narration, category, remitter to ${successCount} transaction(s) and marked as "Matched"`);
      }
      if (failCount > 0) {
        showErrorToast(`❌ Failed to update ${failCount} transaction(s)`);
      }
    }


    async function executeStatementImport() {
      const mappingForm = document.getElementById("columnMapping");
      const selects = mappingForm.querySelectorAll("select");
      const columnMapping = {};

      selects.forEach(select => {
        if (select.value) {
          columnMapping[select.name] = select.value;
        }
      });

      if (!columnMapping.transaction_date || !columnMapping.description) {
        showToast("Transaction Date and Description are required fields", "", "error");
        return;
      }

      const bankAccountId = document.getElementById("selectedBankAccountId").value;
      
      // Validate we have the data
      if (!importPreviewData || !importPreviewData.allData) {
        console.error("Import data not available:", importPreviewData);
        showToast("Import data not available. Please upload the file again.", "", "error");
        return;
      }

      const fullData = importPreviewData.allData;

      try {
        document.getElementById("executeBtn").disabled = true;
        document.getElementById("executeBtn").innerHTML = '<span class="inline-block animate-spin mr-2">⏳</span> Importing & Matching...';

        const response = await fetch("/accounting/transactions/import/execute", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            fileData: fullData,
            columnMapping: columnMapping,
            bankAccountId: bankAccountId,
            fileName: importPreviewData.fileName || 'unknown.csv'
          })
        });

        const result = await response.json();

        if (result.success) {
          showImportResults(result);
        } else {
          console.error("Import failed:", result);
          showToast(result.error || "Import failed", "", "error");
          document.getElementById("executeBtn").disabled = false;
          document.getElementById("executeBtn").innerHTML = 'Import Now';
        }
      } catch (error) {
        console.error("Error executing import:", error);
        showToast("Error executing import", "", "error");
        document.getElementById("executeBtn").disabled = false;
        document.getElementById("executeBtn").innerHTML = 'Import Now';
      }
    }


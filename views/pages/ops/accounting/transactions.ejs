    async function uploadStatementFile() {
      const fileInput = document.getElementById("fileInput");
      const file = fileInput.files[0];
      const bankAccountId = document.getElementById("bankAccountSelect").value;

      if (!file) {
        showToast("Please select a file", "", "error");
        return;
      }

      if (!bankAccountId) {
        showToast("Please select a bank account", "", "error");
        return;
      }

      const formData = new FormData();
      formData.append("file", file);
      formData.append("bankAccountId", bankAccountId);

      try {
        document.getElementById("uploadBtn").disabled = true;
        document.getElementById("uploadBtn").innerHTML = '<span class="inline-block animate-spin mr-2">⏳</span> Processing...';

        const response = await fetch("/accounting/transactions/import/preview", {
          method: "POST",
          body: formData,
        });

        const result = await response.json();

        if (result.success) {
          importPreviewData = result;
          importPreviewData.fileName = file.name; // Store the original filename
          importPreviewData.bankAccountId = bankAccountId; // Store bank account ID
          showMappingStep(result, bankAccountId);

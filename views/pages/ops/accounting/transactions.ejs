            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            ${data.preview.slice(0, 5).map(row => `
              <tr>
                ${data.headers.slice(0, 8).map(h => `<td class="px-2 py-2 text-xs text-gray-900">${row[h] || '-'}</td>`).join('')}
              </tr>

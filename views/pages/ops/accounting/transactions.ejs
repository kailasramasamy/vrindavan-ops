    function closeDiscardImportModal() {
      document.getElementById("discardImportModal").classList.add("hidden");
    }

    async function confirmDiscardImport(batchId, count) {
      if (!confirm(`⚠️ This will PERMANENTLY DELETE ${count} transactions from this import.\n\nAre you sure you want to continue?`)) {
        return;
      }

      try {
        const response = await fetch(`/accounting/api/transactions/batch/${batchId}`, {
          method: 'DELETE'
        });

        const result = await response.json();

        if (result.success) {
          showToast(`Successfully deleted ${result.deletedCount} transactions`, "", "success");
          closeDiscardImportModal();
          setTimeout(() => location.reload(), 1500);
        } else {
          showToast(result.error || "Failed to delete import", "", "error");
        }
      } catch (error) {
        console.error("Error deleting import:", error);
        showToast("Error deleting import", "", "error");
      }
    }

    // Review transactions from a specific import batch
    async function openReviewTransactions() {
      if (!window.currentImportBatchId) {
        showToast("No batch ID found", "", "error");
        return;
      }

      try {
        // Fetch transactions for this batch
        const response = await fetch(`/accounting/api/transactions/batch/${window.currentImportBatchId}`);
        const result = await response.json();

        if (result.success && result.transactions) {
          // Filter for transactions that need attention (missing narration, beneficiary/remitter, or category)
          const needsReview = result.transactions.filter(txn => 
            !txn.narration || 
            (parseFloat(txn.debit_amount) > 0 && !txn.beneficiary_id) ||
            (parseFloat(txn.credit_amount) > 0 && !txn.remitter_id) ||
            !txn.category_id
          );

          if (needsReview.length === 0) {
            showToast("All transactions have complete data!", "", "success");
            finishStatementImport();
            return;
          }

          showReviewModal(needsReview, result.transactions.length, false);
        } else {
          showToast("Failed to load transactions", "", "error");
        }
      } catch (error) {
        console.error("Error loading transactions for review:", error);
        showToast("Error loading transactions", "", "error");
      }
    }

    function showReviewModal(transactions, totalImported, isGeneralReview = false) {
      if (!isGeneralReview) {
        document.getElementById("importModal").classList.add("hidden");
      }
      document.getElementById("reviewModal").classList.remove("hidden");
      
      const reviewList = document.getElementById("reviewTransactionsList");
      reviewList.innerHTML = transactions.map((txn, index) => {
        const isDebit = parseFloat(txn.debit_amount) > 0;
        const amount = isDebit ? parseFloat(txn.debit_amount) : parseFloat(txn.credit_amount);
        const needsNarration = !txn.narration;
        const needsEntity = isDebit ? !txn.beneficiary_id : !txn.remitter_id;
        const needsCategory = !txn.category_id;

        return `
          <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4 bg-white dark:bg-gray-800" id="review-txn-${txn.id}">
            <!-- Transaction Info -->
            <div class="mb-4 pb-4 border-b border-gray-200 dark:border-gray-700">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <p class="text-xs text-gray-500 dark:text-gray-400">Date: ${new Date(txn.transaction_date).toLocaleDateString('en-GB')}</p>
                  <p class="text-sm font-medium text-gray-900 dark:text-white mt-1 break-words">${txn.description || 'N/A'}</p>
                </div>
                <div class="flex-shrink-0">
                  <p class="text-lg font-bold ${isDebit ? 'text-red-600 dark:text-red-400' : 'text-green-600 dark:text-green-400'} whitespace-nowrap">
                    ₹${Math.round(amount).toLocaleString('en-IN')}
                  </p>
                  <p class="text-xs text-gray-500 dark:text-gray-400 text-right">${isDebit ? 'Debit' : 'Credit'}</p>
                </div>
              </div>
            </div>

            <!-- Quick Edit Fields -->
            <div class="space-y-3">
                ${needsNarration ? `
                  <div>
                    <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">Narration *</label>
                    <input type="text" id="narration-${txn.id}" value="${txn.narration || ''}" 
                      placeholder="Add narration..." 
                      class="w-full px-3 py-2 text-sm border border-orange-300 dark:border-orange-600 rounded-lg focus:ring-2 focus:ring-orange-500 dark:bg-gray-700 dark:text-gray-200" />
                  </div>
                ` : `
                  <div class="text-sm text-gray-600 dark:text-gray-400">
                    ✓ Narration: ${txn.narration}
                  </div>
                `}

                <div class="grid grid-cols-2 gap-3">
                  ${needsEntity ? `
                    <div>
                      <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">
                        ${isDebit ? 'Beneficiary *' : 'Remitter *'}
                      </label>
                      <select id="${isDebit ? 'beneficiary' : 'remitter'}-${txn.id}" 
                        class="w-full px-3 py-2 text-sm border border-orange-300 dark:border-orange-600 rounded-lg focus:ring-2 focus:ring-orange-500 dark:bg-gray-700 dark:text-gray-200">
                        <option value="">-- Select --</option>
                        ${isDebit ? 
                          '<% beneficiaries.forEach(b => { %><option value="<%= b.id %>"><%= b.beneficiary_name %></option><% }) %>' : 
                          '<% remitters.forEach(r => { %><option value="<%= r.id %>"><%= r.remitter_name %></option><% }) %>'
                        }
                      </select>
                    </div>
                  ` : `
                    <div class="text-sm text-gray-600 dark:text-gray-400">
                      ✓ ${isDebit ? 'Beneficiary' : 'Remitter'}: ${isDebit ? txn.beneficiary_name : txn.remitter_name}
                    </div>
                  `}

                  ${needsCategory ? `
                    <div>
                      <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">Category *</label>
                      <select id="category-${txn.id}" 
                        class="w-full px-3 py-2 text-sm border border-orange-300 dark:border-orange-600 rounded-lg focus:ring-2 focus:ring-orange-500 dark:bg-gray-700 dark:text-gray-200">
                        <option value="">-- Select --</option>
                        <% categories.forEach(c => { %>
                          <option value="<%= c.id %>"><%= c.category_name %></option>
                        <% }) %>
                      </select>
                    </div>
                  ` : `
                    <div class="text-sm text-gray-600 dark:text-gray-400">
                      ✓ Category: ${txn.category_name || 'N/A'}
                    </div>
                  `}
                </div>

                <div class="flex justify-end gap-2 mt-4">
                  <button onclick="saveReviewTransaction(${txn.id})" 
                    class="px-4 py-2 text-sm bg-blue-600 text-white rounded-lg hover:bg-blue-700">
                    Save Changes
                  </button>
                </div>
            </div>
          </div>
        `;
      }).join('');

      document.getElementById("reviewCount").textContent = `${transactions.length} of ${totalImported}`;
    }

    function closeReviewModal() {
      document.getElementById("reviewModal").classList.add("hidden");
      
      // Only trigger import finish if coming from import flow
      if (window.currentImportBatchId) {
        finishStatementImport();
      } else {
        // Just reload the page for general review
        location.reload();
      }
    }

    async function saveReviewTransaction(txnId) {
      const narration = document.getElementById(`narration-${txnId}`)?.value?.trim();
      const beneficiary = document.getElementById(`beneficiary-${txnId}`)?.value;
      const remitter = document.getElementById(`remitter-${txnId}`)?.value;
      const category = document.getElementById(`category-${txnId}`)?.value;

      const updateData = {};
      if (narration) updateData.narration = narration;
      if (beneficiary) {
        updateData.beneficiary_id = beneficiary;
        updateData.is_matched = true;
      }
      if (remitter) {
        updateData.remitter_id = remitter;
        updateData.is_matched = true;
      }
      if (category) updateData.category_id = category;

      try {
        const response = await fetch(`/accounting/transactions/${txnId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(updateData)
        });

        const result = await response.json();

        if (result.success) {
          // Remove from review list
          document.getElementById(`review-txn-${txnId}`).remove();
          showToast("Transaction updated", "", "success");

          // Check if all transactions reviewed
          const remaining = document.querySelectorAll('[id^="review-txn-"]').length;
          if (remaining === 0) {
            showToast("All transactions reviewed!", "", "success");
            setTimeout(() => closeReviewModal(), 1000);
          }
        } else {
          showToast(result.error || "Failed to update", "", "error");
        }
      } catch (error) {
        console.error("Error updating transaction:", error);
        showToast("Error updating transaction", "", "error");
      }
    }

    async function saveAllReviewTransactions() {
      const allTxnElements = document.querySelectorAll('[id^="review-txn-"]');
      let savedCount = 0;
      let errorCount = 0;

      for (const txnEl of allTxnElements) {
        const txnId = txnEl.id.replace('review-txn-', '');
        
        const narration = document.getElementById(`narration-${txnId}`)?.value?.trim();
        const beneficiary = document.getElementById(`beneficiary-${txnId}`)?.value;
        const remitter = document.getElementById(`remitter-${txnId}`)?.value;
        const category = document.getElementById(`category-${txnId}`)?.value;

        // Only update if something was filled
        if (!narration && !beneficiary && !remitter && !category) continue;

        const updateData = {};
        if (narration) updateData.narration = narration;
        if (beneficiary) {
          updateData.beneficiary_id = beneficiary;
          updateData.is_matched = true;
        }
        if (remitter) {
          updateData.remitter_id = remitter;
          updateData.is_matched = true;
        }
        if (category) updateData.category_id = category;

        try {
          const response = await fetch(`/accounting/transactions/${txnId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(updateData)
          });

          const result = await response.json();
          if (result.success) {
            savedCount++;
            txnEl.remove();
          } else {
            errorCount++;
          }
        } catch (error) {
          errorCount++;
        }
      }

      if (savedCount > 0) {
        showToast(`Updated ${savedCount} transaction(s)`, "", "success");
      }
      if (errorCount > 0) {
        showToast(`Failed to update ${errorCount} transaction(s)`, "", "error");
      }

      // Check if all done
      const remaining = document.querySelectorAll('[id^="review-txn-"]').length;
      if (remaining === 0) {
        setTimeout(() => closeReviewModal(), 1000);
      }
    }
  </script>


  <%- include('../../../partials/_footer') %>
  <%- include('../../../partials/_toast') %>

  <script>
    // Inline Narration Edit Functions
    function enableNarrationEdit(transactionId) {
      const displayDiv = document.getElementById(`narration-display-${transactionId}`);
      const inputField = document.getElementById(`narration-input-${transactionId}`);
      
      if (displayDiv && inputField) {
        displayDiv.classList.add('hidden');
        inputField.classList.remove('hidden');
        inputField.focus();
        inputField.select();
      }
    }

    function handleNarrationKeydown(event, transactionId) {
      if (event.key === 'Enter') {
        event.preventDefault();
        document.getElementById(`narration-input-${transactionId}`).blur();
      } else if (event.key === 'Escape') {
        event.preventDefault();
        cancelNarrationEdit(transactionId);
      }
    }

    function cancelNarrationEdit(transactionId) {
      const displayDiv = document.getElementById(`narration-display-${transactionId}`);
      const inputField = document.getElementById(`narration-input-${transactionId}`);
      
      if (displayDiv && inputField) {
        // Reset to original value
        const originalValue = displayDiv.textContent.trim();
        if (originalValue !== 'Click to add...') {
          inputField.value = originalValue;
        } else {
          inputField.value = '';
        }
        
        inputField.classList.add('hidden');
        displayDiv.classList.remove('hidden');
      }
    }

    async function saveNarration(transactionId) {
      const displayDiv = document.getElementById(`narration-display-${transactionId}`);
      const inputField = document.getElementById(`narration-input-${transactionId}`);
      
      if (!displayDiv || !inputField) return;
      
      const newValue = inputField.value.trim();
      const oldValue = displayDiv.textContent.trim();
      const oldValueForComparison = oldValue === 'Click to add...' ? '' : oldValue;
      
      // If value hasn't changed, just hide the input
      if (newValue === oldValueForComparison) {
        inputField.classList.add('hidden');
        displayDiv.classList.remove('hidden');
        return;
      }
      
      try {
        // Show saving indicator
        inputField.classList.add('opacity-50', 'pointer-events-none');
        
        const response = await fetch(`/accounting/transactions/${transactionId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            narration: newValue || null
          })
        });

        const result = await response.json();

        if (result.success) {
          // Update display
          displayDiv.textContent = newValue || 'Click to add...';
          displayDiv.className = newValue 
            ? 'text-gray-900 dark:text-gray-200 truncate cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-700 px-2 py-1 rounded transition-colors'
            : 'text-gray-400 dark:text-gray-500 italic truncate cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-700 px-2 py-1 rounded transition-colors';
          
          // Hide input, show display
          inputField.classList.add('hidden');
          displayDiv.classList.remove('hidden');
          
          // Show success toast
          showSuccessToast('Narration updated successfully');
        } else {
          throw new Error(result.error || 'Failed to update narration');
        }
      } catch (error) {
        console.error('Error saving narration:', error);
        showErrorToast('Failed to update narration: ' + error.message);
        
        // Revert to original value
        inputField.value = oldValueForComparison;
      } finally {
        // Remove saving indicator
        inputField.classList.remove('opacity-50', 'pointer-events-none');
      }
    }

    // Transaction Search Function - now uses server-side search
    let searchTimeout = null;
    function searchTransactions() {
      const searchInput = document.getElementById('searchInput');
      const searchTerm = searchInput.value.trim();
      const clearBtn = document.getElementById('clearSearchBtn');

      // Show/hide clear button
      if (searchTerm) {
        clearBtn.classList.remove('hidden');
      } else {
        clearBtn.classList.add('hidden');
      }

      // Debounce search - wait 500ms after user stops typing
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        // Update URL with search parameter
        const urlParams = new URLSearchParams(window.location.search);
        
        if (searchTerm) {
          urlParams.set('search', searchTerm);
        } else {
          urlParams.delete('search');
        }
        
        // Reset to page 1 when searching
        urlParams.set('page', '1');
        
        // Reload page with search parameter
        window.location.href = window.location.pathname + '?' + urlParams.toString();
      }, 500);
    }

    // Clear search
    function clearSearch() {
      const searchInput = document.getElementById('searchInput');
      searchInput.value = '';
      
      // Update URL to remove search parameter
      const urlParams = new URLSearchParams(window.location.search);
      urlParams.delete('search');
      urlParams.set('page', '1');
      
      // Reload page without search parameter
      window.location.href = window.location.pathname + '?' + urlParams.toString();
    }

    // Searchable Dropdown Functions
    let currentOpenDropdown = null;

    function showDropdown(fieldId) {
      const dropdown = document.getElementById(`${fieldId}Dropdown`);
      const searchInput = document.getElementById(`${fieldId}Search`);
      
      if (dropdown) {
        // Close any other open dropdown
        if (currentOpenDropdown && currentOpenDropdown !== dropdown) {
          currentOpenDropdown.classList.add('hidden');
        }
        
        dropdown.classList.remove('hidden');
        currentOpenDropdown = dropdown;
        
        // Show all options when opening
        const options = dropdown.querySelectorAll('.searchable-option');
        options.forEach(opt => opt.style.display = 'block');
      }
    }

    function hideDropdown(fieldId) {
      const dropdown = document.getElementById(`${fieldId}Dropdown`);
      if (dropdown) {
        dropdown.classList.add('hidden');
        if (currentOpenDropdown === dropdown) {
          currentOpenDropdown = null;
        }
      }
    }

    function filterDropdown(fieldId, searchText) {
      const dropdown = document.getElementById(`${fieldId}Dropdown`);
      if (!dropdown) return;
      
      showDropdown(fieldId);
      
      const search = searchText.toLowerCase().trim();
      const options = dropdown.querySelectorAll('.searchable-option');
      
      let visibleCount = 0;
      options.forEach(option => {
        const searchData = option.getAttribute('data-search') || option.textContent.toLowerCase();
        if (search === '' || searchData.includes(search)) {
          option.style.display = 'block';
          visibleCount++;
        } else {
          option.style.display = 'none';
        }
      });
      
      // If no results, show a message
      if (visibleCount === 0 || (visibleCount === 1 && options[0].getAttribute('data-value') === '')) {
        // Only the "Select" option is visible, or no options
        // We can add a "No results" message if needed
      }
    }

    function selectOption(fieldId, value, label) {
      const hiddenInput = document.getElementById(fieldId);
      const searchInput = document.getElementById(`${fieldId}Search`);
      const dropdown = document.getElementById(`${fieldId}Dropdown`);
      
      if (hiddenInput) {
        hiddenInput.value = value;
      }
      
      if (searchInput) {
        searchInput.value = label;
      }
      
      if (dropdown) {
        dropdown.classList.add('hidden');
        if (currentOpenDropdown === dropdown) {
          currentOpenDropdown = null;
        }
      }
    }

    // Close dropdown when clicking outside
    document.addEventListener('click', function(event) {
      if (!event.target.closest('.searchable-dropdown')) {
        if (currentOpenDropdown) {
          currentOpenDropdown.classList.add('hidden');
          currentOpenDropdown = null;
        }
      }
    });

    // Handle keyboard navigation in searchable dropdowns
    document.addEventListener('keydown', function(event) {
      if (event.key === 'Escape' && currentOpenDropdown) {
        currentOpenDropdown.classList.add('hidden');
        currentOpenDropdown = null;
      }
    });

    async function autoMatch() {
      if (!confirm('Auto-match unmatched transactions with beneficiaries?')) return;

      try {
        const response = await fetch('/accounting/api/auto-match', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({})
        });

        const result = await response.json();

        if (result.success) {
          showToast(result.message, "", "success");
          setTimeout(() => location.reload(), 1500);
        } else {
          showToast(result.error, "", "error");
        }
      } catch (error) {
        console.error('Error auto-matching:', error);
        showToast("Error during auto-match", "", "error");
      }
    }

    // Edit Transaction
    async function editTransaction(id, viewMode = false) {
      try {
        const response = await fetch(`/accounting/transactions/${id}`);
        const data = await response.json();

        if (data.success && data.transaction) {
          const txn = data.transaction;
          
          // Populate modal
          document.getElementById('editTransactionId').value = txn.id;
          document.getElementById('isViewMode').value = viewMode;
          document.getElementById('transactionInvoiceId').value = txn.invoice_id || '';
          
          // Update modal title
          document.getElementById('editModalTitle').textContent = viewMode ? 'View Transaction' : 'Edit Transaction';
          
          // Calculate common values
          const isDebit = parseFloat(txn.debit_amount) > 0;
          const amount = isDebit ? parseFloat(txn.debit_amount) : parseFloat(txn.credit_amount);
          const amountClass = isDebit ? 'text-red-600 dark:text-red-400' : 'text-green-600 dark:text-green-400';
          const balance = parseFloat(txn.balance || 0);
          const formattedDate = new Date(txn.transaction_date).toLocaleDateString('en-GB');
          
          if (viewMode) {
            // Show view mode, hide edit mode
            document.getElementById('viewModeDisplay').classList.remove('hidden');
            document.getElementById('editModeDisplay').classList.add('hidden');
            document.getElementById('saveTransactionBtn').classList.add('hidden');
            document.getElementById('cancelOrCloseBtn').textContent = 'Close';
            
            // Populate view mode fields
            document.getElementById('viewDate').textContent = formattedDate;
            document.getElementById('viewTxnId').textContent = txn.transaction_id || '-';
            document.getElementById('viewDescription').textContent = txn.description || '-';
            document.getElementById('viewAmount').innerHTML = `<span class="${amountClass}">${formatIndianCurrency(Math.round(amount))} (${isDebit ? 'Debit' : 'Credit'})</span>`;
            document.getElementById('viewBalance').textContent = formatIndianCurrency(Math.round(balance));
            document.getElementById('viewNarration').textContent = txn.narration || '-';
            document.getElementById('viewPaymentMode').textContent = txn.payment_mode || '-';
            
            // Show beneficiary for debits, remitter for credits
            const isCredit = parseFloat(txn.credit_amount) > 0;
            if (isCredit) {
              document.getElementById('viewBeneficiaryRow').classList.add('hidden');
              document.getElementById('viewRemitterRow').classList.remove('hidden');

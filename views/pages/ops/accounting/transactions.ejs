    // ============= Post-Import Review Functionality =============
    
    // Review incomplete transactions from any source
    async function reviewIncompleteTransactions() {
      try {
        // Get current filter parameters
        const urlParams = new URLSearchParams(window.location.search);
        const bankAccountId = urlParams.get('bank_account_id') || '';
        const startDate = urlParams.get('start_date') || '';
        const endDate = urlParams.get('end_date') || '';

        // Build query string with filters
        const queryParams = new URLSearchParams();
        if (bankAccountId) queryParams.append('bank_account_id', bankAccountId);
        if (startDate) queryParams.append('start_date', startDate);
        if (endDate) queryParams.append('end_date', endDate);
        queryParams.append('limit', '100'); // Limit to 100 for performance

        const response = await fetch(`/accounting/api/transactions/incomplete?${queryParams.toString()}`);
        const result = await response.json();

        if (result.success && result.transactions) {
          if (result.transactions.length === 0) {
            showToast("No incomplete transactions found!", "", "success");
            return;
          }

          showReviewModal(result.transactions, result.transactions.length, true);
        } else {
          showToast("Failed to load incomplete transactions", "", "error");
        }
      } catch (error) {
        console.error("Error loading incomplete transactions:", error);
        showToast("Error loading transactions", "", "error");
      }
    }

    // Review transactions with missing mandatory invoices
    function reviewMissingInvoices() {
      // Get current filter parameters
      const urlParams = new URLSearchParams(window.location.search);
      const bankAccountId = urlParams.get('bank_account_id') || '';
      const startDate = urlParams.get('start_date') || '';
      const endDate = urlParams.get('end_date') || '';

      // Build query string with filters
      const queryParams = new URLSearchParams();
      if (bankAccountId) queryParams.append('bank_account_id', bankAccountId);
      if (startDate) queryParams.append('start_date', startDate);
      if (endDate) queryParams.append('end_date', endDate);

      // Redirect to the dedicated missing mandatory invoices page
      window.location.href = `/accounting/missing-mandatory-invoices?${queryParams.toString()}`;
    }

    function showMissingInvoicesModal(transactions) {
      document.getElementById("missingInvoicesModal").classList.remove("hidden");
      window.currentMissingInvoicesModal = true;
      
      const invoiceList = document.getElementById("missingInvoicesList");
      invoiceList.innerHTML = transactions.map(item => {
        // Check if this is a grouped invoice (has invoice_group_id)
        if (item.invoice_group_id) {
          // This is an invoice group with missing invoices
          const totalAmount = parseFloat(item.total_debit);

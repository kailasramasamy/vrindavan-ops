  <script>
    // View Transaction (read-only mode)
    function viewTransaction(id) {
      editTransaction(id, true); // Call edit with viewMode = true
    }

    // Show file upload button when file is selected (Edit mode)
    document.getElementById('invoiceFileInput').addEventListener('change', function() {
      const btn = document.getElementById('uploadInvoiceBtn');
      btn.classList.toggle('hidden', !this.files.length);
    });

    // Show file upload button when file is selected (View mode)
    document.getElementById('viewInvoiceFileInput').addEventListener('change', function() {
      const btn = document.getElementById('viewUploadInvoiceBtn');
      btn.classList.toggle('hidden', !this.files.length);
    });

    // Format all Indian currency elements on page load
    document.addEventListener('DOMContentLoaded', function() {
      const currencyElements = document.querySelectorAll('.indian-currency');
      currencyElements.forEach(element => {
        const amount = element.getAttribute('data-amount');
        if (amount !== null && amount !== undefined) {
          element.textContent = formatIndianCurrency(parseFloat(amount));
        }
      });

      // Populate search input with current search value from URL
      const urlParams = new URLSearchParams(window.location.search);
      const searchValue = urlParams.get('search');
      const searchInput = document.getElementById('searchInput');
      const clearBtn = document.getElementById('clearSearchBtn');
      
      if (searchValue && searchInput) {
        searchInput.value = searchValue;
        if (clearBtn) {
          clearBtn.classList.remove('hidden');
        }
      }
    });

    // Download transactions as CSV
    function downloadTransactionsCSV() {
      try {
        // Get current filter parameters
        const urlParams = new URLSearchParams(window.location.search);
        const bankAccountId = urlParams.get('bank_account_id') || '';
        const startDate = urlParams.get('start_date') || '';
        const endDate = urlParams.get('end_date') || '';
        const categoryId = urlParams.get('category_id') || '';
        const beneficiaryId = urlParams.get('beneficiary_id') || '';
        const remitterId = urlParams.get('remitter_id') || '';
        const isMatched = urlParams.get('is_matched') || '';
        const searchTerm = document.getElementById('searchInput')?.value || '';

        // Build download URL with current filters
        const downloadUrl = `/accounting/api/transactions/csv?` + new URLSearchParams({
          bank_account_id: bankAccountId,
          start_date: startDate,
          end_date: endDate,
          category_id: categoryId,
          beneficiary_id: beneficiaryId,
          remitter_id: remitterId,
          is_matched: isMatched,
          search: searchTerm
        }).toString();

        // Create temporary link and trigger download
        const link = document.createElement('a');
        link.href = downloadUrl;
        link.download = `transactions_${new Date().toISOString().split('T')[0]}.csv`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);

        // Show success message
        showSuccessToast('CSV download started');
      } catch (error) {
        console.error('Error downloading CSV:', error);
        showErrorToast('Failed to download CSV');
      }
    }

    // Pagination functions
    function goToPage(page) {
      if (page < 1) return;
      
      const urlParams = new URLSearchParams(window.location.search);
      urlParams.set('page', page);
      
      // Reload page with new page parameter
      window.location.href = window.location.pathname + '?' + urlParams.toString();
    }

    function changeEntriesPerPage() {
      const entriesPerPage = document.getElementById('entriesPerPage').value;
      
      const urlParams = new URLSearchParams(window.location.search);
      urlParams.set('limit', entriesPerPage);
      urlParams.set('page', '1'); // Reset to first page when changing limit
      
      // Reload page with new limit parameter
      window.location.href = window.location.pathname + '?' + urlParams.toString();
    }
  </script>


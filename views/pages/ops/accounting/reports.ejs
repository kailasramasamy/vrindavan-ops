<%- include('../../../partials/_head', { seo, pageKey }) %>
<link rel="stylesheet" href="/assets/css/accounting-dark-mode.css">

<!-- Indian Number Formatting -->
<script src="/assets/js/indian-number-format.js"></script>

<!-- Initialize theme immediately to prevent flash -->
<script>
  (function() {
    const theme = localStorage.getItem("accounting_theme") || "dark";
    if (theme === "dark") {
      document.documentElement.classList.add("dark");
    }
  })();
</script>

<!-- Print Styles -->
<style>
  @media print {
    body * {
      visibility: hidden;
    }
    .print-content, .print-content * {
      visibility: visible;
    }
    .print-content {
      position: absolute;
      left: 0;
      top: 0;
      width: 100%;
    }
    .no-print {
      display: none !important;
    }
    .print-header {
      text-align: center;
      margin-bottom: 20px;
      border-bottom: 2px solid #000;
      padding-bottom: 10px;
    }
    .print-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 20px;
    }
    .print-table th,
    .print-table td {
      border: 1px solid #000;
      padding: 8px;
      text-align: left;
    }
    .print-table th {
      background-color: #f0f0f0;
      font-weight: bold;
    }
    .print-summary {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      margin-bottom: 30px;
    }
    .print-summary-item {
      text-align: center;
      border: 1px solid #000;
      padding: 15px;
    }
    .print-summary-item h3 {
      margin: 0 0 10px 0;
      font-size: 14px;
    }
    .print-summary-item p {
      margin: 0;
      font-size: 18px;
      font-weight: bold;
    }
  }
</style>

<body class="bg-gray-50 dark:bg-gray-900 transition-colors duration-200">
  <%- include('../../../partials/_subnav', { user, section: 'Accounting', subsection: 'Reports' }) %>

  <div class="min-h-screen pt-16 no-print">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Header -->
      <div class="mb-6">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">Accounting Reports</h1>
            <p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 mt-1">Generate financial reports and analytics</p>
          </div>
          
        </div>
      </div>

      <!-- Quick Report Actions -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-6">
        <button onclick="generateQuickReport('current_month')" class="group bg-white dark:bg-gray-800 border-2 border-gray-200 dark:border-gray-700 hover:border-blue-500 dark:hover:border-blue-400 rounded-xl p-4 transition-all duration-200 hover:shadow-md">
          <div class="flex items-center">
            <div class="w-10 h-10 bg-blue-50 dark:bg-blue-900/20 group-hover:bg-blue-100 dark:group-hover:bg-blue-800/30 rounded-lg flex items-center justify-center mr-3 transition-colors">
              <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-blue-600 transition-colors">Current Month</h3>
              <p class="text-xs text-gray-600 dark:text-gray-400">Complete report</p>
            </div>
          </div>
        </button>

        <button onclick="generateQuickReport('last_month')" class="group bg-white dark:bg-gray-800 border-2 border-gray-200 dark:border-gray-700 hover:border-green-500 dark:hover:border-green-400 rounded-xl p-4 transition-all duration-200 hover:shadow-md">
          <div class="flex items-center">
            <div class="w-10 h-10 bg-green-50 dark:bg-green-900/20 group-hover:bg-green-100 dark:group-hover:bg-green-800/30 rounded-lg flex items-center justify-center mr-3 transition-colors">
              <svg class="w-5 h-5 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-green-600 transition-colors">Last Month</h3>
              <p class="text-xs text-gray-600 dark:text-gray-400">Complete report</p>
            </div>
          </div>
        </button>

        <button onclick="generateQuickReport('quarterly')" class="group bg-white dark:bg-gray-800 border-2 border-gray-200 dark:border-gray-700 hover:border-purple-500 dark:hover:border-purple-400 rounded-xl p-4 transition-all duration-200 hover:shadow-md">
          <div class="flex items-center">
            <div class="w-10 h-10 bg-purple-50 dark:bg-purple-900/20 group-hover:bg-purple-100 dark:group-hover:bg-purple-800/30 rounded-lg flex items-center justify-center mr-3 transition-colors">
              <svg class="w-5 h-5 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-purple-600 transition-colors">Quarterly</h3>
              <p class="text-xs text-gray-600 dark:text-gray-400">3-month report</p>
            </div>
          </div>
        </button>

        <button onclick="generateQuickReport('yearly')" class="group bg-white dark:bg-gray-800 border-2 border-gray-200 dark:border-gray-700 hover:border-orange-500 dark:hover:border-orange-400 rounded-xl p-4 transition-all duration-200 hover:shadow-md">
          <div class="flex items-center">
            <div class="w-10 h-10 bg-orange-50 dark:bg-orange-900/20 group-hover:bg-orange-100 dark:group-hover:bg-orange-800/30 rounded-lg flex items-center justify-center mr-3 transition-colors">
              <svg class="w-5 h-5 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-orange-600 transition-colors">Yearly</h3>
              <p class="text-xs text-gray-600 dark:text-gray-400">Annual report</p>
            </div>
          </div>
        </button>
      </div>

      <!-- Advanced Filters -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Advanced Report Filters</h3>
          <button type="button" onclick="toggleAdvancedFilters()" class="text-sm text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300">
            <span id="advancedToggleText">Show Advanced</span>
          </button>
        </div>

        <form id="reportForm" method="GET" class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Start Date</label>
            <input type="date" name="start_date" value="<%= startDate %>" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-lg" />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">End Date</label>
            <input type="date" name="end_date" value="<%= endDate %>" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-lg" />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Report Type</label>
            <select name="report_type" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-lg">
              <option value="comprehensive" <%= reportType === 'comprehensive' ? 'selected' : '' %>>Comprehensive Transaction Report</option>
              <option value="monthly_summary" <%= reportType === 'monthly_summary' ? 'selected' : '' %>>Month-wise Summary</option>
              <option value="tax_filing" <%= reportType === 'tax_filing' ? 'selected' : '' %>>Tax Filing Report</option>
              <option value="audit_trail" <%= reportType === 'audit_trail' ? 'selected' : '' %>>Audit Trail Report</option>
              <option value="summary" <%= reportType === 'summary' ? 'selected' : '' %>>Overall Summary</option>
              <option value="category" <%= reportType === 'category' ? 'selected' : '' %>>Category-wise</option>
              <option value="beneficiary" <%= reportType === 'beneficiary' ? 'selected' : '' %>>Beneficiary-wise</option>
              <option value="trends" <%= reportType === 'trends' ? 'selected' : '' %>>Daily Trends</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Export Format</label>
            <select name="export_format" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-lg">
              <option value="html">HTML View</option>
              <option value="pdf">PDF Export</option>
              <option value="excel">Excel Export</option>
              <option value="csv">CSV Export</option>
            </select>
          </div>

          <div class="flex items-end">
            <button type="submit" class="w-full px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Generate Report</button>
          </div>
        </form>

        <!-- Advanced Filters (Hidden by default) -->
        <div id="advancedFilters" class="hidden mt-6 pt-6 border-t border-gray-200 dark:border-gray-700">
          <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Bank Account</label>
              <select name="bank_account_id" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-lg">
                <option value="">All Accounts</option>
                <% if (bankAccounts && bankAccounts.length > 0) { %>
                  <% bankAccounts.forEach(account => { %>
                    <option value="<%= account.id %>" <%= bankAccountId == account.id ? 'selected' : '' %>>
                      <%= account.bank_name %> - <%= account.account_number %>
                    </option>
                  <% }) %>
                <% } %>
              </select>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Transaction Type</label>
              <select name="transaction_type" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-lg">
                <option value="">All Types</option>
                <option value="debit">Debit Only</option>
                <option value="credit">Credit Only</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Min Amount</label>
              <input type="number" name="min_amount" placeholder="0" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-lg" />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Max Amount</label>
              <input type="number" name="max_amount" placeholder="No limit" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-lg" />
            </div>
          </div>
        </div>
      </div>

      <!-- Report Content -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <div class="flex items-center justify-between">
            <div>
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white">
                <% if (reportType === 'comprehensive') { %>Comprehensive Transaction Report<% } %>
                <% if (reportType === 'monthly_summary') { %>Month-wise Summary Report<% } %>
                <% if (reportType === 'tax_filing') { %>Tax Filing Report<% } %>
                <% if (reportType === 'audit_trail') { %>Audit Trail Report<% } %>
                <% if (reportType === 'summary') { %>Overall Summary Report<% } %>
                <% if (reportType === 'category') { %>Category-wise Report<% } %>
                <% if (reportType === 'beneficiary') { %>Beneficiary-wise Report<% } %>
                <% if (reportType === 'trends') { %>Daily Trends Report<% } %>
              </h2>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                <%= new Date(startDate).toLocaleDateString() %> to <%= new Date(endDate).toLocaleDateString() %>
              </p>
            </div>
            
            <!-- Export Actions -->
            <% if (reportData) { %>
              <div class="flex gap-2 no-print">
                <button onclick="exportReport('pdf')" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 text-sm font-medium flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                  </svg>
                  PDF
                </button>
                <button onclick="exportReport('excel')" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 text-sm font-medium flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                  </svg>
                  Excel
                </button>
                <button onclick="exportReport('csv')" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                  </svg>
                  CSV
                </button>
                <button onclick="downloadInvoiceZip()" class="px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 text-sm font-medium flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"></path>
                  </svg>
                  Download Invoices
                </button>
              </div>
            <% } %>
          </div>
        </div>

        <div class="p-6">
          <% if (reportType === 'comprehensive' && Array.isArray(reportData)) { %>
            <!-- Comprehensive Transaction Report -->
            <div class="mb-6">
              <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
                <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4 text-center">
                  <h3 class="text-sm font-medium text-red-800 dark:text-red-200 mb-1">Total Debit</h3>
                  <p class="text-2xl font-bold text-red-600 dark:text-red-400 indian-currency" data-amount="<%= Math.round(parseFloat(reportData.reduce((sum, t) => sum + (parseFloat(t.debit_amount) || 0), 0))) %>">₹<%= Math.round(parseFloat(reportData.reduce((sum, t) => sum + (parseFloat(t.debit_amount) || 0), 0))) %></p>
                </div>
                <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-4 text-center">
                  <h3 class="text-sm font-medium text-green-800 dark:text-green-200 mb-1">Total Credit</h3>
                  <p class="text-2xl font-bold text-green-600 dark:text-green-400 indian-currency" data-amount="<%= Math.round(parseFloat(reportData.reduce((sum, t) => sum + (parseFloat(t.credit_amount) || 0), 0))) %>">₹<%= Math.round(parseFloat(reportData.reduce((sum, t) => sum + (parseFloat(t.credit_amount) || 0), 0))) %></p>
                </div>
                <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-4 text-center">
                  <h3 class="text-sm font-medium text-blue-800 dark:text-blue-200 mb-1">Total Transactions</h3>
                  <p class="text-2xl font-bold text-blue-600 dark:text-blue-400"><%= reportData.length %></p>
                </div>
                <div class="bg-purple-50 dark:bg-purple-900/20 border border-purple-200 dark:border-purple-800 rounded-lg p-4 text-center">
                  <h3 class="text-sm font-medium text-purple-800 dark:text-purple-200 mb-1">Net Balance</h3>
                  <p class="text-2xl font-bold text-purple-600 dark:text-purple-400 indian-currency" data-amount="<%= Math.round(parseFloat(reportData.reduce((sum, t) => sum + (parseFloat(t.credit_amount) || 0) - (parseFloat(t.debit_amount) || 0), 0))) %>">₹<%= Math.round(parseFloat(reportData.reduce((sum, t) => sum + (parseFloat(t.credit_amount) || 0) - (parseFloat(t.debit_amount) || 0), 0))) %></p>
                </div>
              </div>
            </div>

            <!-- Detailed Transaction Table -->
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                <thead class="bg-gray-50 dark:bg-gray-900">
                  <tr>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Date</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Description</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Beneficiary</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Category</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Narration</th>
                    <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Debit</th>
                    <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Credit</th>
                    <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Balance</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Invoice</th>
                  </tr>
                </thead>
                <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                  <% reportData.forEach((transaction, index) => { %>
                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                      <td class="px-4 py-3 text-sm text-gray-900 dark:text-white">
                        <%= new Date(transaction.transaction_date).toLocaleDateString() %>
                      </td>
                      <td class="px-4 py-3 text-sm text-gray-900 dark:text-white max-w-xs truncate">
                        <%= transaction.description %>
                      </td>
                      <td class="px-4 py-3 text-sm text-gray-900 dark:text-white">
                        <%= transaction.beneficiary_name || transaction.remitter_name || '-' %>
                      </td>
                      <td class="px-4 py-3 text-sm text-gray-900 dark:text-white">
                        <%= transaction.category_name || '-' %>
                      </td>
                      <td class="px-4 py-3 text-sm text-gray-900 dark:text-white max-w-xs truncate">
                        <%= transaction.narration || '-' %>
                      </td>
                      <td class="px-4 py-3 text-right text-sm text-gray-900 dark:text-white">
                        <% if (transaction.debit_amount && parseFloat(transaction.debit_amount) > 0) { %>
                          <span class="text-red-600 dark:text-red-400 indian-currency" data-amount="<%= Math.round(parseFloat(transaction.debit_amount)) %>">₹<%= Math.round(parseFloat(transaction.debit_amount)) %></span>
                        <% } else { %>
                          -
                        <% } %>
                      </td>
                      <td class="px-4 py-3 text-right text-sm text-gray-900 dark:text-white">
                        <% if (transaction.credit_amount && parseFloat(transaction.credit_amount) > 0) { %>
                          <span class="text-green-600 dark:text-green-400 indian-currency" data-amount="<%= Math.round(parseFloat(transaction.credit_amount)) %>">₹<%= Math.round(parseFloat(transaction.credit_amount)) %></span>
                        <% } else { %>
                          -
                        <% } %>
                      </td>
                      <td class="px-4 py-3 text-right text-sm text-gray-900 dark:text-white">
                        <span class="indian-currency" data-amount="<%= Math.round(parseFloat(transaction.balance || 0)) %>">₹<%= Math.round(parseFloat(transaction.balance || 0)) %></span>
                      </td>
                      <td class="px-4 py-3 text-sm text-gray-900 dark:text-white">
                        <% if (transaction.invoice_url) { %>
                          <a href="<%= transaction.invoice_url %>" target="_blank" class="text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300">
                            <svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                            </svg>
                          </a>
                        <% } else { %>
                          -
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>

          <% } else if (reportType === 'monthly_summary' && Array.isArray(reportData)) { %>
            <!-- Month-wise Summary Report -->
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                <thead class="bg-gray-50 dark:bg-gray-900">
                  <tr>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Month</th>
                    <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Transactions</th>
                    <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Total Debit</th>
                    <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Total Credit</th>
                    <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Net Balance</th>
                    <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Actions</th>
                  </tr>
                </thead>
                <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                  <% reportData.forEach(month => { %>
                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                      <td class="px-4 py-3 text-sm font-medium text-gray-900 dark:text-white">
                        <%= new Date(month.month + '-01').toLocaleDateString('en-US', { year: 'numeric', month: 'long' }) %>
                      </td>
                      <td class="px-4 py-3 text-right text-sm text-gray-900 dark:text-white">
                        <%= month.transaction_count %>
                      </td>
                      <td class="px-4 py-3 text-right text-sm text-red-600 dark:text-red-400 indian-currency" data-amount="<%= Math.round(parseFloat(month.total_debit || 0)) %>">
                        ₹<%= Math.round(parseFloat(month.total_debit || 0)) %>
                      </td>
                      <td class="px-4 py-3 text-right text-sm text-green-600 dark:text-green-400 indian-currency" data-amount="<%= Math.round(parseFloat(month.total_credit || 0)) %>">
                        ₹<%= Math.round(parseFloat(month.total_credit || 0)) %>
                      </td>
                      <td class="px-4 py-3 text-right text-sm font-semibold text-gray-900 dark:text-white indian-currency" data-amount="<%= Math.round(parseFloat((month.total_credit || 0) - (month.total_debit || 0))) %>">
                        ₹<%= Math.round(parseFloat((month.total_credit || 0) - (month.total_debit || 0))) %>
                      </td>
                      <td class="px-4 py-3 text-center">
                        <button onclick="viewMonthDetails('<%= month.month %>')" class="text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 text-sm">
                          View Details
                        </button>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>

          <% } else if (reportType === 'tax_filing' && reportData) { %>
            <!-- Tax Filing Report -->
            <div class="space-y-6">
              <!-- Summary Section -->
              <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-6">
                <h3 class="text-lg font-semibold text-blue-900 dark:text-blue-100 mb-4">Tax Filing Summary</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                  <div class="text-center">
                    <p class="text-sm text-blue-700 dark:text-blue-300">Total Business Expenses</p>
                    <p class="text-2xl font-bold text-blue-900 dark:text-blue-100 indian-currency" data-amount="<%= Math.round(parseFloat(reportData.total_debit || 0)) %>">₹<%= Math.round(parseFloat(reportData.total_debit || 0)) %></p>
                  </div>
                  <div class="text-center">
                    <p class="text-sm text-blue-700 dark:text-blue-300">Total Business Income</p>
                    <p class="text-2xl font-bold text-blue-900 dark:text-blue-100 indian-currency" data-amount="<%= Math.round(parseFloat(reportData.total_credit || 0)) %>">₹<%= Math.round(parseFloat(reportData.total_credit || 0)) %></p>
                  </div>
                  <div class="text-center">
                    <p class="text-sm text-blue-700 dark:text-blue-300">Net Profit/Loss</p>
                    <p class="text-2xl font-bold text-blue-900 dark:text-blue-100 indian-currency" data-amount="<%= Math.round(parseFloat((reportData.total_credit || 0) - (reportData.total_debit || 0))) %>">₹<%= Math.round(parseFloat((reportData.total_credit || 0) - (reportData.total_debit || 0))) %></p>
                  </div>
                </div>
              </div>

              <!-- Category-wise Breakdown for Tax -->
              <% if (reportData.categories && Array.isArray(reportData.categories)) { %>
                <div>
                  <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Category-wise Expenses (Tax Deductible)</h3>
                  <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                      <thead class="bg-gray-50 dark:bg-gray-900">
                        <tr>
                          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Category</th>
                          <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Amount</th>
                          <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Tax Deductible</th>
                          <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Documents</th>
                        </tr>
                      </thead>
                      <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                        <% reportData.categories.forEach(cat => { %>
                          <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                            <td class="px-4 py-3 text-sm font-medium text-gray-900 dark:text-white">
                              <%= cat.category_name %>
                            </td>
                            <td class="px-4 py-3 text-right text-sm text-gray-900 dark:text-white indian-currency" data-amount="<%= Math.round(parseFloat(cat.total_debit || 0)) %>">
                              ₹<%= Math.round(parseFloat(cat.total_debit || 0)) %>
                            </td>
                            <td class="px-4 py-3 text-right text-sm text-gray-900 dark:text-white">
                              <span class="px-2 py-1 text-xs rounded-full bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-200">
                                <%= Math.round((cat.total_debit || 0) * 0.8) %> (80%)
                              </span>
                            </td>
                            <td class="px-4 py-3 text-center">
                              <button onclick="downloadCategoryInvoices('<%= cat.id %>')" class="text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 text-sm">
                                Download
                              </button>
                            </td>
                          </tr>
                        <% }) %>
                      </tbody>
                    </table>
                  </div>
                </div>
              <% } %>
            </div>

          <% } else if (reportType === 'summary' && reportData) { %>
            <!-- Summary Report -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-6 text-center bg-white dark:bg-gray-900">
                <h3 class="text-sm font-medium text-gray-600 dark:text-gray-400 mb-2">Total Debit</h3>
                <p class="text-3xl font-bold text-red-600 dark:text-red-400 indian-currency" data-amount="<%= Math.round(parseFloat(reportData.total_debit || 0)) %>">₹<%= Math.round(parseFloat(reportData.total_debit || 0)) %></p>
              </div>
              <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-6 text-center bg-white dark:bg-gray-900">
                <h3 class="text-sm font-medium text-gray-600 dark:text-gray-400 mb-2">Total Credit</h3>
                <p class="text-3xl font-bold text-green-600 dark:text-green-400 indian-currency" data-amount="<%= Math.round(parseFloat(reportData.total_credit || 0)) %>">₹<%= Math.round(parseFloat(reportData.total_credit || 0)) %></p>
              </div>
              <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-6 text-center bg-white dark:bg-gray-900">
                <h3 class="text-sm font-medium text-gray-600 dark:text-gray-400 mb-2">Net Balance</h3>
                <p class="text-3xl font-bold text-blue-600 dark:text-blue-400 indian-currency" data-amount="<%= Math.round(parseFloat(reportData.net_balance || 0)) %>">₹<%= Math.round(parseFloat(reportData.net_balance || 0)) %></p>
              </div>
            </div>

          <% } else if ((reportType === 'category' || reportType === 'beneficiary') && Array.isArray(reportData)) { %>
            <!-- Table Reports -->
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                <thead class="bg-gray-50 dark:bg-gray-900">
                  <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">
                      <%= reportType === 'category' ? 'Category' : 'Beneficiary' %>
                    </th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Transactions</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Total Amount</th>
                  </tr>
                </thead>
                <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                  <% if (reportData.length > 0) { %>
                    <% reportData.forEach(row => { %>
                      <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                        <td class="px-6 py-4">
                          <div class="font-medium text-gray-900 dark:text-white">
                            <%= reportType === 'category' ? row.category_name : row.beneficiary_name %>
                          </div>
                        </td>
                        <td class="px-6 py-4 text-right text-sm text-gray-900 dark:text-white"><%= parseInt(row.transaction_count || 0) %></td>
                        <td class="px-6 py-4 text-right text-sm font-semibold text-gray-900 dark:text-white indian-currency" data-amount="<%= Math.round(parseFloat(row.total_debit || row.total_paid || 0)) %>">
                          ₹<%= Math.round(parseFloat(row.total_debit || row.total_paid || 0)) %>
                        </td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr>
                      <td colspan="3" class="px-6 py-8 text-center text-gray-500 dark:text-gray-400">No data available</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>

          <% } else { %>
            <p class="text-center text-gray-500 dark:text-gray-400 py-12">Select filters and click "Generate" to view report</p>
          <% } %>
        </div>
      </div>
    </main>
  </div>

  <!-- Print Content Wrapper -->
  <div class="print-content" style="display: none;">
    <div class="print-header">
      <h1>Accounting Report</h1>
      <p>Report Type: <%= reportType || 'Comprehensive' %></p>
      <p>Date Range: <%= startDate %> to <%= endDate %></p>
      <p>Generated on: <%= new Date().toLocaleDateString() %></p>
    </div>
    
    <% if (reportType === 'comprehensive' && Array.isArray(reportData)) { %>
      <!-- Print Summary -->
      <div class="print-summary">
        <div class="print-summary-item">
          <h3>Total Debit</h3>
          <p>₹<%= Math.round(parseFloat(reportData.reduce((sum, t) => sum + (parseFloat(t.debit_amount) || 0), 0))) %></p>
        </div>
        <div class="print-summary-item">
          <h3>Total Credit</h3>
          <p>₹<%= Math.round(parseFloat(reportData.reduce((sum, t) => sum + (parseFloat(t.credit_amount) || 0), 0))) %></p>
        </div>
        <div class="print-summary-item">
          <h3>Net Balance</h3>
          <p>₹<%= Math.round(parseFloat(reportData.reduce((sum, t) => sum + (parseFloat(t.credit_amount) || 0), 0)) - parseFloat(reportData.reduce((sum, t) => sum + (parseFloat(t.debit_amount) || 0), 0))) %></p>
        </div>
        <div class="print-summary-item">
          <h3>Total Transactions</h3>
          <p><%= reportData.length %></p>
        </div>
      </div>
      
      <!-- Print Table -->
      <table class="print-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Description</th>
            <th>Beneficiary/Remitter</th>
            <th>Category</th>
            <th>Narration</th>
            <th>Debit Amount</th>
            <th>Credit Amount</th>
            <th>Balance</th>
            <th>Invoice</th>
          </tr>
        </thead>
        <tbody>
          <% reportData.forEach(transaction => { %>
            <tr>
              <td><%= new Date(transaction.transaction_date).toLocaleDateString() %></td>
              <td><%= transaction.description || '-' %></td>
              <td><%= transaction.beneficiary_name || transaction.remitter_name || '-' %></td>
              <td><%= transaction.category_name || '-' %></td>
              <td><%= transaction.narration || '-' %></td>
              <td><%= parseFloat(transaction.debit_amount) > 0 ? '₹' + Math.round(parseFloat(transaction.debit_amount)) : '-' %></td>
              <td><%= parseFloat(transaction.credit_amount) > 0 ? '₹' + Math.round(parseFloat(transaction.credit_amount)) : '-' %></td>
              <td>₹<%= Math.round(parseFloat(transaction.balance) || 0) %></td>
              <td><%= transaction.invoice_url ? 'Yes' : 'No' %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>

  <%- include('../../../partials/_footer') %>
  <%- include('../../../partials/_toast') %>

  <script>
    // Handle print functionality
    document.addEventListener('DOMContentLoaded', function() {
      // Check if this is a print request
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('print') === 'true') {
        // Hide main content and show print content
        document.querySelector('main').style.display = 'none';
        document.querySelector('.print-content').style.display = 'block';
        
        // Auto-trigger print dialog
        setTimeout(() => {
          window.print();
        }, 500);
        
        // After printing, redirect back to normal view
        window.addEventListener('afterprint', function() {
          const newUrl = window.location.href.replace('&print=true', '');
          window.location.href = newUrl;
        });
      }
      
      // Format all Indian currency elements on page load
      const currencyElements = document.querySelectorAll('.indian-currency');
      currencyElements.forEach(element => {
        const amount = element.getAttribute('data-amount');
        if (amount !== null && amount !== undefined) {
          element.textContent = formatIndianCurrency(parseFloat(amount));
        }
      });
    });

    // Quick Report Generation
    function generateQuickReport(period) {
      const now = new Date();
      let startDate, endDate;
      
      switch(period) {
        case 'current_month':
          // Current month: 1st to last day of current month
          startDate = new Date(now.getFullYear(), now.getMonth(), 1);
          endDate = new Date(now.getFullYear(), now.getMonth() + 1, 0);
          break;
        case 'last_month':
          // Last month: 1st to last day of previous month
          startDate = new Date(now.getFullYear(), now.getMonth() - 1, 1);
          endDate = new Date(now.getFullYear(), now.getMonth(), 0);
          break;
        case 'quarterly':
          // Show quarter selection modal
          showQuarterSelection();
          return;
        case 'yearly':
          // Show year selection modal
          showYearSelection();
          return;
      }
      
      // Format dates in local timezone to avoid timezone issues
      const startStr = `${startDate.getFullYear()}-${String(startDate.getMonth() + 1).padStart(2, '0')}-${String(startDate.getDate()).padStart(2, '0')}`;
      const endStr = `${endDate.getFullYear()}-${String(endDate.getMonth() + 1).padStart(2, '0')}-${String(endDate.getDate()).padStart(2, '0')}`;
      
      // Generate comprehensive report for quick actions
      window.location.href = `/accounting/reports?start_date=${startStr}&end_date=${endStr}&report_type=comprehensive&export_format=html`;
    }

    // Show Quarter Selection Modal
    function showQuarterSelection() {
      const currentYear = new Date().getFullYear();
      const quarters = [
        { name: 'Q1 (Apr-Jun)', months: [3, 4, 5], startMonth: 3, endMonth: 5 },
        { name: 'Q2 (Jul-Sep)', months: [6, 7, 8], startMonth: 6, endMonth: 8 },
        { name: 'Q3 (Oct-Dec)', months: [9, 10, 11], startMonth: 9, endMonth: 11 },
        { name: 'Q4 (Jan-Mar)', months: [0, 1, 2], startMonth: 0, endMonth: 2, yearOffset: 1 }
      ];

      const modal = document.createElement('div');
      modal.className = 'fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4';
      modal.innerHTML = `
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl w-full max-w-md">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Select Quarter</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">Choose a quarter for the report</p>
          </div>
          <div class="p-6">
            <div class="space-y-2">
              ${quarters.map((quarter, index) => {
                const year = quarter.yearOffset ? currentYear + 1 : currentYear;
                const startDate = new Date(year, quarter.startMonth, 1);
                const endDate = new Date(year, quarter.endMonth + 1, 0);
                const startStr = `${startDate.getFullYear()}-${String(startDate.getMonth() + 1).padStart(2, '0')}-${String(startDate.getDate()).padStart(2, '0')}`;
                const endStr = `${endDate.getFullYear()}-${String(endDate.getMonth() + 1).padStart(2, '0')}-${String(endDate.getDate()).padStart(2, '0')}`;
                
                return `
                  <button onclick="selectQuarter('${startStr}', '${endStr}')" 
                          class="w-full text-left px-4 py-3 bg-gray-50 dark:bg-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 rounded-lg transition-colors">
                    <div class="font-medium text-gray-900 dark:text-white">${quarter.name} ${year}</div>
                    <div class="text-sm text-gray-600 dark:text-gray-400">${startStr} to ${endStr}</div>
                  </button>
                `;
              }).join('')}
            </div>
            <div class="mt-6 flex justify-end">
              <button onclick="closeModal()" class="px-4 py-2 text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600">
                Cancel
              </button>
            </div>
          </div>
        </div>
      `;
      
      document.body.appendChild(modal);
    }

    // Show Year Selection Modal
    function showYearSelection() {
      const currentYear = new Date().getFullYear();
      const years = [];
      
      // Generate years from current year back to 2020
      for (let year = currentYear; year >= 2020; year--) {
        years.push(year);
      }

      const modal = document.createElement('div');
      modal.className = 'fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4';
      modal.innerHTML = `
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl w-full max-w-md">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Select Financial Year</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">Choose a financial year (Apr to Mar)</p>
          </div>
          <div class="p-6">
            <div class="space-y-2">
              ${years.map(year => {
                const startDate = new Date(year, 3, 1); // April 1st
                const endDate = new Date(year + 1, 2, 31); // March 31st next year
                const startStr = `${startDate.getFullYear()}-${String(startDate.getMonth() + 1).padStart(2, '0')}-${String(startDate.getDate()).padStart(2, '0')}`;
                const endStr = `${endDate.getFullYear()}-${String(endDate.getMonth() + 1).padStart(2, '0')}-${String(endDate.getDate()).padStart(2, '0')}`;
                
                return `
                  <button onclick="selectYear('${startStr}', '${endStr}')" 
                          class="w-full text-left px-4 py-3 bg-gray-50 dark:bg-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 rounded-lg transition-colors">
                    <div class="font-medium text-gray-900 dark:text-white">FY ${year}-${(year + 1).toString().slice(-2)}</div>
                    <div class="text-sm text-gray-600 dark:text-gray-400">${startStr} to ${endStr}</div>
                  </button>
                `;
              }).join('')}
            </div>
            <div class="mt-6 flex justify-end">
              <button onclick="closeModal()" class="px-4 py-2 text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600">
                Cancel
              </button>
            </div>
          </div>
        </div>
      `;
      
      document.body.appendChild(modal);
    }

    // Select Quarter and Generate Report
    function selectQuarter(startDate, endDate) {
      closeModal();
      window.location.href = `/accounting/reports?start_date=${startDate}&end_date=${endDate}&report_type=comprehensive&export_format=html`;
    }

    // Select Year and Generate Report
    function selectYear(startDate, endDate) {
      closeModal();
      window.location.href = `/accounting/reports?start_date=${startDate}&end_date=${endDate}&report_type=comprehensive&export_format=html`;
    }

    // Close Modal
    function closeModal() {
      const modal = document.querySelector('.fixed.inset-0.bg-black.bg-opacity-50');
      if (modal) {
        modal.remove();
      }
    }

    // Toggle Advanced Filters
    function toggleAdvancedFilters() {
      const filters = document.getElementById('advancedFilters');
      const toggleText = document.getElementById('advancedToggleText');
      
      if (filters.classList.contains('hidden')) {
        filters.classList.remove('hidden');
        toggleText.textContent = 'Hide Advanced';
      } else {
        filters.classList.add('hidden');
        toggleText.textContent = 'Show Advanced';
      }
    }

    // Download Invoice Zip
    function downloadInvoiceZip() {
      // Get current URL parameters
      const urlParams = new URLSearchParams(window.location.search);
      urlParams.set('download_invoices', 'true');
      
      // Create download link
      const downloadUrl = `/accounting/reports?${urlParams.toString()}`;
      
      // Show loading state
      const button = event.target.closest('button');
      const originalText = button.innerHTML;
      button.innerHTML = '<svg class="w-4 h-4 animate-spin mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>Downloading...';
      button.disabled = true;
      
      // Create temporary link and click it
      const link = document.createElement('a');
      link.href = downloadUrl;
      link.download = '';
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      
      // Reset button after delay
      setTimeout(() => {
        button.innerHTML = originalText;
        button.disabled = false;
      }, 3000);
    }

    // Export Report
    function exportReport(format) {
      // Get current URL parameters
      const urlParams = new URLSearchParams(window.location.search);
      
      // Update export format
      urlParams.set('export_format', format);
      
      // Navigate to export URL
      window.location.href = `/accounting/reports?${urlParams.toString()}`;
    }

    // View Month Details
    function viewMonthDetails(month) {
      const startDate = month + '-01';
      const endDate = new Date(new Date(month + '-01').getFullYear(), new Date(month + '-01').getMonth() + 1, 0).toISOString().split('T')[0];
      
      window.location.href = `/accounting/reports?start_date=${startDate}&end_date=${endDate}&report_type=comprehensive&export_format=html`;
    }

    // Download Category Invoices
    function downloadCategoryInvoices(categoryId) {
      const startDate = document.querySelector('input[name="start_date"]').value;
      const endDate = document.querySelector('input[name="end_date"]').value;
      
      // Create a form to download invoices for this category
      const form = document.createElement('form');
      form.method = 'POST';
      form.action = '/accounting/reports/download-invoices';
      form.style.display = 'none';
      
      const inputs = [
        { name: 'start_date', value: startDate },
        { name: 'end_date', value: endDate },
        { name: 'category_id', value: categoryId },
        { name: 'format', value: 'zip' }
      ];
      
      inputs.forEach(input => {
        const inputElement = document.createElement('input');
        inputElement.type = 'hidden';
        inputElement.name = input.name;
        inputElement.value = input.value;
        form.appendChild(inputElement);
      });
      
      document.body.appendChild(form);
      form.submit();
      document.body.removeChild(form);
    }

    // Set default dates if not provided
    document.addEventListener('DOMContentLoaded', function() {
      const startDateInput = document.querySelector('input[name="start_date"]');
      const endDateInput = document.querySelector('input[name="end_date"]');
      
      if (!startDateInput.value) {
        const now = new Date();
        const lastMonth = new Date(now.getFullYear(), now.getMonth() - 1, 1);
        const lastMonthEnd = new Date(now.getFullYear(), now.getMonth(), 0);
        
        startDateInput.value = lastMonth.toISOString().split('T')[0];
        endDateInput.value = lastMonthEnd.toISOString().split('T')[0];
      }
    });
  </script>
</body>
</html>


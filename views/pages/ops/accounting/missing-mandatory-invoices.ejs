<!-- Link to Invoice Group Modal -->
<div id="linkToGroupModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center p-4" onclick="if(event.target === this) closeLinkToGroupModal()">
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl w-full max-w-md">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Link to Invoice Group</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">Link this transaction to an existing invoice group</p>
    </div>

    <form id="linkToGroupForm" class="p-6">
      <input type="hidden" id="linkTransactionId" />

      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Select Invoice Group</label>
        <select id="invoiceGroupSelect" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500" required>
          <option value="">Select an invoice group...</option>
        </select>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Choose the invoice group to link this transaction to</p>
      </div>

      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Amount for this Invoice</label>
        <input type="number" id="invoiceAmount" step="0.01" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500" placeholder="Enter amount" required />
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Amount to allocate to this invoice</p>
      </div>

      <div class="flex justify-end space-x-3">
        <button type="button" onclick="closeLinkToGroupModal()" class="px-4 py-2 text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600">Cancel</button>
        <button type="submit" class="px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700">Link to Group</button>
      </div>
    </form>
  </div>
</div>

<script>
  let currentFilters = {};
  let bankAccounts = [];
  let invoiceGroups = [];
  let currentTransactions = [];

  // Initialize page
  document.addEventListener("DOMContentLoaded", function () {
    initializeFiltersFromURL();
    loadBankAccounts();
    loadMissingInvoices();
    setupEventListeners();
  });

  function initializeFiltersFromURL() {
    // Read URL parameters
    const urlParams = new URLSearchParams(window.location.search);
    const bankAccountId = urlParams.get("bank_account_id") || "";
    const startDate = urlParams.get("start_date") || "";
    const endDate = urlParams.get("end_date") || "";

    // Set filter input values
    if (bankAccountId) {
      document.getElementById("bankAccountFilter").value = bankAccountId;
    }
    if (startDate) {
      document.getElementById("startDateFilter").value = startDate;
    }
    if (endDate) {
      document.getElementById("endDateFilter").value = endDate;
    }

    // Initialize currentFilters with URL parameter values
    currentFilters = {
      search: "",
      bank_account_id: bankAccountId,
      start_date: startDate,
      end_date: endDate,
    };
  }

  function setupEventListeners() {
    // Filter form submission
    document.getElementById("filterForm").addEventListener("submit", function (e) {
      e.preventDefault();
      applyFilters();
    });

    // Real-time search
    document.getElementById("searchFilter").addEventListener("input", function (e) {
      // Debounce search to avoid too many API calls
      clearTimeout(window.searchTimeout);
      window.searchTimeout = setTimeout(() => {
        applyFilters();
      }, 500);
    });

    // Upload form submission
    document.getElementById("uploadInvoiceForm").addEventListener("submit", function (e) {
      e.preventDefault();
      uploadInvoice();
    });

    // Link to group form submission
    document.getElementById("linkToGroupForm").addEventListener("submit", function (e) {
      e.preventDefault();
      linkTransactionToGroup();
    });
  }

  function loadBankAccounts() {
    fetch("/accounting/api/bank-accounts", {
      credentials: "same-origin",
    })
      .then((response) => response.json())
      .then((data) => {
        if (data.success) {
          bankAccounts = Array.isArray(data.bankAccounts) ? data.bankAccounts : [];
          const select = document.getElementById("bankAccountFilter");
          bankAccounts.forEach((account) => {
            const option = document.createElement("option");
            option.value = account.id;
            option.textContent = `${account.bank_name} - ${account.account_number}`;
            select.appendChild(option);
          });

          // Set the selected value from currentFilters (from URL params)
          if (currentFilters.bank_account_id) {
            select.value = currentFilters.bank_account_id;
          }
        }
      })
      .catch((error) => {
        console.error("Error loading bank accounts:", error);
      });
  }

  function applyFilters() {
    currentFilters = {
      search: document.getElementById("searchFilter").value,
      bank_account_id: document.getElementById("bankAccountFilter").value,
      start_date: document.getElementById("startDateFilter").value,
      end_date: document.getElementById("endDateFilter").value,
    };

    loadMissingInvoices();
  }

  async function loadMissingInvoices() {
    try {
      const params = new URLSearchParams();
      Object.keys(currentFilters).forEach((key) => {
        if (currentFilters[key]) {
          params.append(key, currentFilters[key]);
        }
      });

      const response = await fetch(`/accounting/api/transactions/missing-invoices?${params.toString()}`, {
        credentials: "same-origin",
      });

      const result = await response.json();

      if (result.success) {
        currentTransactions = result.transactions || [];
        displayTransactions(currentTransactions);
        updateSummaryCards(currentTransactions);
      } else {
        showError("Failed to load missing invoices: " + result.error);
      }
    } catch (error) {
      console.error("Error loading missing invoices:", error);
      showError("Error loading missing invoices");
    }
  }

  function displayTransactions(transactions) {
    const tbody = document.getElementById("transactionsTableBody");

    if (transactions.length === 0) {
      tbody.innerHTML = `
      <tr>
        <td colspan="6" class="px-6 py-12 text-center">
          <div class="text-gray-500 dark:text-gray-400">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No missing invoices</h3>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">All transactions have their required invoices uploaded.</p>
          </div>
        </td>
      </tr>
    `;
      return;
    }

    tbody.innerHTML = transactions
      .map((transaction) => {
        const isGrouped = transaction.invoice_group_id;
        const groupHasInvoice = transaction.invoice_group_has_invoice;

        return `
        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
          <td class="px-3 py-3">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <div class="w-6 h-6 bg-red-100 dark:bg-red-900/30 rounded-lg flex items-center justify-center">
                  <svg class="w-3 h-3 text-red-600 dark:text-red-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                  </svg>
                </div>
              </div>
              <div class="ml-2 min-w-0 flex-1">
                <div class="text-sm font-medium text-gray-900 dark:text-white truncate">${transaction.description || "N/A"}</div>
                <div class="text-xs text-gray-500 dark:text-gray-400">Txn ID: ${transaction.id}</div>
                ${
                  isGrouped
                    ? `
                <div class="text-xs text-blue-600 dark:text-blue-400 mt-1">
                  <button onclick="viewInvoiceGroup('${transaction.invoice_group_id}')" class="hover:underline truncate">
                    Group: ${transaction.invoice_group_name}
                  </button>
                </div>
                `
                    : ""
                }
              </div>
            </div>
          </td>
          <td class="px-3 py-3">
            <div class="text-sm text-gray-900 dark:text-white truncate">${transaction.beneficiary_name || "N/A"}</div>
            ${transaction.beneficiary_alias ? `<div class="text-xs text-gray-500 dark:text-gray-400 truncate italic">(${transaction.beneficiary_alias})</div>` : ``}
            <div class="text-xs text-gray-500 dark:text-gray-400 truncate">${transaction.beneficiary_account || ""}</div>
          </td>
          <td class="px-3 py-3">
            <div class="text-sm font-medium text-gray-900 dark:text-white">₹${formatIndianNumber(parseFloat(transaction.debit_amount) || 0)}</div>
          </td>
          <td class="px-3 py-3">
            <div class="text-sm text-gray-900 dark:text-white">${formatDate(transaction.transaction_date)}</div>
          </td>
          <td class="px-3 py-3">
            ${isGrouped ? `<span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400">Group</span>` : `<span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-xs font-medium bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-400">Individual</span>`}
          </td>
          <td class="px-3 py-3">
            <div class="flex items-center space-x-2">
              <button onclick="openTransactionDetails('${transaction.id}')" class="p-1 text-gray-600 dark:text-gray-400 hover:text-gray-800 dark:hover:text-gray-300" title="View Details">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                </svg>
              </button>
              ${
                !isGrouped
                  ? `
                <button onclick=\"openUploadModal('${transaction.id}')\" class=\"text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 text-sm font-medium\">Upload</button>
                <button onclick=\"openLinkToGroupModal('${transaction.id}', '${transaction.debit_amount}')\" class=\"text-purple-600 dark:text-purple-400 hover:text-purple-800 dark:hover:text-purple-300 text-sm font-medium\" title=\"Link to Invoice Group\">Link</button>
              `
                  : `
                <span class=\"p-1 text-gray-400 dark:text-gray-500\" title=\"Grouped Transaction\">
                  <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">
                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10\"></path>
                  </svg>
                </span>
              `
              }
            </div>
          </td>
        </tr>
      `;
      })
      .join("");
  }

  function updateSummaryCards(transactions) {
    const individual = transactions.filter((t) => !t.invoice_group_id);
    const groups = transactions.filter((t) => t.invoice_group_id && !t.invoice_group_has_invoice);
    const uniqueGroups = [...new Set(groups.map((t) => t.invoice_group_id))];

    const totalAmount = transactions.reduce((sum, t) => {
      const amount = parseFloat(t.debit_amount) || 0;
      return sum + amount;
    }, 0);

    document.getElementById("totalMissingCount").textContent = individual.length + uniqueGroups.length;
    document.getElementById("individualCount").textContent = individual.length;
    document.getElementById("groupCount").textContent = uniqueGroups.length;
    document.getElementById("totalAmount").textContent = "₹" + formatIndianNumber(totalAmount);
  }

  function openUploadModal(transactionId) {
    document.getElementById("uploadTransactionId").value = transactionId;

    // Find the transaction in currentTransactions
    const transaction = currentTransactions.find((t) => String(t.id) === String(transactionId));

    if (transaction) {
      // Populate transaction details
      document.getElementById("uploadTxnId").textContent = transaction.id;
      document.getElementById("uploadTxnDescription").textContent = transaction.description || "N/A";
      document.getElementById("uploadTxnAmount").textContent = `₹${formatIndianNumber(parseFloat(transaction.debit_amount) || 0)}`;
      document.getElementById("uploadTxnBeneficiary").textContent = transaction.beneficiary_name || "N/A";
      document.getElementById("uploadTxnDate").textContent = formatDate(transaction.transaction_date);

      // Set transaction type badge
      const isGrouped = transaction.invoice_group_id;
      const typeBadge = document.getElementById("uploadTxnType");
      if (isGrouped) {
        typeBadge.textContent = "Group";
        typeBadge.className = "inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400";
      } else {
        typeBadge.textContent = "Individual";
        typeBadge.className = "inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-400";
      }
    }

    document.getElementById("uploadInvoiceModal").classList.remove("hidden");
  }

  function closeUploadModal() {
    document.getElementById("uploadInvoiceModal").classList.add("hidden");
    document.getElementById("uploadInvoiceForm").reset();
  }

  async function uploadInvoice() {
    const transactionId = document.getElementById("uploadTransactionId").value;
    const fileInput = document.getElementById("invoiceFile");
    const file = fileInput.files[0];

    if (!file) {
      showToast("Please select a file", "", "error");
      return;
    }

    const formData = new FormData();
    formData.append("invoice", file);

    try {
      const response = await fetch(`/accounting/transactions/${transactionId}/invoice`, {
        method: "POST",
        body: formData,
        credentials: "same-origin",
      });

      const result = await response.json();

      if (result.success) {
        showToast("Invoice uploaded successfully", "", "success");
        closeUploadModal();
        loadMissingInvoices(); // Refresh the list
      } else {
        showToast(result.error || "Failed to upload invoice", "", "error");
      }
    } catch (error) {
      console.error("Error uploading invoice:", error);
      showToast("Error uploading invoice", "", "error");
    }
  }

  // Load invoice groups for linking
  async function loadInvoiceGroups() {
    try {
      const response = await fetch("/accounting/invoice-groups/list?limit=100", {
        credentials: "same-origin",
      });

      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }

      const result = await response.json();

      if (result.success) {
        invoiceGroups = result.invoices || [];
        const select = document.getElementById("invoiceGroupSelect");

        // Clear existing options except the first one
        select.innerHTML = '<option value="">Select an invoice group...</option>';

        invoiceGroups.forEach((group) => {
          const option = document.createElement("option");
          option.value = group.id;
          const beneficiaryName = group.beneficiary_name || "N/A";
          option.textContent = `${group.invoice_number} - ${beneficiaryName} - ${formatIndianCurrency(Math.round(parseFloat(group.total_amount) || 0))}`;
          select.appendChild(option);
        });
      } else {
        showToast("Error loading invoice groups", result.error || "Unknown error", "error");
      }
    } catch (error) {
      console.error("Error loading invoice groups:", error);
      showToast("Error loading invoice groups", error.message || "", "error");
    }
  }

  function openLinkToGroupModal(transactionId, amount) {
    document.getElementById("linkTransactionId").value = transactionId;
    document.getElementById("invoiceAmount").value = amount;
    document.getElementById("linkToGroupModal").classList.remove("hidden");

    // Load invoice groups if not already loaded
    if (invoiceGroups.length === 0) {
      loadInvoiceGroups();
    }
  }

  function closeLinkToGroupModal() {
    document.getElementById("linkToGroupModal").classList.add("hidden");
    document.getElementById("linkToGroupForm").reset();
  }

  async function linkTransactionToGroup() {
    const transactionId = document.getElementById("linkTransactionId").value;
    const invoiceId = document.getElementById("invoiceGroupSelect").value;
    const amount = parseFloat(document.getElementById("invoiceAmount").value);

    if (!invoiceId) {
      showToast("Please select an invoice group", "", "error");
      return;
    }

    if (!amount || amount <= 0) {
      showToast("Please enter a valid amount", "", "error");
      return;
    }

    try {
      const response = await fetch("/accounting/invoice-groups/add-transaction", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        credentials: "same-origin",
        body: JSON.stringify({
          invoiceId: invoiceId,
          transactionId: transactionId,
          amount: amount,
        }),
      });

      const result = await response.json();

      if (result.success) {
        showToast("Transaction linked to invoice group successfully", "", "success");
        closeLinkToGroupModal();
        // Reload the data to reflect changes
        loadMissingInvoices();
      } else {
        showToast("Error linking transaction", result.error || "Unknown error", "error");
      }
    } catch (error) {
      console.error("Error linking transaction to group:", error);
      showToast("Error linking transaction to group", "", "error");
    }
  }

  function viewInvoiceGroup(invoiceGroupId) {
    window.open(`/accounting/invoice-groups?id=${invoiceGroupId}`, "_blank");
  }

  function refreshData() {
    loadMissingInvoices();
  }

  function showError(message) {
    const tbody = document.getElementById("transactionsTableBody");
    tbody.innerHTML = `
    <tr>
      <td colspan="6" class="px-6 py-12 text-center">
        <div class="text-red-500 dark:text-red-400">
          <svg class="mx-auto h-12 w-12 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">Error</h3>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">${message}</p>
        </div>
      </td>
    </tr>
  `;
  }

  function formatIndianNumber(num) {
    return new Intl.NumberFormat("en-IN").format(num);
  }

  function formatDate(dateString) {
    return new Date(dateString).toLocaleDateString("en-IN");
  }

  function getSourceBankLabel(t) {
    // Prefer explicit bank account details: resolve via bank_account_id if available
    if (t.bank_account_id && Array.isArray(bankAccounts) && bankAccounts.length) {
      const account = bankAccounts.find((ba) => String(ba.id) === String(t.bank_account_id));
      if (account) {
        const label = account.bank_name || account.account_name || account.account_number || "";
        if (label) return normalizeBankName(label);
      }
    }

    // Fallbacks from transaction payload
    const name = t.bank_account_name || t.bank_name || t.source_bank || "";
    if (!name) return "N/A";
    return normalizeBankName(name);
  }

  function normalizeBankName(name) {
    const upper = String(name).toUpperCase();
    if (upper.includes("ICICI")) return "ICICI";
    if (upper.includes("AXIS")) return "Axis";
    if (upper.includes("HDFC")) return "HDFC";
    if (upper.includes("SBI") || upper.includes("STATE BANK")) return "SBI";
    return name;
  }

  // Transaction Details Modal
  async function openTransactionDetails(id) {
    const modalId = "txnDetailsModal";
    let modal = document.getElementById(modalId);
    if (!modal) {
      // create modal container if missing (safety)
      const wrapper = document.createElement("div");
      wrapper.innerHTML = `
<div id="txnDetailsModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center p-4">
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl w-full max-w-2xl max-h-[90vh] overflow-y-auto">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
      <div>
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Transaction Details</h3>
        <p id="txnDetailsSubtitle" class="text-sm text-gray-500 dark:text-gray-400"></p>
      </div>
      <button onclick="closeTxnDetails()" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300" aria-label="Close">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div class="p-6 space-y-4" id="txnDetailsBody"></div>
    <div class="px-6 py-4 border-t border-gray-200 dark:border-gray-700 flex justify-end">
      <button onclick="closeTxnDetails()" class="px-4 py-2 text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600">Close</button>
    </div>
  </div>
</div>`;
      document.body.appendChild(wrapper.firstElementChild);
      modal = document.getElementById(modalId);
    }

    const body = document.getElementById("txnDetailsBody");
    const subtitle = document.getElementById("txnDetailsSubtitle");
    body.innerHTML = '<div class="text-center text-gray-500 dark:text-gray-400">Loading...</div>';
    modal.classList.remove("hidden");

    try {
      const res = await fetch(`/accounting/transactions/${id}`, { credentials: "same-origin" });
      const data = await res.json();
      if (!res.ok || data.success === false) {
        body.innerHTML = '<div class="text-center text-red-500">Failed to load transaction details</div>';
        return;
      }

      const t = data.transaction || data;
      subtitle.textContent = `Txn ID: ${t.id || id}`;

      const debit = parseFloat(t.debit_amount) || 0;
      const credit = parseFloat(t.credit_amount) || 0;
      const amountStr = debit > 0 ? `₹${formatIndianNumber(debit)} (Debit)` : credit > 0 ? `₹${formatIndianNumber(credit)} (Credit)` : "₹0";

      body.innerHTML = `
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-4">
            <div class="text-xs text-gray-500 dark:text-gray-400">Description</div>
            <div class="text-sm font-medium text-gray-900 dark:text-white break-words whitespace-pre-wrap">${t.description || "N/A"}</div>
          </div>
          <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-4">
            <div class="text-xs text-gray-500 dark:text-gray-400">Date</div>
            <div class="text-sm font-medium text-gray-900 dark:text-white">${t.transaction_date ? formatDate(t.transaction_date) : "N/A"}</div>
          </div>
          <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-4">
            <div class="text-xs text-gray-500 dark:text-gray-400">Amount</div>
            <div class="text-sm font-medium text-gray-900 dark:text-white">${amountStr}</div>
          </div>
          <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-4">
            <div class="text-xs text-gray-500 dark:text-gray-400">Source Bank</div>
            <div class="text-sm font-medium text-gray-900 dark:text-white">${getSourceBankLabel(t)}</div>
          </div>
          <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-4 md:col-span-2">
            <div class="text-xs text-gray-500 dark:text-gray-400">Beneficiary</div>
            <div class="text-sm font-medium text-gray-900 dark:text-white">${t.beneficiary_name || "N/A"} ${t.beneficiary_alias ? `<span class='text-xs text-gray-500 dark:text-gray-400'>( ${t.beneficiary_alias} )</span>` : ""}</div>
            <div class="text-xs text-gray-600 dark:text-gray-300">${t.beneficiary_account || ""}</div>
          </div>
          <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-4 md:col-span-2">
            <div class="text-xs text-gray-500 dark:text-gray-400">Remitter</div>
            <div class="text-sm font-medium text-gray-900 dark:text-white">${t.remitter_name || "N/A"}</div>
            <div class="text-xs text-gray-600 dark:text-gray-300">${t.remitter_account || ""}</div>
          </div>
          <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-4">
            <div class="text-xs text-gray-500 dark:text-gray-400">Invoice Group</div>
            <div class="text-sm font-medium text-gray-900 dark:text-white">${t.invoice_group_name || (t.invoice_id ? t.invoice_id : "None")}</div>
          </div>
          <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-4">
            <div class="text-xs text-gray-500 dark:text-gray-400">Invoice Status</div>
            <div class="text-sm font-medium ${t.invoice_group_has_invoice || t.invoice_url ? "text-green-600 dark:text-green-400" : "text-orange-600 dark:text-orange-400"}">${t.invoice_group_has_invoice || t.invoice_url ? "Uploaded" : "Missing"}</div>
          </div>
        </div>`;
    } catch (e) {
      const body = document.getElementById("txnDetailsBody");
      if (body) body.innerHTML = '<div class="text-center text-red-500">Error loading details</div>';
    }
  }

  function closeTxnDetails() {
    const modal = document.getElementById("txnDetailsModal");
    if (modal) modal.classList.add("hidden");
  }

  function clearSearch() {
    document.getElementById("searchFilter").value = "";
    applyFilters();
  }

  function backToTransactions(event) {
    event.preventDefault();

    // Get current filter parameters
    const urlParams = new URLSearchParams(window.location.search);
    const bankAccountId = urlParams.get("bank_account_id") || "";
    const startDate = urlParams.get("start_date") || "";
    const endDate = urlParams.get("end_date") || "";

    // Build query string with filters
    const queryParams = new URLSearchParams();
    if (bankAccountId) queryParams.append("bank_account_id", bankAccountId);
    if (startDate) queryParams.append("start_date", startDate);
    if (endDate) queryParams.append("end_date", endDate);

    // Redirect back to transactions page with filters
    window.location.href = `/accounting/transactions?${queryParams.toString()}`;
  }

  // Toast notification functions
  function showToast(message, title = "", type = "info") {
    // Create toast element
    const toast = document.createElement("div");
    toast.className = `fixed top-4 right-4 z-50 max-w-sm w-full bg-white dark:bg-gray-800 shadow-lg rounded-lg pointer-events-auto ring-1 ring-black ring-opacity-5 overflow-hidden`;

    const bgColor = type === "success" ? "bg-green-500" : type === "error" ? "bg-red-500" : "bg-blue-500";

    toast.innerHTML = `
    <div class="p-4">
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <div class="w-6 h-6 ${bgColor} rounded-full flex items-center justify-center">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
          </div>
        </div>
        <div class="ml-3 w-0 flex-1 pt-0.5">
          <p class="text-sm font-medium text-gray-900 dark:text-white">${title || message}</p>
          ${title ? `<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">${message}</p>` : ""}
        </div>
        <div class="ml-4 flex-shrink-0 flex">
          <button onclick="this.parentElement.parentElement.parentElement.parentElement.remove()" class="bg-white dark:bg-gray-800 rounded-md inline-flex text-gray-400 hover:text-gray-500 focus:outline-none">
            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>
  `;

    document.body.appendChild(toast);

    // Auto remove after 5 seconds
    setTimeout(() => {
      if (toast.parentElement) {
        toast.remove();
      }
    }, 5000);
  }
</script>


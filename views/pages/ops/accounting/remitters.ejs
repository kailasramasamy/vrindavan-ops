<%- include('../../../partials/_head', { seo, pageKey }) %>
<link rel="stylesheet" href="/assets/css/accounting-dark-mode.css">

<!-- Indian Number Formatting -->
<script src="/assets/js/indian-number-format.js"></script>

<!-- Initialize theme immediately to prevent flash -->
<script>
  (function() {
    const theme = localStorage.getItem("accounting_theme") || "dark";
    if (theme === "dark") {
      document.documentElement.classList.add("dark");
    }
  })();
</script>

<body class="bg-gray-50 dark:bg-gray-900 transition-colors duration-200">
  <%- include('../../../partials/_subnav', { user, section: 'Accounting', subsection: 'Remitters' }) %>

  <div class="min-h-screen pt-16">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Header -->
      <div class="mb-6">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">Remitters</h1>
            <p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 mt-1">Manage remitters and sources of incoming payments</p>
          </div>

          <div class="flex items-center gap-4">
            <div class="flex gap-2">
              <button onclick="openImportModal()" class="px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition-colors">
                <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
                </svg>
                Import
              </button>
              <button onclick="openAddRemitterModal()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
                <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                </svg>
                Add Remitter
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Filters -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4 sm:p-6 mb-6">
        <form id="filterForm" method="GET" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Search</label>
            <input type="text" id="searchInput" name="search" placeholder="Name, Account, PAN..." value="<%= typeof filters !== 'undefined' && filters.search ? filters.search : '' %>" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500" />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Category</label>
            <select name="category" id="categorySelect" onchange="document.getElementById('filterForm').submit()" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500">
              <option value="">All Categories</option>
              <% categories.forEach(cat => { %>
                <option value="<%= cat.id %>" <%= typeof filters !== 'undefined' && filters.category == cat.id ? 'selected' : '' %>><%= cat.category_name %></option>
              <% }) %>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Status</label>
            <select name="status" id="statusSelect" onchange="document.getElementById('filterForm').submit()" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500">
              <option value="">All Status</option>
              <option value="active" <%= typeof filters !== 'undefined' && filters.status === 'active' ? 'selected' : '' %>>Active</option>
              <option value="inactive" <%= typeof filters !== 'undefined' && filters.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
            </select>
          </div>
        </form>
        
        <% if ((typeof filters !== 'undefined' && (filters.search || filters.category || filters.status))) { %>
        <div class="mt-3 flex items-center justify-between">
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Showing <%= remitters.length %> filtered result<%= remitters.length !== 1 ? 's' : '' %>
          </p>
          <a href="/accounting/remitters" class="text-sm text-emerald-600 dark:text-emerald-400 hover:text-emerald-700 dark:hover:text-emerald-300 font-medium">
            Clear filters
          </a>
        </div>
        <% } %>
      </div>

      <!-- Stats Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
        <div class="bg-white dark:bg-gray-800 rounded-lg p-4 border border-gray-200 dark:border-gray-700">
          <h3 class="text-sm font-medium text-gray-600 dark:text-gray-400">Total Remitters</h3>
          <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= remitters.length %></p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-lg p-4 border border-gray-200 dark:border-gray-700">
          <h3 class="text-sm font-medium text-gray-600 dark:text-gray-400">Active</h3>
          <p class="text-2xl font-bold text-green-600 dark:text-green-400 mt-1"><%= remitters.filter(b => b.status === 'active').length %></p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-lg p-4 border border-gray-200 dark:border-gray-700">
          <h3 class="text-sm font-medium text-gray-600 dark:text-gray-400">Categories</h3>
          <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= categories.length %></p>
        </div>
      </div>

      <!-- Remitters Table -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-900">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Remitter</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Account Details</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Category</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Transactions</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Total Received</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Status</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Actions</th>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
              <% if (remitters && remitters.length > 0) { %>
                <% remitters.forEach(ben => { %>
                  <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                    <td class="px-6 py-4">
                      <div class="font-medium text-gray-900 dark:text-white"><%= ben.remitter_name %></div>
                      <% if (ben.alias) { %>
                        <div class="text-sm text-gray-500 dark:text-gray-400"><%= ben.alias %></div>
                      <% } %>
                    </td>
                    <td class="px-6 py-4 text-sm text-gray-600 dark:text-gray-400">
                      <% if (ben.account_number) { %>
                        <div><%= ben.account_number %></div>
                        <div class="text-xs text-gray-500 dark:text-gray-500"><%= ben.ifsc_code || '-' %></div>
                      <% } else { %>
                        <span class="text-gray-400 dark:text-gray-500">-</span>
                      <% } %>
                    </td>
                    <td class="px-6 py-4">
                      <% if (ben.category_name) { %>
                        <span class="px-2 py-1 text-xs font-medium rounded-full" style="background-color: <%= ben.color_code %>20; color: <%= ben.color_code %>">
                          <%= ben.category_name %>
                        </span>
                      <% } else { %>
                        <span class="text-gray-400 dark:text-gray-500">-</span>
                      <% } %>
                    </td>
                    <td class="px-6 py-4 text-right text-sm text-gray-900 dark:text-white"><%= parseInt(ben.transaction_count || 0) %></td>
                    <td class="px-6 py-4 text-right text-sm font-semibold text-gray-900 dark:text-white indian-currency" data-amount="<%= Math.round(parseFloat(ben.total_received || 0)) %>">₹<%= Math.round(parseFloat(ben.total_received || 0)) %></td>
                    <td class="px-6 py-4">
                      <% if (ben.status === 'active') { %>
                        <span class="px-2 py-1 text-xs font-medium rounded-full bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-400">Active</span>
                      <% } else { %>
                        <span class="px-2 py-1 text-xs font-medium rounded-full bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-300">Inactive</span>
                      <% } %>
                    </td>
                    <td class="px-6 py-4 text-right">
                      <div class="flex items-center justify-end gap-2">
                        <a href="/accounting/transactions?remitter_id=<%= ben.id %>" class="text-purple-600 dark:text-purple-400 hover:text-purple-900 dark:hover:text-purple-300 p-1" title="View Transactions">
                          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
                          </svg>
                        </a>
                        <button onclick="editRemitter(<%= ben.id %>)" class="text-blue-600 dark:text-blue-400 hover:text-blue-900 dark:hover:text-blue-300 p-1" title="Edit">
                          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                          </svg>
                        </button>
                        <button onclick="deleteRemitter(<%= ben.id %>, '<%= ben.remitter_name %>')" class="text-red-600 dark:text-red-400 hover:text-red-900 dark:hover:text-red-300 p-1" title="Delete">
                          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                          </svg>
                        </button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="7" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400">
                    <svg class="w-12 h-12 mx-auto mb-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                    </svg>
                    <p>No remitters found. Click "Add Remitter" or "Import" to get started.</p>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>

  <%- include('../../../partials/_footer') %>
  <%- include('../../../partials/_toast') %>

  <!-- Add/Edit Remitter Modal -->
  <div id="remitterModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
    <div class="bg-white rounded-2xl shadow-xl max-w-2xl w-full mx-4 max-h-[90vh] overflow-y-auto">
      <div class="bg-gradient-to-r from-blue-500 to-indigo-600 px-6 py-4 sticky top-0 rounded-t-2xl">
        <div class="flex items-center justify-between">
          <h2 id="modalTitle" class="text-xl font-bold text-white">Add Remitter</h2>
          <button type="button" onclick="closeRemitterModal()" class="text-white hover:text-gray-200">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
      </div>

      <form id="remitterForm" class="p-6">
        <input type="hidden" id="remitterId" />

        <!-- Customer Information Section -->
        <div class="mb-6">
          <div class="flex items-center gap-2 mb-4 pb-2 border-b-2 border-blue-500">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
            <h3 class="text-lg font-semibold text-gray-900">Customer Information</h3>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-gray-700 mb-1">Remitter Name *</label>
              <input type="text" name="remitter_name" required placeholder="As per bank records" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Alias / Short Name</label>
              <input type="text" name="alias" placeholder="Optional nickname" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
              <select name="category_id" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                <option value="">Select Category</option>
                <% categories.forEach(cat => { %>
                  <option value="<%= cat.id %>"><%= cat.category_name %></option>
                <% }) %>
              </select>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Contact Number</label>
              <input type="tel" name="contact_number" placeholder="Customer phone" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
              <input type="email" name="email" placeholder="Customer email" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">PAN Number</label>
              <input type="text" name="pan_number" placeholder="PAN" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">GSTIN</label>
              <input type="text" name="gstin" placeholder="GST number" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" />
            </div>

            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-gray-700 mb-1">Customer Address</label>
              <textarea name="address" rows="2" placeholder="Customer address" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"></textarea>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
              <select name="status" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Activation Date</label>
              <input type="date" name="activation_date" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" />
            </div>

            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-gray-700 mb-1">Notes</label>
              <textarea name="notes" rows="2" placeholder="Additional notes" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"></textarea>
            </div>
          </div>
        </div>

        <!-- Bank Information Section -->
        <div class="mb-6">
          <div class="flex items-center gap-2 mb-4 pb-2 border-b-2 border-emerald-500">
            <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"></path>
            </svg>
            <h3 class="text-lg font-semibold text-gray-900">Bank Account Details</h3>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Account Number</label>
              <input type="text" name="account_number" placeholder="Bank account number" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500" />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">IFSC Code</label>
              <div class="flex gap-2">
                <input type="text" id="ifscCodeInputRemitter" name="ifsc_code" placeholder="e.g., ICIC0001234" class="flex-1 px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500" />
                <button type="button" onclick="lookupIFSCRemitter()" id="ifscLookupBtnRemitter" class="px-4 py-2 bg-emerald-600 text-white text-sm rounded-lg hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 whitespace-nowrap">
                  <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                  </svg>
                  Lookup
                </button>
              </div>
              <p class="text-xs text-gray-500 mt-1">Enter IFSC code and click Lookup to auto-fill bank details</p>
            </div>

            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-gray-700 mb-1">Bank Name</label>
              <input type="text" name="bank_name" placeholder="Auto-filled from IFSC lookup" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 bg-gray-50" readonly />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Branch Name</label>
              <input type="text" name="bank_branch" placeholder="Auto-filled from IFSC lookup" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 bg-gray-50" readonly />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Branch City</label>
              <input type="text" name="bank_city" placeholder="Auto-filled from IFSC lookup" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 bg-gray-50" readonly />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Branch State</label>
              <input type="text" name="bank_state" placeholder="Auto-filled from IFSC lookup" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 bg-gray-50" readonly />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">MICR Code</label>
              <input type="text" name="bank_micr" placeholder="Auto-filled from IFSC lookup" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 bg-gray-50" readonly />
            </div>

            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-gray-700 mb-1">Branch Address</label>
              <textarea name="bank_address" rows="2" placeholder="Auto-filled from IFSC lookup" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 bg-gray-50" readonly></textarea>
            </div>

            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-gray-700 mb-1">Branch Contact</label>
              <input type="tel" name="bank_contact" placeholder="Auto-filled from IFSC lookup" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 bg-gray-50" readonly />
            </div>
          </div>
        </div>

        <div class="flex gap-3 pt-6 border-t border-gray-200">
          <button type="submit" class="flex-1 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
            <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            Save Remitter
          </button>
          <button type="button" onclick="closeRemitterModal()" class="px-6 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    // ============= Auto Filter Functionality =============
    let searchTimeout;
    
    // Debounced search - triggers after user stops typing for 500ms
    document.getElementById('searchInput').addEventListener('input', function() {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        document.getElementById('filterForm').submit();
      }, 500);
    });

    let editMode = false;

    function openAddRemitterModal() {
      editMode = false;
      document.getElementById("modalTitle").textContent = "Add Remitter";
      document.getElementById("remitterForm").reset();
      document.getElementById("remitterId").value = "";
      document.getElementById("remitterModal").classList.remove("hidden");
    }

    function closeRemitterModal() {
      document.getElementById("remitterModal").classList.add("hidden");
    }

    // IFSC Lookup Function for Remitters
    async function lookupIFSCRemitter() {
      const ifscInput = document.getElementById('ifscCodeInputRemitter');
      const ifscCode = ifscInput.value.trim().toUpperCase();
      const lookupBtn = document.getElementById('ifscLookupBtnRemitter');

      if (!ifscCode) {
        showErrorToast('Please enter an IFSC code');
        return;
      }

      // Validate IFSC format (11 characters: 4 letters + 7 alphanumeric)
      if (!/^[A-Z]{4}0[A-Z0-9]{6}$/.test(ifscCode)) {
        showErrorToast('Invalid IFSC code format. Example: ICIC0001234');
        return;
      }

      // Show loading state
      lookupBtn.disabled = true;
      lookupBtn.innerHTML = '<svg class="w-4 h-4 inline animate-spin mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg> Looking up...';

      try {
        const response = await fetch(`https://ifsc.razorpay.com/${ifscCode}`);
        
        if (response.ok) {
          const data = await response.json();
          
          // Fill in the bank details
          document.querySelector('[name="bank_name"]').value = data.BANK || '';
          document.querySelector('[name="bank_branch"]').value = data.BRANCH || '';
          document.querySelector('[name="bank_city"]').value = data.CITY || '';
          document.querySelector('[name="bank_state"]').value = data.STATE || '';
          document.querySelector('[name="bank_address"]').value = data.ADDRESS || '';
          document.querySelector('[name="bank_contact"]').value = data.CONTACT || '';
          document.querySelector('[name="bank_micr"]').value = data.MICR || '';

          showSuccessToast('Bank details loaded successfully!');
        } else {
          showErrorToast('IFSC code not found. Please verify the code.');
        }
      } catch (error) {
        console.error('IFSC lookup error:', error);
        showErrorToast('Failed to lookup IFSC code. Please check your internet connection.');
      } finally {
        // Restore button state
        lookupBtn.disabled = false;
        lookupBtn.innerHTML = '<svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg> Lookup';
      }
    }

    async function editRemitter(id) {
      editMode = true;
      document.getElementById("modalTitle").textContent = "Edit Remitter";

      try {
        const response = await fetch(`/accounting/remitters/${id}`);
        const data = await response.json();

        if (data.success) {
          const ben = data.remitter;
          
          // Customer Information
          document.getElementById("remitterId").value = ben.id;
          document.querySelector('[name="remitter_name"]').value = ben.remitter_name || "";
          document.querySelector('[name="alias"]').value = ben.alias || "";
          document.querySelector('[name="category_id"]').value = ben.category_id || "";
          document.querySelector('[name="contact_number"]').value = ben.contact_number || "";
          document.querySelector('[name="email"]').value = ben.email || "";
          document.querySelector('[name="pan_number"]').value = ben.pan_number || "";
          document.querySelector('[name="gstin"]').value = ben.gstin || "";
          document.querySelector('[name="address"]').value = ben.address || "";
          document.querySelector('[name="status"]').value = ben.status || "active";
          document.querySelector('[name="activation_date"]').value = ben.activation_date || "";
          document.querySelector('[name="notes"]').value = ben.notes || "";
          
          // Bank Information
          document.querySelector('[name="account_number"]').value = ben.account_number || "";
          document.querySelector('[name="ifsc_code"]').value = ben.ifsc_code || "";
          document.querySelector('[name="bank_name"]').value = ben.bank_name || "";
          document.querySelector('[name="bank_branch"]').value = ben.bank_branch || "";
          document.querySelector('[name="bank_city"]').value = ben.bank_city || "";
          document.querySelector('[name="bank_state"]').value = ben.bank_state || "";
          document.querySelector('[name="bank_address"]').value = ben.bank_address || "";
          document.querySelector('[name="bank_contact"]').value = ben.bank_contact || "";
          document.querySelector('[name="bank_micr"]').value = ben.bank_micr || "";
          
          document.getElementById("remitterModal").classList.remove("hidden");
        } else {
          showToast(data.error, "", "error");
        }
      } catch (error) {
        console.error("Error loading remitter:", error);
        showToast("Error loading remitter data", "", "error");
      }
    }

    async function deleteRemitter(id, name) {
      if (!confirm(`Are you sure you want to delete "${name}"?`)) return;

      try {
        const response = await fetch(`/accounting/remitters/${id}`, {
          method: "DELETE",
        });

        const result = await response.json();

        if (result.success) {
          showToast(result.message, "", "success");
          setTimeout(() => location.reload(), 1000);
        } else {
          showToast(result.error, "", "error");
        }
      } catch (error) {
        console.error("Error deleting remitter:", error);
        showToast("Error deleting remitter", "", "error");
      }
    }

    document.getElementById("remitterForm").addEventListener("submit", async function (e) {
      e.preventDefault();

      const formData = new FormData(e.target);
      const data = Object.fromEntries(formData.entries());
      const remitterId = document.getElementById("remitterId").value;

      try {
        const url = remitterId 
          ? `/accounting/remitters/${remitterId}`
          : "/accounting/remitters";
        
        const method = remitterId ? "PUT" : "POST";

        const response = await fetch(url, {
          method: method,
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });

        const result = await response.json();

        if (result.success) {
          closeRemitterModal();
          showToast(result.message, "", "success");
          setTimeout(() => location.reload(), 1000);
        } else {
          showToast(result.error, "", "error");
        }
      } catch (error) {
        console.error("Error saving remitter:", error);
        showToast("Error saving remitter", "", "error");
      }
    });
    // ============= Import Functionality =============
    let importPreviewData = null;

    function openImportModal() {
      document.getElementById("importModal").classList.remove("hidden");
      document.getElementById("importStep1").classList.remove("hidden");
      document.getElementById("importStep2").classList.add("hidden");
      document.getElementById("importStep3").classList.add("hidden");
      document.getElementById("fileInput").value = "";
      importPreviewData = null;
    }

    function closeImportModal() {
      document.getElementById("importModal").classList.add("hidden");
    }

    async function uploadFile() {
      const fileInput = document.getElementById("fileInput");
      const file = fileInput.files[0];

      if (!file) {
        showToast("Please select a file", "", "error");
        return;
      }

      const formData = new FormData();
      formData.append("file", file);

      try {
        document.getElementById("uploadBtn").disabled = true;
        document.getElementById("uploadBtn").innerHTML = '<span class="inline-block animate-spin mr-2">⏳</span> Processing...';

        const response = await fetch("/accounting/remitters/import/preview", {
          method: "POST",
          body: formData,
        });

        const result = await response.json();

        if (result.success) {
          importPreviewData = result;
          showMappingStep(result);
        } else {
          showToast(result.error || "Failed to parse file", "", "error");
        }
      } catch (error) {
        console.error("Error uploading file:", error);
        showToast("Error uploading file", "", "error");
      } finally {
        document.getElementById("uploadBtn").disabled = false;
        document.getElementById("uploadBtn").innerHTML = 'Upload & Preview';
      }
    }

    function showMappingStep(data) {
      document.getElementById("importStep1").classList.add("hidden");
      document.getElementById("importStep2").classList.remove("hidden");

      // Display import info
      document.getElementById("importInfo").innerHTML = `
        <p class="text-sm text-gray-600">
          <strong>Total Records:</strong> ${data.totalRows} | 
          <strong>Preview:</strong> ${data.preview.length} rows
        </p>
      `;

      // Create mapping form
      const mappingContainer = document.getElementById("columnMapping");
      mappingContainer.innerHTML = "";

      const fields = {
        remitter_name: "Remitter Name *",
        account_number: "Account Number *",
        ifsc_code: "IFSC Code",
        bank_name: "Bank Name",
        alias: "Alias/Short Name",
        contact_number: "Contact Number",
        email: "Email",
        pan_number: "PAN Number",
        gstin: "GSTIN",
        address: "Address",
        status: "Status",
        activation_date: "Activation Date"
      };

      for (const [field, label] of Object.entries(fields)) {
        const div = document.createElement("div");
        div.innerHTML = `
          <label class="block text-sm font-medium text-gray-700 mb-1">${label}</label>
          <select name="${field}" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500">
            <option value="">-- Skip this field --</option>
            ${data.headers.map(h => `<option value="${h}" ${data.suggestedMapping[field] === h ? 'selected' : ''}>${h}</option>`).join('')}
          </select>
        `;
        mappingContainer.appendChild(div);
      }

      // Show preview table
      const previewTable = document.getElementById("previewTable");
      previewTable.innerHTML = `
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              ${data.headers.map(h => `<th class="px-4 py-2 text-left text-xs font-medium text-gray-500">${h}</th>`).join('')}
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            ${data.preview.slice(0, 5).map(row => `
              <tr>
                ${data.headers.map(h => `<td class="px-4 py-2 text-sm text-gray-900">${row[h] || '-'}</td>`).join('')}
              </tr>
            `).join('')}
          </tbody>
        </table>
      `;
    }

    async function executeImport() {
      const mappingForm = document.getElementById("columnMapping");
      const selects = mappingForm.querySelectorAll("select");
      const columnMapping = {};

      selects.forEach(select => {
        if (select.value) {
          columnMapping[select.name] = select.value;
        }
      });

      if (!columnMapping.remitter_name && !columnMapping.account_number) {
        showToast("At least Remitter Name or Account Number must be mapped", "", "error");
        return;
      }

      // Use all data from the file, not just the preview
      const fullData = importPreviewData.allData || importPreviewData.preview;

      try {
        document.getElementById("executeBtn").disabled = true;
        document.getElementById("executeBtn").innerHTML = '<span class="inline-block animate-spin mr-2">⏳</span> Importing...';

        const response = await fetch("/accounting/remitters/import/execute", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            fileData: fullData,
            columnMapping: columnMapping
          })
        });

        const result = await response.json();

        if (result.success) {
          showImportResults(result);
        } else {
          showToast(result.error || "Import failed", "", "error");
          document.getElementById("executeBtn").disabled = false;
          document.getElementById("executeBtn").innerHTML = 'Import Now';
        }
      } catch (error) {
        console.error("Error executing import:", error);
        showToast("Error executing import", "", "error");
        document.getElementById("executeBtn").disabled = false;
        document.getElementById("executeBtn").innerHTML = 'Import Now';
      }
    }

    function showImportResults(result) {
      document.getElementById("importStep2").classList.add("hidden");
      document.getElementById("importStep3").classList.remove("hidden");

      document.getElementById("importResults").innerHTML = `
        <div class="space-y-4">
          <div class="flex items-center justify-center">
            <svg class="w-16 h-16 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-center text-gray-900">Import Completed!</h3>
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="grid grid-cols-2 gap-4">
              <div class="text-center">
                <p class="text-2xl font-bold text-green-600">${result.imported}</p>
                <p class="text-sm text-gray-600">Successfully Imported</p>
              </div>
              <div class="text-center">
                <p class="text-2xl font-bold text-red-600">${result.failed || 0}</p>
                <p class="text-sm text-gray-600">Failed</p>
              </div>
            </div>
          </div>
          ${result.errors && result.errors.length > 0 ? `
            <div class="mt-4">
              <h4 class="font-medium text-gray-900 mb-2">Errors:</h4>
              <div class="bg-red-50 border border-red-200 rounded-lg p-3 max-h-40 overflow-y-auto">
                <ul class="text-sm text-red-800 space-y-1">
                  ${result.errors.slice(0, 10).map(err => `<li>• ${err}</li>`).join('')}
                </ul>
              </div>
            </div>
          ` : ''}
        </div>
      `;
    }

    function finishImport() {
      closeImportModal();
      showToast("Import completed successfully", "", "success");
      setTimeout(() => location.reload(), 1000);
    }
  </script>

  <!-- Import Modal -->
  <div id="importModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 overflow-y-auto">
    <div class="flex items-center justify-center min-h-screen p-4">
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl w-full max-w-4xl">
        <!-- Step 1: File Upload -->
        <div id="importStep1">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Import Remitters</h2>
            <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Upload a CSV or Excel file</p>
          </div>
          <div class="p-6">
            <div class="border-2 border-dashed border-gray-300 dark:border-gray-600 rounded-lg p-8 text-center">
              <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
              </svg>
              <p class="mt-4 text-sm text-gray-600 dark:text-gray-400">Click to upload or drag and drop</p>
              <p class="mt-1 text-xs text-gray-500 dark:text-gray-500">CSV, XLSX, or XLS file (max 10MB)</p>
              <input type="file" id="fileInput" accept=".csv,.xlsx,.xls" class="mt-4 block w-full text-sm text-gray-900 dark:text-gray-300 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-emerald-50 file:text-emerald-700 hover:file:bg-emerald-100">
            </div>
            <div class="mt-6 bg-blue-50 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-700 rounded-lg p-4">
              <h4 class="font-medium text-blue-900 dark:text-blue-200 mb-2">File Format Guidelines:</h4>
              <ul class="text-sm text-blue-800 dark:text-blue-300 space-y-1">
                <li>• First row must contain column headers</li>
                <li>• Required: Remitter Name OR Account Number</li>
                <li>• Optional: IFSC Code, Bank Name, PAN, GSTIN, Contact, Email, Address</li>
              </ul>
            </div>
          </div>
          <div class="px-6 py-4 bg-gray-50 dark:bg-gray-900 rounded-b-xl flex justify-end gap-3">
            <button onclick="closeImportModal()" class="px-4 py-2 text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600">Cancel</button>
            <button id="uploadBtn" onclick="uploadFile()" class="px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700">Upload & Preview</button>
          </div>
        </div>

        <!-- Step 2: Column Mapping -->
        <div id="importStep2" class="hidden">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Map Columns</h2>
            <div id="importInfo" class="mt-1"></div>
          </div>
          <div class="p-6 max-h-[70vh] overflow-y-auto">
            <div class="mb-6">
              <h3 class="font-medium text-gray-900 dark:text-white mb-3">Column Mapping</h3>
              <div id="columnMapping" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
            </div>
            <div>
              <h3 class="font-medium text-gray-900 dark:text-white mb-3">Data Preview (First 5 rows)</h3>
              <div id="previewTable" class="overflow-x-auto border border-gray-200 dark:border-gray-700 rounded-lg"></div>
            </div>
          </div>
          <div class="px-6 py-4 bg-gray-50 dark:bg-gray-900 rounded-b-xl flex justify-end gap-3">
            <button onclick="closeImportModal()" class="px-4 py-2 text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600">Cancel</button>
            <button id="executeBtn" onclick="executeImport()" class="px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700">Import Now</button>
          </div>
        </div>

        <!-- Step 3: Results -->
        <div id="importStep3" class="hidden">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Import Complete</h2>
          </div>
          <div class="p-6">
            <div id="importResults"></div>
          </div>
          <div class="px-6 py-4 bg-gray-50 dark:bg-gray-900 rounded-b-xl flex justify-end">
            <button onclick="finishImport()" class="px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700">Done</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('../../../partials/_toast') %>

  <script>
    // Format all Indian currency elements on page load
    document.addEventListener('DOMContentLoaded', function() {
      const currencyElements = document.querySelectorAll('.indian-currency');
      currencyElements.forEach(element => {
        const amount = element.getAttribute('data-amount');
        if (amount !== null && amount !== undefined) {
          element.textContent = formatIndianCurrency(parseFloat(amount));
        }
      });
    });
  </script>
</body>
</html>


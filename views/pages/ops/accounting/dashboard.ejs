      <!-- Transaction Trends Chart -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 mt-6">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <div class="flex items-center justify-between">
            <div>
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Transaction Trends</h2>
              <p class="text-sm text-gray-600 dark:text-gray-400">Monthly overview of debits, credits, and net balance</p>
            </div>
            <div class="text-xs text-gray-500 dark:text-gray-400">
              Last 24 Months
            </div>
          </div>

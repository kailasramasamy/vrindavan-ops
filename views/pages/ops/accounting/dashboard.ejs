    </main>
  </div>

  <%- include('../../../partials/_footer') %>
  <%- include('../../../partials/_toast') %>

  <script>
    // Date Filter Functions
    let currentDateFilter = 'lastmonth';

    // Initialize date filter from localStorage or default
    function initDateFilter() {
      const savedFilter = localStorage.getItem('dashboard_date_filter') || 'lastmonth';
      currentDateFilter = savedFilter;
      updateDateFilterLabel(savedFilter);
    }

    function toggleDateFilter() {
      const dropdown = document.getElementById('dateFilterDropdown');
      dropdown.classList.toggle('hidden');
    }

    function selectDateFilter(filter) {
      // Hide all sub-menus first
      document.getElementById('customDateRange').classList.add('hidden');
      document.getElementById('monthlyPicker').classList.add('hidden');

      if (filter === 'custom') {
        document.getElementById('customDateRange').classList.remove('hidden');
        return;
      }

      if (filter === 'monthly') {
        document.getElementById('monthlyPicker').classList.remove('hidden');
        // Set default to current month
        const today = new Date();
        const currentMonth = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}`;
        document.getElementById('selectedMonth').value = currentMonth;
        return;
      }

      currentDateFilter = filter;
      localStorage.setItem('dashboard_date_filter', filter);
      
      const dates = calculateDateRange(filter);
      reloadDashboard(dates.startDate, dates.endDate);
      
      document.getElementById('dateFilterDropdown').classList.add('hidden');
    }

    function applyCustomDateRange() {
      const startDate = document.getElementById('customStartDate').value;
      const endDate = document.getElementById('customEndDate').value;

      if (!startDate || !endDate) {
        showToast('Please select both start and end dates', 'error');
        return;
      }

      if (new Date(startDate) > new Date(endDate)) {
        showToast('Start date must be before end date', 'error');
        return;
      }

      currentDateFilter = 'custom';
      localStorage.setItem('dashboard_date_filter', 'custom');
      localStorage.setItem('dashboard_custom_start', startDate);
      localStorage.setItem('dashboard_custom_end', endDate);

      reloadDashboard(startDate, endDate);
      
      document.getElementById('dateFilterDropdown').classList.add('hidden');
      document.getElementById('customDateRange').classList.add('hidden');
    }

    function applyMonthlyFilter() {
      const selectedMonth = document.getElementById('selectedMonth').value;

      if (!selectedMonth) {
        showToast('Please select a month', 'error');
        return;
      }

      // Parse year and month from YYYY-MM format
      const [year, month] = selectedMonth.split('-').map(Number);
      
      // Calculate first and last day of the month
      const firstDay = new Date(year, month - 1, 1);
      const lastDay = new Date(year, month, 0);
      
      // Format dates
      function formatDate(date) {
        const y = date.getFullYear();
        const m = String(date.getMonth() + 1).padStart(2, '0');
        const d = String(date.getDate()).padStart(2, '0');
        return `${y}-${m}-${d}`;
      }

      const startDate = formatDate(firstDay);
      const endDate = formatDate(lastDay);

      currentDateFilter = 'monthly';
      localStorage.setItem('dashboard_date_filter', 'monthly');
      localStorage.setItem('dashboard_selected_month', selectedMonth);

      // Update label to show selected month
      const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 
                          'July', 'August', 'September', 'October', 'November', 'December'];
      document.getElementById('dateFilterLabel').textContent = `${monthNames[month - 1]} ${year}`;

      reloadDashboard(startDate, endDate);
      
      document.getElementById('dateFilterDropdown').classList.add('hidden');
      document.getElementById('monthlyPicker').classList.add('hidden');
    }

    function calculateDateRange(filter) {
      // Helper function to format date as YYYY-MM-DD in local timezone
      function formatDate(date) {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const day = String(date.getDate()).padStart(2, '0');
        return `${year}-${month}-${day}`;
      }

      const today = new Date();
      let startDate, endDate;

      switch(filter) {
        case 'last7days':
          const last7 = new Date();
          last7.setDate(last7.getDate() - 7);
          startDate = formatDate(last7);
          endDate = formatDate(new Date());
          break;
        case 'last30days':
          const last30 = new Date();
          last30.setDate(last30.getDate() - 30);
          startDate = formatDate(last30);
          endDate = formatDate(new Date());
          break;
        case 'lastmonth':
          // Last month = previous complete calendar month
          // First day of last month
          const firstDayLastMonth = new Date(today.getFullYear(), today.getMonth() - 1, 1);
          startDate = formatDate(firstDayLastMonth);
          // Last day of last month (day 0 of current month)
          const lastDayLastMonth = new Date(today.getFullYear(), today.getMonth(), 0);
          endDate = formatDate(lastDayLastMonth);
          break;
        case 'thismonth':
          // This month = current calendar month from 1st to today
          const firstDayThisMonth = new Date(today.getFullYear(), today.getMonth(), 1);
          startDate = formatDate(firstDayThisMonth);
          endDate = formatDate(new Date());
          break;
        case 'monthly':
          // Get selected month from localStorage
          const selectedMonth = localStorage.getItem('dashboard_selected_month');
          if (selectedMonth) {
            const [year, month] = selectedMonth.split('-').map(Number);
            const firstDay = new Date(year, month - 1, 1);
            const lastDay = new Date(year, month, 0);
            startDate = formatDate(firstDay);
            endDate = formatDate(lastDay);
          } else {
            // Default to current month
            const firstDayCurrentMonth = new Date(today.getFullYear(), today.getMonth(), 1);
            startDate = formatDate(firstDayCurrentMonth);
            endDate = formatDate(new Date());
          }
          break;
        case 'custom':
          startDate = localStorage.getItem('dashboard_custom_start') || formatDate(new Date());
          endDate = localStorage.getItem('dashboard_custom_end') || formatDate(new Date());
          break;
        default:
          const defaultStart = new Date();
          defaultStart.setDate(defaultStart.getDate() - 7);
          startDate = formatDate(defaultStart);
          endDate = formatDate(new Date());
      }

      return { startDate, endDate };
    }

    function updateDateFilterLabel(filter) {
      const labels = {
        'last7days': 'Last 7 Days',
        'last30days': 'Last 30 Days',
        'lastmonth': 'Last Month',
        'thismonth': 'This Month',
        'custom': 'Custom Range'
      };
      
      if (filter === 'monthly') {
        const selectedMonth = localStorage.getItem('dashboard_selected_month');
        if (selectedMonth) {
          const [year, month] = selectedMonth.split('-').map(Number);
          const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 
                              'July', 'August', 'September', 'October', 'November', 'December'];
          document.getElementById('dateFilterLabel').textContent = `${monthNames[month - 1]} ${year}`;
        } else {
          document.getElementById('dateFilterLabel').textContent = 'Monthly';
        }
      } else {
        document.getElementById('dateFilterLabel').textContent = labels[filter] || 'Last 7 Days';
      }
    }

    function reloadDashboard(startDate, endDate) {
      // Show loading state
      const btn = document.getElementById('dateFilterBtn');
      btn.disabled = true;
      btn.classList.add('opacity-50');

      // Reload page with new date range
      window.location.href = `/accounting/dashboard?start_date=${startDate}&end_date=${endDate}`;
    }

    // Close dropdown when clicking outside
    document.addEventListener('click', function(event) {
      const dropdown = document.getElementById('dateFilterDropdown');
      const btn = document.getElementById('dateFilterBtn');
      
      if (!dropdown.contains(event.target) && !btn.contains(event.target)) {
        dropdown.classList.add('hidden');
        document.getElementById('customDateRange').classList.add('hidden');
      }
    });

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', function() {
      initDateFilter();
      
      // Apply default filter if no URL parameters
      const urlParams = new URLSearchParams(window.location.search);
      if (!urlParams.get('start_date') && !urlParams.get('end_date')) {
        selectDateFilter('lastmonth');
      }
      
      // Set custom date inputs to current values if in custom mode
      if (currentDateFilter === 'custom') {
        const startDate = localStorage.getItem('dashboard_custom_start');
        const endDate = localStorage.getItem('dashboard_custom_end');
        if (startDate) document.getElementById('customStartDate').value = startDate;
        if (endDate) document.getElementById('customEndDate').value = endDate;
      }
      
      // Initialize Charts
      initTrendsChart();
      initCategoryPieChart();
      
      // Format all Indian currency elements
      const currencyElements = document.querySelectorAll('.indian-currency');
      currencyElements.forEach(element => {
        const amount = element.getAttribute('data-amount');
        if (amount !== null && amount !== undefined) {
          element.textContent = formatIndianCurrency(parseFloat(amount));
        }
      });
    });

    function initTrendsChart() {
      const ctx = document.getElementById('trendsChart');
      if (!ctx) return;

      // Prepare data from server
      const trendsData = <%- JSON.stringify(monthlyTrends) %>;
      
      if (!trendsData || trendsData.length === 0) {
        ctx.parentElement.innerHTML = '<div class="flex items-center justify-center h-full text-gray-500 dark:text-gray-400 text-sm">No transaction data available</div>';
        return;
      }

      // Extract and format data - monthly format
      const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
      const labels = trendsData.map(d => {
        const monthName = monthNames[d.month_num - 1];
        const year = d.year.toString().slice(-2); // Last 2 digits of year
        return `${monthName} '${year}`;
      });
      
      const debitData = trendsData.map(d => parseFloat(d.total_debit || 0));
      const creditData = trendsData.map(d => parseFloat(d.total_credit || 0));
      const netBalanceData = trendsData.map((d, i) => creditData[i] - debitData[i]);

      // Check dark mode
      const isDarkMode = document.documentElement.classList.contains('dark');
      const textColor = isDarkMode ? '#9CA3AF' : '#6B7280';
      const gridColor = isDarkMode ? 'rgba(75, 85, 99, 0.3)' : 'rgba(229, 231, 235, 0.8)';

      // Create chart
      new Chart(ctx, {
        type: 'line',
        data: {
          labels: labels,
          datasets: [
            {
              label: 'Debit (Payments)',
              data: debitData,
              borderColor: 'rgb(239, 68, 68)',
              backgroundColor: 'rgba(239, 68, 68, 0.1)',
              borderWidth: 2,
              tension: 0.4,
              fill: true,
              pointRadius: 4,
              pointHoverRadius: 6,
              pointBackgroundColor: 'rgb(239, 68, 68)',
              pointBorderColor: '#fff',
              pointBorderWidth: 2,
              datalabels: {
                display: true,
                align: 'bottom',
                anchor: 'end',
                offset: 4,
                color: isDarkMode ? '#FCA5A5' : '#DC2626',
                font: {
                  size: 10,
                  weight: 'bold',
                },
                formatter: function(value) {
                  if (Math.abs(value) >= 100000) {
                    return '₹' + (value / 100000).toFixed(1) + 'L';
                  } else if (Math.abs(value) >= 1000) {
                    return '₹' + (value / 1000).toFixed(0) + 'K';
                  }
                  return '₹' + value.toFixed(0);
                },
              },
            },
            {
              label: 'Credit (Receipts)',
              data: creditData,
              borderColor: 'rgb(34, 197, 94)',
              backgroundColor: 'rgba(34, 197, 94, 0.1)',
              borderWidth: 2,
              tension: 0.4,
              fill: true,
              pointRadius: 4,
              pointHoverRadius: 6,
              pointBackgroundColor: 'rgb(34, 197, 94)',
              pointBorderColor: '#fff',
              pointBorderWidth: 2,
              datalabels: {
                display: true,
                align: 'top',
                anchor: 'end',
                offset: 4,
                color: isDarkMode ? '#86EFAC' : '#16A34A',
                font: {
                  size: 10,
                  weight: 'bold',
                },
                formatter: function(value) {
                  if (Math.abs(value) >= 100000) {
                    return '₹' + (value / 100000).toFixed(1) + 'L';
                  } else if (Math.abs(value) >= 1000) {
                    return '₹' + (value / 1000).toFixed(0) + 'K';
                  }
                  return '₹' + value.toFixed(0);
                },
              },
            },
            {
              label: 'Net Balance',
              data: netBalanceData,
              borderColor: 'rgb(59, 130, 246)',
              backgroundColor: 'rgba(59, 130, 246, 0.1)',
              borderWidth: 3,
              tension: 0.4,
              fill: true,
              pointRadius: 5,
              pointHoverRadius: 7,
              pointBackgroundColor: 'rgb(59, 130, 246)',
              pointBorderColor: '#fff',
              pointBorderWidth: 2,
              datalabels: {
                display: true,
                align: function(context) {
                  // Dynamically position based on value
                  const value = context.dataset.data[context.dataIndex];
                  return value >= 0 ? 'top' : 'bottom';
                },
                anchor: 'end',
                offset: 6,
                color: isDarkMode ? '#93C5FD' : '#2563EB',
                font: {
                  size: 10,
                  weight: 'bold',
                },
                formatter: function(value) {
                  if (Math.abs(value) >= 100000) {
                    return '₹' + (value / 100000).toFixed(1) + 'L';
                  } else if (Math.abs(value) >= 1000) {
                    return '₹' + (value / 1000).toFixed(0) + 'K';
                  }
                  return '₹' + value.toFixed(0);
                },
              },
            },
          ],
        },
        plugins: [ChartDataLabels],
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: {
            mode: 'index',
            intersect: false,
          },
          plugins: {
            legend: {
              display: true,
              position: 'top',
              align: 'end',
              labels: {
                color: textColor,
                font: {
                  size: 12,
                  weight: '500',
                },
                padding: 15,
                usePointStyle: true,
                pointStyle: 'circle',
              },
            },
            tooltip: {
              enabled: true,
              backgroundColor: isDarkMode ? 'rgba(31, 41, 55, 0.95)' : 'rgba(255, 255, 255, 0.95)',
              titleColor: isDarkMode ? '#F3F4F6' : '#111827',
              bodyColor: isDarkMode ? '#D1D5DB' : '#374151',
              borderColor: isDarkMode ? '#4B5563' : '#E5E7EB',
              borderWidth: 1,
              padding: 12,
              displayColors: true,
              callbacks: {
                label: function(context) {
                  let label = context.dataset.label || '';
                  if (label) {
                    label += ': ';
                  }
                  label += '₹' + Math.round(context.parsed.y).toLocaleString('en-IN');
                  return label;
                },
              },
            },
          },
          scales: {
            y: {
              beginAtZero: true,
              ticks: {
                color: textColor,
                font: {
                  size: 11,
                },
                callback: function(value) {
                  if (value >= 100000) {
                    return '₹' + (value / 100000).toFixed(1) + 'L';
                  } else if (value >= 1000) {
                    return '₹' + (value / 1000).toFixed(1) + 'K';
                  }
                  return '₹' + value;
                },
              },
              grid: {
                color: gridColor,
                drawBorder: false,
              },
            },
            x: {
              ticks: {
                color: textColor,
                font: {
                  size: 11,
                },
                maxRotation: 0,
                minRotation: 0,
              },
              grid: {
                display: false,
              },
            },
          },
        },
      });
    }

    // Reinitialize chart on theme change
    window.addEventListener('theme-changed', function() {
      const chartContainer = document.getElementById('trendsChart').parentElement;
      chartContainer.innerHTML = '<canvas id="trendsChart"></canvas>';
      initTrendsChart();
      
      const pieChartContainer = document.getElementById('categoryPieChart').parentElement;
      pieChartContainer.innerHTML = '<canvas id="categoryPieChart"></canvas>';
      initCategoryPieChart();
    });

    function initCategoryPieChart() {
      const ctx = document.getElementById('categoryPieChart');
      if (!ctx) return;

      // Prepare data from server
      const categoryData = <%- JSON.stringify(categoryStats) %>;
      
      if (!categoryData || categoryData.length === 0) {
        ctx.parentElement.innerHTML = '<div class="flex items-center justify-center h-full text-gray-500 dark:text-gray-400 text-sm">No category data available</div>';
        return;
      }

      // Extract category names, amounts, and colors
      const labels = categoryData.slice(0, 10).map(c => c.category_name);
      const amounts = categoryData.slice(0, 10).map(c => parseFloat(c.total_debit || 0));
      const colors = categoryData.slice(0, 10).map(c => c.color_code);
      
      // Create lighter colors for borders
      const borderColors = colors.map(color => {
        // Convert hex to lighter shade for dark mode compatibility
        return color;
      });

      // Check dark mode
      const isDarkMode = document.documentElement.classList.contains('dark');

      // Create chart
        new Chart(ctx, {
          type: 'pie',
          data: {
            labels: labels,
            datasets: [{
              data: amounts,
              backgroundColor: colors,
              borderColor: isDarkMode ? '#1F2937' : '#FFFFFF',
              borderWidth: 2,
              hoverBorderWidth: 3,
              hoverBorderColor: '#FFFFFF',
            }],
          },
          plugins: [ChartDataLabels],
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: {
                display: false,
              },
            tooltip: {
              enabled: true,
              backgroundColor: isDarkMode ? 'rgba(31, 41, 55, 0.95)' : 'rgba(255, 255, 255, 0.95)',
              titleColor: isDarkMode ? '#F3F4F6' : '#111827',
              bodyColor: isDarkMode ? '#D1D5DB' : '#374151',
              borderColor: isDarkMode ? '#4B5563' : '#E5E7EB',
              borderWidth: 1,
              padding: 12,
              callbacks: {
                label: function(context) {
                  const label = context.label || '';
                  const value = context.parsed;
                  const total = context.dataset.data.reduce((a, b) => a + b, 0);
                  const percentage = ((value / total) * 100).toFixed(1);
                  return `${label}: ₹${Math.round(value).toLocaleString('en-IN')} (${percentage}%)`;
                },
              },
            },
            datalabels: {
              display: true,
              color: isDarkMode ? '#F3F4F6' : '#FFFFFF',
              font: {
                size: 11,
                weight: 'bold',
              },
              formatter: function(value, context) {
                const total = context.dataset.data.reduce((a, b) => a + b, 0);
                const percentage = ((value / total) * 100).toFixed(1);
                // Only show label if percentage is > 5%
                if (percentage > 5) {
                  if (value >= 100000) {
                    return '₹' + (value / 100000).toFixed(1) + 'L\n' + percentage + '%';
                  } else if (value >= 1000) {
                    return '₹' + (value / 1000).toFixed(0) + 'K\n' + percentage + '%';
                  }
                  return '₹' + value.toFixed(0) + '\n' + percentage + '%';
                }
                return '';
              },
            },
          },
        },
      });
    }
  </script>
</body>
</html>


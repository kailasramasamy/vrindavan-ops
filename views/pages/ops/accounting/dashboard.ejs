          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-900">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Beneficiary</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Category</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Transactions</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Total Paid</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Last Payment</th>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
              <% if (topBeneficiaries && topBeneficiaries.length > 0) { %>
                <% topBeneficiaries.forEach(ben => { %>
                  <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                    <td class="px-6 py-4">
                      <div class="font-medium text-gray-900 dark:text-white"><%= ben.beneficiary_name %></div>
                      <% if (ben.alias) { %>
                        <div class="text-sm text-gray-500 dark:text-gray-400"><%= ben.alias %></div>
                      <% } %>
                    </td>
                    <td class="px-6 py-4">
                      <span class="px-2 py-1 text-xs font-medium rounded-full" style="background-color: <%= ben.color_code %>20; color: <%= ben.color_code %>">
                        <%= ben.category_name || 'Uncategorized' %>
                      </span>
                    </td>
                    <td class="px-6 py-4 text-right text-sm text-gray-900 dark:text-white"><%= parseInt(ben.transaction_count || 0) %></td>
                    <td class="px-6 py-4 text-right text-sm font-semibold text-gray-900 dark:text-white indian-currency" data-amount="<%= Math.round(parseFloat(ben.total_paid || 0)) %>">₹<%= Math.round(parseFloat(ben.total_paid || 0)) %></td>

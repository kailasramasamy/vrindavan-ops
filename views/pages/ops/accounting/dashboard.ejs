          <p class="text-xs sm:text-sm opacity-80 mt-1">
            <span class="text-green-200"><%= parseInt(summary.matched_count || 0) %> matched</span> • 
            <span class="text-orange-200"><%= parseInt(summary.unmatched_count || 0) %> pending</span>

            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-sm sm:text-base font-semibold text-gray-900 dark:text-white group-hover:text-indigo-600 transition-colors truncate">Categories</h3>
              <p class="text-xs sm:text-sm text-gray-600 dark:text-gray-400 truncate">Manage categories</p>

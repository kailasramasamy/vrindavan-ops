                        </td>
                        <td class="py-3 px-4 text-right">
                          <input type="number" step="0.1" min="0" class="border border-gray-300 dark:border-gray-600 rounded p-1 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 text-right" style="width:70px" value="<%= displayClr || 0 %>" <%= status === 'Accepted' ? 'disabled' : '' %> />
                        </td>
                        <td class="py-3 px-4 text-center">
                          <span class="status-badge px-2 py-1 rounded text-xs font-medium <%= statusClass === 'bg-green-100 text-green-600' ? 'bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-300' : 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300' %>"><%= status %></span>
                        </td>
                        <td class="py-3 px-4 text-center">
                          <div class="flex items-center justify-center gap-2">
                            <button class="edit-btn p-1 text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300" data-cpp-id="<%= cpp.cppId %>" title="Edit">
                              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                              </svg>
                            </button>
                            <button class="accept-btn p-1 text-green-600 dark:text-green-400 hover:text-green-800 dark:hover:text-green-300" data-cpp-id="<%= cpp.cppId %>" title="Accept">
                              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                              </svg>
                            </button>
                          </div>
                        </td>
                      </tr>
                      <% } %>
                      <% } %>
                    <% }) %>
                  </tbody>
                </table>
              </div>
              
              <!-- Mobile: Card layout -->
              <div class="mobile-only space-y-4">
                <% cppSummaryData.forEach((cpp, index) => { %>
                  <% 
                    const existingEntries = (existingRccEntries || []).filter(e => e.cpp_id == cpp.cppId);
                    const hasExistingEntries = existingEntries.length > 0;
                    
                    // For day view, show individual morning/evening entries
                    if (selectedTime === 'day' && hasExistingEntries) {
                      existingEntries.forEach((entry, entryIndex) => {
                        const displayMilkType = entry.milkType;
                        const displayQty = entry.qty;
                        const displayFat = entry.fat;
                        const displaySnf = entry.snf;
                        const displayClr = entry.clr;
                        const displayWater = entry.water;
                        const status = ((entry.status || '').toString().trim().toLowerCase() === 'accepted') ? 'Accepted' : 'Pending';
                        const statusClass = ((entry.status || '').toString().trim().toLowerCase() === 'accepted') ? 'bg-green-100 text-green-600' : 'bg-gray-100 text-gray-600';
                        const timeLabel = entry.time === 'morning' ? 'Morning' : 'Evening';
                        const timeClass = entry.time === 'morning' ? 'bg-blue-50' : 'bg-orange-50';
                  %>
                  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 p-4 <%= timeClass === 'bg-blue-50' ? 'bg-blue-50 dark:bg-blue-900/20' : 'bg-orange-50 dark:bg-orange-900/20' %>" data-cpp-id="<%= cpp.cppId %>" data-entry-id="<%= entry.id %>" data-time="<%= entry.time %>">
                    <div class="flex justify-between items-center mb-3">
                      <h3 class="font-semibold text-slate-900 dark:text-slate-100"><%= cpp.cppName %></h3>
                      <span class="text-xs text-gray-500 dark:text-gray-400">(<%= timeLabel %>)</span>
                    </div>
                    <div class="flex items-center justify-between mb-3">
                      <span class="status-badge px-2 py-1 rounded text-xs font-medium <%= statusClass === 'bg-green-100 text-green-600' ? 'bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-300' : 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300' %>"><%= status %></span>
                    </div>
                    <div class="grid grid-cols-2 gap-3 mb-4">
                      <div>
                        <label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Milk Type</label>
                        <select class="w-full border border-gray-300 dark:border-gray-600 rounded text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700" style="padding:4px 8px;" <%= status === 'Accepted' ? 'disabled' : '' %>>
                          <option value="A1" <%= displayMilkType==='A1'?'selected':'' %> >A1</option>
                          <option value="A2" <%= displayMilkType==='A2'?'selected':'' %> >A2</option>

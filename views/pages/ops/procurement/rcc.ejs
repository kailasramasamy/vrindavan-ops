
<!DOCTYPE html>
<html lang="en">
  <%- include('../../../partials/_head', { seo, pageKey, promo }) %>
  
  
  <body class="bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 antialiased">
    <div class="min-h-dvh flex flex-col">
      <%- include('../../../partials/_subnav', { section: 'Procurement', page: 'RCC — Milk Entry', user }) %>
      <main class="flex-1 bg-white dark:bg-gray-900">
        <section class="max-w-6xl mx-auto px-4 py-10">
          <header class="mb-6">
            <h1 class="text-2xl font-extrabold tracking-tight text-gray-900 dark:text-gray-100">RCC — Daily Milk Entry</h1>
            <p class="text-slate-600 dark:text-slate-300 mt-2">Review and accept aggregated CPP data for the selected date and time.</p>
          </header>

          <!-- Filters -->
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 p-6 mb-6">
            <div class="grid gap-4 grid-cols-1 md:grid-cols-3">
              <div>
                <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">RCC</label>
                <select id="rccFilter" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                  <% rccList.forEach(rcc => { %>
                    <option value="<%= rcc.id %>" <%= (selectedRccId == rcc.id) ? 'selected' : '' %>><%= rcc.name %></option>
                  <% }); %>
                </select>
              </div>
              <div>
                <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Date</label>
                <input type="date" id="dateFilter" name="date" value="<%= selectedDate %>" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">   
              </div>
              <div>
                <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Time</label>
                <select id="timeFilter" name="time" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                  <option value="day" <%= selectedTime === 'day' ? 'selected' : '' %>>Day (Total)</option>
                  <option value="morning" <%= selectedTime === 'morning' ? 'selected' : '' %>>Morning</option>
                  <option value="evening" <%= selectedTime === 'evening' ? 'selected' : '' %>>Evening</option>
                </select>
              </div>
            </div>
          </div>

          <!-- Summary Cards -->
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-2 md:gap-3 mb-6" id="summaryCards">
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 p-2 md:p-3 text-center">
              <div class="text-sm md:text-lg lg:text-xl font-bold text-blue-600 dark:text-blue-400" id="totalVolume"><%= (cppSummaryData || []).reduce((sum, cpp) => sum + parseFloat(cpp.totalQty || 0), 0).toFixed(1) %></div>
              <div class="text-xs text-slate-600 dark:text-slate-300 mt-1">Total Volume (L)</div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 p-2 md:p-3 text-center">
              <div class="text-sm md:text-lg lg:text-xl font-bold text-green-600 dark:text-green-400" id="avgFat"><%= (() => { const totalQty = (cppSummaryData || []).reduce((sum, cpp) => sum + parseFloat(cpp.totalQty || 0), 0); const totalWeightedFat = (cppSummaryData || []).reduce((sum, cpp) => sum + (parseFloat(cpp.fat || 0) * parseFloat(cpp.totalQty || 0)), 0); return totalQty > 0 ? (totalWeightedFat / totalQty).toFixed(1) : '0.0'; })() %></div>
              <div class="text-xs text-slate-600 dark:text-slate-300 mt-1">Avg FAT %</div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 p-2 md:p-3 text-center">
              <div class="text-sm md:text-lg lg:text-xl font-bold text-purple-600 dark:text-purple-400" id="avgSnf"><%= (() => { const totalQty = (cppSummaryData || []).reduce((sum, cpp) => sum + parseFloat(cpp.totalQty || 0), 0); const totalWeightedSnf = (cppSummaryData || []).reduce((sum, cpp) => sum + (parseFloat(cpp.snf || 0) * parseFloat(cpp.totalQty || 0)), 0); return totalQty > 0 ? (totalWeightedSnf / totalQty).toFixed(1) : '0.0'; })() %></div>
              <div class="text-xs text-slate-600 dark:text-slate-300 mt-1">Avg SNF %</div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 p-2 md:p-3 text-center">
              <div class="text-sm md:text-lg lg:text-xl font-bold text-orange-600 dark:text-orange-400" id="avgClr"><%= (() => { const totalQty = (cppSummaryData || []).reduce((sum, cpp) => sum + parseFloat(cpp.totalQty || 0), 0); const totalWeightedClr = (cppSummaryData || []).reduce((sum, cpp) => sum + (parseFloat(cpp.clr || 0) * parseFloat(cpp.totalQty || 0)), 0); return totalQty > 0 ? (totalWeightedClr / totalQty).toFixed(1) : '0.0'; })() %></div>
              <div class="text-xs text-slate-600 dark:text-slate-300 mt-1">Avg CLR</div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 p-2 md:p-3 text-center">
              <div class="text-sm md:text-lg lg:text-xl font-bold text-red-600 dark:text-red-400" id="avgWater"><%= (() => { const totalQty = (cppSummaryData || []).reduce((sum, cpp) => sum + parseFloat(cpp.totalQty || 0), 0); const totalWeightedWater = (cppSummaryData || []).reduce((sum, cpp) => sum + (parseFloat(cpp.water || 0) * parseFloat(cpp.totalQty || 0)), 0); return totalQty > 0 ? (totalWeightedWater / totalQty).toFixed(1) : '0.0'; })() %></div>
              <div class="text-xs text-slate-600 dark:text-slate-300 mt-1">Avg Water %</div>
            </div>
          </div>

          <!-- CPP Data Display -->
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 p-6">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">CPP Data Summary</h3>
              <button type="button" id="acceptAllBtn" class="btn btn-primary">
                <i data-lucide="check-circle" class="w-4 h-4 mr-2"></i>
                Accept All as RCC Data
              </button>
            </div>
            
            <% if ((cppSummaryData||[]).length > 0) { %>
              <!-- Desktop: Table layout -->
              <div class="desktop-only overflow-x-auto">
                <table class="w-full text-sm text-gray-900 dark:text-gray-100">
                  <thead>
                    <tr class="text-left bg-slate-50 dark:bg-gray-800">
                      <th class="py-3 px-4 text-gray-900 dark:text-gray-100 font-semibold">CPP</th>
                      <th class="py-3 px-4 text-gray-900 dark:text-gray-100 font-semibold">Milk Type</th>
                      <th class="py-3 px-4 text-right text-gray-900 dark:text-gray-100 font-semibold">Qty (L)</th>
                      <th class="py-3 px-4 text-right text-gray-900 dark:text-gray-100 font-semibold">FAT %</th>
                      <th class="py-3 px-4 text-right text-gray-900 dark:text-gray-100 font-semibold">SNF %</th>
                      <th class="py-3 px-4 text-right text-gray-900 dark:text-gray-100 font-semibold">Water %</th>
                      <th class="py-3 px-4 text-right text-gray-900 dark:text-gray-100 font-semibold">CLR</th>
                      <th class="py-3 px-4 text-center text-gray-900 dark:text-gray-100 font-semibold">Status</th>
                      <th class="py-3 px-4 text-center text-gray-900 dark:text-gray-100 font-semibold">Actions</th>
                    </tr>
                  </thead>
                  <tbody id="cppDataTable" class="bg-white dark:bg-gray-900">
                    <% cppSummaryData.forEach((cpp, index) => { %>
                      <% 
                        const existingEntries = (existingRccEntries || []).filter(e => e.cpp_id == cpp.cppId);
                        const hasExistingEntries = existingEntries.length > 0;
                        
                        // For day view, show individual morning/evening entries
                        if (selectedTime === 'day' && hasExistingEntries) {
                          // Sort entries by time (morning first, then evening)
                          const sortedEntries = existingEntries.sort((a, b) => {
                            if (a.time === 'morning' && b.time === 'evening') return -1;
                            if (a.time === 'evening' && b.time === 'morning') return 1;
                            return 0;
                          });
                          
                          sortedEntries.forEach((entry, entryIndex) => {
                            const displayMilkType = entry.milkType;
                            const displayQty = entry.qty;
                            const displayFat = entry.fat;
                            const displaySnf = entry.snf;
                            const displayClr = entry.clr;
                            const displayWater = entry.water;
                            const status = ((entry.status || '').toString().trim().toLowerCase() === 'accepted') ? 'Accepted' : 'Pending';
                            const statusClass = ((entry.status || '').toString().trim().toLowerCase() === 'accepted') ? 'bg-green-100 text-green-600' : 'bg-gray-100 text-gray-600';
                            const timeLabel = entry.time === 'morning' ? 'Morning' : 'Evening';
                            const timeClass = entry.time === 'morning' ? 'bg-blue-50' : 'bg-orange-50';
                            
                            // Add separator row before each CPP group (except first)
                            if (entryIndex === 0 && index > 0) {
                      %>
                      <tr class="border-t-2 border-gray-300 dark:border-gray-700">
                        <td colspan="9" class="py-2"></td>
                      </tr>
                      <% } %>
                      <tr data-cpp-id="<%= cpp.cppId %>" data-entry-id="<%= entry.id %>" data-time="<%= entry.time %>" class="border-b border-gray-200 dark:border-gray-700 <%= timeClass === 'bg-blue-50' ? 'bg-blue-50 dark:bg-blue-900/20' : 'bg-orange-50 dark:bg-orange-900/20' %>">
                        <td class="py-3 px-4 font-medium text-gray-900 dark:text-gray-100">
                          <%= cpp.cppName %>
                          <span class="text-xs text-gray-500 dark:text-gray-400 ml-2">(<%= timeLabel %>)</span>
                        </td>
                        <td class="py-3 px-4">
                          <select class="border border-gray-300 dark:border-gray-600 rounded text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700" style="width:80px; height:32px; padding:4px 8px;" <%= status === 'Accepted' ? 'disabled' : '' %>>
                            <option value="A1" <%= displayMilkType==='A1'?'selected':'' %> >A1</option>
                            <option value="A2" <%= displayMilkType==='A2'?'selected':'' %> >A2</option>
                            <option value="Buffalo" <%= displayMilkType==='Buffalo'?'selected':'' %> >Buffalo</option>
                          </select>
                        </td>
                        <td class="py-3 px-4 text-right">
                          <input type="number" step="0.1" min="0" class="border border-gray-300 dark:border-gray-600 rounded p-1 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 text-right" style="width:80px" value="<%= displayQty || 0 %>" <%= status === 'Accepted' ? 'disabled' : '' %> />
                        </td>
                        <td class="py-3 px-4 text-right">
                          <input type="number" step="0.1" min="0" class="border border-gray-300 dark:border-gray-600 rounded p-1 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 text-right" style="width:70px" value="<%= displayFat || 0 %>" <%= status === 'Accepted' ? 'disabled' : '' %> />
                        </td>
                        <td class="py-3 px-4 text-right">
                          <input type="number" step="0.1" min="0" class="border border-gray-300 dark:border-gray-600 rounded p-1 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 text-right" style="width:70px" value="<%= displaySnf || 0 %>" <%= status === 'Accepted' ? 'disabled' : '' %> />
                        </td>
                        <td class="py-3 px-4 text-right">
                          <input type="number" step="0.1" min="0" class="border border-gray-300 dark:border-gray-600 rounded p-1 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 text-right" style="width:70px" value="<%= displayWater || 0 %>" <%= status === 'Accepted' ? 'disabled' : '' %> />
                        </td>
                        <td class="py-3 px-4 text-right">
                          <input type="number" step="0.1" min="0" class="border border-gray-300 dark:border-gray-600 rounded p-1 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 text-right" style="width:70px" value="<%= displayClr || 0 %>" <%= status === 'Accepted' ? 'disabled' : '' %> />
                        </td>
                        <td class="py-3 px-4 text-center">
                          <span class="status-badge px-2 py-1 rounded text-xs font-medium <%= (((entry.status || '').toString().trim().toLowerCase()) === 'accepted') ? 'bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-300' : 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300' %>"><%= status %></span>
                        </td>
                        <td class="py-3 px-4 text-center">
                          <div class="flex items-center justify-center gap-2">
                            <button class="edit-btn text-blue-600 dark:text-blue-400 hover:underline" data-cpp-id="<%= cpp.cppId %>" data-entry-id="<%= entry.id %>" title="Edit">Edit</button>
                            <button class="accept-btn text-green-600 dark:text-green-400 hover:underline" data-cpp-id="<%= cpp.cppId %>" data-entry-id="<%= entry.id %>" title="Accept">Accept</button>
                          </div>
                        </td>
                      </tr>
                      <% }) %>
                      <% } else { %>
                        <% 
                          // For morning/evening view or when no existing entries, show aggregated data
                          // Prefer matching the currently selected time if available
                          const existingEntry = hasExistingEntries ? ((existingEntries.find(e => (e.time || '').toLowerCase() === (selectedTime || '').toLowerCase())) || existingEntries[0]) : null;
                        const displayMilkType = existingEntry ? existingEntry.milkType : cpp.milkType;
                        const displayQty = existingEntry ? existingEntry.qty : cpp.totalQty;
                        const displayFat = existingEntry ? existingEntry.fat : cpp.fat;
                        const displaySnf = existingEntry ? existingEntry.snf : cpp.snf;
                        const displayClr = existingEntry ? existingEntry.clr : cpp.clr;
                        const displayWater = existingEntry ? existingEntry.water : cpp.water;
                        const status = existingEntry ? ((((existingEntry.status || '').toString().trim().toLowerCase()) === 'accepted') ? 'Accepted' : 'Pending') : 'Pending';
                        const statusClass = existingEntry && (((existingEntry.status || '').toString().trim().toLowerCase()) === 'accepted') ? 'bg-green-100 text-green-600' : 'bg-gray-100 text-gray-600';
                      %>
                      
                      <% if (selectedTime === 'day') { %>
                        <!-- Day view: show separate morning and evening rows -->
                        <% 
                          // Get morning and evening data for this CPP
                          const morningData = cpp.morning;
                          const eveningData = cpp.evening;
                          // Match existing RCC entries per time for accurate status after refresh
                          const existingMorning = (existingEntries || []).find(e => (e.time || '').toLowerCase() === 'morning');
                          const existingEvening = (existingEntries || []).find(e => (e.time || '').toLowerCase() === 'evening');
                          const morningStatus = existingMorning ? ((((existingMorning.status || '').toString().trim().toLowerCase()) === 'accepted') ? 'Accepted' : 'Pending') : 'Pending';
                          const eveningStatus = existingEvening ? ((((existingEvening.status || '').toString().trim().toLowerCase()) === 'accepted') ? 'Accepted' : 'Pending') : 'Pending';
                        %>
                        
                        <!-- Morning row -->
                        <tr data-cpp-id="<%= cpp.cppId %>" data-time="morning" class="border-b border-gray-200 dark:border-gray-700 bg-blue-50 dark:bg-blue-900/20">
                          <td class="py-3 px-4 font-medium text-gray-900 dark:text-gray-100">
                            <%= cpp.cppName %>
                            <span class="text-xs text-gray-500 dark:text-gray-400 ml-2">(Morning)</span>
                          </td>
                          <td class="py-3 px-4">
                            <select class="border border-gray-300 dark:border-gray-600 rounded text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700" style="width:80px; height:32px; padding:4px 8px;">
                              <option value="A1" <%= morningData && morningData.milkType==='A1'?'selected':'' %> >A1</option>
                              <option value="A2" <%= morningData && morningData.milkType==='A2'?'selected':'' %> >A2</option>
                              <option value="Buffalo" <%= morningData && morningData.milkType==='Buffalo'?'selected':'' %> >Buffalo</option>
                            </select>
                          </td>
                          <td class="py-3 px-4 text-right">
                            <input type="number" step="0.1" min="0" class="border border-gray-300 dark:border-gray-600 rounded p-1 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 text-right" style="width:80px" value="<%= morningData ? morningData.totalQty : 0 %>" />
                          </td>
                          <td class="py-3 px-4 text-right">
                            <input type="number" step="0.1" min="0" class="border border-gray-300 dark:border-gray-600 rounded p-1 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 text-right" style="width:70px" value="<%= morningData ? morningData.fat : 0 %>" />
                          </td>
                          <td class="py-3 px-4 text-right">
                            <input type="number" step="0.1" min="0" class="border border-gray-300 dark:border-gray-600 rounded p-1 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 text-right" style="width:70px" value="<%= morningData ? morningData.snf : 0 %>" />
                          </td>
                          <td class="py-3 px-4 text-right">
                            <input type="number" step="0.1" min="0" class="border border-gray-300 dark:border-gray-600 rounded p-1 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 text-right" style="width:70px" value="<%= morningData ? morningData.water : 0 %>" />
                          </td>
                          <td class="py-3 px-4 text-right">
                            <input type="number" step="0.1" min="0" class="border border-gray-300 dark:border-gray-600 rounded p-1 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 text-right" style="width:70px" value="<%= morningData ? morningData.clr : 0 %>" />
                          </td>
                          <td class="py-3 px-4 text-center">
                            <span class="status-badge px-2 py-1 rounded text-xs font-medium <%= (morningStatus === 'Accepted') ? 'bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-300' : 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300' %>"><%= morningStatus %></span>
                          </td>
                          <td class="py-3 px-4 text-center">
                            <div class="flex items-center justify-center gap-2">
                              <button class="edit-btn text-blue-600 dark:text-blue-400 hover:underline" data-cpp-id="<%= cpp.cppId %>" title="Edit">Edit</button>
                              <button class="accept-btn text-green-600 dark:text-green-400 hover:underline" data-cpp-id="<%= cpp.cppId %>" title="Accept">Accept</button>
                            </div>
                          </td>
                        </tr>
                        
                        <!-- Evening row -->
                        <tr data-cpp-id="<%= cpp.cppId %>" data-time="evening" class="border-b border-gray-200 dark:border-gray-700 bg-orange-50 dark:bg-orange-900/20">
                          <td class="py-3 px-4 font-medium text-gray-900 dark:text-gray-100">
                            <%= cpp.cppName %>
                            <span class="text-xs text-gray-500 dark:text-gray-400 ml-2">(Evening)</span>
                          </td>
                          <td class="py-3 px-4">
                            <select class="border border-gray-300 dark:border-gray-600 rounded text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700" style="width:80px; height:32px; padding:4px 8px;">
                              <option value="A1" <%= eveningData && eveningData.milkType==='A1'?'selected':'' %> >A1</option>
                              <option value="A2" <%= eveningData && eveningData.milkType==='A2'?'selected':'' %> >A2</option>
                              <option value="Buffalo" <%= eveningData && eveningData.milkType==='Buffalo'?'selected':'' %> >Buffalo</option>
                            </select>
                          </td>
                          <td class="py-3 px-4 text-right">
                            <input type="number" step="0.1" min="0" class="border border-gray-300 dark:border-gray-600 rounded p-1 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 text-right" style="width:80px" value="<%= eveningData ? eveningData.totalQty : 0 %>" />
                          </td>
                          <td class="py-3 px-4 text-right">
                            <input type="number" step="0.1" min="0" class="border border-gray-300 dark:border-gray-600 rounded p-1 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 text-right" style="width:70px" value="<%= eveningData ? eveningData.fat : 0 %>" />
                          </td>
                          <td class="py-3 px-4 text-right">
                            <input type="number" step="0.1" min="0" class="border border-gray-300 dark:border-gray-600 rounded p-1 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 text-right" style="width:70px" value="<%= eveningData ? eveningData.snf : 0 %>" />
                          </td>
                          <td class="py-3 px-4 text-right">
                            <input type="number" step="0.1" min="0" class="border border-gray-300 dark:border-gray-600 rounded p-1 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 text-right" style="width:70px" value="<%= eveningData ? eveningData.water : 0 %>" />
                          </td>
                          <td class="py-3 px-4 text-right">
                            <input type="number" step="0.1" min="0" class="border border-gray-300 dark:border-gray-600 rounded p-1 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 text-right" style="width:70px" value="<%= eveningData ? eveningData.clr : 0 %>" />
                          </td>
                          <td class="py-3 px-4 text-center">
                            <span class="status-badge px-2 py-1 rounded text-xs font-medium <%= (eveningStatus === 'Accepted') ? 'bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-300' : 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300' %>"><%= eveningStatus %></span>
                          </td>
                          <td class="py-3 px-4 text-center">
                            <div class="flex items-center justify-center gap-2">
                              <button class="edit-btn text-blue-600 dark:text-blue-400 hover:underline" data-cpp-id="<%= cpp.cppId %>" title="Edit">Edit</button>
                              <button class="accept-btn text-green-600 dark:text-green-400 hover:underline" data-cpp-id="<%= cpp.cppId %>" title="Accept">Accept</button>
                            </div>
                          </td>
                        </tr>
                      <% } else { %>
                        <!-- Single time view -->
                        <tr data-cpp-id="<%= cpp.cppId %>" data-time="<%= selectedTime %>" class="border-b border-gray-200 dark:border-gray-700">
                        <td class="py-3 px-4 font-medium text-gray-900 dark:text-gray-100"><%= cpp.cppName %></td>
                        <td class="py-3 px-4">
                          <select class="border border-gray-300 dark:border-gray-600 rounded text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700" style="width:80px; height:32px; padding:4px 8px;" <%= status === 'Accepted' ? 'disabled' : '' %>>
                            <option value="A1" <%= displayMilkType==='A1'?'selected':'' %> >A1</option>
                            <option value="A2" <%= displayMilkType==='A2'?'selected':'' %> >A2</option>
                            <option value="Buffalo" <%= displayMilkType==='Buffalo'?'selected':'' %> >Buffalo</option>
                          </select>
                        </td>
                        <td class="py-3 px-4 text-right">

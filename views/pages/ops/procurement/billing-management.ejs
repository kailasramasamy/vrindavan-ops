<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Billing Management - Vrindavan Farm</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <style>
      /* Normalize date input and select styling */
      input[type="date"],
      select {
        height: 48px;
        font-size: 16px;
        line-height: 1.5;
      }

      .card {
        @apply bg-white rounded-lg shadow-sm border border-gray-200;
      }
      .card--white {
        @apply bg-white;
      }
      /* Dark mode overrides for legacy utility classes used in this page */
      .dark .card {
        background-color: #1f2937; /* slate-800 */
        border-color: #334155; /* slate-700 */
      }
      .dark .card--white { background-color: #1f2937; }
      .dark .bg-white { background-color: #0f172a !important; }
      .dark .bg-gray-50 { background-color: #1f2937 !important; }
      .dark .border-gray-200 { border-color: #334155 !important; }
      .dark .divide-gray-200 > :not([hidden]) ~ :not([hidden]) { border-color: #334155 !important; }
      .dark .text-gray-900 { color: #e5e7eb !important; }
      .dark .text-gray-700 { color: #cbd5e1 !important; }
      .dark .text-gray-600 { color: #94a3b8 !important; }
      .dark .text-gray-500 { color: #94a3b8 !important; }
      .dark .text-gray-400 { color: #94a3b8 !important; }
      .dark table thead { background-color: #1f2937; }
      .dark table tbody { background-color: #0f172a; }
      .dark input,
      .dark select,
      .dark textarea {
        background-color: #334155 !important;
        color: #e5e7eb !important;
        border-color: #475569 !important;
      }
      .dark .bg-blue-100 { background-color: rgba(59,130,246,0.15) !important; }
      .dark .bg-green-100 { background-color: rgba(16,185,129,0.15) !important; }
      .dark .bg-yellow-100 { background-color: rgba(234,179,8,0.15) !important; }
      .dark .bg-red-100 { background-color: rgba(239,68,68,0.15) !important; }
      /* Adjust pill text colors in dark */
      .dark .text-blue-800 { color: #93c5fd !important; }
      .dark .text-green-800 { color: #86efac !important; }
      .dark .text-yellow-800 { color: #fde68a !important; }
      .dark .text-red-800 { color: #fca5a5 !important; }
      .dark .text-purple-800 { color: #d8b4fe !important; }
      /* Hover row color for dark mode */
      @media (hover:hover) {
        .dark .hover\:bg-gray-50:hover { background-color: #334155 !important; }
      }
    </style>
  </head>
  <body class="bg-slate-900 text-slate-100">
    <div class="min-h-screen">
      <%- include('../../../partials/_head') %> <%- include('../../../partials/_subnav', { section: 'Procurement', subsection: 'Billing', page: 'Billing Management', user }) %>

      <main class="max-w-7xl mx-auto px-4 py-8">
        <!-- Header -->
        <div class="mb-8">
          <h1 class="text-3xl font-bold mb-2 text-slate-100">Billing Management</h1>
          <p class="text-slate-400">Manage billing status, payments, and financial records</p>
        </div>

        

        <!-- Billing Status Overview -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
          <div class="card p-6 bg-slate-800 border border-slate-700">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-slate-400">Pending Bills</p>
                <p class="text-2xl font-bold text-yellow-400" id="pendingBills">0</p>
              </div>
              <div class="w-12 h-12 bg-yellow-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-clock text-yellow-600"></i>
              </div>
            </div>
          </div>

          <div class="card p-6 bg-slate-800 border border-slate-700">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-slate-400">Approved Bills</p>
                <p class="text-2xl font-bold text-green-400" id="approvedBills">0</p>
              </div>
              <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-check text-green-600"></i>
              </div>
            </div>
          </div>

          <div class="card p-6 bg-slate-800 border border-slate-700">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-slate-400">Completed Payments</p>
                <p class="text-2xl font-bold text-blue-400" id="completedPayments">0</p>
              </div>
              <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-check-circle text-blue-600"></i>
              </div>
            </div>
          </div>

          <div class="card p-6 bg-slate-800 border border-slate-700">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-slate-400">Overdue Payments</p>
                <p class="text-2xl font-bold text-red-400" id="overduePayments">0</p>
              </div>
              <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-exclamation-triangle text-red-600"></i>
              </div>
            </div>
          </div>
        </div>

        <!-- Bills Management -->
        <div class="card p-6">
          <div class="flex flex-col lg:flex-row lg:justify-between lg:items-center mb-6">
            <h2 class="text-xl font-semibold mb-4 lg:mb-0">Bills Management</h2>

            <!-- Desktop Filters -->
            <div class="space-x-4" id="desktopFilters">
              <select id="yearFilter" class="px-3 py-2 border border-gray-300 rounded-md text-sm"></select>
              <select id="monthFilter" class="px-3 py-2 border border-gray-300 rounded-md text-sm"></select>
              <select id="periodFilter" class="px-3 py-2 border border-gray-300 rounded-md text-sm">
                <option value="H1">H1 (1st Half)</option>
                <option value="H2">H2 (2nd Half)</option>
              </select>
              <select id="entityFilter" class="px-3 py-2 border border-gray-300 rounded-md text-sm">
                <option value="">All Entities</option>
                <option value="farmers">Farmers</option>
                <option value="cpp">CPP</option>
                <option value="rcc">RCC</option>
                <option value="mp">MP</option>
              </select>
              <select id="milkTypeFilter" class="px-3 py-2 border border-gray-300 rounded-md text-sm">
                <option value="all" selected>All Milk Types</option>
                <option value="A1">A1</option>
                <option value="A2">A2</option>
                <option value="Buffalo">Buffalo</option>
              </select>
              <select id="statusFilter" class="px-3 py-2 border border-gray-300 rounded-md text-sm">
                <option value="">All Statuses</option>
                <option value="1">Pending</option>
                <option value="2">Approved</option>
                <option value="9">Completed</option>
                <option value="3">Rejected</option>
                <option value="4">Cancelled</option>
              </select>
              <button id="refreshBills" class="px-4 py-2 bg-blue-600 text-white rounded-md text-sm hover:bg-blue-700">
                <i class="fas fa-sync-alt mr-2"></i>
                Refresh
              </button>
              <button id="regenAllBills" class="px-4 py-2 bg-orange-600 text-white rounded-md text-sm hover:bg-orange-700">Regenerate Bills</button>
            </div>
          </div>

          <!-- Mobile Filters Card -->
          <div class="lg:hidden mb-6" id="mobileFilters">
            <div class="bg-gray-50 rounded-lg p-4">
              <h3 class="text-sm font-medium text-gray-700 mb-3">Filters</h3>
              <div class="grid grid-cols-1 gap-3">
              <div class="grid grid-cols-2 gap-2">
                  <select id="yearFilterMobile" class="px-3 py-2 border border-gray-300 rounded-md text-sm"></select>
                  <select id="monthFilterMobile" class="px-3 py-2 border border-gray-300 rounded-md text-sm"></select>
                </div>
                <div class="grid grid-cols-2 gap-2">
                  <select id="periodFilterMobile" class="px-3 py-2 border border-gray-300 rounded-md text-sm">
                    <option value="H1">H1 (1st Half)</option>
                    <option value="H2">H2 (2nd Half)</option>
                  </select>
                  <select id="entityFilterMobile" class="px-3 py-2 border border-gray-300 rounded-md text-sm">
                    <option value="">All Entities</option>
                    <option value="farmers">Farmers</option>
                    <option value="cpp">CPP</option>
                    <option value="rcc">RCC</option>
                    <option value="mp">MP</option>
                  </select>
                </div>
                <div class="grid grid-cols-2 gap-2">
                  <select id="milkTypeFilterMobile" class="px-3 py-2 border border-gray-300 rounded-md text-sm">
                    <option value="all" selected>All Milk Types</option>
                    <option value="A1">A1</option>
                    <option value="A2">A2</option>
                    <option value="Buffalo">Buffalo</option>
                  </select>
                  <div></div>
                </div>
                <div class="grid grid-cols-2 gap-2">
                  <select id="statusFilterMobile" class="px-3 py-2 border border-gray-300 rounded-md text-sm">
                    <option value="">All Statuses</option>
                    <option value="1">Pending</option>
                    <option value="2">Approved</option>
                    <option value="9">Completed</option>
                    <option value="3">Rejected</option>
                    <option value="4">Cancelled</option>
                  </select>
                  <button id="refreshBillsMobile" class="px-4 py-2 bg-blue-600 text-white rounded-md text-sm hover:bg-blue-700">
                    <i class="fas fa-sync-alt mr-2"></i>
                    Refresh
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- Filter-based Summary Cards -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 mb-6" id="summaryCards">
            <div class="bg-white rounded-lg border border-gray-200 p-3 shadow-sm">
              <div class="flex items-center justify-between">
                <div class="flex-1 min-w-0">
                  <p class="text-xs text-gray-600 truncate">Pending Bills</p>
                  <p class="text-lg font-bold text-yellow-600" id="summaryPendingBills">0</p>
                </div>
                <div class="w-8 h-8 bg-yellow-100 rounded-lg flex items-center justify-center flex-shrink-0 ml-2">
                  <i class="fas fa-clock text-yellow-600 text-sm"></i>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg border border-gray-200 p-3 shadow-sm">
              <div class="flex items-center justify-between">
                <div class="flex-1 min-w-0">
                  <p class="text-xs text-gray-600 truncate">Completed Payments</p>
                  <p class="text-lg font-bold text-green-600" id="summaryCompletedPayments">0</p>
                </div>
                <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0 ml-2">
                  <i class="fas fa-check-circle text-green-600 text-sm"></i>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg border border-gray-200 p-3 shadow-sm">
              <div class="flex items-center justify-between">
                <div class="flex-1 min-w-0">
                  <p class="text-xs text-gray-600 truncate">Total Due Amount</p>
                  <p class="text-lg font-bold text-blue-600" id="summaryTotalDue">₹0</p>
                </div>
                <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0 ml-2">
                  <i class="fas fa-rupee-sign text-blue-600 text-sm"></i>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg border border-gray-200 p-3 shadow-sm">
              <div class="flex items-center justify-between">
                <div class="flex-1 min-w-0">
                  <p class="text-xs text-gray-600 truncate">Pending Due Amount</p>
                  <p class="text-lg font-bold text-red-600" id="summaryPendingDue">₹0</p>
                </div>
                <div class="w-8 h-8 bg-red-100 rounded-lg flex items-center justify-center flex-shrink-0 ml-2">
                  <i class="fas fa-exclamation-triangle text-red-600 text-sm"></i>
                </div>
              </div>
            </div>
          </div>

          <!-- Desktop Table View -->
          <div class="overflow-x-auto" id="desktopTableView">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Entity</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Period</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Quantity</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Billing Status</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Payment Status</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Due Date</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                </tr>
              </thead>
              <tbody id="billsTableBody" class="bg-white divide-y divide-gray-200">
                <!-- Bills will be loaded here -->
              </tbody>
            </table>
          </div>

          <!-- Mobile Card View -->
          <div id="billsCardContainer" class="lg:hidden space-y-4">
            <!-- Bills will be loaded here as cards -->
          </div>

          <div id="billsLoading" class="text-center py-8">
            <i class="fas fa-spinner fa-spin text-2xl text-gray-400"></i>
            <p class="text-gray-500 mt-2">Loading bills...</p>
          </div>

          <div id="noBills" class="text-center py-8 hidden">
            <i class="fas fa-file-invoice text-4xl text-gray-400 mb-4"></i>
            <p class="text-gray-400 mb-4">No bills found for the selected criteria.</p>
            <div class="flex items-center justify-center">
              <button id="generateBillsBtn" class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-md text-sm inline-flex items-center">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Generate Bills
              </button>
            </div>
          </div>
        </div>
      </main>

      
    </div>

    <!-- Edit Bill Modal -->
    <div id="editBillModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full hidden z-50">
      <div class="relative top-20 mx-auto p-5 border border-slate-700 w-96 shadow-lg rounded-md bg-slate-800 text-slate-100">
        <div class="mt-3">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-medium text-slate-100">Edit Bill</h3>
            <button id="closeEditModal" class="text-slate-400 hover:text-slate-200">
              <i class="fas fa-times"></i>
            </button>
          </div>
          <form id="editBillForm">
            <input type="hidden" id="editBillId" name="billId" />
            <input type="hidden" id="editEntityType" name="entityType" />

            <div class="mb-4">
              <label class="block text-sm font-medium text-gray-700 mb-2">Billing Status</label>
              <select id="editBillingStatus" name="billingStatus" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                <option value="1">Pending</option>
                <option value="2">Approved</option>
                <option value="9">Completed</option>
                <option value="3">Rejected</option>
                <option value="4">Cancelled</option>
              </select>
            </div>

            <div class="mb-4">
              <label class="block text-sm font-medium text-gray-700 mb-2">Due Date</label>
              <input type="date" id="editDueDate" name="dueDate" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" />
            </div>

            <div class="mb-4">
              <label class="block text-sm font-medium text-gray-700 mb-2">Notes</label>
              <textarea id="editNotes" name="notes" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Add any notes..."></textarea>
            </div>

            <div class="flex justify-end space-x-3">
              <button type="button" id="cancelEdit" class="px-4 py-2 bg-slate-700 text-slate-200 rounded-md hover:bg-slate-600">Cancel</button>
              <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700">Update Bill</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Record Payment Modal -->
    <div id="recordPaymentModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full hidden z-50">
      <div class="relative top-10 mx-auto p-5 border border-slate-700 w-11/12 max-w-2xl shadow-lg rounded-md bg-slate-800 text-slate-100">
        <div class="mt-3">
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-xl font-semibold text-slate-100">Record Payment</h3>
            <button id="closePaymentModal" class="text-slate-400 hover:text-slate-200">
              <i class="fas fa-times text-xl"></i>
            </button>
          </div>

          <form id="recordPaymentForm">
            <input type="hidden" id="paymentBillId" name="billId" />
            <input type="hidden" id="paymentEntityType" name="entityType" />

            <!-- Bill Information Section -->
            <div class="bg-gray-50 rounded-lg p-4 mb-6">
              <h4 class="text-lg font-medium text-gray-900 mb-3">Bill Information</h4>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Entity</label>
                  <div id="paymentEntityInfo" class="text-sm text-gray-900">-</div>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Current Status</label>
                  <div id="paymentCurrentStatus" class="text-sm">
                    <span class="px-2 py-1 text-xs rounded-full bg-yellow-100 text-yellow-800">Pending</span>
                  </div>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Total Amount</label>
                  <div id="paymentTotalAmount" class="text-sm font-semibold text-gray-900">₹0.00</div>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Due Amount</label>
                  <div class="text-lg font-bold text-red-600">
                    ₹
                    <span id="dueAmount">0.00</span>
                  </div>
                </div>
                <div id="paymentCompleteDateSection" class="hidden">
                  <label class="block text-sm font-medium text-gray-700 mb-1">Payment Complete Date</label>
                  <div id="paymentCompleteDate" class="text-sm text-gray-900">-</div>
                </div>
              </div>
            </div>

            <!-- Payment Details Section -->
            <div class="space-y-4">
              <h4 class="text-lg font-medium text-gray-900">Payment Details</h4>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">Payment Type</label>
                  <div class="flex space-x-4">
                    <label class="flex items-center">
                      <input type="radio" id="paymentTypeFull" name="paymentType" value="full" checked class="mr-2" />
                      <span class="text-sm">Full Payment</span>
                    </label>
                    <label class="flex items-center">
                      <input type="radio" id="paymentTypePartial" name="paymentType" value="partial" class="mr-2" />
                      <span class="text-sm">Partial Payment</span>
                    </label>
                  </div>
                </div>

                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">Payment Amount (₹)</label>
                  <input type="number" id="paymentAmount" name="paymentAmount" step="0.01" min="0" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="0.00" />
                  <div id="balanceAmount" class="mt-1 text-sm text-gray-600 hidden">
                    Balance: ₹
                    <span id="balanceValue">0.00</span>
                  </div>
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">Payment Method</label>
                  <select id="paymentMethod" name="paymentMethod" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" required>
                    <option value="">Select Payment Method</option>
                    <option value="1">Cash</option>
                    <option value="2">Bank Transfer</option>
                    <option value="3">Check</option>
                    <option value="4">UPI</option>
                    <option value="5">Other</option>
                  </select>
                </div>

                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">Payment Date</label>
                  <input type="date" id="paymentDate" name="paymentDate" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" required />
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Reference Number</label>
                <input type="text" id="paymentReference" name="paymentReference" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Transaction ID, Check number, etc." />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Notes</label>
                <textarea id="paymentNotes" name="paymentNotes" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Add any payment notes..."></textarea>
              </div>
            </div>

            <div class="flex flex-col sm:flex-row justify-end space-y-2 sm:space-y-0 sm:space-x-3 mt-6 pr-4" style="align-items: flex-start">
              <button type="button" id="cancelPayment" class="w-full sm:w-auto px-4 py-2 bg-slate-700 text-slate-200 rounded-md hover:bg-slate-600 transition-colors flex items-center justify-center" style="height: 40px; line-height: 1; font-size: 14px; border: none; outline: none; box-sizing: border-box; margin: 0 12px 0 0; padding: 8px 16px">
                <i class="fas fa-times mr-2" style="font-size: 14px; line-height: 1"></i>
                <span style="font-size: 14px; line-height: 1">Cancel</span>
              </button>
              <button type="submit" class="w-full sm:w-auto px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700 transition-colors flex items-center justify-center" style="height: 40px; line-height: 1; font-size: 14px; border: none; outline: none; box-sizing: border-box; margin: 0; padding: 8px 16px">
                <i class="fas fa-credit-card mr-2" style="font-size: 14px; line-height: 1"></i>
                <span id="submitButtonText" style="font-size: 14px; line-height: 1">Record Payment</span>
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- View Bill Modal -->

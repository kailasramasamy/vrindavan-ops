      // Load bill data for viewing
      async function loadBillDataForView(entityType, billId) {
        try {
          const response = await fetch(`/api/billing/bills/${billId}?entityType=${entityType}`);
          const data = await response.json();

          if (data.success && data.bill) {
            const bill = data.bill;

            // Fetch payment details
            let paymentDetails = null;
            try {
              const paymentResponse = await fetch(`/api/billing/${entityType}/${billId}/payments`);
              const paymentData = await paymentResponse.json();
              if (paymentData.success && paymentData.payments && paymentData.payments.length > 0) {
                paymentDetails = paymentData.payments[0]; // Get the first (most recent) payment
              }
            } catch (paymentError) {}

            // Add a small delay to ensure DOM elements are ready
            setTimeout(() => {
              // Set basic information
              document.getElementById("viewBillId").textContent = bill.id;
              document.getElementById("viewEntityType").textContent = bill.entity_type.toUpperCase();
              document.getElementById("viewEntityName").textContent = bill.entity_name || "-";
              document.getElementById("viewVillage").textContent = bill.village || "-";

              // Set billing period
              document.getElementById("viewPeriodType").textContent = bill.period_type || "-";
              document.getElementById("viewPeriodStart").textContent = bill.billing_period_start ? new Date(bill.billing_period_start).toLocaleDateString() : "-";
              document.getElementById("viewPeriodEnd").textContent = bill.billing_period_end ? new Date(bill.billing_period_end).toLocaleDateString() : "-";

              // Set financial details
              document.getElementById("viewTotalQuantity").textContent = bill.total_quantity ? parseFloat(bill.total_quantity).toFixed(1) + " L" : "-";
            document.getElementById("viewTotalAmount").textContent = bill.total_amount !== undefined && bill.total_amount !== null ? `₹${(parseFloat(bill.total_amount) || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}` : "-";
              // Rate and Salary
              const rateEl = document.getElementById("viewRate");
              const salaryEl = document.getElementById("viewSalary");
              const milkCostEl = document.getElementById("viewMilkCost");
              if (rateEl) {
                let rateVal = null;
                if (bill.rate !== undefined && bill.rate !== null) {
                  rateVal = parseFloat(bill.rate);
                } else if (bill.total_amount && bill.total_quantity) {
                  const qty = parseFloat(bill.total_quantity);
                  const amt = parseFloat(bill.total_amount);
                  if (qty && qty > 0) {
                    rateVal = amt / qty;
                  }
                }
                rateEl.textContent = rateVal !== null ? `₹${(rateVal || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}` : "-";
              }

              // Milk Cost: prefer DB milk_cost for CPP; else compute qty * rate
              if (milkCostEl) {
                let milkCostVal = null;
                if (bill.milk_cost !== undefined && bill.milk_cost !== null) {
                  milkCostVal = parseFloat(bill.milk_cost) || 0;
                } else {
                  const qty = parseFloat(bill.total_quantity || 0) || 0;
                  let rateVal = null;
                  if (bill.rate !== undefined && bill.rate !== null) {
                    rateVal = parseFloat(bill.rate);
                  }
                  if (!rateVal && bill.total_amount && qty > 0) {
                    // if we don't have explicit rate, approximate milk cost as total - salary if salary known, else amt/qty
                    const amt = parseFloat(bill.total_amount) || 0;
                    // will refine below after salary computed
                    rateVal = amt / qty;
                  }
                  if (qty > 0 && rateVal) {
                    milkCostVal = qty * rateVal;
                  }
                }
                milkCostEl.textContent = milkCostVal !== null ? `₹${(milkCostVal || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}` : "-";
              }
              if (salaryEl) {
                let salaryVal = null;
                if (bill.entity_type === 'cpp') {
                  if (bill.computed_salary !== undefined && bill.computed_salary !== null) {
                    salaryVal = parseFloat(bill.computed_salary) || 0;
                  } else {
                  const st = (bill.salary_type || '').toLowerCase();
                  const sa = parseFloat(bill.salary_amount || 0) || 0;
                  const qty = parseFloat(bill.total_quantity || 0) || 0;
                  if (st === 'fixed' || st === 'flat') {
                    salaryVal = sa;
                  } else if (st === 'commission') {
                    salaryVal = sa * qty; // salary_amount treated as per-litre commission
                  }
                  }
                }
                salaryEl.textContent = salaryVal !== null ? `₹${(salaryVal || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}` : "-";
              }

              // Set status information
              const billingStatusElement = document.getElementById("viewBillingStatus");
              billingStatusElement.textContent = bill.billing_status || "Pending";
              billingStatusElement.className = `px-2 py-1 text-xs rounded-full ${bill.billing_status === "completed" ? "bg-green-100 text-green-800" : bill.billing_status === "approved" ? "bg-blue-100 text-blue-800" : bill.billing_status === "rejected" ? "bg-red-100 text-red-800" : bill.billing_status === "cancelled" ? "bg-gray-100 text-gray-800" : "bg-yellow-100 text-yellow-800"}`;

              const paymentStatusElement = document.getElementById("viewPaymentStatus");
              paymentStatusElement.textContent = bill.payment_status || "Pending";
              paymentStatusElement.className = `px-2 py-1 text-xs rounded-full ${bill.payment_status === "completed" ? "bg-green-100 text-green-800" : bill.payment_status === "partial" ? "bg-yellow-100 text-yellow-800" : "bg-blue-100 text-blue-800"}`;

              // Set dates
              document.getElementById("viewBillingDate").textContent = bill.billing_date ? new Date(bill.billing_date).toLocaleDateString() : "-";
              document.getElementById("viewDueDate").textContent = bill.due_date ? new Date(bill.due_date).toLocaleDateString() : "-";
              document.getElementById("viewPaymentDate").textContent = bill.payment_date ? new Date(bill.payment_date).toLocaleDateString() : "-";

              // Set payment details - use payment confirmation data if available
              if (paymentDetails) {
                document.getElementById("viewPaymentReference").textContent = paymentDetails.payment_reference || "-";
                document.getElementById("viewNotes").textContent = paymentDetails.notes || bill.notes || "-";

                // Update payment details section with confirmation data
                document.getElementById("viewPaymentMethod").textContent = paymentDetails.payment_method || "-";
                document.getElementById("viewPaymentAmount").textContent = paymentDetails.payment_amount !== undefined && paymentDetails.payment_amount !== null ? `₹${(parseFloat(paymentDetails.payment_amount) || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}` : "-";
                document.getElementById("viewPaymentConfirmationDate").textContent = paymentDetails.payment_date ? new Date(paymentDetails.payment_date).toLocaleDateString() : "-";
              } else {
                document.getElementById("viewPaymentReference").textContent = bill.payment_reference || "-";
                document.getElementById("viewNotes").textContent = bill.notes || "-";
                document.getElementById("viewPaymentMethod").textContent = "-";
                document.getElementById("viewPaymentAmount").textContent = "-";
                document.getElementById("viewPaymentConfirmationDate").textContent = "-";
              }
            }, 100);
          } else {
            console.error("Failed to load bill data:", data);
            showToast("Failed to load bill details", "error");
          }
        } catch (error) {
          console.error("Error loading bill data:", error);
          showToast("Error loading bill details", "error");
        }
      }

      // Load bill data for payment
      async function loadBillDataForPayment(entityType, billId) {
        try {
          // Get the specific bill by ID
          const response = await fetch(`/api/billing/bills/${billId}?entityType=${entityType}`);
          const data = await response.json();

          if (data.success && data.bill) {
            const bill = data.bill;

            const totalAmount = parseFloat(bill.total_amount);

            // Check if payment is completed
            const status = bill.billing_status || "pending";
            const isCompleted = status.toLowerCase() === "completed";

            // Get existing payments for this bill
            const paymentResponse = await fetch(`/api/billing/${entityType}/${billId}/payments`);
            const paymentData = await paymentResponse.json();

            let totalPaid = 0;
            if (paymentData.success && paymentData.payments) {
              totalPaid = paymentData.payments.reduce((sum, payment) => sum + parseFloat(payment.payment_amount), 0);
            }

            // Calculate due amount - for completed payments, due should be 0
            let dueAmount = totalAmount - totalPaid;
            if (isCompleted) {
              dueAmount = 0; // Completed payments have no due amount
            }

            // Update bill information section
            document.getElementById("paymentEntityInfo").textContent = bill.entity_name || "-";
            document.getElementById("paymentTotalAmount").textContent = `₹${(totalAmount || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
            document.getElementById("dueAmount").textContent = dueAmount.toFixed(2);

            // Update current status with appropriate styling
            const statusElement = document.getElementById("paymentCurrentStatus");
            let statusClass = "bg-yellow-100 text-yellow-800";
            let statusText = "Pending";

            switch (status.toLowerCase()) {
              case "approved":
                statusClass = "bg-green-100 text-green-800";
                statusText = "Approved";
                break;
              case "completed":
                statusClass = "bg-blue-100 text-blue-800";
                statusText = "Completed";
                break;
              case "rejected":
                statusClass = "bg-red-100 text-red-800";
                statusText = "Rejected";
                break;
              case "cancelled":
                statusClass = "bg-gray-100 text-gray-800";
                statusText = "Cancelled";
                break;
            }

            statusElement.innerHTML = `<span class="px-2 py-1 text-xs rounded-full ${statusClass}">${statusText}</span>`;

            // Show/hide payment complete date section
            const paymentCompleteDateSection = document.getElementById("paymentCompleteDateSection");
            if (isCompleted && bill.payment_date) {
              paymentCompleteDateSection.classList.remove("hidden");
              document.getElementById("paymentCompleteDate").textContent = new Date(bill.payment_date).toLocaleDateString();
            } else {
              paymentCompleteDateSection.classList.add("hidden");
            }

            // Populate existing data if available
            document.getElementById("paymentReference").value = bill.payment_reference || "";
            document.getElementById("paymentNotes").value = bill.notes || "";

            // Set payment date from existing payment or today's date
            if (bill.payment_date) {
              // Use the date string directly if it's already in YYYY-MM-DD format
              const paymentDateStr = bill.payment_date.toString();
              if (paymentDateStr.match(/^\d{4}-\d{2}-\d{2}$/)) {
                document.getElementById("paymentDate").value = paymentDateStr;
              } else {
                // Fallback to date conversion for other formats
                const date = new Date(bill.payment_date);
                const year = date.getFullYear();
                const month = String(date.getMonth() + 1).padStart(2, "0");
                const day = String(date.getDate()).padStart(2, "0");
                document.getElementById("paymentDate").value = `${year}-${month}-${day}`;
              }
            } else {
              document.getElementById("paymentDate").value = new Date().toISOString().split("T")[0];
            }

            // Set payment method from existing payment
            document.getElementById("paymentMethod").value = bill.payment_method_id || "";

            // Handle payment amount field based on completion status
            const paymentAmountField = document.getElementById("paymentAmount");
            if (isCompleted) {
              // For completed payments, show the paid amount (total amount since due is 0)
              const paidAmount = totalAmount; // When completed, total amount equals paid amount
              paymentAmountField.value = paidAmount.toFixed(2);
              paymentAmountField.readOnly = true;
              paymentAmountField.classList.add("bg-gray-100");
              document.getElementById("submitButtonText").textContent = "Update Payment";

              // Disable payment type selection for completed payments
              document.getElementById("paymentTypeFull").disabled = true;
              document.getElementById("paymentTypePartial").disabled = true;
            } else {
              // For pending payments, allow editing
              paymentAmountField.value = dueAmount.toFixed(2);
              paymentAmountField.readOnly = false;
              paymentAmountField.classList.remove("bg-gray-100");
              paymentAmountField.max = dueAmount;
              document.getElementById("submitButtonText").textContent = "Record Payment";

              // Enable payment type selection for pending payments
              document.getElementById("paymentTypeFull").disabled = false;
              document.getElementById("paymentTypePartial").disabled = false;
            }

            // Reset payment type to full
            document.getElementById("paymentTypeFull").checked = true;
            document.getElementById("paymentTypePartial").checked = false;

            // Hide balance initially
            document.getElementById("balanceAmount").classList.add("hidden");
          } else {
            showToast("Bill not found!", "error");
          }
        } catch (error) {
          console.error("Error loading bill data for payment:", error);
          showToast("Error loading bill data", "error");
        }
      }

      // Handle edit bill form submission
      async function handleEditBill(event) {
        event.preventDefault();

        const formData = new FormData(event.target);
        const billId = formData.get("billId");
        const entityType = formData.get("entityType");
        const billingStatus = formData.get("billingStatus");
        const dueDate = formData.get("dueDate");
        const notes = formData.get("notes");

        // Show loading spinner
        const submitButton = event.target.querySelector('button[type="submit"]');
        const originalText = submitButton.innerHTML;
        submitButton.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Updating Bill...';
        submitButton.disabled = true;

        try {
          const response = await fetch(`/api/billing/${entityType}/${billId}`, {
            method: "PUT",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              billing_status_id: parseInt(billingStatus),
              due_date: dueDate,
              notes: notes,
            }),
          });

          const data = await response.json();

          if (data.success) {
            showToast("Bill updated successfully!", "success");
            closeEditModal();
            loadBills(); // Refresh the bills list
            loadBillingStatus(); // Refresh all-time summary cards
            loadSummaryCards(); // Refresh filter-based summary cards
          } else {
            showToast("Error updating bill: " + data.error, "error");
          }
        } catch (error) {
          console.error("Error updating bill:", error);
          showToast("Error updating bill: " + error.message, "error");
        } finally {
          // Reset button state
          submitButton.innerHTML = originalText;
          submitButton.disabled = false;
        }
      }

      // Handle payment type change
      function handlePaymentTypeChange() {
        const paymentType = document.querySelector('input[name="paymentType"]:checked').value;
        const dueAmount = parseFloat(document.getElementById("dueAmount").textContent);
        const paymentAmountInput = document.getElementById("paymentAmount");
        const balanceDiv = document.getElementById("balanceAmount");
        const balanceValue = document.getElementById("balanceValue");

        // Skip if payment amount field is read-only (completed payment)
        if (paymentAmountInput.readOnly) {
          return;
        }

        if (paymentType === "full") {
          // Set to full amount (only if due amount > 0)
          if (dueAmount > 0) {
            paymentAmountInput.value = dueAmount.toFixed(2);
          } else {
            paymentAmountInput.value = "";
          }
          paymentAmountInput.max = dueAmount;
          balanceDiv.classList.add("hidden");
        } else {
          // Allow partial payment
          paymentAmountInput.value = "";
          paymentAmountInput.max = dueAmount;
          balanceDiv.classList.remove("hidden");
        }
      }

      // Handle payment amount change for partial payments
      function handlePaymentAmountChange() {
        const paymentType = document.querySelector('input[name="paymentType"]:checked').value;

        if (paymentType === "partial") {
          const dueAmount = parseFloat(document.getElementById("dueAmount").textContent);
          const paymentAmount = parseFloat(document.getElementById("paymentAmount").value) || 0;
          const balance = dueAmount - paymentAmount;

          document.getElementById("balanceValue").textContent = balance.toFixed(2);

          // Show balance div
          document.getElementById("balanceAmount").classList.remove("hidden");
        }
      }

      // Handle record payment form submission
      async function handleRecordPayment(event) {
        event.preventDefault();

        const formData = new FormData(event.target);
        const billId = formData.get("billId");
        const entityType = formData.get("entityType");
        const paymentAmount = parseFloat(formData.get("paymentAmount"));
        const paymentMethod = formData.get("paymentMethod");
        const paymentDate = formData.get("paymentDate");
        const paymentReference = formData.get("paymentReference");
        const paymentNotes = formData.get("paymentNotes");
        const paymentType = formData.get("paymentType");

        // Check if this is a completed payment (read-only amount field)
        const paymentAmountField = document.getElementById("paymentAmount");
        const isCompletedPayment = paymentAmountField.readOnly;

        // Validate payment amount only for non-completed payments
        if (!isCompletedPayment) {
          const dueAmount = parseFloat(document.getElementById("dueAmount").textContent);
          if (paymentAmount > dueAmount) {
            showToast("Payment amount cannot exceed due amount!", "error");
            return;
          }

          if (paymentAmount <= 0) {
            showToast("Payment amount must be greater than 0!", "error");
            return;
          }
        }

        // Show loading spinner
        const submitButton = event.target.querySelector('button[type="submit"]');
        const originalText = submitButton.innerHTML;
        submitButton.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Recording Payment...';
        submitButton.disabled = true;

        try {
          const response = await fetch(`/api/billing/${entityType}/${billId}/payment`, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              payment_amount: paymentAmount,
              payment_method_id: parseInt(paymentMethod),
              payment_date: paymentDate,
              payment_reference: paymentReference,
              notes: paymentNotes,
              payment_type: paymentType,
            }),
          });

          const data = await response.json();

          if (data.success) {
            const remainingBalance = dueAmount - paymentAmount;
            let successMessage;

            if (remainingBalance > 0) {
              successMessage = `Payment recorded successfully! Remaining balance: ₹${(remainingBalance || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
            } else {
              successMessage = "Payment recorded successfully! Bill is now fully paid.";

              // If billing status also changed to completed, add that info
              if (data.billing_status_changed && data.billing_status === "completed") {
                successMessage += " Billing status updated to completed.";
              }
            }

            showToast(successMessage, "success");
            closePaymentModal();
            loadBills(); // Refresh the bills list
            loadBillingStatus(); // Refresh all-time summary cards
            loadSummaryCards(); // Refresh filter-based summary cards
          } else {
            showToast("Error recording payment: " + data.error, "error");
          }
        } catch (error) {
          console.error("Error recording payment:", error);
          showToast("Error recording payment: " + error.message, "error");
        } finally {
          // Reset button state
          submitButton.innerHTML = originalText;
          submitButton.disabled = false;
        }
      }


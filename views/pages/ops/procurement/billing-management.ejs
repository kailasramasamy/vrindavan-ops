    <script>
      // Toast notification system
      function showToast(message, type = "info", duration = 5000) {
        const container = document.getElementById("toastContainer");
        const toast = document.createElement("div");

        const bgColor = type === "success" ? "bg-green-500" : type === "error" ? "bg-red-500" : type === "warning" ? "bg-yellow-500" : "bg-blue-500";

        toast.className = `${bgColor} text-white px-6 py-3 rounded-lg shadow-lg flex items-center justify-between min-w-80 max-w-96 transform transition-all duration-300 ease-in-out translate-x-full`;

        toast.innerHTML = `
          <div class="flex items-center">
            <div class="flex-shrink-0">
              ${type === "success" ? '<i class="fas fa-check-circle"></i>' : type === "error" ? '<i class="fas fa-exclamation-circle"></i>' : type === "warning" ? '<i class="fas fa-exclamation-triangle"></i>' : '<i class="fas fa-info-circle"></i>'}
            </div>
            <div class="ml-3">
              <p class="text-sm font-medium">${message}</p>
            </div>
          </div>
          <button onclick="this.parentElement.remove()" class="ml-4 flex-shrink-0 text-white hover:text-gray-200">
            <i class="fas fa-times"></i>
          </button>
        `;

        container.appendChild(toast);

        // Animate in
        setTimeout(() => {
          toast.classList.remove("translate-x-full");
        }, 100);

        // Auto remove
        setTimeout(() => {
          toast.classList.add("translate-x-full");
          setTimeout(() => {
            if (toast.parentElement) {
              toast.remove();
            }
          }, 300);
        }, duration);
      }

      // Test function
      function testFunction() {
        // alert("JavaScript is working!"); // Removed alert for better UX
      }

      // Copy amount to clipboard (numeric value only, without rupee symbol)
      async function copyAmountToClipboard(amount) {
        try {
          // Ensure amount is a clean numeric string
          const numericValue = parseFloat(amount).toFixed(2);
          await navigator.clipboard.writeText(numericValue);
          showToast(`Amount copied: ${numericValue}`, "success", 2000);
        } catch (error) {
          console.error("Failed to copy amount:", error);
          showToast("Failed to copy amount", "error", 2000);
        }
      }

      // Load all bills
      function loadBills() {
        // Hide loading and show table
        const loading = document.getElementById("billsLoading");
        const tbody = document.getElementById("billsTableBody");
        const cardContainer = document.getElementById("billsCardContainer");

        if (loading) {
          loading.classList.add("hidden");
        }

        // Get filter values (check both desktop and mobile filters)
        const monthFilter = document.getElementById("monthFilter") ? document.getElementById("monthFilter").value : document.getElementById("monthFilterMobile") ? document.getElementById("monthFilterMobile").value : "";
        const yearFilter = document.getElementById("yearFilter") ? document.getElementById("yearFilter").value : document.getElementById("yearFilterMobile") ? document.getElementById("yearFilterMobile").value : "";
        const periodFilter = document.getElementById("periodFilter") ? document.getElementById("periodFilter").value : document.getElementById("periodFilterMobile") ? document.getElementById("periodFilterMobile").value : "";
        const entityFilter = document.getElementById("entityFilter") ? document.getElementById("entityFilter").value : document.getElementById("entityFilterMobile") ? document.getElementById("entityFilterMobile").value : "";
        const statusFilter = document.getElementById("statusFilter") ? document.getElementById("statusFilter").value : document.getElementById("statusFilterMobile") ? document.getElementById("statusFilterMobile").value : "";

        // Show loading message
        if (tbody) {
          tbody.innerHTML = '<tr><td colspan="9" class="px-6 py-4 text-center text-blue-600">Loading bills... Please wait.</td></tr>';
        }
        if (cardContainer) {
          cardContainer.innerHTML = '<div class="text-center py-4 text-blue-600">Loading bills... Please wait.</div>';
        }

        // Build query parameters
        const params = new URLSearchParams();
        if (monthFilter) params.append("month", monthFilter);
        if (yearFilter) params.append("year", yearFilter);
        if (periodFilter) params.append("period", periodFilter);
        if (entityFilter) params.append("entityType", entityFilter);
        if (statusFilter) params.append("status", statusFilter);
        const milkType = document.getElementById("milkTypeFilter") ? document.getElementById("milkTypeFilter").value : (document.getElementById("milkTypeFilterMobile") ? document.getElementById("milkTypeFilterMobile").value : "all");
        if (milkType) params.append("milkType", milkType);

        const url = `/api/billing/bills?${params.toString()}`;

        // Make the API call
        fetch(url)
          .then((response) => {
            if (!response.ok) {
              throw new Error(`HTTP error! status: ${response.status}`);
            }
            return response.json();
          })
          .then((data) => {
            if (data.success) {
              displayBills(data.bills);
            } else {
              console.error("Error loading bills:", data.error);
              if (tbody) {
                tbody.innerHTML = '<tr><td colspan="9" class="px-6 py-4 text-center text-red-600">Error loading bills: ' + data.error + "</td></tr>";
              }
              if (cardContainer) {
                cardContainer.innerHTML = '<div class="text-center py-4 text-red-600">Error loading bills: ' + data.error + "</div>";
              }
            }
          })
          .catch((error) => {
            console.error("Error loading bills:", error);
            if (tbody) {
              tbody.innerHTML = '<tr><td colspan="9" class="px-6 py-4 text-center text-red-600">Error loading bills: ' + error.message + "</td></tr>";
            }
            if (cardContainer) {
              cardContainer.innerHTML = '<div class="text-center py-4 text-red-600">Error loading bills: ' + error.message + "</div>";
            }
          });
      }

      // Display bills in table and cards
      function displayBills(bills) {
        const tbody = document.getElementById("billsTableBody");
        const cardContainer = document.getElementById("billsCardContainer");
        const loading = document.getElementById("billsLoading");
        const noBills = document.getElementById("noBills");

        loading.classList.add("hidden");

        if (bills.length === 0) {
          noBills.classList.remove("hidden");
          if (tbody) tbody.innerHTML = "";
          if (cardContainer) cardContainer.innerHTML = "";
          return;
        }

        noBills.classList.add("hidden");

        // Handle responsive display
        const desktopTable = document.getElementById("desktopTableView");
        const mobileCards = document.getElementById("billsCardContainer");
        const desktopFilters = document.getElementById("desktopFilters");
        const mobileFilters = document.getElementById("mobileFilters");

        if (window.innerWidth >= 1024) {
          // Desktop view - show table and desktop filters, hide cards and mobile filters
          if (desktopTable) desktopTable.style.display = "block";
          if (mobileCards) mobileCards.style.display = "none";
          if (desktopFilters) desktopFilters.style.display = "flex";
          if (mobileFilters) mobileFilters.style.display = "none";
        } else {
          // Mobile view - hide table and desktop filters, show cards and mobile filters
          if (desktopTable) desktopTable.style.display = "none";
          if (mobileCards) mobileCards.style.display = "block";
          if (desktopFilters) desktopFilters.style.display = "none";
          if (mobileFilters) mobileFilters.style.display = "block";
        }

        // Display desktop table
        if (tbody) {
          tbody.innerHTML = bills
            .map(
              (bill) => `
            <tr class="hover:bg-gray-50 dark:hover:bg-slate-700">
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${bill.entity_type === "farmers" ? "bg-blue-100 text-blue-800" : bill.entity_type === "cpp" ? "bg-green-100 text-green-800" : bill.entity_type === "rcc" ? "bg-yellow-100 text-yellow-800" : "bg-purple-100 text-purple-800"}">
                  ${bill.entity_type.toUpperCase()}
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900">${bill.entity_name}</div>
                <div class="text-sm text-gray-500">${bill.village || ""}</div>
              </td>
              <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-900">
                ${new Date(bill.billing_period_start).toLocaleDateString()} to ${new Date(bill.billing_period_end).toLocaleDateString()}
                <div class="text-xs text-gray-500">${bill.period_type}</div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                ${Number(bill.total_quantity).toFixed(1)}L
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                <div class="flex items-center gap-2 group/amount">
                  <span>₹${(Number(bill.total_amount) || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</span>
                  <button onclick="copyAmountToClipboard('${(Number(bill.total_amount) || 0).toFixed(2)}')" class="opacity-0 group-hover/amount:opacity-100 transition-opacity cursor-pointer text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300" title="Copy amount">
                    <i class="fas fa-copy text-xs"></i>
                  </button>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${bill.billing_status === "pending" ? "bg-yellow-100 text-yellow-800" : bill.billing_status === "approved" ? "bg-green-100 text-green-800" : bill.billing_status === "completed" ? "bg-blue-100 text-blue-800" : "bg-red-100 text-red-800"}">
                  ${bill.billing_status || "Pending"}
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${bill.payment_status === "pending" ? "bg-yellow-100 text-yellow-800" : bill.payment_status === "partial" ? "bg-orange-100 text-orange-800" : bill.payment_status === "completed" ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800"}">
                  ${bill.payment_status || "Pending"}
                </span>
              </td>
              <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-900">
                ${new Date(bill.due_date).toLocaleDateString()}
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                <div class="flex space-x-2">
                  <button class="text-blue-600 hover:text-blue-900" onclick="viewBill('${bill.entity_type}', ${bill.id})">
                    <i class="fas fa-eye"></i>
                  </button>
                  <button class="text-green-600 hover:text-green-900" onclick="editBill('${bill.entity_type}', ${bill.id})">
                    <i class="fas fa-edit"></i>
                  </button>
                  <button class="text-purple-600 hover:text-purple-900" onclick="recordPayment('${bill.entity_type}', ${bill.id})">
                    <i class="fas fa-credit-card"></i>
                  </button>
                </div>
              </td>
            </tr>
          `,
            )
            .join("");
        }

        // Display mobile cards
        if (cardContainer) {
          cardContainer.innerHTML = bills
            .map(
              (bill) => `
            <div class="bg-white rounded-lg border border-gray-200 p-4 shadow-sm">
              <div class="flex justify-between items-start mb-3">
                <div class="flex items-center space-x-2">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${bill.entity_type === "farmers" ? "bg-blue-100 text-blue-800" : bill.entity_type === "cpp" ? "bg-green-100 text-green-800" : bill.entity_type === "rcc" ? "bg-yellow-100 text-yellow-800" : "bg-purple-100 text-purple-800"}">
                    ${bill.entity_type.toUpperCase()}
                  </span>
                  <span class="text-sm font-medium text-gray-900">${bill.entity_name}</span>
                </div>
                <div class="flex space-x-1">
                  <button onclick="viewBill('${bill.entity_type}', ${bill.id})" class="p-2 text-indigo-600 hover:text-indigo-900 hover:bg-indigo-50 rounded-full" title="View Bill">
                    <i class="fas fa-eye text-sm"></i>
                  </button>
                  <button onclick="editBill('${bill.entity_type}', ${bill.id})" class="p-2 text-blue-600 hover:text-blue-900 hover:bg-blue-50 rounded-full" title="Edit Bill">
                    <i class="fas fa-edit text-sm"></i>
                  </button>
                  <button onclick="recordPayment('${bill.entity_type}', ${bill.id})" class="p-2 text-green-600 hover:text-green-900 hover:bg-green-50 rounded-full" title="Record Payment">
                    <i class="fas fa-credit-card text-sm"></i>
                  </button>
                </div>
              </div>
              
              <div class="space-y-2 text-sm">
                <div class="flex justify-between">
                  <span class="text-gray-500">Period:</span>
                  <span class="text-gray-900">${new Date(bill.billing_period_start).toLocaleDateString()} - ${new Date(bill.billing_period_end).toLocaleDateString()}</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-gray-500">Type:</span>
                  <span class="text-gray-900">${bill.period_type}</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-gray-500">Quantity:</span>
                  <span class="text-gray-900">${Number(bill.total_quantity).toFixed(1)}L</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-gray-500">Amount:</span>
                  <div class="flex items-center gap-2 group/amount">
                    <span class="text-gray-900 font-semibold">₹${(Number(bill.total_amount) || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</span>
                    <button onclick="copyAmountToClipboard('${(Number(bill.total_amount) || 0).toFixed(2)}')" class="opacity-0 group-hover/amount:opacity-100 transition-opacity cursor-pointer text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300" title="Copy amount">
                      <i class="fas fa-copy text-xs"></i>
                    </button>
                  </div>
                </div>
                <div class="flex justify-between">
                  <span class="text-gray-500">Billing Status:</span>
                  <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium ${bill.billing_status === "pending" ? "bg-yellow-100 text-yellow-800" : bill.billing_status === "approved" ? "bg-green-100 text-green-800" : bill.billing_status === "completed" ? "bg-blue-100 text-blue-800" : "bg-red-100 text-red-800"}">
                    ${bill.billing_status || "Pending"}
                  </span>
                </div>
                <div class="flex justify-between">
                  <span class="text-gray-500">Payment Status:</span>
                  <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium ${bill.payment_status === "pending" ? "bg-yellow-100 text-yellow-800" : bill.payment_status === "partial" ? "bg-orange-100 text-orange-800" : bill.payment_status === "completed" ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800"}">
                    ${bill.payment_status || "Pending"}
                  </span>
                </div>
                <div class="flex justify-between">
                  <span class="text-gray-500">Due Date:</span>
                  <span class="text-gray-900">${new Date(bill.due_date).toLocaleDateString()}</span>
                </div>
                ${
                  bill.village
                    ? `
                <div class="flex justify-between">
                  <span class="text-gray-500">Location:</span>
                  <span class="text-gray-900">${bill.village}</span>
                </div>
                `
                    : ""
                }
              </div>
            </div>
          `,
            )
            .join("");
        }
      }

      // Action functions
      function viewBill(entityType, billId) {
        // Open view modal
        document.getElementById("viewBillId").value = billId;
        document.getElementById("viewEntityType").value = entityType;

        // Show modal first
        document.getElementById("viewBillModal").classList.remove("hidden");

        // Load bill data for viewing
        loadBillDataForView(entityType, billId);
      }

      function editBill(entityType, billId) {
        // Open edit modal
        document.getElementById("editBillId").value = billId;
        document.getElementById("editEntityType").value = entityType;

        // Show modal first
        document.getElementById("editBillModal").classList.remove("hidden");

        // Load current bill data after modal is shown
        loadBillData(entityType, billId);
      }

      function recordPayment(entityType, billId) {
        // Open payment recording modal
        document.getElementById("paymentBillId").value = billId;
        document.getElementById("paymentEntityType").value = entityType;

        // Set today's date as default
        document.getElementById("paymentDate").value = new Date().toISOString().split("T")[0];

        // Load bill data for payment
        loadBillDataForPayment(entityType, billId);


                <div class="flex items-center p-3 bg-gray-50 rounded-lg">
                    <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center mr-3">
                        <i class="fas fa-credit-card text-blue-600 text-sm"></i>
                    </div>
                    <div class="flex-1">
                        <p class="text-sm font-medium">Partial payment from RCC #2</p>
                        <p class="text-xs text-gray-500">1 day ago</p>
                    </div>
                    <span class="text-sm text-blue-600 font-medium">₹15,000</span>
                </div>
            `;
        } else {
        }
      }

      // Initialize page
      document.addEventListener("DOMContentLoaded", function () {
        // Test JavaScript execution
        testFunction();

        // Test if JavaScript is working
        setTimeout(() => {
          const loading = document.getElementById("billsLoading");
          if (loading && !loading.classList.contains("hidden")) {
            loading.innerHTML = '<p class="text-red-600">JavaScript Error - Check console for details</p>';
          }
        }, 2000);

        // Set default entity to CPP and initialize date filters before initial loads
        (function initDefaultEntity(){
          const ef = document.getElementById('entityFilter');
          const efm = document.getElementById('entityFilterMobile');
          if (ef && !ef.value) ef.value = 'cpp';
          if (efm && !efm.value) efm.value = 'cpp';
        })();
        // Ensure date defaults are set before initial loads as well
        (function ensureDateDefaults(){
          const now = new Date();
          const currentYear = now.getFullYear();
          const currentMonth = now.getMonth() + 1;
          const currentPeriod = (now.getDate() <= 15) ? 'H1' : 'H2';
          const yf = document.getElementById('yearFilter');
          const mf = document.getElementById('monthFilter');
          const pf = document.getElementById('periodFilter');
          const yfm = document.getElementById('yearFilterMobile');
          const mfm = document.getElementById('monthFilterMobile');
          const pfm = document.getElementById('periodFilterMobile');
          if (yf && !yf.value) yf.innerHTML = `<option value="${currentYear}" selected>${currentYear}</option>`;
          if (yfm && !yfm.value) yfm.innerHTML = `<option value="${currentYear}" selected>${currentYear}</option>`;
          if (mf && !mf.value) mf.innerHTML = `<option value="${currentMonth}" selected>${['January','February','March','April','May','June','July','August','September','October','November','December'][currentMonth-1]}</option>`;
          if (mfm && !mfm.value) mfm.innerHTML = `<option value="${currentMonth}" selected>${['January','February','March','April','May','June','July','August','September','October','November','December'][currentMonth-1]}</option>`;
          if (pf) pf.value = currentPeriod;
          if (pfm) pfm.value = currentPeriod;
        })();

        loadBillingStatus();
        loadSummaryCards();
        loadRecentActivity();
        loadBills();

        // Set initial responsive display
        const desktopTable = document.getElementById("desktopTableView");
        const mobileCards = document.getElementById("billsCardContainer");
        const desktopFilters = document.getElementById("desktopFilters");
        const mobileFilters = document.getElementById("mobileFilters");

        if (window.innerWidth >= 1024) {
          // Desktop view - show table and desktop filters, hide cards and mobile filters
          if (desktopTable) desktopTable.style.display = "block";
          if (mobileCards) mobileCards.style.display = "none";
          if (desktopFilters) desktopFilters.style.display = "flex";
          if (mobileFilters) mobileFilters.style.display = "none";
        } else {
          // Mobile view - hide table and desktop filters, show cards and mobile filters
          if (desktopTable) desktopTable.style.display = "none";
          if (mobileCards) mobileCards.style.display = "block";
          if (desktopFilters) desktopFilters.style.display = "none";
          if (mobileFilters) mobileFilters.style.display = "block";
        }

        // Populate year/month selects with defaults
        (function initDateFilters(){
          const now = new Date();
          const currentYear = now.getFullYear();
          const currentMonth = now.getMonth() + 1;
          const currentPeriod = (now.getDate() <= 15) ? 'H1' : 'H2';
          function fillYear(select){
            if (!select) return;
            select.innerHTML = '';
            for (let y = currentYear + 1; y >= 2020; y--) {
              const opt = document.createElement('option');
              opt.value = String(y);
              opt.textContent = String(y);
              if (y === currentYear) opt.selected = true;
              select.appendChild(opt);
            }
          }
          function fillMonth(select){
            if (!select) return;
            select.innerHTML = '';
            const names = ['January','February','March','April','May','June','July','August','September','October','November','December'];
            for (let i = 1; i <= 12; i++) {
              const opt = document.createElement('option');
              opt.value = String(i);
              opt.textContent = names[i-1];
              if (i === currentMonth) opt.selected = true;
              select.appendChild(opt);
            }
          }
          fillYear(document.getElementById('yearFilter'));
          fillYear(document.getElementById('yearFilterMobile'));
          fillMonth(document.getElementById('monthFilter'));
          fillMonth(document.getElementById('monthFilterMobile'));
          const periodDesktop = document.getElementById('periodFilter');
          const periodMobile = document.getElementById('periodFilterMobile');
          if (periodDesktop) periodDesktop.value = currentPeriod;
          if (periodMobile) periodMobile.value = currentPeriod;
        })();

        // Add event listeners for filters
        document.getElementById("monthFilter").addEventListener("change", () => {
          loadBills();
          loadSummaryCards();
        });
        document.getElementById("yearFilter").addEventListener("change", () => {
          loadBills();
          loadSummaryCards();
        });
        document.getElementById("periodFilter").addEventListener("change", () => {
          loadBills();
          loadSummaryCards();
        });
        document.getElementById("entityFilter").addEventListener("change", () => {
          loadBills();
          loadSummaryCards();
        });
        document.getElementById("milkTypeFilter").addEventListener("change", () => {
          loadBills();
          loadSummaryCards();
        });
        document.getElementById("statusFilter").addEventListener("change", () => {
          loadBills();
          loadSummaryCards();
        });
        document.getElementById("refreshBills").addEventListener("click", () => {
          loadBills();
          loadBillingStatus();
          loadSummaryCards();
        });
        const regenAll = document.getElementById('regenAllBills');
        if (regenAll) regenAll.addEventListener('click', () => triggerBillGeneration('regenerate'));

        // Add event listeners for mobile filters
        document.getElementById("monthFilterMobile").addEventListener("change", () => {
          // Sync with desktop filter
          document.getElementById("monthFilter").value = document.getElementById("monthFilterMobile").value;
          loadBills();
          loadSummaryCards();
        });
        document.getElementById("yearFilterMobile").addEventListener("change", () => {
          // Sync with desktop filter
          document.getElementById("yearFilter").value = document.getElementById("yearFilterMobile").value;
          loadBills();
          loadSummaryCards();
        });
        document.getElementById("periodFilterMobile").addEventListener("change", () => {
          // Sync with desktop filter
          document.getElementById("periodFilter").value = document.getElementById("periodFilterMobile").value;
          loadBills();
          loadSummaryCards();
        });
        document.getElementById("entityFilterMobile").addEventListener("change", () => {
          // Sync with desktop filter
          document.getElementById("entityFilter").value = document.getElementById("entityFilterMobile").value;
          loadBills();
          loadSummaryCards();
        });
        document.getElementById("milkTypeFilterMobile").addEventListener("change", () => {
          document.getElementById("milkTypeFilter").value = document.getElementById("milkTypeFilterMobile").value;
          loadBills();
          loadSummaryCards();
        });
        document.getElementById("statusFilterMobile").addEventListener("change", () => {
          // Sync with desktop filter
          document.getElementById("statusFilter").value = document.getElementById("statusFilterMobile").value;
          loadBills();
          loadSummaryCards();
        });
        document.getElementById("refreshBillsMobile").addEventListener("click", () => {
          loadBills();
          loadBillingStatus();
          loadSummaryCards();
        });
        const genBtn = document.getElementById('generateBillsBtn');
        const regenBtn = document.getElementById('regenerateBillsBtn');
        if (genBtn) genBtn.addEventListener('click', () => triggerBillGeneration('generate'));
        if (regenBtn) regenBtn.addEventListener('click', () => triggerBillGeneration('regenerate'));

        // Handle window resize for responsive display
        window.addEventListener("resize", () => {
          const desktopTable = document.getElementById("desktopTableView");
          const mobileCards = document.getElementById("billsCardContainer");
          const desktopFilters = document.getElementById("desktopFilters");
          const mobileFilters = document.getElementById("mobileFilters");

          if (window.innerWidth >= 1024) {
            // Desktop view - show table and desktop filters, hide cards and mobile filters
            if (desktopTable) desktopTable.style.display = "block";
            if (mobileCards) mobileCards.style.display = "none";
            if (desktopFilters) desktopFilters.style.display = "flex";
            if (mobileFilters) mobileFilters.style.display = "none";
          } else {
            // Mobile view - hide table and desktop filters, show cards and mobile filters
            if (desktopTable) desktopTable.style.display = "none";
            if (mobileCards) mobileCards.style.display = "block";
            if (desktopFilters) desktopFilters.style.display = "none";
            if (mobileFilters) mobileFilters.style.display = "block";
          }
        });

        // Add event listeners for modals
        document.getElementById("editBillForm").addEventListener("submit", handleEditBill);
        document.getElementById("recordPaymentForm").addEventListener("submit", handleRecordPayment);

        // Payment type and amount change listeners
        document.querySelectorAll('input[name="paymentType"]').forEach((radio) => {
          radio.addEventListener("change", handlePaymentTypeChange);
        });
        document.getElementById("paymentAmount").addEventListener("input", handlePaymentAmountChange);

        // Modal close buttons
        document.getElementById("closeEditModal").addEventListener("click", closeEditModal);
        document.getElementById("cancelEdit").addEventListener("click", closeEditModal);
        document.getElementById("closePaymentModal").addEventListener("click", closePaymentModal);
        document.getElementById("cancelPayment").addEventListener("click", closePaymentModal);
        document.getElementById("closeViewModal").addEventListener("click", closeViewModal);
        document.getElementById("closeViewModalBtn").addEventListener("click", closeViewModal);

        // Close modals when clicking outside
        document.getElementById("editBillModal").addEventListener("click", function (e) {
          if (e.target === this) closeEditModal();
        });
        document.getElementById("recordPaymentModal").addEventListener("click", function (e) {
          if (e.target === this) closePaymentModal();
        });
        document.getElementById("viewBillModal").addEventListener("click", function (e) {
          if (e.target === this) closeViewModal();
        });
      });

      function getPeriodDates(year, month, period){
        const startDay = period === 'H1' ? 1 : 16;
        const endDay = period === 'H1' ? 15 : new Date(year, month, 0).getDate();
        const pad = (n) => String(n).padStart(2,'0');
        return {
          start: `${year}-${pad(month)}-${pad(startDay)}`,
          end: `${year}-${pad(month)}-${pad(endDay)}`
        };
      }

      async function triggerBillGeneration(action){
        try{
          const y = document.getElementById('yearFilter')?.value || document.getElementById('yearFilterMobile')?.value;
          const m = document.getElementById('monthFilter')?.value || document.getElementById('monthFilterMobile')?.value;
          const p = document.getElementById('periodFilter')?.value || document.getElementById('periodFilterMobile')?.value || 'H1';
          const mt = document.getElementById('milkTypeFilter')?.value || document.getElementById('milkTypeFilterMobile')?.value || 'all';
          
          // Validate inputs
          if (!y || !m || y === '' || m === ''){ 
            showToast('Select year and month first','warning'); 
            return; 
          }
          
          // Validate periodType
          if (!p || p === '') {
            showToast('Period type is required','warning');
            return;
          }
          
          const { start, end } = getPeriodDates(parseInt(y), parseInt(m), p);
          
          // Validate dates
          if (!start || !end || start === '' || end === '') {
            showToast('Invalid date range. Please check your filters.','error');
            return;
          }
          
          // show progress on buttons if present
          const btn = action === 'regenerate' ? (document.getElementById('regenAllBills') || document.getElementById('regenerateBillsBtn')) : document.getElementById('generateBillsBtn');
          const original = btn ? btn.innerHTML : '';
          if (btn){ btn.disabled = true; btn.innerHTML = `<i class=\"fas fa-spinner fa-spin mr-2\"></i>${action==='regenerate'?'Regenerating…':'Generating…'}`; }
          
          const endpoint = action==='regenerate' ? '/api/bills/regenerate/all' : '/api/bills/generate/all';
          const requestBody = {
            startDate: start,
            endDate: end,
            periodType: p,
            milkType: mt
          };
          
          const res = await fetch(endpoint, { 
            method:'POST', 
            headers:{'Content-Type':'application/json'}, 
            body: JSON.stringify(requestBody) 
          });
          
          const data = await res.json();
          
          if (!res.ok || data.success===false){ 
            console.error('Error response:', data);
            showToast(data.error||'Failed to process bills','error'); 
          }
          else { 
            showToast('Bills processed successfully','success'); 
            loadBills(); 
            loadSummaryCards(); 
          }
          
          if (btn){ btn.disabled=false; btn.innerHTML = original; }
        }catch(err){ 
          console.error('Error in triggerBillGeneration:', err); 
          showToast('Failed to process bills: ' + (err.message || 'Unknown error'),'error'); 
          const btn = action === 'regenerate' ? (document.getElementById('regenAllBills') || document.getElementById('regenerateBillsBtn')) : document.getElementById('generateBillsBtn');
          if (btn){ btn.disabled=false; }
        }
      }
    </script>
  </body>
</html>

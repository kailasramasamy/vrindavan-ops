<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../../../partials/_head', { seo }) %>
  <style>
    .gradient-bg {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
    .card-gradient-blue {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
    .card-gradient-green {
      background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
    }
    .card-gradient-orange {
      background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    }
    .card-gradient-purple {
      background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    }
    .glass-effect {
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.2);
    }
    .modern-card {
      border-radius: 20px;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
      transition: all 0.3s ease;
    }
    .modern-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 25px 50px rgba(0, 0, 0, 0.15);
    }
    .data-table {
      border-radius: 15px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }
    .table-header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
    }
    .metric-value {
      font-size: 2rem;
      font-weight: 700;
      color: white;
    }
    .metric-label {
      font-size: 0.875rem;
      opacity: 0.9;
      color: white;
    }
  </style>
</head>

<body class="bg-gray-50">
  <%- include('../../../partials/_header', { user: user }) %>
  
  <!-- Sub Navigation -->
  <%- include('../../../partials/_subnav', { section: 'Procurement', page: 'Dashboard', user }) %>

  <main class="min-h-screen py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Header -->
      <div class="mb-8">
        <h1 class="text-4xl font-bold text-gray-900 mb-2">Procurement Dashboard</h1>
        <p class="text-gray-600">Real-time milk collection and quality metrics</p>
      </div>

      <!-- Filters -->
      <div class="modern-card glass-effect p-6 mb-8">
        <form class="flex flex-col sm:flex-row gap-4">
          <div class="flex-1">
            <label class="block text-sm font-semibold text-gray-700 mb-2">Date</label>
            <input 
              type="date" 
              name="date" 
              value="<%= date %>" 
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              onchange="this.form.submit()" 
            />
          </div>
          <div class="flex-1">
            <label class="block text-sm font-semibold text-gray-700 mb-2">Time Period</label>
            <select 
              name="time" 
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              onchange="this.form.submit()"
            >
              <option value="day" <%= (time === 'day') ? 'selected' : '' %>>Day (Total)</option>
              <option value="morning" <%= (time === 'morning') ? 'selected' : '' %>>Morning</option>
              <option value="evening" <%= (time === 'evening') ? 'selected' : '' %>>Evening</option>
            </select>
          </div>
        </form>
      </div>

      <!-- Milk Type Cards -->
      <div class="mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Milk Collection by Type</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <% milkTypeData.forEach((item, index) => { %>
            <div class="modern-card p-6 <%= index === 0 ? 'card-gradient-blue' : index === 1 ? 'card-gradient-green' : 'card-gradient-orange' %>">
              <div class="text-center">
                <h3 class="text-xl font-bold text-white mb-4"><%= item.milk_type %></h3>
                <div class="space-y-3">
                  <div>
                    <div class="metric-value"><%= Number(item.total_volume || 0).toFixed(1) %> L</div>
                    <div class="metric-label">Volume</div>
                  </div>
                  <div class="grid grid-cols-2 gap-4">
                    <div>
                      <div class="text-lg font-semibold text-white"><%= Number(item.avg_fat || 0).toFixed(1) %>%</div>
                      <div class="metric-label">Fat</div>
                    </div>
                    <div>
                      <div class="text-lg font-semibold text-white"><%= Number(item.avg_water || 0).toFixed(1) %>%</div>
                      <div class="metric-label">Water</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
          
          <% if (!milkTypeData || milkTypeData.length === 0) { %>
            <div class="col-span-full text-center py-12">
              <div class="text-gray-500 text-lg">No milk collection data available</div>
            </div>
          <% } %>
        </div>
      </div>

      <!-- RCC Data -->
      <div class="mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Regional Collection Centers (RCC)</h2>
        
        <!-- Desktop Table -->
        <div class="hidden lg:block data-table bg-white">
          <table class="w-full">
            <thead class="table-header">
              <tr>
                <th class="px-6 py-4 text-left font-semibold">RCC Name</th>
                <th class="px-6 py-4 text-right font-semibold">Volume (L)</th>
                <th class="px-6 py-4 text-right font-semibold">Fat %</th>
                <th class="px-6 py-4 text-right font-semibold">SNF %</th>
                <th class="px-6 py-4 text-right font-semibold">CLR</th>
                <th class="px-6 py-4 text-right font-semibold">Water %</th>
              </tr>
            </thead>
            <tbody>
              <% rccData.forEach((item, index) => { %>
                <tr class="<%= index % 2 === 0 ? 'bg-white' : 'bg-gray-50' %> hover:bg-blue-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-gray-900"><%= item.rcc_name %></td>
                  <td class="px-6 py-4 text-right font-semibold text-green-600"><%= Number(item.total_volume || 0).toFixed(1) %></td>
                  <td class="px-6 py-4 text-right text-gray-700"><%= Number(item.avg_fat || 0).toFixed(1) %></td>
                  <td class="px-6 py-4 text-right text-gray-700"><%= Number(item.avg_snf || 0).toFixed(1) %></td>
                  <td class="px-6 py-4 text-right text-gray-700"><%= Number(item.avg_clr || 0).toFixed(1) %></td>
                  <td class="px-6 py-4 text-right text-gray-700"><%= Number(item.avg_water || 0).toFixed(1) %></td>
                </tr>
              <% }) %>
              
              <% if (!rccData || rccData.length === 0) { %>
                <tr>
                  <td colspan="6" class="px-6 py-12 text-center text-gray-500">No RCC data available</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <!-- Mobile Cards -->
        <div class="lg:hidden space-y-4">
          <% rccData.forEach((item) => { %>
            <div class="modern-card bg-white p-6">
              <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-semibold text-gray-900"><%= item.rcc_name %></h3>
                <span class="text-xl font-bold text-green-600"><%= Number(item.total_volume || 0).toFixed(1) %> L</span>
              </div>
              <div class="grid grid-cols-2 gap-4">
                <div class="text-center p-3 bg-blue-50 rounded-lg">
                  <div class="text-lg font-semibold text-blue-600"><%= Number(item.avg_fat || 0).toFixed(1) %>%</div>
                  <div class="text-sm text-gray-600">Fat</div>
                </div>
                <div class="text-center p-3 bg-green-50 rounded-lg">
                  <div class="text-lg font-semibold text-green-600"><%= Number(item.avg_snf || 0).toFixed(1) %>%</div>
                  <div class="text-sm text-gray-600">SNF</div>
                </div>
                <div class="text-center p-3 bg-purple-50 rounded-lg">
                  <div class="text-lg font-semibold text-purple-600"><%= Number(item.avg_clr || 0).toFixed(1) %></div>
                  <div class="text-sm text-gray-600">CLR</div>
                </div>
                <div class="text-center p-3 bg-orange-50 rounded-lg">
                  <div class="text-lg font-semibold text-orange-600"><%= Number(item.avg_water || 0).toFixed(1) %>%</div>
                  <div class="text-sm text-gray-600">Water</div>
                </div>
              </div>
            </div>
          <% }) %>
          
          <% if (!rccData || rccData.length === 0) { %>
            <div class="modern-card bg-white p-12 text-center">
              <div class="text-gray-500 text-lg">No RCC data available</div>
            </div>
          <% } %>
        </div>
      </div>

      <!-- CPP Data -->
      <div class="mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Collection Points (CPP)</h2>
        
        <!-- Desktop Table -->
        <div class="hidden lg:block data-table bg-white">
          <table class="w-full">
            <thead class="table-header">
              <tr>
                <th class="px-6 py-4 text-left font-semibold">CPP Name</th>
                <th class="px-6 py-4 text-right font-semibold">Volume (L)</th>
                <th class="px-6 py-4 text-right font-semibold">Fat %</th>
                <th class="px-6 py-4 text-right font-semibold">SNF %</th>
                <th class="px-6 py-4 text-right font-semibold">CLR</th>
                <th class="px-6 py-4 text-right font-semibold">Water %</th>
              </tr>
            </thead>
            <tbody>
              <% cppData.forEach((item, index) => { %>
                <tr class="<%= index % 2 === 0 ? 'bg-white' : 'bg-gray-50' %> hover:bg-green-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-gray-900"><%= item.cpp_name %></td>
                  <td class="px-6 py-4 text-right font-semibold text-green-600"><%= Number(item.total_volume || 0).toFixed(1) %></td>
                  <td class="px-6 py-4 text-right text-gray-700"><%= Number(item.avg_fat || 0).toFixed(1) %></td>
                  <td class="px-6 py-4 text-right text-gray-700"><%= Number(item.avg_snf || 0).toFixed(1) %></td>
                  <td class="px-6 py-4 text-right text-gray-700"><%= Number(item.avg_clr || 0).toFixed(1) %></td>
                  <td class="px-6 py-4 text-right text-gray-700"><%= Number(item.avg_water || 0).toFixed(1) %></td>
                </tr>
              <% }) %>
              
              <% if (!cppData || cppData.length === 0) { %>
                <tr>
                  <td colspan="6" class="px-6 py-12 text-center text-gray-500">No CPP data available</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <!-- Mobile Cards -->
        <div class="lg:hidden space-y-4">
          <% cppData.forEach((item) => { %>
            <div class="modern-card bg-white p-6">
              <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-semibold text-gray-900"><%= item.cpp_name %></h3>
                <span class="text-xl font-bold text-green-600"><%= Number(item.total_volume || 0).toFixed(1) %> L</span>
              </div>
              <div class="grid grid-cols-2 gap-4">
                <div class="text-center p-3 bg-blue-50 rounded-lg">
                  <div class="text-lg font-semibold text-blue-600"><%= Number(item.avg_fat || 0).toFixed(1) %>%</div>
                  <div class="text-sm text-gray-600">Fat</div>
                </div>
                <div class="text-center p-3 bg-green-50 rounded-lg">
                  <div class="text-lg font-semibold text-green-600"><%= Number(item.avg_snf || 0).toFixed(1) %>%</div>
                  <div class="text-sm text-gray-600">SNF</div>
                </div>
                <div class="text-center p-3 bg-purple-50 rounded-lg">
                  <div class="text-lg font-semibold text-purple-600"><%= Number(item.avg_clr || 0).toFixed(1) %></div>
                  <div class="text-sm text-gray-600">CLR</div>
                </div>
                <div class="text-center p-3 bg-orange-50 rounded-lg">
                  <div class="text-lg font-semibold text-orange-600"><%= Number(item.avg_water || 0).toFixed(1) %>%</div>
                  <div class="text-sm text-gray-600">Water</div>
                </div>
              </div>
            </div>
          <% }) %>
          
          <% if (!cppData || cppData.length === 0) { %>
            <div class="modern-card bg-white p-12 text-center">
              <div class="text-gray-500 text-lg">No CPP data available</div>
            </div>
          <% } %>
        </div>
      </div>

    </div>
  </main>

  <%- include('../../../partials/_footer') %>
</body>
</html>


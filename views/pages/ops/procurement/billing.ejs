                      <td class="py-2 pr-4 text-right"><%= Number(cycle.volume || 0).toFixed(1) %></td>
                      <td class="py-2 pr-4 text-right">₹<%= Number(cycle.amount || 0).toFixed(2) %></td>
                      <td class="py-2 pr-4">
                        <% if (cycle.status === 'Paid') { %>
                        <span class="px-2 py-1 rounded bg-green-500/15 text-green-300 text-xs">Paid</span>
                        <% } else if (cycle.status === 'Pending') { %>
                        <span class="px-2 py-1 rounded bg-yellow-500/15 text-yellow-300 text-xs">Pending</span>
                        <% } else { %>
                        <span class="px-2 py-1 rounded bg-slate-600 text-slate-200 text-xs">No Bills</span>
                        <% } %>
                      </td>
                      <td class="py-2 text-right">
                        <a href="/procurement/billing/cpp?month=<%= cycle.month %>&year=<%= cycle.year %>&period=<%= cycle.period %>" class="text-indigo-400 hover:text-indigo-300">View</a>
                      </td>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>

            <!-- RCC -->
            <div class="bg-slate-800 border border-slate-700 rounded-lg shadow p-6">
              <div class="flex items-center justify-between mb-4">
                <h2 class="text-xl font-semibold flex items-center">
                  <span class="mr-2 inline-flex w-7 h-7 rounded bg-yellow-500/20 text-yellow-300 items-center justify-center">
                    <!-- Building icon -->
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="3" y="7" width="18" height="14" rx="2"/>
                      <path d="M7 7V3h10v4"/>
                      <path d="M7 12h2M11 12h2M15 12h2M7 16h2M11 16h2M15 16h2"/>
                    </svg>
                  </span>
                  RCC
                </h2>
                <a href="/procurement/billing/rcc" class="text-indigo-400 hover:text-indigo-300 text-sm">Go to page</a>
              </div>
              <div>
                <table class="w-full text-sm table-fixed">
                  <thead class="text-slate-300">
                    <tr>
                      <th class="text-left py-2 pr-4">Cycle</th>
                      <th class="text-right py-2 pr-4">Volume (L)</th>
                      <th class="text-right py-2 pr-4">Amount (₹)</th>
                      <th class="text-left py-2 pr-4">Billing Status</th>
                      <th class="text-right py-2">Action</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-slate-700">
                    <% (rccCycles || []).forEach(function(cycle){ %>
                    <tr>
                      <td class="py-2 pr-4"><%= cycle.label %></td>
                      <td class="py-2 pr-4 text-right"><%= Number(cycle.volume || 0).toFixed(1) %></td>
                      <td class="py-2 pr-4 text-right">₹<%= Number(cycle.amount || 0).toFixed(2) %></td>
                      <td class="py-2 pr-4">
                        <% if (cycle.status === 'Paid') { %>
                        <span class="px-2 py-1 rounded bg-green-500/15 text-green-300 text-xs">Paid</span>
                        <% } else if (cycle.status === 'Pending') { %>
                        <span class="px-2 py-1 rounded bg-yellow-500/15 text-yellow-300 text-xs">Pending</span>
                        <% } else { %>
                        <span class="px-2 py-1 rounded bg-slate-600 text-slate-200 text-xs">No Bills</span>
                        <% } %>
                      </td>
                      <td class="py-2 text-right">
                        <a href="/procurement/billing/rcc?month=<%= cycle.month %>&year=<%= cycle.year %>&period=<%= cycle.period %>" class="text-indigo-400 hover:text-indigo-300">View</a>
                      </td>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>

            <!-- MP -->
            <div class="bg-slate-800 border border-slate-700 rounded-lg shadow p-6">
              <div class="flex items-center justify-between mb-4">
                <h2 class="text-xl font-semibold flex items-center">
                  <span class="mr-2 inline-flex w-7 h-7 rounded bg-purple-500/20 text-purple-300 items-center justify-center">
                    <!-- Factory icon -->
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M3 21V9l6 4V9l6 4V9l6 4v8H3z"/>
                      <path d="M7 21v-3M11 21v-3M15 21v-3M19 21v-3"/>
                      <path d="M14 3h4v4h-4z"/>
                    </svg>
                  </span>
                  MP
                </h2>
                <a href="/procurement/billing/mp" class="text-indigo-400 hover:text-indigo-300 text-sm">Go to page</a>
              </div>
              <div>
                <table class="w-full text-sm table-fixed">
                  <thead class="text-slate-300">
                    <tr>
                      <th class="text-left py-2 pr-4">Cycle</th>
                      <th class="text-right py-2 pr-4">Volume (L)</th>
                      <th class="text-right py-2 pr-4">Amount (₹)</th>
                      <th class="text-left py-2 pr-4">Billing Status</th>
                      <th class="text-right py-2">Action</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-slate-700">
                    <% (mpCycles || []).forEach(function(cycle){ %>
                    <tr>
                      <td class="py-2 pr-4"><%= cycle.label %></td>
                      <td class="py-2 pr-4 text-right"><%= Number(cycle.volume || 0).toFixed(1) %></td>
                      <td class="py-2 pr-4 text-right">₹<%= Number(cycle.amount || 0).toFixed(2) %></td>
                      <td class="py-2 pr-4">
                        <% if (cycle.status === 'Paid') { %>
                        <span class="px-2 py-1 rounded bg-green-500/15 text-green-300 text-xs">Paid</span>
                        <% } else if (cycle.status === 'Pending') { %>
                        <span class="px-2 py-1 rounded bg-yellow-500/15 text-yellow-300 text-xs">Pending</span>
                        <% } else { %>
                        <span class="px-2 py-1 rounded bg-slate-600 text-slate-200 text-xs">No Bills</span>
                        <% } %>
                      </td>
                      <td class="py-2 text-right">
                        <a href="/procurement/billing/mp?month=<%= cycle.month %>&year=<%= cycle.year %>&period=<%= cycle.period %>" class="text-indigo-400 hover:text-indigo-300">View</a>
                      </td>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </section>
      </main>
    </div>
    <script>
      // Force dark mode for this page
      document.documentElement.classList.add('dark');
    </script>
    <script src="/assets/js/main.js" defer></script>
  </body>
</html>

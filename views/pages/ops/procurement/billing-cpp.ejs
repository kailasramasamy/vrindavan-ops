<!DOCTYPE html>
<html lang="en">
  <%- include('../../../partials/_head', { seo }) %>
  <body class="bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 antialiased">
    <div class="min-h-dvh flex flex-col">
      <%- include('../../../partials/_subnav', { section: 'Procurement', subsection: 'Billing', page: 'CPP', user }) %>
      
      <main class="flex-1 bg-white dark:bg-gray-900">
        <section class="max-w-7xl mx-auto px-4 py-10">

          <div class="flex items-center justify-between mb-8">
            <div>
              <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">Collection Points Billing</h1>
              <p class="text-gray-600 dark:text-gray-300 mt-2">Manage CPP level billing and aggregations</p>
            </div>
            <div class="flex items-center space-x-2">
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <span class="text-sm text-gray-600 dark:text-gray-300">Active Level</span>
            </div>
          </div>
          
          <!-- Filters -->
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 p-6 mb-8">
            <form method="get" action="/procurement/billing/cpp" class="grid grid-cols-1 md:grid-cols-4 gap-4">
              <div>
                <label class="block text-sm font-semibold mb-2 text-gray-700 dark:text-gray-300">Year</label>
                <select name="year" class="w-full border border-gray-300 dark:border-gray-600 rounded p-2 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700" onchange="this.form.submit()">
                  <% const currentYear = new Date().getFullYear(); for(let y = currentYear + 1; y >= 2020; y--) { %>
                    <option value="<%= y %>" <%= Number(year) === y ? 'selected' : '' %>><%= y %></option>
                  <% } %>
                </select>
              </div>
              <div>
                <label class="block text-sm font-semibold mb-2 text-gray-700 dark:text-gray-300">Month</label>
                <select name="month" class="w-full border border-gray-300 dark:border-gray-600 rounded p-2 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700" onchange="this.form.submit()">
                  <% for(let i = 1; i <= 12; i++) { %>
                    <option value="<%= i %>" <%= Number(month) === i ? 'selected' : '' %>>
                      <%= new Date(2024, i-1).toLocaleString('default', { month: 'long' }) %>
                    </option>
                  <% } %>
                </select>
              </div>
              <div>
                <label class="block text-sm font-semibold mb-2 text-gray-700 dark:text-gray-300">Period</label>
                <select name="period" class="w-full border border-gray-300 dark:border-gray-600 rounded p-2 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700" onchange="this.form.submit()">
                  <option value="H1" <%= period === 'H1' ? 'selected' : '' %>>H1 (1-15)</option>
                  <option value="H2" <%= period === 'H2' ? 'selected' : '' %>>H2 (16-31)</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-semibold mb-2 text-gray-700 dark:text-gray-300">Milk Type</label>
                <select name="milkType" class="w-full border border-gray-300 dark:border-gray-600 rounded p-2 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700" onchange="this.form.submit()">
                  <option value="all" <%= (milkType || 'all') === 'all' ? 'selected' : '' %>>All</option>
                  <option value="A1" <%= milkType === 'A1' ? 'selected' : '' %>>A1</option>
                  <option value="A2" <%= milkType === 'A2' ? 'selected' : '' %>>A2</option>
                  <option value="Buffalo" <%= milkType === 'Buffalo' ? 'selected' : '' %>>Buffalo</option>
                </select>
              </div>
              
            </form>
          </div>

          <!-- Error Message -->
          <% if (typeof error !== 'undefined' && error) { %>
            <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4 mb-6">
              <p class="text-red-800 dark:text-red-300"><%= error %></p>
            </div>
          <% } %>

          <!-- Summary Cards -->
          <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 p-6">
              <div class="flex items-center">
                <div class="w-10 h-10 bg-green-100 dark:bg-green-900/30 rounded-lg flex items-center justify-center mr-3">
                  <svg class="w-5 h-5 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-gray-600 dark:text-gray-300">Total CPPs</p>
                  <p class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= cppData.summary.count %></p>
                </div>
              </div>
            </div>
            
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 p-6">
              <div class="flex items-center">
                <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center mr-3">
                  <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-gray-600 dark:text-gray-300">Total Volume</p>
                  <p class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= cppData.summary.totalQty.toFixed(1) %>L</p>
                </div>
              </div>
            </div>
            
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 p-6">
              <div class="flex items-center">
                <div class="w-10 h-10 bg-yellow-100 dark:bg-yellow-900/30 rounded-lg flex items-center justify-center mr-3">
                  <svg class="w-5 h-5 text-yellow-600 dark:text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-gray-600 dark:text-gray-300">Total Amount</p>
                  <p class="text-2xl font-bold text-gray-900 dark:text-gray-100">₹<%= Number(cppData.summary.totalAmount || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></p>
                </div>
              </div>
            </div>
            
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 p-6">
              <div class="flex items-center">
                <div class="w-10 h-10 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center mr-3">
                  <svg class="w-5 h-5 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-gray-600 dark:text-gray-300">Avg per CPP</p>
                  <p class="text-2xl font-bold text-gray-900 dark:text-gray-100">₹<%= cppData.summary.count > 0 ? Number(cppData.summary.totalAmount / cppData.summary.count).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) : '0.00' %></p>
                </div>
              </div>
            </div>
          </div>

          <!-- Payment Breakup Section -->
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 p-6 mb-8">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100">Payment Breakup</h2>
              <div id="paymentBreakupActions"></div>
            </div>
            <div id="paymentBreakupContent">
              <div class="flex items-center justify-center py-8">
                <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
                <span class="ml-3 text-gray-600 dark:text-gray-300">Loading payment breakup...</span>
              </div>
            </div>
          </div>

          <!-- CPP Data Table -->
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 p-6">
            <div class="flex justify-between items-center mb-6">
              <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100">Collection Point Details</h2>
              <span class="px-3 py-1 bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300 rounded-full text-sm">
                <%= cppData.summary.count %> CPPs
              </span>
            </div>

            <% if (cppData.data.length > 0) { %>
              <!-- Desktop Table View -->
              <div class="overflow-x-auto" style="display: none;" id="desktop-table">
                <table class="w-full text-sm">
                  <thead class="bg-gray-50 dark:bg-gray-800">
                    <tr>
                      <th class="px-4 py-3 text-left font-semibold text-gray-900 dark:text-gray-100">CPP Name</th>
                      <th class="px-4 py-3 text-left font-semibold text-gray-900 dark:text-gray-100">RCC</th>
                      <th class="px-4 py-3 text-right font-semibold text-gray-900 dark:text-gray-100">Qty (L)</th>
                      <th class="px-4 py-3 text-right font-semibold text-gray-900 dark:text-gray-100">Avg Fat</th>
                      <th class="px-4 py-3 text-right font-semibold text-gray-900 dark:text-gray-100">Avg SNF</th>
                      <th class="px-4 py-3 text-right font-semibold text-gray-900 dark:text-gray-100">Rate</th>
                      <th class="px-4 py-3 text-right font-semibold text-gray-900 dark:text-gray-100">Milk Cost</th>
                      <th class="px-4 py-3 text-right font-semibold text-gray-900 dark:text-gray-100">Salary</th>
                      <th class="px-4 py-3 text-right font-semibold text-gray-900 dark:text-gray-100">Amount</th>
                      <th class="px-4 py-3 text-center font-semibold text-gray-900 dark:text-gray-100">Billing Status</th>
                      <th class="px-4 py-3 text-center font-semibold text-gray-900 dark:text-gray-100">Payment Status</th>
                      <th class="px-4 py-3 text-center font-semibold text-gray-900 dark:text-gray-100">Payment Date</th>
                    </tr>
                  </thead>
                  <tbody class="bg-white dark:bg-gray-900">
                    <% cppData.data.forEach(cpp => { %>
                      <tr class="border-t border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800">
                        <td class="px-4 py-3 text-gray-900 dark:text-gray-100">
                          <div class="font-medium"><%= cpp.name %></div>
                          <div class="text-xs text-gray-500 dark:text-gray-400"><%= cpp.milk_type %></div>
                          <% if (cpp.village) { %>
                          <div class="text-xs text-gray-500 dark:text-gray-400">Village: <%= cpp.village %></div>
                          <% } %>
                        </td>
                        <td class="px-4 py-3 text-gray-900 dark:text-gray-100"><%= cpp.rcc_name || '-' %></td>
                        <td class="px-4 py-3 text-right text-gray-900 dark:text-gray-100"><%= cpp.total_qty ? Number(cpp.total_qty).toFixed(1) : '0.0' %></td>
                        <td class="px-4 py-3 text-right text-gray-900 dark:text-gray-100"><%= cpp.avg_fat ? Number(cpp.avg_fat).toFixed(1) : '-' %></td>
                        <td class="px-4 py-3 text-right text-gray-900 dark:text-gray-100"><%= cpp.avg_snf ? Number(cpp.avg_snf).toFixed(1) : '-' %></td>
                        <td class="px-4 py-3 text-right text-gray-900 dark:text-gray-100">₹<%= cpp.rate ? Number(cpp.rate).toFixed(2) : '0.00' %></td>
                        <td class="px-4 py-3 text-right text-gray-900 dark:text-gray-100">₹<%= Number(cpp.milkCost || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                        <td class="px-4 py-3 text-right text-gray-900 dark:text-gray-100">₹<%= Number(cpp.salary || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                        <td class="px-4 py-3 text-right font-semibold text-gray-900 dark:text-gray-100">₹<%= Number(cpp.amount || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                        <td class="px-4 py-3 text-center">
                          <% 
                            const billingStatus = cpp.billing_status || 'Pending';
                            const isBillingCompleted = billingStatus.toLowerCase() === 'completed' || billingStatus.toLowerCase() === 'done' || billingStatus.toLowerCase() === 'paid';
                            const billingClass = isBillingCompleted ? 'bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300' : 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-300';
                          %>
                          <span class="px-2 py-1 text-xs rounded-full <%= billingClass %>">
                            <%= billingStatus %>
                          </span>
                        </td>
                        <td class="px-4 py-3 text-center">
                          <% 
                            const paymentStatus = cpp.payment_status || 'Pending';
                            const isPaymentCompleted = paymentStatus.toLowerCase() === 'completed' || paymentStatus.toLowerCase() === 'done' || paymentStatus.toLowerCase() === 'paid';
                            const paymentClass = isPaymentCompleted ? 'bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300' : 'bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-300';
                          %>
                          <span class="px-2 py-1 text-xs rounded-full <%= paymentClass %>">
                            <%= paymentStatus %>
                          </span>
                        </td>
                        <td class="px-4 py-3 text-center text-sm text-gray-600 dark:text-gray-400">
                          <%= cpp.payment_date ? new Date(cpp.payment_date).toISOString().split('T')[0] : '-' %>
                        </td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>

              <!-- Mobile Card View -->
              <div class="space-y-4" style="display: block;" id="mobile-cards">
                <% cppData.data.forEach(cpp => { %>
                  <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4 shadow-sm">
                    <!-- CPP Header -->
                    <div class="flex items-center justify-between mb-3">
                      <div class="flex items-center">
                        <div class="w-10 h-10 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center mr-3">
                          <svg class="w-5 h-5 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                          </svg>
                        </div>
                        <div>
                          <h3 class="font-semibold text-gray-900 dark:text-gray-100"><%= cpp.name %></h3>
                          <p class="text-sm text-gray-500 dark:text-gray-400"><%= cpp.milk_type %></p>
                        </div>
                      </div>
                      <div class="text-right">
                        <div class="text-lg font-bold text-green-600 dark:text-green-400">₹<%= Number(cpp.amount || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></div>
                        <div class="text-xs text-gray-500 dark:text-gray-400">Total Amount</div>
                      </div>
                    </div>

                    <!-- CPP Details Grid -->
                    <div class="grid grid-cols-2 gap-3 text-sm">
                      <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-3">
                        <div class="text-gray-600 dark:text-gray-300 text-xs uppercase tracking-wide">Village</div>
                        <div class="font-medium text-gray-900 dark:text-gray-100"><%= cpp.village || '-' %></div>
                      </div>
                      <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-3">
                        <div class="text-gray-600 dark:text-gray-300 text-xs uppercase tracking-wide">RCC</div>
                        <div class="font-medium text-gray-900 dark:text-gray-100"><%= cpp.rcc_name || '-' %></div>
                      </div>
                      <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-3">
                        <div class="text-gray-600 dark:text-gray-300 text-xs uppercase tracking-wide">Quantity</div>
                        <div class="font-medium text-gray-900 dark:text-gray-100"><%= cpp.total_qty ? Number(cpp.total_qty).toFixed(1) : '0.0' %>L</div>
                      </div>
                      <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-3">
                        <div class="text-gray-600 dark:text-gray-300 text-xs uppercase tracking-wide">Rate</div>
                        <div class="font-medium text-gray-900 dark:text-gray-100">₹<%= cpp.rate ? Number(cpp.rate).toFixed(2) : '0.00' %></div>
                      </div>
                      <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-3">
                        <div class="text-gray-600 dark:text-gray-300 text-xs uppercase tracking-wide">Avg Fat</div>
                        <div class="font-medium text-gray-900 dark:text-gray-100"><%= cpp.avg_fat ? Number(cpp.avg_fat).toFixed(1) : '-' %>%</div>
                      </div>
                      <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-3">
                        <div class="text-gray-600 dark:text-gray-300 text-xs uppercase tracking-wide">Avg SNF</div>
                        <div class="font-medium text-gray-900 dark:text-gray-100"><%= cpp.avg_snf ? Number(cpp.avg_snf).toFixed(1) : '-' %>%</div>
                      </div>
                      <div class="bg-green-50 dark:bg-green-900/20 rounded-lg p-3">
                        <div class="text-green-600 dark:text-green-400 text-xs uppercase tracking-wide">Milk Cost</div>
                        <div class="font-medium text-green-900 dark:text-green-300">₹<%= Number(cpp.milkCost || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></div>
                      </div>
                      <div class="bg-orange-50 dark:bg-orange-900/20 rounded-lg p-3">
                        <div class="text-orange-600 dark:text-orange-400 text-xs uppercase tracking-wide">Salary</div>
                        <div class="font-medium text-orange-900 dark:text-orange-300">₹<%= Number(cpp.salary || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></div>
                      </div>
                      <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-3">
                        <div class="text-gray-600 dark:text-gray-300 text-xs uppercase tracking-wide">Billing Status</div>
                        <div class="font-medium text-gray-900 dark:text-gray-100">
                          <% 
                            const billingStatus = cpp.billing_status || 'Pending';
                            const isBillingCompleted = billingStatus.toLowerCase() === 'completed' || billingStatus.toLowerCase() === 'done' || billingStatus.toLowerCase() === 'paid';
                            const billingClass = isBillingCompleted ? 'bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300' : 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-300';
                          %>
                          <span class="px-2 py-1 text-xs rounded-full <%= billingClass %>">
                            <%= billingStatus %>
                          </span>
                        </div>
                      </div>
                      <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-3">
                        <div class="text-gray-600 dark:text-gray-300 text-xs uppercase tracking-wide">Payment Status</div>
                        <div class="font-medium text-gray-900 dark:text-gray-100">
                          <% 
                            const paymentStatus = cpp.payment_status || 'Pending';
                            const isPaymentCompleted = paymentStatus.toLowerCase() === 'completed' || paymentStatus.toLowerCase() === 'done' || paymentStatus.toLowerCase() === 'paid';
                            const paymentClass = isPaymentCompleted ? 'bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300' : 'bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-300';
                          %>
                          <span class="px-2 py-1 text-xs rounded-full <%= paymentClass %>">
                            <%= paymentStatus %>
                          </span>
                        </div>
                      </div>
                      <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-3">
                        <div class="text-gray-600 dark:text-gray-300 text-xs uppercase tracking-wide">Payment Date</div>
                        <div class="font-medium text-gray-900 dark:text-gray-100">
                          <%= cpp.payment_date ? new Date(cpp.payment_date).toISOString().split('T')[0] : '-' %>
                        </div>
                      </div>
                    </div>
                  </div>
                <% }); %>
              </div>
            <% } else { %>
              <div class="text-center py-8 text-gray-500 dark:text-gray-400">
                <svg class="w-12 h-12 mx-auto mb-4 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                </svg>
                <p class="text-lg font-medium text-gray-900 dark:text-gray-100">No CPP data available</p>
                <p class="text-sm text-gray-600 dark:text-gray-300">Try adjusting your filters or check back later</p>
              </div>
            <% } %>
          </div>
        </section>
      </main>
    </div>
    <script src="/assets/js/main.js" defer></script>
    <script>
      // Responsive view handling
      function toggleViews() {
        const desktopTable = document.getElementById('desktop-table');
        const mobileCards = document.getElementById('mobile-cards');
        
        if (window.innerWidth >= 1024) {
          // Large screens - show table, hide cards
          if (desktopTable) desktopTable.style.display = 'block';
          if (mobileCards) mobileCards.style.display = 'none';
        } else {
          // Small/medium screens - show cards, hide table
          if (desktopTable) desktopTable.style.display = 'none';
          if (mobileCards) mobileCards.style.display = 'block';
        }
      }
      
      // Load payment breakup data
      async function loadPaymentBreakup() {
        try {
          const urlParams = new URLSearchParams(window.location.search);
          const month = urlParams.get('month') || '<%= month %>';
          const year = urlParams.get('year') || '<%= year %>';
          const period = urlParams.get('period') || '<%= period %>';
          const milkType = urlParams.get('milkType') || '<%= milkType || 'all' %>';
          
          const url = `/api/billing/payment-breakup?month=${month}&year=${year}&period=${period}&entity=cpp&milkType=${encodeURIComponent(milkType)}`;
          const response = await fetch(url);
          const data = await response.json();
          
          if (data.success) {
            displayPaymentBreakup(data.data);
          } else {
            displayPaymentBreakupError(data.error || 'Failed to load payment breakup');
          }
        } catch (error) {
          console.error('Error loading payment breakup:', error);
          displayPaymentBreakupError('Failed to load payment breakup data');
        }
      }
      
      // Display payment breakup data
      function displayPaymentBreakup(data) {
        const content = document.getElementById('paymentBreakupContent');
        
        if (!data.hasBills) {
          const actions = document.getElementById('paymentBreakupActions');
          if (actions) {
            actions.innerHTML = `
              <button id=\"generateCppBillsBtn\" class=\"inline-flex items-center px-3 py-2 rounded bg-blue-600 hover:bg-blue-700 text-white text-sm\">
                <svg class=\"w-4 h-4 mr-2\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 4v16m8-8H4\"/></svg>
                Generate CPP Bills
              </button>
            `;
            const btn = document.getElementById('generateCppBillsBtn');
            if (btn) btn.addEventListener('click', () => triggerBillAction('generate'));
          }
          content.innerHTML = `
            <div class="text-center py-8 text-gray-500 dark:text-gray-400">
              <svg class="w-12 h-12 mx-auto mb-4 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              <p class="text-lg font-medium text-gray-900 dark:text-gray-100">No Bills Generated</p>
              <p class="text-sm text-gray-600 dark:text-gray-300">No bills have been generated for the selected period</p>
            </div>
          `;
          return;
        }
        
        content.innerHTML = `
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <!-- Total Bills -->
            <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg p-4 border border-blue-200 dark:border-blue-800">
              <div class="flex items-start justify-between">
                <div class="flex items-center">
                  <div class="w-9 h-9 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center mr-3">
                    <svg class="w-4 h-4 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-base font-semibold text-blue-900 dark:text-blue-300">Total Bills</h3>
                    <p class="text-xs text-blue-700 dark:text-blue-400">All generated bills</p>
                  </div>
                </div>
                <div class="text-right">
                  <div class="text-2xl font-bold text-blue-900 dark:text-blue-300">₹${Number(data.totalBills.amount || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</div>
                  <div class="text-[11px] font-medium text-blue-800 dark:text-blue-400">${data.totalBills.count} bills</div>
                </div>
              </div>
            </div>
            
            <!-- Pending Bills -->
            <div class="bg-orange-50 dark:bg-orange-900/20 rounded-lg p-4 border border-orange-200 dark:border-orange-800">
              <div class="flex items-start justify-between">
                <div class="flex items-center">
                  <div class="w-9 h-9 bg-orange-100 dark:bg-orange-900/30 rounded-lg flex items-center justify-center mr-3">
                    <svg class="w-4 h-4 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-base font-semibold text-orange-900 dark:text-orange-300">Pending Bills</h3>
                    <p class="text-xs text-orange-700 dark:text-orange-400">Awaiting payment</p>
                  </div>
                </div>
                <div class="text-right">
                  <div class="text-2xl font-bold text-orange-900 dark:text-orange-300">₹${Number(data.pendingBills.amount || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</div>
                  <div class="text-[11px] font-medium text-orange-800 dark:text-orange-400">${data.pendingBills.count} bills</div>
                </div>
              </div>
            </div>
            
            <!-- Paid Bills -->
            <div class="bg-green-50 dark:bg-green-900/20 rounded-lg p-4 border border-green-200 dark:border-green-800">
              <div class="flex items-start justify-between">
                <div class="flex items-center">
                  <div class="w-9 h-9 bg-green-100 dark:bg-green-900/30 rounded-lg flex items-center justify-center mr-3">
                    <svg class="w-4 h-4 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-base font-semibold text-green-900 dark:text-green-300">Paid Bills</h3>
                    <p class="text-xs text-green-700 dark:text-green-400">Payment completed</p>
                  </div>
                </div>
                <div class="text-right">
                  <div class="text-2xl font-bold text-green-900 dark:text-green-300">₹${Number(data.paidBills.amount || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</div>
                  <div class="text-[11px] font-medium text-green-800 dark:text-green-400">${data.paidBills.count} bills</div>
                </div>
              </div>
            </div>
          </div>
        `;
        const actions = document.getElementById('paymentBreakupActions');
        if (actions) {
          actions.innerHTML = `
            <button id=\"regenerateCppBillsBtn\" class=\"inline-flex items-center px-3 py-1.5 rounded bg-orange-600 hover:bg-orange-700 text-white text-xs\">
              <svg class=\"w-4 h-4 mr-1\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\">
                <path d=\"M3 2v6h6\"/>
                <path d=\"M3 10a9 9 0 1 0 3-6.7\"/>
              </svg>
              Regenerate CPP Bills (overwrite)
            </button>
          `;
          const regenBtn = document.getElementById('regenerateCppBillsBtn');
          if (regenBtn) regenBtn.addEventListener('click', () => triggerBillAction('regenerate'));
        }
      }
      
      // Display payment breakup error
      function displayPaymentBreakupError(error) {
        const content = document.getElementById('paymentBreakupContent');
        content.innerHTML = `
          <div class="text-center py-8 text-red-500 dark:text-red-400">
            <svg class="w-12 h-12 mx-auto mb-4 text-red-400 dark:text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <p class="text-lg font-medium text-gray-900 dark:text-gray-100">Error Loading Payment Breakup</p>
            <p class="text-sm text-gray-600 dark:text-gray-300">${error}</p>
          </div>
        `;
      }

      // Run on load and resize
      window.addEventListener('load', () => {
        toggleViews();
        loadPaymentBreakup();
      });
      window.addEventListener('resize', toggleViews);
      async function triggerBillAction(action) {
        const btnId = action === 'regenerate' ? 'regenerateCppBillsBtn' : 'generateCppBillsBtn';
        const btn = document.getElementById(btnId);
        const originalHtml = btn ? btn.innerHTML : '';
        try {
          if (btn) {
            btn.disabled = true;
            btn.classList.add('opacity-70','cursor-not-allowed');
            btn.innerHTML = `
              <svg class="w-4 h-4 mr-2 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 12a9 9 0 1 1-9-9"/>
              </svg>
              ${action === 'regenerate' ? 'Regenerating…' : 'Generating…'}
            `;
          }
          // Show inline progress note
          const content = document.getElementById('paymentBreakupContent');
          if (content) {
            const note = document.createElement('div');
            note.id = 'billProgressNote';
            note.className = 'mt-2 text-xs text-slate-500 dark:text-slate-400';
            note.textContent = `${action === 'regenerate' ? 'Regenerating' : 'Generating'} CPP bills for the selected period…`;
            content.prepend(note);
          }

          const body = {
            startDate: '<%= startDate %>',
            endDate: '<%= endDate %>',
            periodType: '<%= period %>'
          };
          const endpoint = action === 'regenerate' ? '/api/bills/regenerate/cpp' : '/api/bills/generate/cpp';
          const res = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
          });
          const result = await res.json();
          if (res.ok && result && result.success !== false) {
            location.reload();
          } else {
            alert((result && result.error) || 'Failed to process bills');
          }
        } catch (err) {
          console.error('Bill action error', err);
          alert('Failed to process bills');
        } finally {
          if (btn) {
            btn.disabled = false;
            btn.classList.remove('opacity-70','cursor-not-allowed');
            btn.innerHTML = originalHtml;
          }
        }
      }
    </script>
    
    <style>
      /* Normalize date input and select styling */
      input[type="date"], select {
        height: 48px;
        font-size: 16px;
        line-height: 1.5;
      }
    </style>
  </body>
</html>

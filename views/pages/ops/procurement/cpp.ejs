                              <i data-lucide="layers" class="w-4 h-4"></i>
                            </button>
                          </div>
                        </td>
                        <td class="p-3">
                          <input type="number" step="any" min="0" class="w-full border rounded p-2 text-slate-900 fat" 
                                 value="<%= existingEntry?.fat || '' %>" 
                                 placeholder="0.0"
                                 <%= (isAccepted && !isEditing) ? 'disabled' : '' %> />
                        </td>
                        <td class="p-3">
                          <input type="number" step="any" min="0" class="w-full border rounded p-2 text-slate-900 snf" 
                                 value="<%= existingEntry?.snf || '' %>" 
                                 placeholder="0.0"
                                 <%= (isAccepted && !isEditing) ? 'disabled' : '' %> />

              inputs.forEach((el) => {
                if (el.dataset.prevValue === undefined) el.dataset.prevValue = el.value;
                el.disabled = false;
              });
              const cancelBtn = container.querySelector('.bulk-cancel-edit');
              if (cancelBtn) cancelBtn.classList.remove('hidden');
            }
            btn.dataset.mode = 'accept';
            btn.classList.remove('btn-warning');
            btn.classList.add('btn-primary');
            const label = btn.querySelector('.label');
            const icon = btn.querySelector('i');
            if (label) label.textContent = 'Accept';
            if (icon) icon.setAttribute('data-lucide', 'check');
            if (typeof lucide !== 'undefined') lucide.createIcons();

            // Update status badge to "Editing" in UI
            const statusBadge = container.querySelector('.bulk-cpp-status');
            if (statusBadge) {
              statusBadge.textContent = 'Editing';
              statusBadge.className = 'inline-flex items-center px-2 py-1 rounded-full text-xs font-medium border bg-yellow-100 text-yellow-700 border-yellow-200 dark:bg-yellow-900/30 dark:text-yellow-300 dark:border-yellow-800 bulk-cpp-status';
            }

            // Also update the matching mobile/desktop card for same CPP
            const allMatchingCards = document.querySelectorAll(`.cpp-bulk-entry-row[data-cpp-id="${cppId}"], .cpp-bulk-entry[data-cpp-id="${cppId}"]`);
            allMatchingCards.forEach(card => {
              if (card !== container) {
                const badge = card.querySelector('.bulk-cpp-status');
                if (badge) {
                  badge.textContent = 'Editing';
                  badge.className = 'inline-flex items-center px-2 py-1 rounded-full text-xs font-medium border bg-yellow-100 text-yellow-700 border-yellow-200 dark:bg-yellow-900/30 dark:text-yellow-300 dark:border-yellow-800 bulk-cpp-status';
                }
                const cardBtn = card.querySelector('.bulk-accept-btn');
                if (cardBtn) {
                  cardBtn.dataset.mode = 'accept';
                  cardBtn.classList.remove('btn-warning');
                  cardBtn.classList.add('btn-primary');
                  const cardLabel = cardBtn.querySelector('.label');
                  const cardIcon = cardBtn.querySelector('i');
                  if (cardLabel) cardLabel.textContent = 'Accept';
                  if (cardIcon) cardIcon.setAttribute('data-lucide', 'check');
                }
                card.querySelectorAll('input, select').forEach((el) => {
                  if (el.dataset.prevValue === undefined) el.dataset.prevValue = el.value;
                  el.disabled = false;
                });
                const cardCancelBtn = card.querySelector('.bulk-cancel-edit');
                if (cardCancelBtn) cardCancelBtn.classList.remove('hidden');
              }
            });
            if (typeof lucide !== 'undefined') lucide.createIcons();

            // Update status to 'editing' in database
            const editDate = bulkDateFilter?.value || bulkDateFilterMobile?.value;
            const editTime = bulkTimeFilter?.value || bulkTimeFilterMobile?.value;
            if (editDate && editTime) {
              fetch('/api/procurement/cpp/entries-status', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ cpp_id: Number(cppId), date: editDate, time: editTime, status: 'editing' })
              }).catch(err => console.error('Failed to update status to editing:', err));
            }
            return;
          }

          // Accept mode
          if (cppId) {
            handleBulkAccept(Number(cppId));
          }
        }

        // Cancel edit handler
        if (e.target.closest('.bulk-cancel-edit')) {
          const cancel = e.target.closest('.bulk-cancel-edit');
          const container = cancel.closest('.cpp-bulk-entry-row, .cpp-bulk-entry');
          const btn = container.querySelector('.bulk-accept-btn');
          const cppIdCancel = btn?.dataset?.cppId;
          if (container && btn) {
            container.querySelectorAll('input, select').forEach((el) => {
              if (el.dataset.prevValue !== undefined) el.value = el.dataset.prevValue;
              el.disabled = true;
            });
            cancel.classList.add('hidden');
            btn.dataset.mode = 'edit';
            btn.classList.remove('btn-primary');
            btn.classList.add('btn-warning');
            const label = btn.querySelector('.label');
            const icon = btn.querySelector('i');
            if (label) label.textContent = 'Edit';
            if (icon) icon.setAttribute('data-lucide', 'edit');

            // Revert status badge to "Accepted"
            const statusBadge = container.querySelector('.bulk-cpp-status');
            if (statusBadge) {
              statusBadge.textContent = 'Accepted';
              statusBadge.className = 'inline-flex items-center px-2 py-1 rounded-full text-xs font-medium border bg-green-100 text-green-700 border-green-200 dark:bg-green-900/30 dark:text-green-300 dark:border-green-800 bulk-cpp-status';
            }

            // Also revert the matching mobile/desktop card
            if (cppIdCancel) {
              const allMatchingCards = document.querySelectorAll(`.cpp-bulk-entry-row[data-cpp-id="${cppIdCancel}"], .cpp-bulk-entry[data-cpp-id="${cppIdCancel}"]`);
              allMatchingCards.forEach(card => {
                if (card !== container) {
                  const badge = card.querySelector('.bulk-cpp-status');
                  if (badge) {
                    badge.textContent = 'Accepted';
                    badge.className = 'inline-flex items-center px-2 py-1 rounded-full text-xs font-medium border bg-green-100 text-green-700 border-green-200 dark:bg-green-900/30 dark:text-green-300 dark:border-green-800 bulk-cpp-status';
                  }
                  card.querySelectorAll('input, select').forEach((el) => {
                    if (el.dataset.prevValue !== undefined) el.value = el.dataset.prevValue;
                    el.disabled = true;
                  });
                  const cardBtn = card.querySelector('.bulk-accept-btn');
                  if (cardBtn) {
                    cardBtn.dataset.mode = 'edit';
                    cardBtn.classList.remove('btn-primary');
                    cardBtn.classList.add('btn-warning');
                    const cardLabel = cardBtn.querySelector('.label');
                    const cardIcon = cardBtn.querySelector('i');
                    if (cardLabel) cardLabel.textContent = 'Edit';
                    if (cardIcon) cardIcon.setAttribute('data-lucide', 'edit');
                  }
                  const cardCancelBtn = card.querySelector('.bulk-cancel-edit');
                  if (cardCancelBtn) cardCancelBtn.classList.add('hidden');
                }
              });
            }

            if (typeof lucide !== 'undefined') lucide.createIcons();

            // Revert status back to 'accepted' in database
            const cancelDate = bulkDateFilter?.value || bulkDateFilterMobile?.value;
            const cancelTime = bulkTimeFilter?.value || bulkTimeFilterMobile?.value;
            if (cppIdCancel && cancelDate && cancelTime) {
              fetch('/api/procurement/cpp/entries-status', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ cpp_id: Number(cppIdCancel), date: cancelDate, time: cancelTime, status: 'accepted' })
              }).catch(() => {});
            }
          }
        }

        // Accept All button handler
        if (e.target.closest('#acceptAllCppBtn')) {
          // Get all CPP entries from both table and card views
          const allCppCards = document.querySelectorAll('.cpp-bulk-entry-row, .cpp-bulk-entry');
          let acceptedCount = 0;
          let errorCount = 0;
          let skippedCount = 0;
          const processedCppIds = new Set();

          async function processAllCpps() {
            for (const cppCard of allCppCards) {
              const cppId = cppCard.dataset.cppId;

              // Skip duplicate desktop/mobile cards for same CPP
              if (processedCppIds.has(cppId)) continue;
              processedCppIds.add(cppId);

              const statusBadge = cppCard.querySelector('.bulk-cpp-status');
              const statusText = statusBadge ? statusBadge.textContent.trim() : '';

              // Skip if already accepted (but NOT if editing)
              if (statusText === 'Accepted') {
                skippedCount++;
                continue;
              }

              try {
                // Call handleBulkAccept but suppress individual toasts
                const milkType = cppCard.querySelector('.bulk-milk-type').value;
                const qty = parseFloat(cppCard.querySelector('.bulk-qty').value) || 0;

                // If no quantity entered, skip silently
                if (qty <= 0) {
                  skippedCount++;
                  continue;
                }

                const fat = parseFloat(cppCard.querySelector('.bulk-fat').value) || 0;
                const snf = parseFloat(cppCard.querySelector('.bulk-snf').value) || 0;
                const water = parseFloat(cppCard.querySelector('.bulk-water').value) || 0;
                const clr = parseFloat(cppCard.querySelector('.bulk-clr').value) || 0;

                const date = bulkDateFilter?.value || bulkDateFilterMobile?.value;
                const time = bulkTimeFilter?.value || bulkTimeFilterMobile?.value;

                // If date/time missing, skip (not an error)
                if (!date || !time) {
                  skippedCount++;
                  continue;
                }

                // Save without showing toast
                await saveBulkCppEntrySilent({
                  cpp_id: Number(cppId),
                  date: date,
                  time: time,
                  milk_type: milkType,
                  qty_litres: qty,
                  fat: fat || null,
                  snf: snf || null,
                  water_pct: water || null,
                  clr: clr || null,
                }, cppCard);

                // Also update the matching mobile/desktop card
                const allMatchingCards = document.querySelectorAll(`.cpp-bulk-entry-row[data-cpp-id="${cppId}"], .cpp-bulk-entry[data-cpp-id="${cppId}"]`);
                allMatchingCards.forEach(card => {
                  if (card !== cppCard) {
                    const badge = card.querySelector('.bulk-cpp-status');
                    if (badge) {
                      badge.textContent = 'Accepted';
                      badge.className = 'inline-flex items-center px-2 py-1 rounded-full text-xs font-medium border bg-green-100 text-green-700 border-green-200 dark:bg-green-900/30 dark:text-green-300 dark:border-green-800 bulk-cpp-status';
                    }
                    const cardBtn = card.querySelector('.bulk-accept-btn');
                    if (cardBtn) {
                      cardBtn.dataset.mode = 'edit';
                      cardBtn.classList.remove('btn-primary');
                      cardBtn.classList.add('btn-warning');
                      const label = cardBtn.querySelector('.label');
                      const icon = cardBtn.querySelector('i');
                      if (label) label.textContent = 'Edit';
                      if (icon) icon.setAttribute('data-lucide', 'edit');
                    }
                    card.querySelectorAll('input, select').forEach(input => input.disabled = true);
                    const cancelBtn = card.querySelector('.bulk-cancel-edit');
                    if (cancelBtn) cancelBtn.classList.add('hidden');
                  }
                });

                acceptedCount++;
              } catch (error) {
                errorCount++;
                console.error(`Error processing CPP ${cppId}:`, error);
              }
            }

            if (typeof lucide !== 'undefined') lucide.createIcons();

            // Show single summary toast
            if (acceptedCount > 0 && errorCount === 0) {
              showSuccessToast(`Successfully accepted ${acceptedCount} CPP${acceptedCount > 1 ? 's' : ''}`);
            } else if (acceptedCount > 0 && errorCount > 0) {
              showWarningToast(`Accepted ${acceptedCount} CPP${acceptedCount > 1 ? 's' : ''}, ${errorCount} failed`);
            } else if (errorCount > 0) {
              showErrorToast(`Failed to accept ${errorCount} CPP${errorCount > 1 ? 's' : ''}`);
            } else if (skippedCount > 0 && acceptedCount === 0 && errorCount === 0) {
              showSuccessToast(`All CPPs already accepted`);
            }
          }

          processAllCpps();
        }
      });

      // Prefill helpers
      async function prefillBulkForCpp(cppCard) {
        try {
          const cppId = cppCard?.dataset?.cppId;
          if (!cppId) return;
          // Skip hidden cards/rows
          if (cppCard.style.display === 'none') return;

          const date = bulkDateFilter?.value || bulkDateFilterMobile?.value;
          const time = bulkTimeFilter?.value || bulkTimeFilterMobile?.value;
          if (!date || !time) return;

          const res = await fetch(`/api/procurement/cpp/entries?cpp_id=${cppId}&date=${date}&time=${time}&_ts=${Date.now()}`);
          if (!res.ok) return;
          const json = await res.json();
          if (!json.ok) return;

          const items = Array.isArray(json.items) ? json.items : [];
          const qtyInput = cppCard.querySelector('.bulk-qty');
          const fatInput = cppCard.querySelector('.bulk-fat');
          const snfInput = cppCard.querySelector('.bulk-snf');
          const waterInput = cppCard.querySelector('.bulk-water');
          const clrInput = cppCard.querySelector('.bulk-clr');

          if (!items.length) {
            // Clear fields and reset to Pending/Accept state
            if (qtyInput) qtyInput.value = '';
            if (fatInput) fatInput.value = '';
            if (snfInput) snfInput.value = '';
            if (waterInput) waterInput.value = '';
            if (clrInput) clrInput.value = '';

            cppCard.querySelectorAll('input, select').forEach(el => el.disabled = false);
            const btn = cppCard.querySelector('.bulk-accept-btn');
            if (btn) {
              btn.dataset.mode = 'accept';
              btn.classList.remove('btn-warning');
              btn.classList.add('btn-primary');
              const label = btn.querySelector('.label');
              const icon = btn.querySelector('i');
              if (label) label.textContent = 'Accept';
              if (icon) icon.setAttribute('data-lucide', 'check');
              if (typeof lucide !== 'undefined') lucide.createIcons();
            }
            const cancelBtn = cppCard.querySelector('.bulk-cancel-edit');
            if (cancelBtn) cancelBtn.classList.add('hidden');
            const statusBadge = cppCard.querySelector('.bulk-cpp-status');
            if (statusBadge) {
              statusBadge.textContent = 'Pending';
              statusBadge.className = 'inline-flex items-center px-2 py-1 rounded-full text-xs font-medium border bg-slate-100 text-slate-600 border-slate-200 dark:bg-gray-800 dark:text-gray-300 dark:border-gray-700 bulk-cpp-status';
            }
            return;
          }

          // Aggregate totals and weighted averages
          let totalQty = 0;
          let wFat = 0, wSnf = 0, wWater = 0, wClr = 0;
          items.forEach(it => {
            const q = Number(it.qty || 0);
            totalQty += q;
            const fat = it.fat != null ? Number(it.fat) : 0;
            const snf = it.snf != null ? Number(it.snf) : 0;
            const water = it.water != null ? Number(it.water) : 0;
            const clr = it.clr != null ? Number(it.clr) : 0;
            wFat += fat * q;
            wSnf += snf * q;
            wWater += water * q;
            wClr += clr * q;
          });

          if (qtyInput) qtyInput.value = totalQty.toFixed(1);
          if (fatInput) fatInput.value = totalQty > 0 ? (wFat / totalQty).toFixed(2) : '';
          if (snfInput) snfInput.value = totalQty > 0 ? (wSnf / totalQty).toFixed(2) : '';
          if (waterInput) waterInput.value = totalQty > 0 ? (wWater / totalQty).toFixed(2) : '';
          if (clrInput) clrInput.value = totalQty > 0 ? (wClr / totalQty).toFixed(2) : '';

          // Disable inputs and switch button to Edit state
          cppCard.querySelectorAll('input, select').forEach(el => el.disabled = true);
          const btn = cppCard.querySelector('.bulk-accept-btn');
          if (btn) {
            btn.dataset.mode = 'edit';
            btn.classList.remove('btn-primary');
            btn.classList.add('btn-warning');
            const label = btn.querySelector('.label');
            const icon = btn.querySelector('i');
            if (label) label.textContent = 'Edit';
            if (icon) icon.setAttribute('data-lucide', 'edit');
            if (typeof lucide !== 'undefined') lucide.createIcons();
          }
          const cancelBtn = cppCard.querySelector('.bulk-cancel-edit');
          if (cancelBtn) cancelBtn.classList.add('hidden');

          // Update status badge
          const statusBadge = cppCard.querySelector('.bulk-cpp-status');
          if (statusBadge) {
            statusBadge.textContent = 'Accepted';
            statusBadge.className = 'inline-flex items-center px-2 py-1 rounded-full text-xs font-medium border bg-green-100 text-green-700 border-green-200 dark:bg-green-900/30 dark:text-green-300 dark:border-green-800 bulk-cpp-status';
          }
        } catch (_) { /* ignore */ }
      }

      async function prefillAllBulkCpp() {
        const cards = document.querySelectorAll('.cpp-bulk-entry-row, .cpp-bulk-entry');
        for (const card of cards) {
          await prefillBulkForCpp(card);
        }
      }

      // Initialize on page load - set daily as default and update filters applied
      const defaultFilterType = 'daily';
      const dailyRadio = document.getElementById('filterTypeDaily');
      if (dailyRadio) {
        dailyRadio.checked = true;
        updateFiltersAppliedIndicator(defaultFilterType);
      }
    }

    // Function to fetch monthly data
    async function fetchMonthlyData(cppId, month, year, period) {
      try {
        const response = await fetch(`/api/procurement/cpp/monthly-data?cpp_id=${cppId}&month=${month}&year=${year}&period=${period}`);
        const data = await response.json();
        
        if (data.success) {
          displayMonthlyData(data.data);
        } else {
          showErrorToast('Failed to load monthly data');
        }
      } catch (error) {
        console.error('Error fetching monthly data:', error);
        showErrorToast('Error loading monthly data');
      }
    }

    // Function to display monthly data
    function displayMonthlyData(data) {
      const tbody = document.getElementById('monthlyDataTableBody');
      const cardsContainer = document.getElementById('monthlyDataCards');
      const chartCanvas = document.getElementById('monthlyTrendChart');
      
      if (!tbody || !cardsContainer) return;

      // Clear both containers
      tbody.innerHTML = '';
      cardsContainer.innerHTML = '';

      if (!data || data.length === 0) {
        // Show chart placeholder
        const chartPlaceholder = document.getElementById('monthlyChartPlaceholder');
        if (chartPlaceholder) {
          chartPlaceholder.classList.remove('hidden');
        }
        
        // Destroy chart if it exists
        if (window.monthlyChart && window.monthlyChart.destroy) {
          window.monthlyChart.destroy();
          window.monthlyChart = null;
        }
        
        tbody.innerHTML = `
          <tr>
            <td colspan="8" class="px-4 py-8 text-center text-gray-500 dark:text-gray-400">
              No data available for the selected period
            </td>
          </tr>
        `;
        cardsContainer.innerHTML = `
          <div class="text-center py-8 text-gray-500 dark:text-gray-400">
            <div class="bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-6">
              <div class="flex items-center justify-center mb-2">
                <i data-lucide="info" class="w-6 h-6 text-gray-400 dark:text-gray-500 mr-2"></i>
                <h3 class="text-lg font-semibold text-gray-600 dark:text-gray-300">No Data Available</h3>
              </div>
              <p class="text-gray-500 dark:text-gray-400">No data available for the selected period</p>
            </div>
          </div>
        `;
        return;
      }
      
      // Hide chart placeholder when data exists
      const chartPlaceholder = document.getElementById('monthlyChartPlaceholder');
      if (chartPlaceholder) {
        chartPlaceholder.classList.add('hidden');
      }

      data.forEach(dayData => {
        const morningStatus = dayData.morning?.status || 'No data';
        const eveningStatus = dayData.evening?.status || 'No data';
        const morningQty = dayData.morning?.total_qty || 0;
        const eveningQty = dayData.evening?.total_qty || 0;
        const totalQty = parseFloat(morningQty) + parseFloat(eveningQty);
        
        // Calculate weighted averages
        const morningWeight = parseFloat(morningQty) || 0;
        const eveningWeight = parseFloat(eveningQty) || 0;
        const totalWeight = morningWeight + eveningWeight;
        
        let avgFat = 0, avgSnf = 0, avgWater = 0, avgClr = 0;
        if (totalWeight > 0) {
          const morningFat = parseFloat(dayData.morning?.avg_fat || 0) * morningWeight;
          const eveningFat = parseFloat(dayData.evening?.avg_fat || 0) * eveningWeight;
          avgFat = (morningFat + eveningFat) / totalWeight;
          
          const morningSnf = parseFloat(dayData.morning?.avg_snf || 0) * morningWeight;
          const eveningSnf = parseFloat(dayData.evening?.avg_snf || 0) * eveningWeight;
          avgSnf = (morningSnf + eveningSnf) / totalWeight;
          
          const morningWater = parseFloat(dayData.morning?.avg_water || 0) * morningWeight;
          const eveningWater = parseFloat(dayData.evening?.avg_water || 0) * eveningWeight;
          avgWater = (morningWater + eveningWater) / totalWeight;
          
          const morningClr = parseFloat(dayData.morning?.avg_clr || 0) * morningWeight;
          const eveningClr = parseFloat(dayData.evening?.avg_clr || 0) * eveningWeight;
          avgClr = (morningClr + eveningClr) / totalWeight;
        }

        // Desktop table row
        const row = document.createElement('tr');
        row.className = 'border-t border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800';
        const morningPillClass = morningStatus === 'accepted' ? 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 border-green-200 dark:border-green-700' : morningStatus === 'pending' ? 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-300 border-yellow-200 dark:border-yellow-700' : 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 border-gray-200 dark:border-gray-600';
        const eveningPillClass = eveningStatus === 'accepted' ? 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 border-green-200 dark:border-green-700' : eveningStatus === 'pending' ? 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-300 border-yellow-200 dark:border-yellow-700' : 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 border-gray-200 dark:border-gray-600';
        row.innerHTML = `
          <td class="px-4 py-3 font-medium text-gray-900 dark:text-gray-100">${dayData.date}</td>
          <td class="px-4 py-3 text-center">
            <div class="flex flex-col items-center">
              <span class="text-sm font-medium text-gray-900 dark:text-gray-100">${parseFloat(morningQty).toFixed(1)}L</span>
              <span class="text-xs px-2 py-1 rounded-full border ${morningPillClass}">
                ${morningStatus}
              </span>
            </div>
          </td>
          <td class="px-4 py-3 text-center">
            <div class="flex flex-col items-center">
              <span class="text-sm font-medium text-gray-900 dark:text-gray-100">${parseFloat(eveningQty).toFixed(1)}L</span>
              <span class="text-xs px-2 py-1 rounded-full border ${eveningPillClass}">
                ${eveningStatus}
              </span>
            </div>
          </td>
          <td class="px-4 py-3 text-center font-semibold text-gray-900 dark:text-gray-100">${totalQty.toFixed(1)}L</td>
          <td class="px-4 py-3 text-center text-gray-900 dark:text-gray-100">${avgFat.toFixed(1)}%</td>
          <td class="px-4 py-3 text-center text-gray-900 dark:text-gray-100">${avgSnf.toFixed(1)}%</td>
          <td class="px-4 py-3 text-center text-gray-900 dark:text-gray-100">${avgWater.toFixed(1)}%</td>
          <td class="px-4 py-3 text-center text-gray-900 dark:text-gray-100">${avgClr.toFixed(1)}</td>
        `;
        tbody.appendChild(row);

        // Mobile card
        const card = document.createElement('div');
        card.className = 'bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4 shadow-sm';
        const mobileMorningPillClass = morningStatus === 'accepted' ? 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 border-green-200 dark:border-green-700' : morningStatus === 'pending' ? 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-300 border-yellow-200 dark:border-yellow-700' : 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 border-gray-200 dark:border-gray-600';
        const mobileEveningPillClass = eveningStatus === 'accepted' ? 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 border-green-200 dark:border-green-700' : eveningStatus === 'pending' ? 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-300 border-yellow-200 dark:border-yellow-700' : 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 border-gray-200 dark:border-gray-600';
        card.innerHTML = `
          <div class="flex items-center justify-between mb-4">
            <h4 class="text-lg font-semibold text-gray-900 dark:text-gray-100">${dayData.date}</h4>
            <div class="text-right">
              <div class="text-sm font-medium text-gray-600 dark:text-gray-300">Total</div>
              <div class="text-lg font-bold text-blue-600 dark:text-blue-400">${totalQty.toFixed(1)}L</div>
            </div>
          </div>
          
          <div class="grid grid-cols-2 gap-4 mb-4">
            <!-- Morning Data -->
            <div class="bg-orange-50 dark:bg-orange-900/20 border border-orange-200 dark:border-orange-800 rounded-lg p-3">
              <div class="flex items-center mb-2">
                <svg class="w-4 h-4 mr-2 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
                </svg>
                <span class="text-sm font-semibold text-orange-800 dark:text-orange-300">Morning</span>
              </div>
              <div class="text-lg font-bold text-orange-700 dark:text-orange-300 mb-1">${parseFloat(morningQty).toFixed(1)}L</div>
              <span class="text-xs px-2 py-1 rounded-full border ${mobileMorningPillClass}">
                ${morningStatus}
              </span>
            </div>
            
            <!-- Evening Data -->
            <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-3">
              <div class="flex items-center mb-2">
                <svg class="w-4 h-4 mr-2 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
                </svg>
                <span class="text-sm font-semibold text-blue-800 dark:text-blue-300">Evening</span>
              </div>
              <div class="text-lg font-bold text-blue-700 dark:text-blue-300 mb-1">${parseFloat(eveningQty).toFixed(1)}L</div>
              <span class="text-xs px-2 py-1 rounded-full border ${mobileEveningPillClass}">
                ${eveningStatus}
              </span>
            </div>
          </div>
          
          <!-- Quality Parameters -->
          <div class="grid grid-cols-2 gap-3 text-sm">
            <div class="flex justify-between">
              <span class="text-gray-600 dark:text-gray-300">Fat:</span>
              <span class="font-medium text-gray-900 dark:text-gray-100">${avgFat.toFixed(1)}%</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600 dark:text-gray-300">SNF:</span>
              <span class="font-medium text-gray-900 dark:text-gray-100">${avgSnf.toFixed(1)}%</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600 dark:text-gray-300">Water:</span>
              <span class="font-medium text-gray-900 dark:text-gray-100">${avgWater.toFixed(1)}%</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600 dark:text-gray-300">CLR:</span>
              <span class="font-medium text-gray-900 dark:text-gray-100">${avgClr.toFixed(1)}</span>
            </div>
          </div>
        `;
        cardsContainer.appendChild(card);
      });

      // Build chart data (Morning, Evening, Total) and render
      try {
        if (chartCanvas && typeof Chart !== 'undefined') {
          // Prepare arrays
          const labels = data.map(d => {
            try {
              const parts = (d.date || '').split('-');
              if (parts.length === 3) {
                return `${parts[2]}-${parts[1]}`; // DD-MM
              }
              const dt = new Date(d.date);
              const dd = String(dt.getDate()).padStart(2,'0');
              const mm = String(dt.getMonth()+1).padStart(2,'0');
              return `${dd}-${mm}`;
            } catch(_) { return d.date; }
          });
          const morningArr = data.map(d => parseFloat(d.morning?.total_qty || 0));
          const eveningArr = data.map(d => parseFloat(d.evening?.total_qty || 0));
          const totalArr = data.map((_, i) => (morningArr[i] + eveningArr[i]));

          // Recreate chart each time for simplicity
          if (window.monthlyChart && window.monthlyChart.destroy) {
            window.monthlyChart.destroy();
          }

          // Optional: register datalabels if available
          if (typeof ChartDataLabels !== 'undefined' && Chart && Chart.register) {
            try { Chart.register(ChartDataLabels); } catch(_) {}
          }

          const isDark = document.documentElement.classList.contains('dark');
          const tickColor = isDark ? '#CBD5E1' : '#374151';

          window.monthlyChart = new Chart(chartCanvas.getContext('2d'), {
            type: 'line',
            data: {
              labels,
              datasets: [
                { label: 'Morning', data: morningArr, borderColor: '#F59E0B', backgroundColor: 'rgba(245,158,11,0.15)', tension: 0.3, fill: true, borderWidth: 2 },
                { label: 'Evening', data: eveningArr, borderColor: '#3B82F6', backgroundColor: 'rgba(59,130,246,0.15)', tension: 0.3, fill: true, borderWidth: 2 },
                { label: 'Total', data: totalArr, borderColor: '#10B981', backgroundColor: 'rgba(16,185,129,0.15)', tension: 0.3, fill: true, borderWidth: 3 }
              ]
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              plugins: {
                legend: { labels: { color: tickColor } },
                tooltip: {
                  callbacks: {
                    label: (ctx) => `${ctx.dataset.label}: ${Number(ctx.parsed.y||0).toFixed(1)} L`
                  },
                  titleColor: tickColor,
                  bodyColor: tickColor,
                  backgroundColor: isDark ? 'rgba(15,23,42,0.9)' : 'rgba(255,255,255,0.95)',
                  borderColor: isDark ? 'rgba(148,163,184,0.25)' : 'rgba(148,163,184,0.5)',
                  borderWidth: 1
                },
                datalabels: {
                  color: tickColor,
                  align: 'top',
                  anchor: 'end',
                  offset: 4,
                  formatter: (v) => (Number(v)||0).toFixed(1)
                }
              },
              scales: {
                x: { ticks: { color: tickColor } },
                y: { ticks: { color: tickColor, callback: (v)=> `${v} L` }, grid: { color: isDark ? 'rgba(148,163,184,0.2)' : 'rgba(0,0,0,0.08)' } }
              }
            }
          });
        }
      } catch (e) { console.error('Chart render error', e); }
    }

    // Multi-Container Entry Modal Functions
    let currentFarmerId = null;
    let currentFarmerName = null;
    let currentTime = null;
    let containerCount = 0;

    // Function to create a container form
    function createContainerForm(containerIndex) {
      return `
        <div class="container-form border border-gray-200 dark:border-gray-700 rounded-lg p-4" data-container-index="${containerIndex}">
          <div class="flex items-center mb-4">
            <h4 class="text-lg font-medium text-gray-900 dark:text-gray-100">Container ${containerIndex + 1}</h4>
          </div>
          
          <div class="grid grid-cols-2 md:flex md:flex-row md:items-start gap-3 md:gap-2">
            <div class="flex flex-col">
              <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Type</label>
              <select title="Type" class="w-full border border-gray-300 dark:border-gray-700 rounded-md p-2 md:p-1 text-sm text-slate-900 dark:text-gray-100 bg-white dark:bg-gray-900 hover:border-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors container-milk-type h-10 md:h-9">
                <option value="A2" selected>A2</option>
                <option value="A1">A1</option>
                <option value="Buffalo">Buffalo</option>
              </select>
            </div>

            <div class="flex flex-col">
              <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Qty</label>
              <input title="Qty" type="number" step="0.1" min="0" class="w-full border border-gray-300 dark:border-gray-700 rounded-md p-2 md:p-1 text-sm text-slate-900 dark:text-gray-100 bg-white dark:bg-gray-900 hover:border-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors container-qty h-10 md:h-9" placeholder="0.0" />
            </div>

            <div class="flex flex-col">
              <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Fat</label>
              <input title="Fat" type="number" step="any" min="0" class="w-full border border-gray-300 dark:border-gray-700 rounded-md p-2 md:p-1 text-sm text-slate-900 dark:text-gray-100 bg-white dark:bg-gray-900 hover:border-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors container-fat h-10 md:h-9" placeholder="0.0" />
            </div>

            <div class="flex flex-col">
              <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">SNF</label>
              <input title="SNF" type="number" step="any" min="0" class="w-full border border-gray-300 dark:border-gray-700 rounded-md p-2 md:p-1 text-sm text-slate-900 dark:text-gray-100 bg-white dark:bg-gray-900 hover:border-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors container-snf h-10 md:h-9" placeholder="0.0" />
            </div>

            <div class="flex flex-col">
              <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Water</label>
              <input title="Water" type="number" step="any" min="0" class="w-full border border-gray-300 dark:border-gray-700 rounded-md p-2 md:p-1 text-sm text-slate-900 dark:text-gray-100 bg-white dark:bg-gray-900 hover:border-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors container-water h-10 md:h-9" placeholder="0.0" />
            </div>

            <div class="flex flex-col">
              <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">CLR</label>
              <input title="CLR" type="number" step="any" min="0" class="w-full border border-gray-300 dark:border-gray-700 rounded-md p-2 md:p-1 text-sm text-slate-900 dark:text-gray-100 bg-white dark:bg-gray-900 hover:border-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors container-clr h-10 md:h-9" placeholder="0.0" />
            </div>

            <div class="md:ml-auto md:self-start">
              ${containerIndex > 1 ? `<button type="button" class="remove-container-btn text-red-600 hover:text-red-800 p-2" data-container-index="${containerIndex}">
                <i data-lucide="trash-2" class="w-4 h-4"></i>
              </button>` : ''}
            </div>
          </div>
        </div>
      `;
    }

    // Function to open multi-container modal
    function openMultiContainerModal(farmerId, farmerName, time) {
      currentFarmerId = farmerId;
      currentFarmerName = farmerName;
      currentTime = time;
      containerCount = 2; // Start with 2 containers
      
      document.getElementById('modalFarmerName').textContent = farmerName;
      
      // Clear existing forms
      const containerForms = document.getElementById('containerForms');
      containerForms.innerHTML = '';
      
      // Add initial 2 containers
      for (let i = 0; i < containerCount; i++) {
        containerForms.insertAdjacentHTML('beforeend', createContainerForm(i));
      }
      
      // Show modal
      document.getElementById('multiContainerModal').classList.remove('hidden');
      
      // Initialize Lucide icons
      if (typeof lucide !== 'undefined') {
        lucide.createIcons();
      }
    }

    // Function to close multi-container modal
    function closeMultiContainerModal() {
      document.getElementById('multiContainerModal').classList.add('hidden');
      currentFarmerId = null;
      currentFarmerName = null;
      currentTime = null;
      containerCount = 0;
    }

    // Function to calculate weighted averages
    function calculateWeightedAverages() {
      const containers = document.querySelectorAll('.container-form');
      let totalQty = 0;
      let weightedFat = 0;
      let weightedSnf = 0;
      let weightedWater = 0;
      let weightedClr = 0;
      let primaryMilkType = 'A2';

      containers.forEach((container, index) => {
        const qty = parseFloat(container.querySelector('.container-qty').value) || 0;
        const fat = parseFloat(container.querySelector('.container-fat').value) || 0;
        const snf = parseFloat(container.querySelector('.container-snf').value) || 0;
        const water = parseFloat(container.querySelector('.container-water').value) || 0;
        const clr = parseFloat(container.querySelector('.container-clr').value) || 0;
        const milkType = container.querySelector('.container-milk-type').value;

        if (qty > 0) {
          totalQty += qty;
          weightedFat += fat * qty;
          weightedSnf += snf * qty;
          weightedWater += water * qty;
          weightedClr += clr * qty;
          
          // Use the milk type from the container with the highest quantity
          if (index === 0 || qty > parseFloat(containers[0].querySelector('.container-qty').value)) {
            primaryMilkType = milkType;
          }
        }
      });

      return {
        totalQty: totalQty,
        avgFat: totalQty > 0 ? weightedFat / totalQty : 0,
        avgSnf: totalQty > 0 ? weightedSnf / totalQty : 0,
        avgWater: totalQty > 0 ? weightedWater / totalQty : 0,
        avgClr: totalQty > 0 ? weightedClr / totalQty : 0,
        milkType: primaryMilkType
      };
    }

    // Function to apply calculated values to the main form
    function applyCalculatedValues(calculated) {
      // Check if we're in mobile view and prioritize farmer cards
      const isMobileView = isMobileLayout();
      
      let container;
      if (isMobileView) {
        // In mobile view, look for farmer card first
        container = document.querySelector(`.farmer-card[data-farmer-id="${currentFarmerId}"]`);
        if (!container) {
          // Fallback to table row if card not found
          container = document.querySelector(`tr[data-farmer-id="${currentFarmerId}"]`);
        }
      } else {
        // In desktop view, look for table row first
        container = document.querySelector(`tr[data-farmer-id="${currentFarmerId}"]`);
        if (!container) {
          // Fallback to farmer card if row not found
          container = document.querySelector(`.farmer-card[data-farmer-id="${currentFarmerId}"]`);
        }
      }
      
      if (container) {
        // Update the form fields
        const milkTypeField = container.querySelector('.milk-type');
        const qtyField = container.querySelector('.qty');
        const fatField = container.querySelector('.fat');
        const snfField = container.querySelector('.snf');
        const waterField = container.querySelector('.water');
        const clrField = container.querySelector('.clr');
        
        if (milkTypeField) milkTypeField.value = calculated.milkType;
        if (qtyField) qtyField.value = calculated.totalQty.toFixed(1);
        if (fatField) fatField.value = calculated.avgFat.toFixed(2);
        if (snfField) snfField.value = calculated.avgSnf.toFixed(2);
        if (waterField) waterField.value = calculated.avgWater.toFixed(2);
        if (clrField) clrField.value = calculated.avgClr.toFixed(2);
        
        // Enable the form for editing
        container.querySelectorAll('input, select').forEach(input => {
          input.disabled = false;
        });
        
        // Update status to editing
        const statusBadge = container.querySelector('[class*="inline-flex"]');
        if (statusBadge) {
          statusBadge.textContent = 'Editing';
          statusBadge.className = 'inline-flex items-center px-2 py-1 rounded-full text-xs font-medium border bg-yellow-100 text-yellow-700 border-yellow-200';
        }
      }
    }

    // Event listeners for multi-container modal
    document.addEventListener('click', function(event) {
      // Open modal
      if (event.target.closest('.multi-container-btn')) {
        const button = event.target.closest('.multi-container-btn');
        const farmerId = button.dataset.farmerId;
        const farmerName = button.dataset.farmerName;
        const container = button.closest('tr[data-time], .farmer-card[data-time]');
        const time = container ? container.dataset.time : 'morning';
        
        openMultiContainerModal(farmerId, farmerName, time);
      }
      
      // Close modal
      if (event.target.closest('#closeMultiContainerModal') || event.target.closest('#cancelMultiContainer')) {
        closeMultiContainerModal();
      }
      
      // Add container
      if (event.target.closest('#addContainerBtn')) {
        const containerForms = document.getElementById('containerForms');
        containerForms.insertAdjacentHTML('beforeend', createContainerForm(containerCount));
        containerCount++;
        
        if (typeof lucide !== 'undefined') {
          if (typeof lucide !== 'undefined') lucide.createIcons();
        }
      }
      
      // Remove container
      if (event.target.closest('.remove-container-btn')) {
        const button = event.target.closest('.remove-container-btn');
        const containerIndex = parseInt(button.dataset.containerIndex);
        const container = document.querySelector(`[data-container-index="${containerIndex}"]`);
        if (container) {
          container.remove();
        }
      }
      
      // Save and apply
      if (event.target.closest('#saveMultiContainer')) {
        const calculated = calculateWeightedAverages();
        
        if (calculated.totalQty <= 0) {
          showWarningToast('Please enter at least one container with quantity > 0');
          return;
        }
        
        applyCalculatedValues(calculated);
        closeMultiContainerModal();
        
        showSuccessToast(`Multi-container data applied successfully! Total: ${calculated.totalQty.toFixed(1)}L`);
      }
    });

    // Initialize monthly filter on page load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        setupButtonHandlers();
        initializeMonthlyFilter();
      });
    } else {
      setupButtonHandlers();
      initializeMonthlyFilter();
    }
  </script>
  
  <!-- Multi-Container Entry Modal -->
  <div id="multiContainerModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden">
    <div class="flex items-center justify-center min-h-screen p-4">
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-gray-900 dark:text-gray-100 rounded-lg shadow-xl max-w-3xl w-4/5 max-h-[90vh] overflow-y-auto mx-4">
        <div class="p-4 md:p-6">
          <div class="flex justify-between items-center mb-4 md:mb-6">
            <h3 class="text-lg md:text-xl font-semibold text-gray-900 dark:text-gray-100">
              Multi-Container Entry - <span id="modalFarmerName"></span>
            </h3>
            <button type="button" id="closeMultiContainerModal" class="text-gray-400 hover:text-gray-600 dark:text-gray-300 dark:hover:text-gray-200">
              <i data-lucide="x" class="w-6 h-6"></i>
            </button>
          </div>
          
          <div class="mb-6">
            <p class="text-sm text-gray-600 dark:text-gray-300 mb-4">
              Enter milk data for each container separately. The system will calculate total quantity and weighted averages for Fat, SNF, Water, and CLR.
            </p>
          </div>
          
          <div id="containerForms" class="space-y-6">
            <!-- Container forms will be dynamically added here -->
          </div>
          
          <div class="flex flex-col md:flex-row justify-between items-center mt-4 md:mt-6 gap-3 md:gap-0">
            <button type="button" id="addContainerBtn" class="btn btn-secondary flex items-center gap-2 w-full md:w-auto">
              <i data-lucide="plus" class="w-4 h-4"></i>
              Add Container
            </button>
            
            <div class="flex flex-col md:flex-row gap-3 w-full md:w-auto">
              <button type="button" id="cancelMultiContainer" class="btn btn-secondary w-full md:w-auto">
                Cancel
              </button>
              <button type="button" id="saveMultiContainer" class="btn btn-primary w-full md:w-auto">
                <i data-lucide="check" class="w-4 h-4"></i>
                Save & Apply
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Charts: Chart.js and Datalabels (loaded at end for performance) -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js" defer></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js" defer></script>

  <%- include('../../../partials/_toast') %>
  <style>
    /* Dark mode enhancements for Multi-Container modal */
    .dark #multiContainerModal input,
    .dark #multiContainerModal select,
    .dark #multiContainerModal textarea {
      background-color: #111827 !important; /* gray-900 */
      color: #f3f4f6 !important;            /* gray-100 */
      border-color: #374151 !important;     /* gray-700 */
      -webkit-text-fill-color: #f3f4f6 !important; /* Safari */
    }
    .dark #multiContainerModal input::placeholder,
    .dark #multiContainerModal textarea::placeholder {
      color: #9ca3af !important; /* gray-400 */
      opacity: 1 !important;
    }
    .dark #multiContainerModal label,
    .dark #multiContainerModal th,
    .dark #multiContainerModal td,
    .dark #multiContainerModal p,
    .dark #multiContainerModal h3,
    .dark #multiContainerModal span {
      color: #e5e7eb !important; /* slate-200 */
    }
    .dark #multiContainerModal .btn-secondary {
      background-color: #374151 !important; /* gray-700 */
      color: #e5e7eb !important;
      border-color: #4b5563 !important; /* gray-600 */
    }
    .dark #multiContainerModal .btn-secondary:hover {
      background-color: #4b5563 !important; /* gray-600 */
    }
    .dark #multiContainerModal .btn-primary { color: #ffffff !important; }
  </style>
</body>
</html>

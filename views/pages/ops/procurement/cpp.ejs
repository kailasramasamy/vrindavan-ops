        if (qty <= 0) {
          showWarningToast('Please enter quantity for this CPP');
          return;
        }

        const date = bulkDateFilter?.value || bulkDateFilterMobile?.value;
        const time = bulkTimeFilter?.value || bulkTimeFilterMobile?.value;

        if (!date || !time) {
          showErrorToast('Please select date and time');
          return;
        }

        // Get all farmers for this CPP (we'll save as aggregate entry per CPP)
        // For bulk entry, we'll save as a single entry per CPP representing all farmers
        saveBulkCppEntry({
          cpp_id: cppId,
          date: date,
          time: time,
          milk_type: milkType,
          qty_litres: qty,
          fat: fat || null,
          snf: snf || null,
          water_pct: water || null,
          clr: clr || null,
        }, cppCard);
      }

      async function saveBulkCppEntry(data, cppCard) {
        try {
          // Fetch all farmers for this CPP to create entries
          const response = await fetch(`/api/procurement/cpp/entries?cpp_id=${data.cpp_id}&date=${data.date}&time=${data.time}`);
          const existing = await response.json();

          // For bulk entry, we'll create entries for all farmers of this CPP with the same data
          // This requires fetching farmers list
          const farmersResponse = await fetch(`/api/procurement/cpp/farmers?cpp_id=${data.cpp_id}`);
          let farmers = [];
          if (farmersResponse.ok) {
            const farmersData = await farmersResponse.json();
            farmers = farmersData.farmers || [];
          }

          // Build items payload expected by backend controller
          const items = (farmers.length > 0
            ? farmers.map(farmer => ({
                farmerId: farmer.id,
                farmer: farmer.name,
                milkType: data.milk_type,
                qty: data.qty_litres / farmers.length,
                fat: data.fat,
                snf: data.snf,
                water: data.water_pct,
                clr: data.clr,
              }))
            : []).filter(i => i.qty > 0);

          const saveResponse = await fetch('/api/procurement/cpp/entries', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ cpp_id: data.cpp_id, date: data.date, time: data.time, items })
          });

          const result = await saveResponse.json();

          if (result.ok) {
            // Update all matching cards (desktop row + mobile card) for this CPP
            const allMatchingCards = document.querySelectorAll(`.cpp-bulk-entry-row[data-cpp-id="${data.cpp_id}"], .cpp-bulk-entry[data-cpp-id="${data.cpp_id}"]`);
            allMatchingCards.forEach(card => {
              const statusBadge = card.querySelector('.bulk-cpp-status');
              if (statusBadge) {
                statusBadge.textContent = 'Accepted';
                statusBadge.className = 'inline-flex items-center px-2 py-1 rounded-full text-xs font-medium border bg-green-100 text-green-700 border-green-200 dark:bg-green-900/30 dark:text-green-300 dark:border-green-800 bulk-cpp-status';
              }
              const acceptBtn = card.querySelector('.bulk-accept-btn');
              if (acceptBtn) {
                acceptBtn.dataset.mode = 'edit';
                acceptBtn.classList.remove('btn-primary');
                acceptBtn.classList.add('btn-warning');
                acceptBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                const label = acceptBtn.querySelector('.label');
                const icon = acceptBtn.querySelector('i');
                if (label) label.textContent = 'Edit';
                if (icon) icon.setAttribute('data-lucide', 'edit');
              }
              card.querySelectorAll('input, select').forEach(input => input.disabled = true);
              const cancelBtn = card.querySelector('.bulk-cancel-edit');
              if (cancelBtn) cancelBtn.classList.add('hidden');
            });
            if (typeof lucide !== 'undefined') lucide.createIcons();
            showSuccessToast(`CPP ${data.cpp_id} entry saved successfully`);
          } else {
            showErrorToast(result.error || 'Failed to save entry');
          }
        } catch (error) {
          console.error('Error saving bulk entry:', error);
          showErrorToast('Error saving entry');
        }
      }


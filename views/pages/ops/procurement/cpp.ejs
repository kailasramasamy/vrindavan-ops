          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin'
        });

        // Check if the response is a redirect (authentication issue)
        if (response.redirected || response.status === 302) {
          showErrorToast('Authentication required. Please ensure you are logged in and have proper permissions.');
          return;
        }

        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);

                            <option value="A1" <%= (normalizedType === 'A1') ? 'selected' : '' %>>A1</option>
                            <option value="A2" <%= (normalizedType === 'A2') ? 'selected' : '' %>>A2</option>
                            <option value="Buffalo" <%= (normalizedType === 'BUFFALO') ? 'selected' : '' %>>Buffalo</option>

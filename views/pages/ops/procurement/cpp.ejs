                        const existingEntry = existingCppEntries?.morning?.find(e => e.farmerId === farmer.id);
                        const isEditing = existingEntry?.status === 'editing';
                        const isAccepted = existingEntry?.status === 'accepted';
                        // Get farmer's milk type - handle both property name variations
                        const farmerMilkTypeRaw = farmer.milk_type || farmer.milkType || null;
                        const farmerMilkType = farmerMilkTypeRaw ? String(farmerMilkTypeRaw).trim() : 'A2';
                        
                        // Calculate default milk type
                        let defaultMilkType = 'A2';
                        if (existingEntry && existingEntry.milkType) {
                          defaultMilkType = String(existingEntry.milkType).trim();
                        } else {
                          // Use farmer's milk type from database
                          defaultMilkType = String(farmerMilkType).trim();
                        }
                        // Normalize to uppercase for comparison
                        const normalizedType = defaultMilkType.toUpperCase();
                      %>

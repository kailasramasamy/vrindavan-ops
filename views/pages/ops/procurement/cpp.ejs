  <style>
    /* Normalize date input and select styling */
    input[type="date"], select {
      height: 48px;
      font-size: 16px;
      line-height: 1.5;
    }
    
    .btn { 
      @apply px-4 py-2 rounded-lg font-medium transition-all duration-200 ease-in-out;
      @apply transform hover:scale-105 active:scale-95;
    }
    .btn-primary { 
      @apply bg-blue-600 text-white hover:bg-blue-700 hover:shadow-lg;
      @apply border border-blue-700;
    }
    .btn-success { 
      @apply bg-green-600 text-white hover:bg-green-700 hover:shadow-lg;
      @apply border border-green-700;
    }
    .btn-warning { 
      @apply bg-amber-600 text-white hover:bg-amber-700 hover:shadow-lg;
      @apply border border-amber-700;
    }
    .btn-danger { 
      background-color: #fef2f2 !important;
      color: #dc2626 !important;
      border-color: #fecaca !important;
    }
    .btn-danger:hover {
      background-color: #fee2e2 !important;
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05) !important;
    }
    /* Dark mode variant for danger button */
    .dark .btn-danger {
      background-color: #7f1d1d !important; /* red-900 */
      color: #fecaca !important;            /* red-200 */
      border-color: #991b1b !important;     /* red-800 */
    }
    .dark .btn-danger:hover {
      background-color: #991b1b !important; /* red-800 */
    }
    .btn-sm { @apply px-2 py-1 text-xs font-medium; }
    
    /* Dark mode: improve readability of disabled inputs/selects when entries are accepted */
    .dark input[disabled],
    .dark select[disabled],
    .dark input:disabled,
    .dark select:disabled {
      background-color: #1f2937 !important; /* gray-800 */
      color: #e5e7eb !important;            /* slate-200 */
      border-color: #374151 !important;     /* gray-700 */
      opacity: 1 !important;                /* avoid dimming making text illegible */
      -webkit-text-fill-color: #e5e7eb !important; /* Safari */
      cursor: not-allowed;
    }
    .dark input[disabled]::placeholder,
    .dark select[disabled]::placeholder {
      color: #9ca3af !important; /* gray-400 */
      opacity: 1 !important;
    }
    /* Keep enabled inputs clearly styled in dark mode */
    .dark input:not([disabled]),
    .dark select:not([disabled]) {
      background-color: #111827; /* gray-900 */
      color: #f3f4f6;            /* gray-100 */
      border-color: #374151;     /* gray-700 */
    }
    
    /* Responsive visibility */
    .desktop-only { @apply hidden md:block; }
    .mobile-only { @apply block md:hidden; }
    
    /* Card styling for mobile */
    .farmer-card {
      @apply border border-slate-200 rounded-lg shadow-sm;
    }
    
    /* Mobile responsive adjustments */
    @media (max-width: 640px) {
      .grid-cols-2 {
        gap: 0.75rem;
      }
      .farmer-card .grid-cols-2 > div {
        min-width: 0;
      }
      .farmer-card label {
        font-size: 0.75rem;
        line-height: 1rem;
      }
      .farmer-card input,
      .farmer-card select {
        font-size: 0.875rem;
        padding: 0.5rem;
      }
    }
  </style>
  <script>
    // Global variables
    const SCOPE_CPP_ID = <%- JSON.stringify(typeof selectedCppId !== 'undefined' ? selectedCppId : null) %>;
    const SCOPE_DATE = '<%= typeof selectedDate !== "undefined" ? selectedDate : "" %>';
    const SCOPE_TIME = '<%= typeof selectedTime !== "undefined" ? selectedTime : "" %>';
    
    // Make data available to client-side
    window.existingCppEntries = <%- JSON.stringify(typeof existingCppEntries !== 'undefined' ? existingCppEntries : []) %>;
    window.farmerList = <%- JSON.stringify(typeof farmerList !== 'undefined' ? farmerList : []) %>;
    // Populate CPP selects (desktop & mobile) from server-provided cppList
    (function populateCppSelects() {
      try {
        const cppList = <%- JSON.stringify(typeof cppList !== 'undefined' ? cppList : []) %>;
        if (!Array.isArray(cppList) || cppList.length === 0) return;
        const desktop = document.getElementById('cppFilter');
        const mobile = document.getElementById('cppFilterMobile');
        const selected = String(<%- JSON.stringify(typeof selectedCppId !== 'undefined' ? selectedCppId : '') %> || '');
        [desktop, mobile].forEach(select => {
          if (!select) return;
          // remove existing non-placeholder options
          Array.from(select.querySelectorAll('option')).forEach(opt => { if (opt.value) opt.remove(); });
          cppList.forEach(cpp => {
            const opt = document.createElement('option');
            opt.value = cpp.id;
            opt.textContent = cpp.name;
            if (String(cpp.id) === selected) opt.selected = true;
            select.appendChild(opt);
          });
        });
      } catch (e) {
        console.error('populateCppSelects error', e);
      }
    })();

    // Initialize Lucide icons (wait for lucide to be available)
    if (typeof lucide !== 'undefined') {
      lucide.createIcons();
    } else {
      // Wait for lucide to load
      document.addEventListener('DOMContentLoaded', function() {
        if (typeof lucide !== 'undefined') {
          if (typeof lucide !== 'undefined') lucide.createIcons();
        }
      });
    }
    
    // Initialize CPP dropdown based on milk type filter on page load
    (async function() {
      const filters = getCurrentFilters();
      if (filters.milkType && filters.milkType !== 'all') {
        await loadCppsByMilkType(filters.milkType);
      }
    })();

    // Ensure milk type dropdowns show correct default value from farmer's milk_type
    function initializeMilkTypeDefaults() {
      const milkTypeSelects = document.querySelectorAll('.milk-type');
      
      if (milkTypeSelects.length === 0) {
        return;
      }
      
      milkTypeSelects.forEach((select) => {
        // Try to get farmer ID and milk type from the select element
        let farmerMilkType = select.getAttribute('data-farmer-milk-type');
        let farmerId = select.getAttribute('data-farmer-id');
        
        // If not found on select, try parent row or card
        const parentRow = select.closest('tr.farmer-row, .farmer-card');
        if (parentRow) {
          if (!farmerId || farmerId === 'null') {
            farmerId = parentRow.getAttribute('data-farmer-id');
          }
          if (!farmerMilkType || farmerMilkType === 'null' || farmerMilkType === '') {
            farmerMilkType = parentRow.getAttribute('data-farmer-milk-type');
          }
        }
        
        // Try to get from window.farmerList if available
        if ((!farmerMilkType || farmerMilkType === 'null' || farmerMilkType === '') && window.farmerList && farmerId) {
          const farmer = window.farmerList.find(f => f.id == farmerId);
          if (farmer && (farmer.milk_type || farmer.milkType)) {
            farmerMilkType = farmer.milk_type || farmer.milkType;
          }
        }
        
        const currentValue = select.value;
        
        // If we have farmer's milk type and current value is default or empty, update it
        if (farmerMilkType && farmerMilkType !== 'null' && farmerMilkType !== '') {
          // Normalize the farmer's milk type
          const normalizedType = String(farmerMilkType).toUpperCase().trim();
          let targetValue = 'A2'; // default
          
          if (normalizedType === 'A1') {
            targetValue = 'A1';
          } else if (normalizedType === 'A2') {
            targetValue = 'A2';
          } else if (normalizedType === 'BUFFALO') {
            targetValue = 'Buffalo';
          }
          
          // Update if current value doesn't match (or is empty/default)
          if (!currentValue || currentValue === 'A2' || currentValue !== targetValue) {
            select.value = targetValue;
            // Trigger change event to ensure any listeners are notified
            select.dispatchEvent(new Event('change', { bubbles: true }));
          }
        }
      });
    }
    
    // Run on page load and after DOM updates
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        setTimeout(initializeMilkTypeDefaults, 100);
      });
    } else {
      setTimeout(initializeMilkTypeDefaults, 100);
    }
    
    // Also run after a longer delay to catch dynamically loaded content
    setTimeout(initializeMilkTypeDefaults, 1000);
    
    // Helper to determine whether mobile layout is active.
    // Some pages may not include the marker elements, so fall back to window width.
    function isMobileLayout() {
      const el = document.querySelector('.mobile-only');
      if (el) {
        try {
          return window.getComputedStyle(el).display !== 'none';
        } catch (e) {
          return window.innerWidth < 768;
        }
      }
      return window.innerWidth < 768;
    }

    // Filter change handlers
    // Function to get current filter values (works for both desktop and mobile)
    function getCurrentFilters() {
      const desktopDate = document.getElementById('dateFilter');
      const mobileDate = document.getElementById('dateFilterMobile');
      const desktopTime = document.getElementById('timeFilter');
      const mobileTime = document.getElementById('timeFilterMobile');
      const desktopCpp = document.getElementById('cppFilter');
      const mobileCpp = document.getElementById('cppFilterMobile');
      const desktopMilkType = document.getElementById('milkTypeFilter');
      const mobileMilkType = document.getElementById('milkTypeFilterMobile');

      const mobile = isMobileLayout();

      const date = mobile ? (mobileDate?.value || desktopDate?.value || '') : (desktopDate?.value || mobileDate?.value || '');
      const time = mobile ? (mobileTime?.value || desktopTime?.value || '') : (desktopTime?.value || mobileTime?.value || '');
      const cppId = mobile ? (mobileCpp?.value || desktopCpp?.value || '') : (desktopCpp?.value || mobileCpp?.value || '');
      const milkType = mobile ? (mobileMilkType?.value || desktopMilkType?.value || 'all') : (desktopMilkType?.value || mobileMilkType?.value || 'all');

      return { date, time, cppId, milkType };
    }

    // Function to navigate with current filters
    function navigateWithFilters() {
      const filters = getCurrentFilters();
      if (filters.cppId && filters.date && filters.time) {
        let url = `/procurement/cpp?cpp_id=${filters.cppId}&date=${filters.date}&time=${filters.time}`;
        if (filters.milkType && filters.milkType !== 'all') {
          url += `&milkType=${filters.milkType}`;
        }
        window.location.href = url;
      }
    }

    // Function to load CPPs based on milk type
    async function loadCppsByMilkType(milkType) {
      try {
        const response = await fetch(`/api/procurement/cpp/list?milkType=${milkType || 'all'}`);
        const result = await response.json();
        
        if (result.ok && result.cpps) {
          const desktopCpp = document.getElementById('cppFilter');
          const mobileCpp = document.getElementById('cppFilterMobile');
          const currentCppId = desktopCpp?.value || mobileCpp?.value || '';
          
          // Update desktop CPP dropdown
          if (desktopCpp) {
            desktopCpp.innerHTML = '<option value="">Select CPP</option>';
            result.cpps.forEach(cpp => {
              const option = document.createElement('option');
              option.value = cpp.id;
              option.textContent = cpp.name;
              if (String(cpp.id) === currentCppId) {
                option.selected = true;
              }
              desktopCpp.appendChild(option);
            });
          }
          
          // Update mobile CPP dropdown
          if (mobileCpp) {
            mobileCpp.innerHTML = '<option value="">Select CPP</option>';
            result.cpps.forEach(cpp => {
              const option = document.createElement('option');
              option.value = cpp.id;
              option.textContent = cpp.name;
              if (String(cpp.id) === currentCppId) {
                option.selected = true;
              }
              mobileCpp.appendChild(option);
            });
          }
          
          // If current CPP is not in the filtered list, clear selection
          const cppExists = result.cpps.some(cpp => String(cpp.id) === currentCppId);
          if (currentCppId && !cppExists) {
            if (desktopCpp) desktopCpp.value = '';
            if (mobileCpp) mobileCpp.value = '';
          }
        }
      } catch (error) {
        console.error('Error loading CPPs:', error);
      }
    }

    // Add event listeners to filter elements
    ['dateFilter', 'dateFilterMobile', 'timeFilter', 'timeFilterMobile', 'cppFilter', 'cppFilterMobile'].forEach(id => {
      const element = document.getElementById(id);
      if (element) {
        element.addEventListener('change', function() {
          navigateWithFilters();
        });
      }
    });

    // Special handling for milk type filter - update CPP dropdown dynamically
    ['milkTypeFilter', 'milkTypeFilterMobile'].forEach(id => {
      const element = document.getElementById(id);
      if (element) {
        element.addEventListener('change', async function() {
          const milkType = this.value;
          await loadCppsByMilkType(milkType);
          
          // If a CPP is already selected, navigate immediately to show filtered results
          const filters = getCurrentFilters();
          if (filters.cppId && filters.date && filters.time) {
            navigateWithFilters();
          }
        });
      }
    });


    // Setup button handlers using event delegation
    function setupButtonHandlers() {
      // Prevent duplicate event listeners
      if (window.buttonHandlersAttached) {
        return;
      }
      window.buttonHandlersAttached = true;
      
      // Remove any existing click listeners to prevent duplicates
      if (window.buttonClickHandler) {
        document.removeEventListener('click', window.buttonClickHandler);
      }
      
      // Create the click handler function
      window.buttonClickHandler = function(event) {
        // Handle edit buttons
        if (event.target.closest('.edit-btn')) {
          event.preventDefault();
          event.stopPropagation();
          const button = event.target.closest('.edit-btn');
          const farmerId = button.dataset.farmerId;
          enableEdit(farmerId, event);
          return;
        }
        
        // Handle accept buttons
        if (event.target.closest('.accept-btn')) {
          event.preventDefault();
          event.stopPropagation();
          const button = event.target.closest('.accept-btn');
          const farmerId = button.dataset.farmerId;
          
          acceptData(farmerId, event);
          return;
        }
        
        // Handle delete buttons
        if (event.target.closest('.delete-btn')) {
          event.preventDefault();
          event.stopPropagation();
          const button = event.target.closest('.delete-btn');
          const farmerId = button.dataset.farmerId;
          
          deleteData(farmerId, event);
          return;
        }
      };
      
      // Add the event listener
      document.addEventListener('click', window.buttonClickHandler);
    }

    // Enable edit mode
    function enableEdit(farmerId, event) {
      // Find the container that contains the clicked button
      let container = null;
      if (event && event.target) {
        // Find the closest container (row or card) that contains the clicked button
        container = event.target.closest('tr[data-farmer-id], .farmer-card[data-farmer-id]');
      }
      
      // Fallback: if no event or container not found, use the old method
      if (!container) {
        const row = document.querySelector(`tr[data-farmer-id="${farmerId}"]`);
        const card = document.querySelector(`.farmer-card[data-farmer-id="${farmerId}"]`);
        const isMobileView = isMobileLayout();
        container = isMobileView ? card : row;
      }
      
      // Check if we're in mobile view for UI updates
      const isMobileView = isMobileLayout();
      
      
      if (!container) return;

      // Enable all input fields
      container.querySelectorAll('input, select').forEach(input => {
        input.disabled = false;
      });

      // Update status
      const statusBadge = container.querySelector('[class*="status-badge"], [class*="inline-flex"]');
      statusBadge.textContent = 'Editing';
      statusBadge.className = 'inline-flex items-center px-2 py-1 rounded-full text-xs font-medium border bg-yellow-100 text-yellow-700 border-yellow-200';

      // Update button (handle both desktop and mobile)
      const editBtn = container.querySelector('.edit-btn');
      if (editBtn) {
        if (isMobileView) {
          // Mobile: icon + text (always show text on mobile)
          editBtn.innerHTML = '<i data-lucide="check" class="w-4 h-4"></i>Accept';
          editBtn.className = 'btn btn-success btn-sm accept-btn flex items-center gap-2 px-4 py-2 shadow-lg hover:shadow-xl transition-all';
        } else {
          // Desktop: icon + text with responsive behavior
          editBtn.innerHTML = '<i data-lucide="check" class="w-4 h-4"></i><span class="hidden sm:inline">Accept</span>';
          editBtn.className = 'btn btn-success btn-sm accept-btn flex items-center gap-2 px-3 py-2 shadow-lg hover:shadow-xl transition-all';
        }
        editBtn.onclick = (event) => acceptData(farmerId, event);
      }

      if (typeof lucide !== 'undefined') lucide.createIcons();
    }

    // Accept data
    async function acceptData(farmerId, event) {
      // Prevent duplicate calls - use a simple flag per farmer
      const callKey = `acceptData_${farmerId}`;
      if (window[callKey]) {
        return;
      }
      window[callKey] = true;
      
      // Clear the flag after 2 seconds
      setTimeout(() => {
        window[callKey] = false;
      }, 2000);
      
      // Find the container that contains the clicked button
      let container = null;
      if (event && event.target) {
        // Find the closest container (row or card) that contains the clicked button
        container = event.target.closest('tr[data-farmer-id], .farmer-card[data-farmer-id]');
      }
      
      // Fallback: if no event or container not found, use the old method
      if (!container) {
        const row = document.querySelector(`tr[data-farmer-id="${farmerId}"]`);
        const card = document.querySelector(`.farmer-card[data-farmer-id="${farmerId}"]`);
        const isMobileView = isMobileLayout();
        container = isMobileView ? card : row;
      }
      
      const qtyInput = container ? container.querySelector('.qty') : null;
      
      // Check if we're in mobile view for UI updates
      const isMobileView = isMobileLayout();
      
      if (!container) return;

      // Add a small delay to ensure input values are captured
      await new Promise(resolve => setTimeout(resolve, 10));

      const farmerName = container.dataset.farmerName;
      const milkType = container.querySelector('.milk-type').value;
      
      const qty = parseFloat(qtyInput.value) || 0;
      const fat = parseFloat(container.querySelector('.fat').value) || null;
      const snf = parseFloat(container.querySelector('.snf').value) || null;
      const clr = parseFloat(container.querySelector('.clr').value) || null;
      const water = parseFloat(container.querySelector('.water').value) || null;


      // Check HTML5 validation first
      if (!qtyInput.validity.valid) {
        showErrorToast('Please enter a valid quantity (HTML5 validation failed)');
        return;
      }

        // Determine the actual time for day view
        let actualTime = SCOPE_TIME;
        if (SCOPE_TIME === 'day') {
          // For day view, determine if this is morning or evening based on the container
          const rowTime = container.getAttribute('data-time');
          if (rowTime) {
            actualTime = rowTime;
          } else {
            // Fallback: check if container is in evening table
            const eveningTable = container.closest('#farmerTableBodyEvening');
            const eveningCard = container.closest('[data-time="evening"]');
            actualTime = (eveningTable || eveningCard) ? 'evening' : 'morning';
          }
        }

      // Find existing entry based on time structure
      let existingEntry = null;
      if (SCOPE_TIME === 'day') {
        // Day view: look in morning or evening array
        existingEntry = window.existingCppEntries?.[actualTime]?.find(e => e.farmerId == farmerId);
      } else {
        // Single time view: look in array
        existingEntry = window.existingCppEntries?.find(e => e.farmerId == farmerId);
      }
      const isUpdate = !!existingEntry;

      // For new entries, require qty > 0. For edits, allow qty = 0 (to correct mistaken entries).
      if (qty < 0) {
        showErrorToast('Please enter a valid quantity');
        return;
      }
      if (qty <= 0 && !isUpdate) {
        showErrorToast('Please enter a valid quantity (value must be greater than 0)');
        return;
      }

      try {
        const url = isUpdate 
          ? `/api/procurement/cpp/entries/${existingEntry.id}`
          : '/api/procurement/cpp/entries';
        
        const method = isUpdate ? 'PUT' : 'POST';
        
          const payload = isUpdate ? {
            milkType,
            qty,
            fat,
            snf,
            clr,
            water
          } : {
            cpp_id: SCOPE_CPP_ID,
            date: SCOPE_DATE,
            time: actualTime, // Use the determined actual time
            items: [{
              farmerId: parseInt(farmerId),
              farmer: farmerName,
              milkType,
              qty,
              fat,
              snf,
              clr,
              water
            }]
          };

        const response = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        const result = await response.json();
        
        
        if (result.ok) {
          showSuccessToast(`Data ${isUpdate ? 'updated' : 'saved'} successfully`);
          
          // Disable fields and update status
          container.querySelectorAll('input, select').forEach(input => {
            input.disabled = true;
          });
          
          const statusBadge = container.querySelector('[class*="status-badge"], [class*="inline-flex"]');
          statusBadge.textContent = 'Accepted';
          statusBadge.className = 'inline-flex items-center px-2 py-1 rounded-full text-xs font-medium border bg-green-100 text-green-700 border-green-200';
          
          // Update button to edit mode (handle both desktop and mobile)
          const acceptBtn = container.querySelector('.accept-btn');
          
          if (acceptBtn) {
            if (isMobileView) {
              // Mobile: icon + text (always show text on mobile)
              acceptBtn.innerHTML = '<i data-lucide="edit" class="w-4 h-4"></i>Edit';
              acceptBtn.className = 'btn btn-warning btn-sm edit-btn flex items-center gap-2 px-4 py-2 shadow-lg hover:shadow-xl transition-all';
            } else {
              // Desktop: icon + text with responsive behavior
              acceptBtn.innerHTML = '<i data-lucide="edit" class="w-4 h-4"></i><span class="hidden sm:inline">Edit</span>';
              acceptBtn.className = 'btn btn-warning btn-sm edit-btn flex items-center gap-2 px-3 py-2 shadow-lg hover:shadow-xl transition-all';
            }
            acceptBtn.onclick = () => enableEdit(farmerId);
          }
          
          // Add delete button if it doesn't exist
          let deleteBtn = container.querySelector('.delete-btn');
          if (!deleteBtn) {
            deleteBtn = document.createElement('button');
            deleteBtn.type = 'button';
            deleteBtn.className = 'btn btn-danger btn-sm delete-btn flex items-center gap-2 px-3 py-2 shadow-lg hover:shadow-xl transition-all';
            deleteBtn.dataset.farmerId = farmerId;
            
            if (isMobileView) {
              // Mobile: icon + text (always show text on mobile)
              deleteBtn.innerHTML = '<i data-lucide="trash-2" class="w-4 h-4"></i>Delete';
              deleteBtn.className = 'btn btn-danger btn-sm delete-btn flex items-center gap-2 px-4 py-2 shadow-lg hover:shadow-xl transition-all';
            } else {
              // Desktop: icon + text with responsive behavior
              deleteBtn.innerHTML = '<i data-lucide="trash-2" class="w-4 h-4"></i><span class="hidden sm:inline">Delete</span>';
              deleteBtn.className = 'btn btn-danger btn-sm delete-btn flex items-center gap-2 px-3 py-2 shadow-lg hover:shadow-xl transition-all';
            }
            
            // Insert delete button after the edit button
            if (acceptBtn && acceptBtn.parentNode) {
              acceptBtn.parentNode.insertBefore(deleteBtn, acceptBtn.nextSibling);
            }
          }
          
          if (typeof lucide !== 'undefined') lucide.createIcons();
          
          // Update local data
          if (isUpdate) {
            // Handle day view vs single time view data structure
            if (SCOPE_TIME === 'day') {
              // Day view: find in the appropriate time array
              const timeArray = window.existingCppEntries?.[actualTime] || [];
              const entry = timeArray.find(e => e.farmerId == farmerId);
              if (entry) {
                entry.milkType = milkType;
                entry.qty = qty;
                entry.fat = fat;
                entry.snf = snf;
                entry.clr = clr;
                entry.water = water;
                entry.status = 'accepted';
              }
            } else {
              // Single time view: find in array
              const entry = window.existingCppEntries.find(e => e.farmerId == farmerId);
              if (entry) {
                entry.milkType = milkType;
                entry.qty = qty;
                entry.fat = fat;
                entry.snf = snf;
                entry.clr = clr;
                entry.water = water;
                entry.status = 'accepted';
              }
            }
          } else {
            // Handle day view vs single time view data structure
            if (SCOPE_TIME === 'day') {
              // Day view: add to the appropriate time array
              window.existingCppEntries = window.existingCppEntries || { morning: [], evening: [] };
              const newEntry = {
                id: result.saved?.id || Date.now(),
                farmerId: parseInt(farmerId),
                farmerName,
                milkType,
                qty,
                fat,
                snf,
                clr,
                water,
                status: 'accepted',
                time: actualTime
              };
              window.existingCppEntries[actualTime].push(newEntry);
            } else {
              // Single time view: add to array
              window.existingCppEntries = window.existingCppEntries || [];
              window.existingCppEntries.push({
                id: result.saved?.id || Date.now(),
                farmerId: parseInt(farmerId),
                farmerName,
                milkType,
                qty,
                fat,
                snf,
                clr,
                water,
                status: 'accepted'
              });
            }
          }
        } else {
          showErrorToast(result.error || 'Error saving data');
        }
      } catch (error) {
        console.error('Error:', error);
        showErrorToast('Error saving data');
      }
    }

    // Delete data
    async function deleteData(farmerId, event) {
      // Find the container that contains the clicked button
      let container = null;
      if (event && event.target) {
        // Find the closest container (row or card) that contains the clicked button
        container = event.target.closest('tr[data-farmer-id], .farmer-card[data-farmer-id]');
      }
      
      // Fallback: if no event or container not found, use the old method
      if (!container) {
        const row = document.querySelector(`tr[data-farmer-id="${farmerId}"]`);
        const card = document.querySelector(`.farmer-card[data-farmer-id="${farmerId}"]`);
        const isMobileView = isMobileLayout();
        container = isMobileView ? card : row;
      }
      
      // Check if we're in mobile view for UI updates
      const isMobileView = isMobileLayout();
      
      if (!container) return;

      // Determine the actual time for day view
      let actualTime = SCOPE_TIME;
      if (SCOPE_TIME === 'day') {
        // For day view, determine if this is morning or evening based on the container
        const rowTime = container.getAttribute('data-time');
        if (rowTime) {
          actualTime = rowTime;
        } else {
          // Fallback: check if container is in evening table
          const eveningTable = container.closest('#farmerTableBodyEvening');
          actualTime = eveningTable ? 'evening' : 'morning';
        }
      }
      
      // Find existing entry based on time structure
      let existingEntry = null;
      if (SCOPE_TIME === 'day') {
        // Day view: look in morning or evening array
        existingEntry = window.existingCppEntries?.[actualTime]?.find(e => e.farmerId == farmerId);
      } else {
        // Single time view: look in array
        existingEntry = window.existingCppEntries?.find(e => e.farmerId == farmerId);
      }
      
      if (!existingEntry) {
        showErrorToast('No data found to delete');
        return;
      }

      // Confirm deletion

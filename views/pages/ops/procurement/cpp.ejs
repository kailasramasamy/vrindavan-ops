<!DOCTYPE html>
<html lang="en">
  <%- include('../../../partials/_head', { seo, pageKey, promo }) %>
  
  <style>
    /* Ensure consistent input heights */
    .milk-type, .qty, .fat, .snf, .water, .clr {
      height: 40px !important;
      box-sizing: border-box;
    }
    
    /* Make Multi button more visible */
    .multi-container-btn {
      height: 28px !important;
      width: 28px !important;
      font-size: 11px !important;
      line-height: 1 !important;
      display: flex !important;
      visibility: visible !important;
      opacity: 1 !important;
      background: transparent !important;
      color: #3b82f6 !important;
      border: none !important;
      border-radius: 6px !important;
      margin-top: 4px !important;
      padding: 0 !important;
      justify-content: center !important;
      align-items: center !important;
    }
    
    .multi-container-btn:hover {
      color: #2563eb !important;
      background: transparent !important;
    }
  </style>
  
  <body class="bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 antialiased">
    <div class="min-h-dvh flex flex-col">
      <%- include('../../../partials/_subnav', { section: 'Procurement', page: 'CPP — Milk Entry', user }) %>
      <main class="flex-1 bg-white dark:bg-gray-900">
        <section class="max-w-6xl mx-auto px-4 py-10">
          <header class="mb-6">
            <h1 class="text-2xl font-extrabold tracking-tight text-slate-900 dark:text-slate-100">CPP — Milk Entry</h1>
            <p class="text-slate-600 dark:text-slate-300 mt-2">Enter milk data from farmers for the selected CPP, date, and time.</p>
          </header>

          <!-- Filters Section -->
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700 p-6 mb-8">
            <div class="flex items-center justify-between mb-4 md:mb-6">
              <!-- Inline Filter Type (Desktop) -->
              <div class="hidden md:flex items-center space-x-4" id="filterTypeDesktopRow">
                <label class="flex items-center p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                  <input type="radio" name="filterType" value="daily" id="filterTypeDaily" class="mr-2 text-blue-600 focus:ring-blue-500" checked>
                  <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Daily</span>
                </label>
                <label class="flex items-center p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                  <input type="radio" name="filterType" value="bulk" id="filterTypeBulk" class="mr-2 text-blue-600 focus:ring-blue-500">
                  <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Bulk Entry</span>
                </label>
                <label class="flex items-center p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                  <input type="radio" name="filterType" value="monthly" id="filterTypeMonthly" class="mr-2 text-blue-600 focus:ring-blue-500">
                  <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Monthly</span>
                </label>
              </div>
              <!-- Live Indicator -->
              <div class="flex items-center space-x-2">
                <div class="w-2 h-2 bg-green-500 rounded-full"></div>
                <span class="text-sm text-gray-600 dark:text-gray-300">Live Data</span>
              </div>
            </div>

            <!-- Desktop Filter Type Selection (moved inline above) -->
            <div class="hidden"></div>
            
            <!-- Daily Filter Layout -->
            <div id="dailyFilters" class="hidden md:flex items-end space-x-6">
              <!-- Date Filter -->
              <div class="flex-1">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">
                  <div class="flex items-center">
                    <svg class="w-4 h-4 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                    Date
                  </div>
                </label>
                <input type="date" id="dateFilter" name="date" value="<%= selectedDate %>" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
              </div>
              
              <!-- Time Filter -->
              <div class="flex-1">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">
                  <div class="flex items-center">
                    <svg class="w-4 h-4 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    Time
                  </div>
                </label>
                <select id="timeFilter" name="time" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                  <option value="day" <%= selectedTime === 'day' ? 'selected' : '' %>>Day (Total)</option>
                  <option value="morning" <%= selectedTime === 'morning' ? 'selected' : '' %>>Morning</option>
                  <option value="evening" <%= selectedTime === 'evening' ? 'selected' : '' %>>Evening</option>
                </select>
              </div>
              
              <!-- Milk Type Filter -->
              <div class="flex-1">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">
                  <div class="flex items-center">
                    <svg class="w-4 h-4 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                    </svg>
                    Milk Type
                  </div>
                </label>
                <select id="milkTypeFilter" name="milkType" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                  <option value="all" <%= (selectedMilkType === 'all' || !selectedMilkType) ? 'selected' : '' %>>All</option>
                  <option value="A1" <%= selectedMilkType === 'A1' ? 'selected' : '' %>>A1</option>
                  <option value="A2" <%= selectedMilkType === 'A2' ? 'selected' : '' %>>A2</option>
                  <option value="Buffalo" <%= selectedMilkType === 'Buffalo' ? 'selected' : '' %>>Buffalo</option>
                </select>
              </div>
              
              <!-- CPP Filter -->
              <div class="flex-1">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">
                  <div class="flex items-center">
                    <svg class="w-4 h-4 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                    </svg>
                    Collection Point (CPP)
                  </div>
                </label>
                <select id="cppFilter" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                  <option value="">Select CPP</option>
                  <% if (typeof cppList !== 'undefined' && cppList && cppList.length > 0) { %>
                    <% cppList.forEach(cpp => { %>
                      <option value="<%= cpp.id %>" <%= (selectedCppId == cpp.id) ? 'selected' : '' %>><%= cpp.name %></option>
                    <% }) %>
                  <% } %>
                </select>
              </div>
            </div>

            <!-- Bulk Entry Filter Layout -->
            <div id="bulkFilters" class="hidden md:flex items-end space-x-6" style="display: none;">
              <!-- Date Filter -->
              <div class="flex-1">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">
                  <div class="flex items-center">
                    <svg class="w-4 h-4 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                    Date
                  </div>
                </label>
                <input type="date" id="bulkDateFilter" name="bulkDate" value="<%= selectedDate %>" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
              </div>
              
              <!-- Time Filter -->
              <div class="flex-1">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">
                  <div class="flex items-center">
                    <svg class="w-4 h-4 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    Time
                  </div>
                </label>
                <select id="bulkTimeFilter" name="bulkTime" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                  <option value="morning" <%= selectedTime === 'morning' ? 'selected' : '' %>>Morning</option>
                  <option value="evening" <%= selectedTime === 'evening' ? 'selected' : '' %>>Evening</option>
                </select>
              </div>
              
              <!-- Milk Type Filter -->
              <div class="flex-1">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">
                  <div class="flex items-center">
                    <svg class="w-4 h-4 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                    </svg>
                    Milk Type
                  </div>
                </label>
                <select id="bulkMilkTypeFilter" name="bulkMilkType" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                  <option value="all" selected>All</option>
                  <option value="A1">A1</option>
                  <option value="A2">A2</option>
                  <option value="Buffalo">Buffalo</option>
                </select>
              </div>
            </div>

            <!-- Monthly Filter Layout -->
            <div id="monthlyFilters" class="hidden md:flex items-end space-x-6" style="display: none;">
              <!-- Year Filter -->
              <div class="flex-1">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">
                  <div class="flex items-center">
                    <svg class="w-4 h-4 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                    Year
                  </div>
                </label>
                <select id="yearFilter" name="year" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                  <option value="2024">2024</option>
                  <option value="2025" selected>2025</option>
                  <option value="2026">2026</option>
                </select>
              </div>
              
              <!-- Month Filter -->
              <div class="flex-1">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">
                  <div class="flex items-center">
                    <svg class="w-4 h-4 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                    Month
                  </div>
                </label>
                <select id="monthFilter" name="month" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                  <option value="1">January</option>
                  <option value="2">February</option>
                  <option value="3">March</option>
                  <option value="4">April</option>
                  <option value="5">May</option>
                  <option value="6">June</option>
                  <option value="7">July</option>
                  <option value="8">August</option>
                  <option value="9" selected>September</option>
                  <option value="10">October</option>
                  <option value="11">November</option>
                  <option value="12">December</option>
                </select>
              </div>
              
              <!-- Period Filter -->
              <div class="flex-1">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">
                  <div class="flex items-center">
                    <svg class="w-4 h-4 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                  </svg>
                    Period
                  </div>
                </label>
                <select id="periodFilter" name="period" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                  <option value="H1">First Half (1-15)</option>
                  <option value="H2">Second Half (16-31)</option>
                </select>
              </div>

              <!-- CPP Filter -->
              <div class="flex-1">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">
                  <div class="flex items-center">
                    <svg class="w-4 h-4 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                    </svg>
                    Collection Point (CPP)
                  </div>
                </label>
                <select id="monthlyCppFilter" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                  <option value="">Select CPP</option>
                  <% if (typeof cppList !== 'undefined' && cppList && cppList.length > 0) { %>
                    <% cppList.forEach(cpp => { %>
                      <option value="<%= cpp.id %>" <%= (selectedCppId == cpp.id) ? 'selected' : '' %>><%= cpp.name %></option>
                    <% }) %>
                  <% } %>
                </select>
              </div>
            </div>
            
            <!-- Mobile Layout: Vertical -->
            <div class="md:hidden">
              <!-- Mobile Filter Type Selection -->
              <div class="mb-4 p-4 bg-blue-50 dark:bg-blue-900/20 rounded-lg border border-blue-200 dark:border-blue-800">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-200 mb-3">
                  <div class="flex items-center">
                    <svg class="w-4 h-4 mr-2 text-gray-600 dark:text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path>
                    </svg>
                    Filter Type
                  </div>
                </label>
                <div class="flex space-x-4">
                  <label class="flex items-center p-2 rounded-lg hover:bg-blue-100 dark:hover:bg-blue-800 transition-colors flex-1 justify-center">
                    <input type="radio" name="filterTypeMobile" value="daily" id="filterTypeDailyMobile" class="mr-2 text-blue-600 dark:text-blue-400 focus:ring-blue-500" checked>
                    <span class="text-sm font-medium text-gray-700 dark:text-gray-200">Daily</span>
                  </label>
                  <label class="flex items-center p-2 rounded-lg hover:bg-blue-100 dark:hover:bg-blue-800 transition-colors flex-1 justify-center">
                    <input type="radio" name="filterTypeMobile" value="bulk" id="filterTypeBulkMobile" class="mr-2 text-blue-600 dark:text-blue-400 focus:ring-blue-500">
                    <span class="text-sm font-medium text-gray-700 dark:text-gray-200">Bulk Entry</span>
                  </label>
                  <label class="flex items-center p-2 rounded-lg hover:bg-blue-100 dark:hover:bg-blue-800 transition-colors flex-1 justify-center">
                    <input type="radio" name="filterTypeMobile" value="monthly" id="filterTypeMonthlyMobile" class="mr-2 text-blue-600 dark:text-blue-400 focus:ring-blue-500">
                    <span class="text-sm font-medium text-gray-700 dark:text-gray-200">Monthly</span>
                  </label>
                </div>
              </div>

              <!-- Daily Mobile Filters -->
              <div id="dailyFiltersMobile" class="space-y-4">
                <div class="grid grid-cols-1 gap-4 p-4 bg-gray-50 dark:bg-gray-800 rounded-lg">
                  <!-- Date Filter -->
                  <div>
                    <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">
                      <div class="flex items-center">
                        <svg class="w-4 h-4 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                        Date
                      </div>
                    </label>
                    <input type="date" id="dateFilterMobile" name="date" value="<%= selectedDate %>" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                  </div>
                  
                  <!-- Time Filter -->
                  <div>
                    <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">
                      <div class="flex items-center">
                        <svg class="w-4 h-4 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        Time
                      </div>
                    </label>
                    <select id="timeFilterMobile" name="time" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                      <option value="day" <%= selectedTime === 'day' ? 'selected' : '' %>>Day (Total)</option>
                      <option value="morning" <%= selectedTime === 'morning' ? 'selected' : '' %>>Morning</option>
                      <option value="evening" <%= selectedTime === 'evening' ? 'selected' : '' %>>Evening</option>
                    </select>
                  </div>
                  
                  <!-- Milk Type Filter -->
                  <div>
                    <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">
                      <div class="flex items-center">
                        <svg class="w-4 h-4 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                        </svg>
                        Milk Type
                      </div>
                    </label>
                    <select id="milkTypeFilterMobile" name="milkType" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                      <option value="all" <%= (selectedMilkType === 'all' || !selectedMilkType) ? 'selected' : '' %>>All</option>
                      <option value="A1" <%= selectedMilkType === 'A1' ? 'selected' : '' %>>A1</option>
                      <option value="A2" <%= selectedMilkType === 'A2' ? 'selected' : '' %>>A2</option>
                      <option value="Buffalo" <%= selectedMilkType === 'Buffalo' ? 'selected' : '' %>>Buffalo</option>
                    </select>
                  </div>
                  
                  <!-- CPP Filter -->
                  <div>
                    <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">
                      <div class="flex items-center">
                        <svg class="w-4 h-4 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">

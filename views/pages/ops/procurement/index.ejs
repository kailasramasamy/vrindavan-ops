<!DOCTYPE html>
<html lang="en">
  <%- include('../../../partials/_head', { seo }) %>

  <body class="bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 antialiased">
    <div class="min-h-dvh flex flex-col">
      <%- include('../../../partials/_subnav', { section: 'Procurement', user }) %>
      <main class="flex-1 bg-white dark:bg-gray-900">
        <section class="max-w-7xl mx-auto px-4 py-10">
          <header class="mb-6">
            <div>
              <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 dark:text-slate-100">Milk Procurement</h1>
              <p class="text-slate-600 dark:text-slate-300 mt-2">Dashboard</p>
            </div>
          </header>

          <!-- Quick Actions -->
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 mb-8">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-6">Quick Actions</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
              <a href="/procurement/cpp" class="flex items-center gap-4 p-5 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors group" title="Collection Point">
                <div class="p-2 bg-blue-100 dark:bg-blue-900/40 rounded-lg group-hover:bg-blue-200 dark:group-hover:bg-blue-900/50 transition-colors">
                  <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                  </svg>
                </div>
                <div>
                  <div class="text-base font-semibold text-gray-900 dark:text-gray-100">CPP</div>
                  <div class="text-sm text-gray-600 dark:text-gray-400">Collection Point</div>
                </div>
              </a>
              <a href="/procurement/rcc" class="flex items-center gap-4 p-5 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg hover:bg-green-100 dark:hover:bg-green-900/30 transition-colors group" title="Regional Collection Center">
                <div class="p-2 bg-green-100 dark:bg-green-900/40 rounded-lg group-hover:bg-green-200 dark:group-hover:bg-green-900/50 transition-colors">
                  <svg class="w-6 h-6 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                </div>
                <div>
                  <div class="text-base font-semibold text-gray-900 dark:text-gray-100">RCC</div>
                  <div class="text-sm text-gray-600 dark:text-gray-400">Regional Collection Center</div>
                </div>
              </a>
              <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'plant_manager')) { %>
              <a href="/procurement/mp" class="flex items-center gap-4 p-5 bg-purple-50 dark:bg-purple-900/20 border border-purple-200 dark:border-purple-800 rounded-lg hover:bg-purple-100 dark:hover:bg-purple-900/30 transition-colors group" title="Main Plant">
                <div class="p-2 bg-purple-100 dark:bg-purple-900/40 rounded-lg group-hover:bg-purple-200 dark:group-hover:bg-purple-900/50 transition-colors">
                  <svg class="w-6 h-6 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                  </svg>
                </div>
                <div>
                  <div class="text-base font-semibold text-gray-900 dark:text-gray-100">MP</div>
                  <div class="text-sm text-gray-600 dark:text-gray-400">Main Plant</div>
                </div>
              </a>
              <% } %> <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || (user.permissions && user.permissions.procurement && user.permissions.procurement.billing))) { %>
              <a href="/procurement/billing" class="flex items-center gap-4 p-5 bg-orange-50 dark:bg-orange-900/20 border border-orange-200 dark:border-orange-800 rounded-lg hover:bg-orange-100 dark:hover:bg-orange-900/30 transition-colors group" title="Billing">
                <div class="p-2 bg-orange-100 dark:bg-orange-900/40 rounded-lg group-hover:bg-orange-200 dark:group-hover:bg-orange-900/50 transition-colors">
                  <svg class="w-6 h-6 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                  </svg>
                </div>
                <div>
                  <div class="text-base font-semibold text-gray-900 dark:text-gray-100">Billing</div>
                  <div class="text-sm text-gray-600 dark:text-gray-400">Financial Management</div>
                </div>
              </a>
              <% } %>
            </div>
          </div>

          <!-- Dashboard Section -->
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 mb-8">
            <div class="flex items-center justify-between mb-6">
              <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Summary</h2>
              <div class="flex items-center gap-3">
                <label for="rangeDays" class="text-sm text-slate-600 dark:text-slate-300">Range</label>
                <select id="rangeDays" class="h-10 px-3 rounded-md border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 text-sm">
                  <option value="1">Today</option>
                  <option value="7">Last 7 days</option>
                  <option value="30" selected>Last 30 days</option>
                  <option value="90">Last 90 days</option>
                  <option value="custom">Custom Range</option>
                </select>
                <div id="customRangeContainer" class="hidden items-center gap-2">
                  <input type="date" id="customStart" class="h-10 px-3 rounded-md border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 text-sm" />
                  <span class="text-sm text-slate-500">to</span>

        </section>
      </main>
    </div>
    <script src="/assets/js/main.js" defer></script>
    <!-- Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- Chart.js Datalabels Plugin -->
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
    <script>
      // Chart functionality
      let volumeChart = null;

      function initializeChart() {
        try {
          const canvas = document.getElementById("volumeChart");
          if (!canvas) return;

          const ctx = canvas.getContext("2d");

          // Register the datalabels plugin if available
          let datalabelsEnabled = false;
          if (typeof ChartDataLabels !== "undefined") {
            try {
              Chart.register(ChartDataLabels);
              datalabelsEnabled = true;
            } catch (e) {
              console.warn("Failed to register ChartDataLabels plugin:", e);
            }
          }

          // Helper function to detect dark mode
          function isDarkMode() {
            return document.documentElement.classList.contains("dark") || document.body.classList.contains("dark") || (window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches);
          }

          // Set colors based on theme with better contrast
          const darkMode = isDarkMode();
          const textColor = darkMode ? "#d1d5db" : "#1f2937"; // lighter gray for dark mode (#d1d5db), darker for light mode
          const gridColor = darkMode ? "rgba(156, 163, 175, 0.2)" : "rgba(229, 231, 235, 0.4)";
          const titleColor = darkMode ? "#e5e7eb" : "#111827"; // very light gray for dark mode, very dark for light mode

          volumeChart = new Chart(ctx, {
            type: "line",
            data: {
              labels: [],
              datasets: [
                {
                  label: "Total Volume",
                  data: [],
                  borderColor: "#8b5cf6",
                  backgroundColor: "rgba(139, 92, 246, 0.1)",
                  borderWidth: 3,
                  fill: true,
                  tension: 0.4,
                },
                {
                  label: "A1 Milk",
                  data: [],
                  borderColor: "#10b981",
                  backgroundColor: "rgba(16, 185, 129, 0.1)",
                  borderWidth: 2,
                  fill: false,
                  tension: 0.4,
                },
                {
                  label: "A2 Milk",
                  data: [],
                  borderColor: "#ef4444",
                  backgroundColor: "rgba(239, 68, 68, 0.1)",
                  borderWidth: 2,
                  fill: false,
                  tension: 0.4,
                },
                {
                  label: "Buffalo Milk",
                  data: [],
                  borderColor: "#3b82f6",
                  backgroundColor: "rgba(59, 130, 246, 0.1)",
                  borderWidth: 2,
                  fill: false,
                  tension: 0.4,
                },
              ],
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              layout: {
                padding: {
                  top: 30,
                  right: 10,
                  bottom: 10,
                  left: 10,
                },
              },
              plugins: {
                legend: {
                  display: false,
                },
                tooltip: {
                  mode: "index",
                  intersect: false,
                  backgroundColor: "rgba(0, 0, 0, 0.8)",
                  titleColor: "white",
                  bodyColor: "white",
                  borderColor: "#e5e7eb",
                  borderWidth: 1,
                  callbacks: {
                    label: function (context) {
                      return context.dataset.label + ": " + context.parsed.y.toFixed(1) + " L";
                    },
                  },
                },
                ...(datalabelsEnabled && {
                  datalabels: {
                    display: function (context) {
                      // Show labels for all datasets (Total Volume, A1, A2, Buffalo)
                      // Get the value from the dataset data array
                      const dataPoint = context.dataset.data[context.dataIndex];
                      const value = typeof dataPoint === "object" && dataPoint !== null ? dataPoint.y || dataPoint : dataPoint;

                      // Show label if value exists and is greater than 0
                      return value !== null && value !== undefined && value !== "" && !isNaN(Number(value)) && Number(value) > 0;
                    },
                    color: function (context) {
                      // Total Volume line shows white labels
                      if (context.datasetIndex === 0) {
                        return "#ffffff";
                      }
                      // Match the border color of each dataset for others
                      const colors = ["#8b5cf6", "#10b981", "#ef4444", "#3b82f6"]; // Total (purple), A1 (green), A2 (red), Buffalo (blue)
                      return colors[context.datasetIndex] || "#374151";
                    },
                    font: {
                      size: 10,
                      weight: "normal",
                    },
                    formatter: function (value, context) {
                      // Get the actual value from the dataset data array
                      const dataPoint = context.dataset.data[context.dataIndex];
                      const dataValue = typeof dataPoint === "object" && dataPoint !== null ? dataPoint.y || dataPoint : dataPoint || value || 0;
                      const numValue = Number(dataValue);

                      if (!isNaN(numValue) && numValue > 0) {
                        return numValue.toFixed(0);
                      }
                      return "";
                    },
                    anchor: "end",
                    align: "top",
                    offset: 4,
                    clamp: true,
                  },
                }),
              },
              scales: {
                x: {
                  display: true,
                  title: {
                    display: true,
                    text: "Date",
                    color: titleColor,
                    font: {
                      size: 13,
                      weight: "bold",
                    },
                    padding: {
                      top: 10,
                    },
                  },
                  grid: {
                    display: false,
                    color: gridColor,
                  },
                  ticks: {
                    color: textColor,
                    font: {
                      size: 11,
                      weight: "500",
                    },
                    maxRotation: 45,
                    minRotation: 0,
                  },
                },
                y: {
                  display: true,
                  title: {
                    display: true,
                    text: "Volume (Liters)",
                    color: titleColor,
                    font: {
                      size: 13,
                      weight: "bold",
                    },
                    padding: {
                      bottom: 10,
                    },
                  },
                  grid: {
                    color: gridColor,
                    drawBorder: false,
                  },
                  ticks: {
                    color: textColor,
                    font: {
                      size: 11,
                      weight: "500",
                    },
                    callback: function (value) {
                      return value.toFixed(0) + "L";
                    },
                  },
                },
              },
              interaction: {
                mode: "nearest",
                axis: "x",
                intersect: false,
              },
            },
          });
        } catch (error) {
          console.error("Error initializing chart:", error);
        }
      }

      function formatDateLabel(label) {
        if (!label) return "";

        // If already in DD/MM format, return as is
        if (/^\d{2}\/\d{2}$/.test(label)) {
          return label;
        }

        // Try parsing as date string (handles formats like "Jan 15", "2024-01-15", etc.)
        try {
          const date = new Date(label);
          if (!isNaN(date.getTime())) {
            const day = String(date.getDate()).padStart(2, "0");
            const month = String(date.getMonth() + 1).padStart(2, "0");
            return day + "/" + month;
          }
        } catch (e) {
          // Try to parse month abbreviations like "Jan 15"
          const monthMap = {
            Jan: "01",
            Feb: "02",
            Mar: "03",
            Apr: "04",
            May: "05",
            Jun: "06",
            Jul: "07",
            Aug: "08",
            Sep: "09",
            Oct: "10",
            Nov: "11",
            Dec: "12",
          };

          const parts = label.trim().split(" ");
          if (parts.length >= 2) {
            const monthStr = parts[0];
            const dayStr = parts[1];
            if (monthMap[monthStr] && dayStr) {
              const day = String(parseInt(dayStr)).padStart(2, "0");
              return day + "/" + monthMap[monthStr];
            }
          }
        }

        return label;
      }

      function updateChartColors() {
        if (!volumeChart) return;

        const darkMode = document.documentElement.classList.contains("dark") || document.body.classList.contains("dark") || (window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches);

        const textColor = darkMode ? "#d1d5db" : "#1f2937";
        const gridColor = darkMode ? "rgba(156, 163, 175, 0.2)" : "rgba(229, 231, 235, 0.4)";
        const titleColor = darkMode ? "#e5e7eb" : "#111827";

        // Update axis colors
        if (volumeChart.options.scales) {
          if (volumeChart.options.scales.x) {
            volumeChart.options.scales.x.title.color = titleColor;
            volumeChart.options.scales.x.ticks.color = textColor;
          }
          if (volumeChart.options.scales.y) {
            volumeChart.options.scales.y.title.color = titleColor;
            volumeChart.options.scales.y.ticks.color = textColor;
            volumeChart.options.scales.y.grid.color = gridColor;
          }
        }

        volumeChart.update("none");
      }

      function updateChart(data) {
        if (!volumeChart) return;

        // Format labels as DD/MM
        const formattedLabels = (data.labels || []).map(formatDateLabel);

        volumeChart.data.labels = formattedLabels;
        volumeChart.data.datasets[0].data = data.datasets.total || [];
        volumeChart.data.datasets[1].data = data.datasets.milkTypes?.A1 || [];
        volumeChart.data.datasets[2].data = data.datasets.milkTypes?.A2 || [];
        volumeChart.data.datasets[3].data = data.datasets.milkTypes?.Buffalo || [];

        // Update colors in case theme changed
        updateChartColors();
      }

      function showChartLoading(show) {
        const loading = document.getElementById("chartLoading");
        if (loading) {
          loading.style.display = show ? "flex" : "none";
        }
      }

      async function loadDashboard(days, endDate) {
        const spinner = document.getElementById("dashboardSpinner");
        const content = document.getElementById("dashboardContent");
        spinner.classList.remove("hidden");
        content.classList.add("hidden");
        showChartLoading(true);

        try {
          const qs = new URLSearchParams();
          qs.append('days', String(days));
          if (endDate) qs.append('endDate', endDate);
          const res = await fetch(`/api/procurement/dashboard/chart?${qs.toString()}`);
          const json = await res.json();
          if (!json.success) throw new Error("Failed to load");

          const data = json.data;
          const volumes = data.datasets.total || [];
          const cppCounts = data.datasets.cppCount || [];
          const avgFatArr = data.datasets.avgFat || [];
          const avgSnfArr = data.datasets.avgSnf || [];

          const totalVolume = data.summary?.totalVolume || volumes.reduce((a, b) => a + (b || 0), 0);
          const avgFat = avgFatArr.length ? avgFatArr.reduce((a, b) => a + (b || 0), 0) / avgFatArr.length : 0;
          const avgSnf = avgSnfArr.length ? avgSnfArr.reduce((a, b) => a + (b || 0), 0) / avgSnfArr.length : 0;
          const avgCpp = cppCounts.length ? Math.round(cppCounts.reduce((a, b) => a + (b || 0), 0) / cppCounts.length) : 0;

          document.getElementById("totalVolume").textContent = (totalVolume || 0).toLocaleString("en-IN", { maximumFractionDigits: 2 }) + " L";
          document.getElementById("cppCount").textContent = avgCpp;
          document.getElementById("avgFat").textContent = (avgFat || 0).toFixed(2) + "%";
          document.getElementById("avgSnf").textContent = (avgSnf || 0).toFixed(2) + "%";

          const milkTypeContainer = document.getElementById("milkTypeBreakdown");
          const milkTypes = data.datasets.milkTypes || {};
          const entries = Object.entries(milkTypes);
          if (entries.length) {
            milkTypeContainer.innerHTML = entries
              .map(([type, arr]) => {
                const sum = (arr || []).reduce((a, b) => a + (b || 0), 0);
                return `
                <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-4 border border-gray-200 dark:border-gray-600">
                  <div class="flex items-center justify-between mb-2">
                    <span class="text-sm font-medium text-gray-700 dark:text-gray-300">${type}</span>
                    <span class="text-lg font-bold text-gray-900 dark:text-white">${sum.toLocaleString("en-IN", { maximumFractionDigits: 2 })} L</span>
                  </div>
                </div>
              `;
              })
              .join("");
          } else {
            milkTypeContainer.innerHTML = '<p class="text-gray-500 dark:text-gray-400 text-sm col-span-full text-center py-4">No milk type data available</p>';
          }

          // Update chart with data
          if (volumeChart) {
            updateChart(data);
          }

          spinner.classList.add("hidden");
          content.classList.remove("hidden");
          showChartLoading(false);
        } catch (e) {
          spinner.innerHTML = '<p class="text-gray-600 dark:text-gray-300 text-sm">Unable to load dashboard</p>';
          showChartLoading(false);
          console.error(e);
        }
      }

      function initDashboard() {
        // Initialize chart first
        if (typeof Chart !== "undefined") {
          initializeChart();
        } else {
          // Wait for Chart.js to load
          setTimeout(initializeChart, 100);
        }

        const rangeEl = document.getElementById("rangeDays");
        const customWrap = document.getElementById("customRangeContainer");
        const customStart = document.getElementById("customStart");
        const customEnd = document.getElementById("customEnd");

        const todayStr = new Date().toISOString().slice(0,10);
        if (customStart) customStart.value = todayStr;
        if (customEnd) customEnd.value = todayStr;

        function computeDaysDiff(startStr, endStr){
          try{
            const s = new Date(startStr);
            const e = new Date(endStr);
            const diffMs = e - s;
            if (isNaN(diffMs) || diffMs < 0) return null;
            return Math.floor(diffMs / (1000*60*60*24)) + 1;
          }catch(_){ return null; }
        }

        function loadForSelection(){
          const val = rangeEl.value;
          if (val === 'custom'){
            if (customWrap) customWrap.classList.remove('hidden');
            const d = computeDaysDiff(customStart.value, customEnd.value) || 1;
            const end = customEnd.value || todayStr;
            loadDashboard(d, end);
          } else {
            if (customWrap) customWrap.classList.add('hidden');
            const num = parseInt(val || '30', 10);
            loadDashboard(num, todayStr);
          }
        }

        loadForSelection();
        rangeEl.addEventListener('change', loadForSelection);
        if (customStart) customStart.addEventListener('change', loadForSelection);
        if (customEnd) customEnd.addEventListener('change', loadForSelection);

        // Watch for theme changes
        const observer = new MutationObserver(() => {
          if (volumeChart) {
            updateChartColors();
          }
        });

        observer.observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["class"],
        });

        observer.observe(document.body, {
          attributes: true,
          attributeFilter: ["class"],
        });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initDashboard);
      } else {
        initDashboard();
      }
    </script>
  </body>
</html>

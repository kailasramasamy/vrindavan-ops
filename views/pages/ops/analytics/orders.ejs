  async function loadCategoryPerformanceData() {
    const categoryId = document.getElementById('categorySelect').value;
    const subCategoryId = document.getElementById('subCategorySelect').value;
    const dateRange = document.getElementById('categoryPerformanceDateRange').value;
    
    if (!categoryId || !subCategoryId) {
      // Clear chart if no category/sub-category selected
      if (categoryPerformanceChart) {
        categoryPerformanceChart.data.labels = [];
        categoryPerformanceChart.data.datasets = [];
        categoryPerformanceChart.update();
      }
      return;
    }

    // Show loading spinner
    const btn = document.getElementById('applyCategoryFilterBtn');
    const btnText = document.getElementById('categoryFilterBtnText');
    const spinner = document.getElementById('categoryFilterSpinner');
    
    btn.disabled = true;
    btnText.textContent = 'Loading...';
    spinner.classList.remove('hidden');

    try {
      const response = await fetch(`/analytics/api/orders/category-performance?categoryId=${categoryId}&subCategoryId=${subCategoryId}&range=${dateRange}&groupBy=day`, {
        credentials: 'include',
        headers: {
          'Accept': 'application/json',
          'Content-Type': 'application/json'
        }
      });
      const result = await response.json();

      if (result.success && categoryPerformanceChart) {
        const data = result.data;
        
        if (data.length > 0) {
          // Get all unique date periods
          const allDates = [...new Set(data.flatMap(product => product.data.map(item => item.date_period)))].sort();
          
          // Create datasets for each product
          const datasets = data.map((product, index) => {
            const colors = [
              'rgb(59, 130, 246)',   // Blue
              'rgb(16, 185, 129)',   // Green
              'rgb(245, 158, 11)',   // Yellow
              'rgb(239, 68, 68)',    // Red
              'rgb(139, 92, 246)',   // Purple
              'rgb(236, 72, 153)',   // Pink
              'rgb(14, 165, 233)',   // Sky Blue
              'rgb(34, 197, 94)',    // Emerald
              'rgb(251, 146, 60)',   // Orange
              'rgb(168, 85, 247)'    // Violet
            ];
            
            const dataPoints = allDates.map(date => {
              const productData = product.data.find(item => item.date_period === date);
              return productData ? productData.total_quantity : 0;
            });

            return {
              label: `${product.name} ${product.unit ? `(${product.unit})` : ''}`,
              data: dataPoints,
              borderColor: colors[index % colors.length],
              backgroundColor: colors[index % colors.length] + '20',
              pointBackgroundColor: colors[index % colors.length],
              pointBorderColor: colors[index % colors.length],
              borderWidth: 2,
              fill: false,
              tension: 0.4
            };
          });

          // Format labels based on groupBy
          const labels = allDates.map(date => {
            const dateObj = new Date(date);
            return dateObj.toLocaleDateString('en-GB', { day: '2-digit', month: '2-digit' });
          });

          // Dynamically adjust chart height based on number of products
          const chartContainer = document.getElementById('categoryPerformanceChartContainer');
          const baseHeight = 400;
          const additionalHeight = Math.max(0, (data.length - 5) * 50); // Add 50px for each product beyond 5
          chartContainer.style.height = `${baseHeight + additionalHeight}px`;

          categoryPerformanceChart.data.labels = labels;
          categoryPerformanceChart.data.datasets = datasets;
          categoryPerformanceChart.update();
        }
      }
    } catch (error) {
      console.error('Error loading category performance data:', error);
    } finally {
      // Hide loading spinner
      btn.disabled = false;
      btnText.textContent = 'Apply Filter';
      spinner.classList.add('hidden');
    }
  }

  // Initialize category dropdowns
  async function initializeCategoryDropdowns() {
    try {
      // Load categories
      const categoriesResponse = await fetch('/analytics/api/orders/categories', {
        credentials: 'include',
        headers: {
          'Accept': 'application/json',
          'Content-Type': 'application/json'
        }
      });
      const categoriesResult = await categoriesResponse.json();
      
      if (categoriesResult.success) {
        const categorySelect = document.getElementById('categorySelect');
        categoriesResult.data.forEach(category => {
          const option = document.createElement('option');
          option.value = category.id;
          option.textContent = category.name;
          categorySelect.appendChild(option);
        });
      }

      // Category change handler
      document.getElementById('categorySelect').addEventListener('change', async function() {
        const categoryId = this.value;
        const subCategorySelect = document.getElementById('subCategorySelect');
        
        // Clear sub-categories
        subCategorySelect.innerHTML = '<option value="">Select Sub-Category</option>';
        
        if (categoryId) {
          try {
            const response = await fetch(`/analytics/api/orders/sub-categories?categoryId=${categoryId}`, {
              credentials: 'include',

  // Milk Trend Data Loading Functionality
  // Auto-load milk trend data when page loads
  async function loadMilkTrendData() {
    const spinnerOverlay = document.getElementById('milkTrendSpinnerOverlay');
    
    // Show spinner overlay when starting to load
    if (spinnerOverlay) {
      spinnerOverlay.style.display = 'flex';
    }
    
    try {
      // Get current date range from the dropdown selector
      const dateRangeSelect = document.getElementById('dateRange');
      const range = dateRangeSelect ? dateRangeSelect.value : 'last_7_days'; // Default to 7 days for faster loading
      
      // Load milk trend data via API
      const response = await fetch(`/analytics/api/orders/milk-trend-expanded?range=${range}&groupBy=day&page=1`, {
        credentials: 'include',
        headers: {
          'Accept': 'application/json',
          'Content-Type': 'application/json'
        }
      });
      if (!response.ok) {
        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
      }
      
      const result = await response.json();
      
      if (result && result.success && result.data && result.data.length > 0) {
        // Update the milk trend data
        window.milkTrendData = result.data;
        
        // Recreate the milk trend chart with new data
        recreateMilkTrendChart();
        
        // Hide spinner overlay
        spinnerOverlay.style.display = 'none';
        
        // Show success message
      } else if (result && result.success && result.data && result.data.length === 0) {
        // No data available for this date range - show empty chart
        recreateMilkTrendChart();
        spinnerOverlay.style.display = 'none';
        
      } else {
        throw new Error(result?.error || 'No data received');
      }
    } catch (error) {
      console.error('Error loading milk trend data:', error);
      spinnerOverlay.style.display = 'none';
      
    }
  }

  // Start loading milk trend data when page loads
  loadMilkTrendData();


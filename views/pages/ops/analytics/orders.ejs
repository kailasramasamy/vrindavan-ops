  // Get selected product IDs from checkboxes
  function getSelectedProductIds() {
    const checkboxes = document.querySelectorAll('.product-checkbox:checked');
    return Array.from(checkboxes).map(cb => cb.dataset.id);
  }

  async function loadProductPerformanceData() {
    const selectedProducts = getSelectedProductIds();
    const dateRange = document.getElementById('performanceDateRange').value;
    const groupBy = "day"; // Fixed to day grouping
    
    

    if (selectedProducts.length === 0) {
      // Clear chart if no products selected
      if (productPerformanceChart) {
        productPerformanceChart.data.labels = [];
        productPerformanceChart.data.datasets = [];
        productPerformanceChart.update();
      }
      return;
    }

    // Show loading spinner
    const btn = document.getElementById('applyFilterBtn');
    const btnText = document.getElementById('productFilterBtnText');
    const spinner = document.getElementById('productFilterSpinner');
    
    btn.disabled = true;
    btnText.textContent = 'Loading...';
    spinner.classList.remove('hidden');

    try {
      const productIds = selectedProducts.join(',');
      const response = await fetch(`/analytics/api/orders/product-performance?productId=${productIds}&range=${dateRange}&groupBy=${groupBy}`, {
        credentials: 'include',
        headers: {
          'Accept': 'application/json',
          'Content-Type': 'application/json'
        }
      });
      const result = await response.json();

      if (result.success && productPerformanceChart) {
        // For multiple products, we need to structure the data differently
        const data = result.data;
        
        
        
        if (data.length > 0) {
          // Get all unique date periods
          const allDates = [...new Set(data.flatMap(product => product.data.map(item => item.date_period)))].sort();
          
          // Create datasets for each product
          const datasets = data.map((product, index) => {
            const colors = [
              'rgb(59, 130, 246)',   // Blue
              'rgb(16, 185, 129)',   // Green
              'rgb(245, 158, 11)',   // Yellow
              'rgb(239, 68, 68)',    // Red
              'rgb(139, 92, 246)'    // Purple
            ];
            
            const dataPoints = allDates.map(date => {
              const productData = product.data.find(item => item.date_period === date);
              return productData ? productData.total_quantity : 0;
            });

            return {
              label: `${product.name} ${product.unit ? `(${product.unit})` : ''}`,
              data: dataPoints,
              borderColor: colors[index % colors.length],
              backgroundColor: colors[index % colors.length] + '20',
              pointBackgroundColor: colors[index % colors.length],
              pointBorderColor: colors[index % colors.length],
              borderWidth: 2,
              fill: false,
              tension: 0.4
            };
          });

          // Format labels based on groupBy
            const labels = allDates.map(date => {
              const dateObj = new Date(date);
              return dateObj.toLocaleDateString('en-GB', { day: '2-digit', month: '2-digit' });
            });

          productPerformanceChart.data.labels = labels;
          productPerformanceChart.data.datasets = datasets;
          productPerformanceChart.update();
        }
      }
    } catch (error) {
      console.error('Error loading product performance data:', error);
    } finally {
      // Hide loading spinner
      btn.disabled = false;
      btnText.textContent = 'Apply Filter';
      spinner.classList.add('hidden');
    }
  }


  // Global function to update selected products display
  function updateSelectedProducts() {
    const selectedProductsContainer = document.getElementById('selectedProducts');
    selectedProductsContainer.innerHTML = '';
    const selectedCheckboxes = document.querySelectorAll('.product-checkbox:checked');
    
    selectedCheckboxes.forEach(checkbox => {
      const productOption = checkbox.closest('.product-option');
      const productName = productOption.dataset.name;
      const productUnit = productOption.dataset.unit;
      
      const selectedTag = document.createElement('div');
      selectedTag.className = 'inline-flex items-center px-2 py-1 rounded-full text-xs bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200';
      selectedTag.innerHTML = `
        ${productName} ${productUnit ? `(${productUnit})` : ''}
        <button type="button" class="ml-1 text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-200" onclick="removeSelectedProduct('${checkbox.dataset.id}')">
          ×
        </button>
      `;
      selectedProductsContainer.appendChild(selectedTag);
    });
  }

  // Searchable dropdown functionality
  function initializeSearchableDropdown() {
    const searchInput = document.getElementById('productSearchInput');
    const dropdown = document.getElementById('productDropdown');
    const selectedProductsContainer = document.getElementById('selectedProducts');
    const productOptions = document.querySelectorAll('.product-option');
    const checkboxes = document.querySelectorAll('.product-checkbox');

    // Show/hide dropdown based on search input
    searchInput.addEventListener('input', function() {
      const searchTerm = this.value.toLowerCase();
      
      if (searchTerm.length > 0) {
        dropdown.classList.remove('hidden');
        
        productOptions.forEach(option => {
          const productName = option.dataset.name.toLowerCase();
          const unit = option.dataset.unit.toLowerCase();
          const searchText = `${productName} ${unit}`;
          
          if (searchText.includes(searchTerm)) {
            option.style.display = 'block';
          } else {
            option.style.display = 'none';
          }
        });
      } else {
        dropdown.classList.add('hidden');
      }
    });

    // Handle checkbox selection
    checkboxes.forEach(checkbox => {
      checkbox.addEventListener('change', function() {
        const productId = this.dataset.id;
        const productOption = this.closest('.product-option');
        const productName = productOption.dataset.name;
        const productUnit = productOption.dataset.unit;
        
        updateSelectedProducts();
        
        // Automatically update chart when products are selected/deselected (with debounce)
        if (chartUpdateTimeout) {
          clearTimeout(chartUpdateTimeout);
        }
        chartUpdateTimeout = setTimeout(() => {
          loadProductPerformanceData();
        }, 300);
      });
    });

    // Handle clicking on product option (not just checkbox)
    productOptions.forEach(option => {
      option.addEventListener('click', function(e) {
        if (e.target.type !== 'checkbox') {
          const checkbox = this.querySelector('.product-checkbox');
          checkbox.checked = !checkbox.checked;
          checkbox.dispatchEvent(new Event('change'));
        }
      });
    });

    // Hide dropdown when clicking outside
    document.addEventListener('click', function(e) {
      if (!searchInput.contains(e.target) && !dropdown.contains(e.target)) {
        dropdown.classList.add('hidden');
      }
    });


    // Make removeSelectedProduct globally available
    window.removeSelectedProduct = function(productId) {
      const checkbox = document.querySelector(`.product-checkbox[data-id="${productId}"]`);
      if (checkbox) {
        checkbox.checked = false;
        checkbox.dispatchEvent(new Event('change'));
      }
      // Chart will be updated automatically via the change event
    };
  }

  // Reset selected products only (keep date range unchanged)
  function resetProductSelection() {
    // Uncheck all checkboxes
    const checkboxes = document.querySelectorAll('.product-checkbox:checked');
    checkboxes.forEach(checkbox => {
      checkbox.checked = false;
    });

    // Clear selected products display
    updateSelectedProducts();

    // Clear the search input
    const searchInput = document.getElementById('productSearchInput');
    if (searchInput) {
      searchInput.value = '';
      searchInput.placeholder = 'Search and select multiple products...';
    }

    // Hide the dropdown
    const dropdown = document.getElementById('productDropdown');
    if (dropdown) {
      dropdown.classList.add('hidden');
    }


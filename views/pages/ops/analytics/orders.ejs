  function updateSelectedCategoryInfo() {
    const categorySelect = document.getElementById('categorySelect');
    const subCategorySelect = document.getElementById('subCategorySelect');
    const selectedCategoryInfo = document.getElementById('selectedCategoryInfo');
    
    const categoryText = categorySelect.options[categorySelect.selectedIndex]?.text || '';
    const subCategoryText = subCategorySelect.options[subCategorySelect.selectedIndex]?.text || '';
    
    if (categoryText && subCategoryText) {
      selectedCategoryInfo.innerHTML = `<strong>${categoryText}</strong> → <strong>${subCategoryText}</strong>`;
    } else if (categoryText) {
      selectedCategoryInfo.innerHTML = `<strong>${categoryText}</strong> → Select Sub-Category`;
    } else {
      selectedCategoryInfo.innerHTML = 'Select Category and Sub-Category';
    }

  function recreateMilkTrendChart() {
    // Destroy existing chart if it exists
    const existingChart = Chart.getChart('milkOrderTrendChart');
    if (existingChart) {
      existingChart.destroy();
    }
    
    // Get chart context
    const milkOrderTrendCtx = document.getElementById('milkOrderTrendChart').getContext('2d');
    
    // Process milk trend data for multiple products
    let milkLabels = [];
    let milkDatasets = [];
    
    if (window.milkTrendData && window.milkTrendData.length > 0) {
      // Get all unique dates from all products
      const allMilkDates = [...new Set(window.milkTrendData.flatMap(product => product.data.map(item => item.period)))].sort();
      
      // Format labels
      milkLabels = allMilkDates.map(date => {
        if (date.includes('T') || date.includes(' ')) {
          const datePart = date.split('T')[0].split(' ')[0];
          const [year, month, day] = datePart.split('-');
          return `${day}/${month}`;
        } else if (date.includes('-') && date.split('-').length === 3) {
          const [year, month, day] = date.split('-');
          return `${day}/${month}`;
        }
        return date;
      });
      
      // Create datasets for each product with custom colors
      milkDatasets = window.milkTrendData.map((product) => {
        const dataPoints = allMilkDates.map(date => {
          const productData = product.data.find(item => item.period === date);
          return productData ? productData.total_quantity : 0;
        });

        const color = getMilkColor(product.name, product.unit);

        return {
          label: `${product.name} ${product.unit ? `(${product.unit})` : ''}`,
          data: dataPoints,
          borderColor: color,
          backgroundColor: color + '20',
          pointBackgroundColor: color,
          pointBorderColor: color,
          borderWidth: 2,
          fill: false,
          tension: 0.4

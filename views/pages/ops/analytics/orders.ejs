        responsive: true,
        maintainAspectRatio: false,
        layout: {
          padding: {
            top: 10
          }
        },
        plugins: {
          legend: {
            labels: {
              color: document.documentElement.classList.contains('dark') ? '#e5e7eb' : '#374151',
              usePointStyle: true,
              pointStyle: 'circle',
              padding: 25,
              boxWidth: 12,
              boxHeight: 12
            },
            position: 'top',

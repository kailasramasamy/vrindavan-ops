              bottom: 0
            }
          },
          datalabels: {
            color: document.documentElement.classList.contains('dark') ? '#e5e7eb' : '#374151',
            font: {
              weight: 'bold',
              size: 10
            },
            formatter: function(value) {
              return value > 0 ? value : '';

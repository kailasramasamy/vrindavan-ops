<%
  const typeLabels = {
    total: "Total Products",
    low_stock: "Low Stock Products",
    out_of_stock: "Out of Stock Products",
    best_selling: "Best Selling Products",
    worst_selling: "Worst Selling Products",
    no_sales: "Products Without Sales",
  };

  const typeDescriptions = {
    total: "Products with positive stock balance.",
    low_stock: "Inventory-tracked products with stock at or below the defined threshold.",
    out_of_stock: "Inventory-tracked products with zero or negative stock.",
    best_selling: "Products performing above average sales volume for the selected period.",
    worst_selling: "Products with minimal sales volume in the selected period.",
    no_sales: "Active products that recorded no sales during the selected period.",
  };

  const label = typeLabels[listType] || "Products";
  const description = typeDescriptions[listType] || "Detailed product breakdown.";
  const usesRangeFlag = typeof usesRange !== "undefined" ? usesRange : false;
  const startLabel = usesRangeFlag ? (filters.startDate || "N/A") : "All Time";
  const endLabel = usesRangeFlag ? (filters.endDate || "N/A") : "All Time";
  const rangeLabel = usesRangeFlag ? (filters.range || "N/A") : "All Time";
%>

<%- include('../../../partials/_head', { title, seo }) %>
<%- include('../../../partials/_subnav', { section: 'Analytics', subsection: 'Products', page: label, user }) %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 mb-6">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white"><%= label %></h1>
        <p class="text-gray-600 dark:text-gray-300 mt-2"><%= description %></p>
      </div>
      <div class="flex items-center gap-2">
        <a href="/analytics/products" class="inline-flex items-center px-4 py-2 text-sm font-medium rounded-md border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          Back to Summary
        </a>
      </div>
    </div>

    <div id="productsListRoot"
      data-list-type="<%= listType %>"
      data-range="<%= filters.range %>"
      data-start-date="<%= filters.startDate %>"
      data-end-date="<%= filters.endDate %>"
      class="space-y-6">

      <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700">
        <div class="p-5 border-b border-gray-200 dark:border-gray-700">
          <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-4">
            <div>
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Product Breakdown</h2>
              <p class="text-sm text-gray-500 dark:text-gray-400">Detailed list generated from the analytics summary.</p>
            </div>
            
            <!-- Date Range Filter - Top Right -->
            <div class="flex flex-col gap-2">
              <div class="flex flex-wrap items-center gap-2">
                <label class="text-sm font-medium text-gray-600 dark:text-gray-400">Date Range:</label>
                <select id="productsListRangeFilter" class="px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm">
                  <option value="today">Today</option>
                  <option value="yesterday">Yesterday</option>
                  <option value="7d">Last 7 Days</option>
                  <option value="30d" selected>Last 30 Days</option>
                  <option value="90d">Last 90 Days</option>
                  <option value="1y">Last 1 Year</option>
                  <option value="custom">Custom Range</option>
                </select>
              </div>
              <div id="productsListCustomRange" class="hidden flex items-center gap-2">
                <input type="date" id="productsListStartDate" class="px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm">
                <span class="text-gray-500 text-sm">to</span>
                <input type="date" id="productsListEndDate" class="px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-sm">
                <button id="productsListApplyCustomRange" class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 text-sm">Apply</button>
              </div>
            </div>
          </div>

          <!-- Category Filters and Product Count -->
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div id="productsListRangeSummary" class="text-xs text-gray-500 dark:text-gray-400 italic"></div>
            <div class="flex flex-wrap items-center gap-3">
              <label class="text-sm font-medium text-gray-600 dark:text-gray-400" for="productsListCategoryFilter">Category</label>
              <select id="productsListCategoryFilter" class="px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
                <option value="">All</option>
              </select>
              <label class="text-sm font-medium text-gray-600 dark:text-gray-400" for="productsListSubcategoryFilter">Sub-category</label>
              <select id="productsListSubcategoryFilter" class="px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
                <option value="">All</option>
              </select>
              <button id="productsListResetFilters" class="px-3 py-2 text-sm text-gray-600 dark:text-gray-300 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700">
                Reset
              </button>
            </div>
            <div class="text-sm text-gray-500 dark:text-gray-400">
              Showing <span id="productsListCount" class="font-semibold text-gray-900 dark:text-white">0</span> products
            </div>
          </div>
        </div>
        <div class="overflow-x-auto relative">
          <!-- Loading Spinner Overlay -->
          <div id="productsListSpinner" class="hidden absolute inset-0 bg-white dark:bg-gray-800 bg-opacity-75 dark:bg-opacity-75 z-10 flex items-center justify-center">
            <div class="flex flex-col items-center gap-2">
              <svg class="animate-spin h-8 w-8 text-blue-600 dark:text-blue-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              <p class="text-sm text-gray-600 dark:text-gray-400">Loading...</p>
            </div>
          </div>
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-900">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Product<br/><span class="text-xs font-normal text-gray-400">(Unit)</span></th>
                <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Category</th>
                <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Sub-category</th>
                <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Stock</th>
                <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Low Threshold</th>
                <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Qty Sold</th>
                <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Revenue (₹)</th>
                <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Avg Daily Sales</th>
                <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Days Since Last Sale</th>
                <th class="px-3 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Last Sale</th>
              </tr>
            </thead>
            <tbody id="productsListTbody" class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
              <tr>
                <td colspan="10" class="px-4 py-6 text-center text-gray-500 dark:text-gray-400">Loading products...</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  window.productsListConfig = {
    type: "<%= listType %>",
    range: "<%= filters.range %>",
    startDate: "<%= filters.startDate %>",
    endDate: "<%= filters.endDate %>",
    usesRange: <%= usesRangeFlag ? "true" : "false" %>
  };
</script>
<script src="/assets/js/analytics-products-list.js?v=<%= Date.now() %>"></script>


<%- include('../../../partials/_head', { title: title, seo: seo }) %>
<%- include('../../../partials/_subnav', { section: 'Analytics', subsection: 'Products', page: 'Products', user }) %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col gap-3 mb-8">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Products Analytics</h1>
        <p class="text-gray-600 dark:text-gray-300 mt-1">Track product availability, sales performance, and stock velocity.</p>
      </div>
    </div>

    <div id="productsAnalyticsRoot"
      data-default-range="<%= filters.range %>"
      data-start-date="<%= filters.startDate %>"
      data-end-date="<%= filters.endDate %>"
      class="space-y-8">

      <section>
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Inventory Overview</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <a data-product-card-link data-scope="global" data-type="total" href="/analytics/products/list?type=total" class="block bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-5 hover:shadow-lg transition-shadow focus:outline-none focus:ring-2 focus:ring-blue-500">
            <div class="flex items-center gap-3">
              <div class="p-3 rounded-md bg-blue-100 dark:bg-blue-900">
                <svg class="w-6 h-6 text-blue-600 dark:text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2"></path></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Total Products</p>
                <p id="cardTotalProducts" class="text-2xl font-bold text-gray-900 dark:text-white">--</p>
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Active catalog items</p>
              </div>
            </div>
          </a>

          <a data-product-card-link data-scope="global" data-type="low_stock" href="/analytics/products/list?type=low_stock" class="block bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-5 hover:shadow-lg transition-shadow focus:outline-none focus:ring-2 focus:ring-amber-500">
            <div class="flex items-center gap-3">
              <div class="p-3 rounded-md bg-amber-100 dark:bg-amber-900">
                <svg class="w-6 h-6 text-amber-600 dark:text-amber-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M9 21h6a2 2 0 002-2V7a2 2 0 00-2-2h-1.586a1 1 0 01-.707-.293l-1.414-1.414A1 1 0 0011.586 3H9a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Low Stock (&le; threshold)</p>
                <p id="cardLowStock" class="text-2xl font-bold text-gray-900 dark:text-white">--</p>
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Inventory-tracked items nearing depletion</p>
              </div>
            </div>
          </a>

          <a data-product-card-link data-scope="global" data-type="out_of_stock" href="/analytics/products/list?type=out_of_stock" class="block bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-5 hover:shadow-lg transition-shadow focus:outline-none focus:ring-2 focus:ring-red-500">
            <div class="flex items-center gap-3">
              <div class="p-3 rounded-md bg-red-100 dark:bg-red-900">
                <svg class="w-6 h-6 text-red-600 dark:text-red-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-12.728 12.728m12.728 0L5.636 5.636"></path></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Out of Stock</p>
                <p id="cardOutOfStock" class="text-2xl font-bold text-gray-900 dark:text-white">--</p>
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Inventory-tracked items with zero balance</p>
              </div>
            </div>
          </a>

        </div>
      </section>

      <section>
        <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
          <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Sales Performance</h2>
          <div class="flex flex-wrap items-center gap-2 justify-end">
            <label for="productsRange" class="text-sm font-medium text-gray-700 dark:text-gray-300">Sales Date Range</label>
            <select id="productsRange" class="px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
              <option value="7d" <%= filters.range === '7d' ? 'selected' : '' %>>Last 7 days</option>
              <option value="14d" <%= filters.range === '14d' ? 'selected' : '' %>>Last 14 days</option>
              <option value="30d" <%= !filters || filters.range === '30d' ? 'selected' : '' %>>Last 30 days</option>
              <option value="90d" <%= filters.range === '90d' ? 'selected' : '' %>>Last 90 days</option>
              <option value="180d" <%= filters.range === '180d' ? 'selected' : '' %>>Last 180 days</option>
              <option value="365d" <%= filters.range === '365d' ? 'selected' : '' %>>Last 12 months</option>
              <option value="custom" <%= filters.range === 'custom' ? 'selected' : '' %>>Custom Range</option>
            </select>
            <div id="customRangePicker" class="hidden items-center gap-2">
              <input type="date" id="productsRangeStart" value="<%= filters.startDate %>" class="px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
              <span class="text-gray-500 dark:text-gray-400">to</span>
              <input type="date" id="productsRangeEnd" value="<%= filters.endDate %>" class="px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
              <button id="applyCustomRange" class="px-3 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-md text-sm">Apply</button>
            </div>
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <a data-product-card-link data-scope="range" data-type="best_selling" href="/analytics/products/list?type=best_selling" class="block bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-5 hover:shadow-lg transition-shadow focus:outline-none focus:ring-2 focus:ring-emerald-500">
            <div class="flex items-center gap-3">
              <div class="p-3 rounded-md bg-emerald-100 dark:bg-emerald-900">
                <svg class="w-6 h-6 text-emerald-600 dark:text-emerald-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m4 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Best Selling</p>
                <p id="cardBestSelling" class="text-2xl font-bold text-gray-900 dark:text-white">--</p>
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Above-average sales in selected range</p>
              </div>
            </div>
          </a>

          <a data-product-card-link data-scope="range" data-type="worst_selling" href="/analytics/products/list?type=worst_selling" class="block bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-5 hover:shadow-lg transition-shadow focus:outline-none focus:ring-2 focus:ring-violet-500">
            <div class="flex items-center gap-3">
              <div class="p-3 rounded-md bg-violet-100 dark:bg-violet-900">
                <svg class="w-6 h-6 text-violet-600 dark:text-violet-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6 6 0 10-12 0v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Worst Selling (&le;5)</p>
                <p id="cardWorstSelling" class="text-2xl font-bold text-gray-900 dark:text-white">--</p>
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Minimal sales activity this range</p>
              </div>
            </div>
          </a>

          <a data-product-card-link data-scope="range" data-type="no_sales" href="/analytics/products/list?type=no_sales" class="block bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-5 hover:shadow-lg transition-shadow focus:outline-none focus:ring-2 focus:ring-sky-500">
            <div class="flex items-center gap-3">
              <div class="p-3 rounded-md bg-sky-100 dark:bg-sky-900">
                <svg class="w-6 h-6 text-sky-600 dark:text-sky-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3h2a1 1 0 011 1v4H10V4a1 1 0 011-1zM5 21h14M5 10h14M5 15h14"></path></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-600 dark:text-gray-400">No Sales Products</p>
                <p id="cardNoSales" class="text-2xl font-bold text-gray-900 dark:text-white">--</p>
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Active products without orders</p>
              </div>
            </div>
          </a>
        </div>
      </section>

      <section class="space-y-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700">
            <div class="p-5 border-b border-gray-200 dark:border-gray-700">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Top 5 Best Selling Products</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">Highest volume sold in the selected range</p>
            </div>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                <thead class="bg-gray-50 dark:bg-gray-900">
                  <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Product</th>
                    <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Qty Sold</th>
                    <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Orders</th>
                    <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Revenue (₹)</th>
                  </tr>
                </thead>
                <tbody id="bestSellingTbody" class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                  <tr><td colspan="4" class="px-4 py-4 text-center text-gray-500 dark:text-gray-400">Loading...</td></tr>
                </tbody>
              </table>
            </div>
          </div>

          <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700">
            <div class="p-5 border-b border-gray-200 dark:border-gray-700">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Top 5 Average Selling Products</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">Closest to the mean sales volume</p>
            </div>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                <thead class="bg-gray-50 dark:bg-gray-900">
                  <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Product</th>
                    <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Qty Sold</th>
                    <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Orders</th>
                    <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Revenue (₹)</th>
                  </tr>
                </thead>
                <tbody id="averageSellingTbody" class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                  <tr><td colspan="4" class="px-4 py-4 text-center text-gray-500 dark:text-gray-400">Loading...</td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700">
            <div class="p-5 border-b border-gray-200 dark:border-gray-700">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Top 5 Worst Selling Products</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">Minimal sales with days since last order</p>
            </div>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                <thead class="bg-gray-50 dark:bg-gray-900">
                  <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Product</th>
                    <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Qty Sold</th>
                    <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Days w/o Sale</th>
                    <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Last Order</th>
                  </tr>
                </thead>
                <tbody id="worstSellingTbody" class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                  <tr><td colspan="4" class="px-4 py-4 text-center text-gray-500 dark:text-gray-400">Loading...</td></tr>
                </tbody>
              </table>
            </div>
          </div>

          <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700">
            <div class="p-5 border-b border-gray-200 dark:border-gray-700">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Top 5 Products Approaching Stockout</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">Based on low stock thresholds and sales velocity</p>
            </div>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                <thead class="bg-gray-50 dark:bg-gray-900">
                  <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Product</th>
                    <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Avg Daily Sales</th>
                    <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Threshold</th>
                    <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Days to OOS</th>
                  </tr>
                </thead>
                <tbody id="fastStockoutTbody" class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                  <tr><td colspan="4" class="px-4 py-4 text-center text-gray-500 dark:text-gray-400">Loading...</td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700">
          <div class="p-5 border-b border-gray-200 dark:border-gray-700">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Top 5 Products by Revenue</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400">Highest revenue contribution in the selected period</p>
          </div>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
              <thead class="bg-gray-50 dark:bg-gray-900">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Product</th>
                  <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Revenue (₹)</th>
                  <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Qty Sold</th>
                  <th class="px-3 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Avg Daily Sales</th>
                </tr>
              </thead>
              <tbody id="topRevenueTbody" class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                <tr><td colspan="4" class="px-4 py-4 text-center text-gray-500 dark:text-gray-400">Loading...</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>
    </div>
  </div>
</div>

<script>
  window.productsAnalyticsConfig = {
    defaultRange: "<%= filters.range %>",
    startDate: "<%= filters.startDate %>",
    endDate: "<%= filters.endDate %>"
  };
</script>
<script src="/assets/js/analytics-products.js?v=<%= Date.now() %>"></script>


      function filterByIssueType(issueTypeName) {
        // When clicking a card, update both filters
        // Update Issues by Delivery Boy filter
        issuesState.filters.deliveryBoySection.issueType = issueTypeName;
        if (issuesElements.issueTypeFilter) {
          issuesElements.issueTypeFilter.value = issueTypeName;
        }
        // Update All Issues table filter
        issuesState.filters.allIssuesTable.issueType = issueTypeName;
        if (issuesElements.issuesFilterType) {
          issuesElements.issuesFilterType.value = issueTypeName;
        }
        // Update both tables
        renderDeliveryBoyCounts();
        renderAllIssuesTable();
      }

      function initIssueTypeFilter() {
        // Populate the issue type filter dropdown (in Issues by Delivery Boy section)
        if (issuesElements.issueTypeFilter) {
          const typeOptions = issuesState.issueTypes.map(type => 
            `<option value="${escapeHtml(type.name)}">${escapeHtml(type.name)}</option>`
          ).join("");
          issuesElements.issueTypeFilter.innerHTML = '<option value="">All Issue Types</option>' + typeOptions;
          
          // Set default to "Delivered less quantity" if it exists
          const defaultType = "Delivered less quantity";
          const defaultTypeExists = issuesState.issueTypes.some(type => type.name === defaultType);
          if (defaultTypeExists) {
            issuesElements.issueTypeFilter.value = defaultType;
            issuesState.filters.deliveryBoySection.issueType = defaultType;
          }

          issuesElements.issueTypeFilter.addEventListener("change", (e) => {
            issuesState.filters.deliveryBoySection.issueType = e.target.value;
            // Only update the Issues by Delivery Boy table
            renderDeliveryBoyCounts();
          });
        }
      }

      function initFilters() {
        // Populate issue type filter in the All Issues table
        if (issuesElements.issuesFilterType) {
          const typeOptions = issuesState.issueTypes.map(type => 
            `<option value="${escapeHtml(type.name)}">${escapeHtml(type.name)}</option>`
          ).join("");
          issuesElements.issuesFilterType.innerHTML = '<option value="">All Types</option>' + typeOptions;
          
          // Set default to "All Types" (empty value) for All Issues table
          issuesElements.issuesFilterType.value = "";
          issuesState.filters.allIssuesTable.issueType = "";

          issuesElements.issuesFilterType.addEventListener("change", (e) => {
            issuesState.filters.allIssuesTable.issueType = e.target.value;
            issuesState.pagination.currentPage = 1; // Reset to first page
            // Only update the All Issues table
            renderAllIssuesTable();
          });
        }

        // Populate status filter
        if (issuesElements.issuesFilterStatus) {
          const statusOptions = issuesState.statuses.map(status => 
            `<option value="${escapeHtml(status.name)}">${escapeHtml(status.name)}</option>`
          ).join("");
          issuesElements.issuesFilterStatus.innerHTML = '<option value="">All Statuses</option>' + statusOptions;
          
          // Set default to empty
          issuesElements.issuesFilterStatus.value = "";
          issuesState.filters.allIssuesTable.status = "";

          issuesElements.issuesFilterStatus.addEventListener("change", (e) => {
            issuesState.filters.allIssuesTable.status = e.target.value;
            issuesState.pagination.currentPage = 1; // Reset to first page
            renderAllIssuesTable();
          });
        }

        // Populate delivery boy filter
        if (issuesElements.issuesFilterDeliveryBoy) {
          // Get unique delivery boys from issues
          const deliveryBoys = [...new Set(issuesState.issues
            .filter(issue => issue.delivery_boy_name)
            .map(issue => issue.delivery_boy_name)
            .sort())];
          
          const deliveryBoyOptions = deliveryBoys.map(db => 
            `<option value="${escapeHtml(db)}">${escapeHtml(db)}</option>`
          ).join("");
          issuesElements.issuesFilterDeliveryBoy.innerHTML = '<option value="">All Delivery Boys</option>' + deliveryBoyOptions;
          
          // Set default to empty
          issuesElements.issuesFilterDeliveryBoy.value = "";
          issuesState.filters.allIssuesTable.deliveryBoy = "";

          issuesElements.issuesFilterDeliveryBoy.addEventListener("change", (e) => {
            issuesState.filters.allIssuesTable.deliveryBoy = e.target.value;
            issuesState.pagination.currentPage = 1; // Reset to first page
            renderAllIssuesTable();
          });
        }
      }

      function renderDeliveryBoyCounts() {
        if (!issuesElements.deliveryBoyCountsTableBody) return;

        // Apply filters to get filtered issues (only use deliveryBoySection filters)
        let filteredIssues = [...(issuesState.issues || [])];

        if (issuesState.filters.deliveryBoySection.issueType) {
          filteredIssues = filteredIssues.filter(issue => 
            issue.issue_type_name === issuesState.filters.deliveryBoySection.issueType
          );
        }

        // Count issues by delivery boy
        const deliveryBoyCounts = {};
        filteredIssues.forEach(issue => {
          if (issue.delivery_boy_name) {
            if (!deliveryBoyCounts[issue.delivery_boy_name]) {
              deliveryBoyCounts[issue.delivery_boy_name] = 0;
            }
            deliveryBoyCounts[issue.delivery_boy_name]++;
          }
        });

        // Convert to array, filter positive counts, and sort by count descending
        const deliveryBoyList = Object.entries(deliveryBoyCounts)
          .filter(([name, count]) => count > 0)
          .map(([name, count]) => ({ name, count }))
          .sort((a, b) => b.count - a.count);

        if (deliveryBoyList.length === 0) {
          // Clear table body and show empty state
          issuesElements.deliveryBoyCountsTableBody.innerHTML = "";
          
          // Create and show empty row
          const emptyRow = document.createElement("tr");
          emptyRow.id = "deliveryBoyCountsEmptyRow";
          const hasFilter = issuesState.filters.deliveryBoySection.issueType;
          emptyRow.innerHTML = `
            <td colspan="3" class="px-6 py-12 text-center">
              <div class="flex flex-col items-center justify-center gap-2">
                <p class="text-sm text-gray-500 dark:text-gray-400">${hasFilter ? "No delivery boys with issues found for the selected issue type." : "No delivery boys with issues found for the selected date range."}</p>
              </div>
            </td>
          `;
          issuesElements.deliveryBoyCountsTableBody.appendChild(emptyRow);
          
          if (issuesElements.deliveryBoyCountsLoadingRow) {
            issuesElements.deliveryBoyCountsLoadingRow.classList.add("hidden");
          }
          return;
        }

        if (issuesElements.deliveryBoyCountsLoadingRow) {
          issuesElements.deliveryBoyCountsLoadingRow.classList.add("hidden");
        }

        issuesElements.deliveryBoyCountsTableBody.innerHTML = deliveryBoyList.map(item => {
          // Build URL with delivery boy name and current filters
          const params = new URLSearchParams();
          params.set("deliveryBoy", item.name);
          if (issuesState.filters.deliveryBoySection.issueType) {
            params.set("issueType", issuesState.filters.deliveryBoySection.issueType);
          }
          if (issuesState.dateRange) {
            params.set("range", issuesState.dateRange);
          }
          if (issuesState.startDate && issuesState.endDate) {
            params.set("startDate", issuesState.startDate);
            params.set("endDate", issuesState.endDate);
          }
          const viewUrl = `/analytics/delivery/issues?${params.toString()}`;
          
          return `
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900 dark:text-white">${escapeHtml(item.name)}</div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white font-semibold">${item.count}</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <a href="${viewUrl}" class="text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-medium">
                  View
                </a>
              </td>
            </tr>
          `;
        }).join("");
      }

      function renderAllIssuesTable() {
        if (!issuesElements.allIssuesTableBody) return;

        // Apply filters (only use allIssuesTable filters)
        let filteredIssues = [...(issuesState.issues || [])];

        if (issuesState.filters.allIssuesTable.issueType) {
          filteredIssues = filteredIssues.filter(issue => 
            issue.issue_type_name === issuesState.filters.allIssuesTable.issueType
          );
        }

        if (issuesState.filters.allIssuesTable.status) {
          filteredIssues = filteredIssues.filter(issue => 
            issue.current_status_name === issuesState.filters.allIssuesTable.status
          );
        }

        if (issuesState.filters.allIssuesTable.deliveryBoy) {
          filteredIssues = filteredIssues.filter(issue => 
            issue.delivery_boy_name === issuesState.filters.allIssuesTable.deliveryBoy
          );
        }

        // Calculate pagination
        const totalItems = filteredIssues.length;
        const totalPages = Math.ceil(totalItems / issuesState.pagination.itemsPerPage);
        
        // Reset to page 1 if current page is out of bounds
        if (issuesState.pagination.currentPage > totalPages && totalPages > 0) {
          issuesState.pagination.currentPage = 1;
        }
        
        // Get current page items
        const startIndex = (issuesState.pagination.currentPage - 1) * issuesState.pagination.itemsPerPage;
        const endIndex = startIndex + issuesState.pagination.itemsPerPage;
        const currentPageItems = filteredIssues.slice(startIndex, endIndex);

        if (filteredIssues.length === 0) {
          // Clear table body and show empty state
          issuesElements.allIssuesTableBody.innerHTML = "";
          
          // Create and show empty row
          const emptyRow = document.createElement("tr");
          emptyRow.id = "allIssuesEmptyRow";
          const hasFilters = issuesState.filters.allIssuesTable.issueType || issuesState.filters.allIssuesTable.status || issuesState.filters.allIssuesTable.deliveryBoy;
          emptyRow.innerHTML = `
            <td colspan="7" class="px-6 py-12 text-center">
              <div class="flex flex-col items-center justify-center gap-2">
                <p class="text-sm text-gray-500 dark:text-gray-400">${hasFilters ? "No issues found for the selected filters." : "No issues found for the selected date range."}</p>
              </div>
            </td>
          `;
          issuesElements.allIssuesTableBody.appendChild(emptyRow);
          
          // Hide pagination
          if (issuesElements.allIssuesPagination) {
            issuesElements.allIssuesPagination.classList.add("hidden");
          }
          return;
        }

        // Show pagination
        if (issuesElements.allIssuesPagination) {
          issuesElements.allIssuesPagination.classList.remove("hidden");
        }

        // Format date helper
        function formatDate(dateStr) {
          if (!dateStr) return "—";
          try {
            const date = new Date(dateStr);
            return date.toLocaleDateString("en-US", { 
              year: "numeric", 
              month: "short", 
              day: "numeric",
              hour: "2-digit",
              minute: "2-digit"
            });
          } catch (e) {
            return dateStr;
          }
        }

        // Render current page items
        issuesElements.allIssuesTableBody.innerHTML = currentPageItems.map(issue => {
          return `
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">${issue.id || "—"}</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">${escapeHtml(issue.issue_type_name || "Unknown")}</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">${escapeHtml(issue.current_status_name || "Unknown")}</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">${escapeHtml(issue.delivery_boy_name || "—")}</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">${issue.order_id || "—"}</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">${formatDate(issue.created_at)}</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <button 
                  onclick="viewIssueDetails(${issue.id})"
                  class="text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-medium">
                  View
                </button>
              </td>
            </tr>
          `;
        }).join("");

        // Render pagination controls
        renderAllIssuesPagination(totalItems, totalPages);
      }

      function renderAllIssuesPagination(totalItems, totalPages) {
        if (!issuesElements.allIssuesPaginationInfo || !issuesElements.allIssuesPaginationPages) return;

        const currentPage = issuesState.pagination.currentPage;
        const itemsPerPage = issuesState.pagination.itemsPerPage;
        const startItem = totalItems === 0 ? 0 : (currentPage - 1) * itemsPerPage + 1;
        const endItem = Math.min(currentPage * itemsPerPage, totalItems);

        // Update pagination info
        issuesElements.allIssuesPaginationInfo.textContent = 
          `Showing ${startItem} to ${endItem} of ${totalItems} entries`;

        // Update Previous/Next buttons
        if (issuesElements.allIssuesPaginationPrev) {
          issuesElements.allIssuesPaginationPrev.disabled = currentPage === 1;
        }
        if (issuesElements.allIssuesPaginationNext) {
          issuesElements.allIssuesPaginationNext.disabled = currentPage === totalPages || totalPages === 0;
        }

        // Render page numbers
        const maxVisiblePages = 5;
        let startPage = Math.max(1, currentPage - Math.floor(maxVisiblePages / 2));
        let endPage = Math.min(totalPages, startPage + maxVisiblePages - 1);
        
        // Adjust start page if we're near the end
        if (endPage - startPage < maxVisiblePages - 1) {
          startPage = Math.max(1, endPage - maxVisiblePages + 1);
        }

        let pageButtonsHTML = "";
        
        // First page
        if (startPage > 1) {
          pageButtonsHTML += `
            <button 
              onclick="goToAllIssuesPage(1)"
              class="px-3 py-1.5 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:hover:bg-gray-700">
              1
            </button>
          `;
          if (startPage > 2) {
            pageButtonsHTML += `<span class="px-2 text-gray-500 dark:text-gray-400">...</span>`;
          }
        }

        // Page numbers
        for (let i = startPage; i <= endPage; i++) {
          pageButtonsHTML += `
            <button 
              onclick="goToAllIssuesPage(${i})"
              class="px-3 py-1.5 text-sm font-medium rounded-md ${
                i === currentPage
                  ? "bg-blue-600 text-white border border-blue-600"
                  : "text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700"
              }">
              ${i}
            </button>
          `;
        }

        // Last page
        if (endPage < totalPages) {
          if (endPage < totalPages - 1) {
            pageButtonsHTML += `<span class="px-2 text-gray-500 dark:text-gray-400">...</span>`;
          }
          pageButtonsHTML += `
            <button 
              onclick="goToAllIssuesPage(${totalPages})"
              class="px-3 py-1.5 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:hover:bg-gray-700">
              ${totalPages}
            </button>
          `;
        }

        issuesElements.allIssuesPaginationPages.innerHTML = pageButtonsHTML;
      }

      function goToAllIssuesPage(page) {
        issuesState.pagination.currentPage = page;
        renderAllIssuesTable();
      }
      
      // Make function globally accessible for onclick handlers
      window.goToAllIssuesPage = goToAllIssuesPage;

      function showIssuesError(message) {
        if (issuesElements.allIssuesEmptyRow) {
          issuesElements.allIssuesEmptyRow.innerHTML = `
            <td colspan="7" class="px-6 py-6 text-center text-red-500 dark:text-red-400 text-sm">
              ${escapeHtml(message)}
            </td>
          `;
          issuesElements.allIssuesEmptyRow.classList.remove("hidden");
        }
      }



      // Make functions globally accessible
      // window.viewIssueDetails = viewIssueDetails; // Now provided by shared script
      // window.closeIssueDetailsModal = closeIssueDetailsModal; // Now provided by shared script

      function initIssues() {
        initIssuesFilters();
        loadIssuesData();
      }

      // Initialize on DOM ready
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", () => {
          init();
          initIssues();
        });
      } else {
        init();
        initIssues();
      }
    })();
  </script>
  <script src="/assets/js/delivery-issue-modal.js"></script>
</body>
</html>


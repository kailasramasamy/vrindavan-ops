                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Delivery Boy</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Orders</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Revenue</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Profit (20%)</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Salary</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Payment Type</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Net</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</th>
                </tr>
              </thead>
              <tbody id="deliveryPerformanceTableBody" class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                <tr id="deliveryPerformanceLoadingRow">
                  <td colspan="8" class="px-6 py-12 text-center">
                    <div class="flex flex-col items-center justify-center gap-3">
                      <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
                      <p class="text-sm text-gray-500 dark:text-gray-400">Loading performance data...</p>
                    </div>
                  </td>
                </tr>
                <tr id="deliveryPerformanceEmptyRow" class="hidden">
                  <td colspan="8" class="px-6 py-6 text-center text-gray-500 dark:text-gray-400 text-sm">
                    <div class="flex flex-col items-center gap-2">
                      <p>No delivery performance data found for the selected date range.</p>
                    </div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
        </div>
      </div>

  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>

  <script>
    // Tab switching function
    function switchTab(tabName) {
      // Hide all tab contents
      document.getElementById('tabContentIssues').classList.add('hidden');
      document.getElementById('tabContentPerformance').classList.add('hidden');
      
      // Remove active class from all tabs
      document.getElementById('tabIssues').classList.remove('active', 'border-blue-600', 'text-blue-600', 'dark:text-blue-400');
      document.getElementById('tabIssues').classList.add('border-transparent', 'text-gray-500', 'dark:text-gray-400');
      document.getElementById('tabPerformance').classList.remove('active', 'border-blue-600', 'text-blue-600', 'dark:text-blue-400');
      document.getElementById('tabPerformance').classList.add('border-transparent', 'text-gray-500', 'dark:text-gray-400');
      
      // Show selected tab content and activate tab button
      if (tabName === 'issues') {
        document.getElementById('tabContentIssues').classList.remove('hidden');
        document.getElementById('tabIssues').classList.add('active', 'border-blue-600', 'text-blue-600', 'dark:text-blue-400');
        document.getElementById('tabIssues').classList.remove('border-transparent', 'text-gray-500', 'dark:text-gray-400');
      } else if (tabName === 'performance') {
        document.getElementById('tabContentPerformance').classList.remove('hidden');
        document.getElementById('tabPerformance').classList.add('active', 'border-blue-600', 'text-blue-600', 'dark:text-blue-400');
        document.getElementById('tabPerformance').classList.remove('border-transparent', 'text-gray-500', 'dark:text-gray-400');
      }
    }

    // Initialize tabs on page load
    document.addEventListener('DOMContentLoaded', function() {
      switchTab('issues'); // Default to Issues tab
    });
  </script>

  <script>
    (function() {
      const API_BASE = "/analytics/api/delivery";
      const STORAGE_KEY = "deliveryAnalyticsState";

      const state = {
        range: "last_month",
        startDate: null,
        endDate: null,
        selectedMonth: null, // { start, end, label } for monthly selection
        performance: [],
        stats: null,
        chart: null,
      };

      const elements = {
        dateRangeSelect: document.getElementById("perfDateRange"),
        monthlySelection: document.getElementById("perfMonthlySelection"),
        monthlyButtons: document.getElementById("perfMonthlyButtons"),
        customRangeSelection: document.getElementById("perfCustomRangeSelection"),
        customStartDate: document.getElementById("perfCustomStartDate"),
        customEndDate: document.getElementById("perfCustomEndDate"),
        customApplyBtn: document.getElementById("perfCustomApplyBtn"),
        tableBody: document.getElementById("deliveryPerformanceTableBody"),
        loadingRow: document.getElementById("deliveryPerformanceLoadingRow"),
        emptyRow: document.getElementById("deliveryPerformanceEmptyRow"),
        goodProfitCount: document.getElementById("goodProfitCount"),
        averageProfitCount: document.getElementById("averageProfitCount"),
        lossMakingCount: document.getElementById("lossMakingCount"),
        chartContainer: document.getElementById("profitVsSalaryChart"),
        exportCsvBtn: document.getElementById("perfExportCsvBtn"),
      };

      function loadStateFromStorage() {
        try {
          const raw = localStorage.getItem(STORAGE_KEY);
          if (raw) {
            const saved = JSON.parse(raw);
            if (saved && typeof saved === "object") {
              if (saved.range) state.range = saved.range;
              if (saved.startDate) state.startDate = saved.startDate;
              if (saved.endDate) state.endDate = saved.endDate;
              if (saved.selectedMonth) state.selectedMonth = saved.selectedMonth;
            }
          }
        } catch (error) {
          console.error("Failed to load delivery analytics state", error);
        }
      }

      function saveStateToStorage() {
        try {
          localStorage.setItem(STORAGE_KEY, JSON.stringify({
            range: state.range,
            startDate: state.startDate,
            endDate: state.endDate,
            selectedMonth: state.selectedMonth,
          }));
        } catch (error) {
          console.error("Failed to save delivery analytics state", error);
        }
      }

      function getMonthDateRange(yearMonth) {
        const [year, month] = yearMonth.split("-").map(Number);
        const startDate = `${year}-${String(month).padStart(2, "0")}-01`;
        const lastDay = new Date(year, month, 0).getDate();
        const endDate = `${year}-${String(month).padStart(2, "0")}-${String(lastDay).padStart(2, "0")}`;
        return { start: startDate, end: endDate };
      }

      function getThisMonthRange() {
        const now = new Date();
        return getMonthDateRange(`${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, "0")}`);
      }

      function getLastMonthRange() {
        const now = new Date();
        const prev = new Date(now.getFullYear(), now.getMonth() - 1, 1);
        return getMonthDateRange(`${prev.getFullYear()}-${String(prev.getMonth() + 1).padStart(2, "0")}`);
      }

      function generateMonthButtons() {
        if (!elements.monthlyButtons) return;
        const now = new Date();
        const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
        let html = "";
        for (let i = 0; i < 18; i++) {
          const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
          const label = monthNames[d.getMonth()] + " " + d.getFullYear();
          const startStr = d.getFullYear() + "-" + String(d.getMonth() + 1).padStart(2, "0") + "-01";
          const lastDay = new Date(d.getFullYear(), d.getMonth() + 1, 0).getDate();
          const endStr = d.getFullYear() + "-" + String(d.getMonth() + 1).padStart(2, "0") + "-" + String(lastDay).padStart(2, "0");
          const isSelected = state.selectedMonth && state.selectedMonth.start === startStr && state.selectedMonth.end === endStr;
          html += `<button type="button" data-start="${startStr}" data-end="${endStr}" data-label="${label}"
            class="perf-month-btn px-3 py-1.5 text-xs font-medium rounded-lg border transition-colors ${
              isSelected
                ? "bg-blue-600 text-white border-blue-600"
                : "bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700"
            }">${label}</button>`;
        }
        elements.monthlyButtons.innerHTML = html;

        // Add click handlers
        elements.monthlyButtons.querySelectorAll(".perf-month-btn").forEach(btn => {
          btn.addEventListener("click", () => {
            state.selectedMonth = {
              start: btn.dataset.start,
              end: btn.dataset.end,
              label: btn.dataset.label,
            };
            // Update button styles
            elements.monthlyButtons.querySelectorAll(".perf-month-btn").forEach(b => {
              b.className = "perf-month-btn px-3 py-1.5 text-xs font-medium rounded-lg border transition-colors bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700";
            });
            btn.className = "perf-month-btn px-3 py-1.5 text-xs font-medium rounded-lg border transition-colors bg-blue-600 text-white border-blue-600";
            saveStateToStorage();
            loadData();
          });
        });
      }

      function hideAllSelections() {
        if (elements.monthlySelection) elements.monthlySelection.classList.add("hidden");
        if (elements.customRangeSelection) elements.customRangeSelection.classList.add("hidden");
      }

      function handleRangeChange() {
        hideAllSelections();

        if (state.range === "monthly") {
          if (elements.monthlySelection) elements.monthlySelection.classList.remove("hidden");
          generateMonthButtons();
          // If a month was already selected, use it; otherwise don't auto-load
          if (state.selectedMonth) {
            loadData();
          }
          return;
        }

        if (state.range === "custom") {
          if (elements.customRangeSelection) elements.customRangeSelection.classList.remove("hidden");
          if (!state.startDate || !state.endDate) {
            const lastMonth = getLastMonthRange();
            state.startDate = lastMonth.start;
            state.endDate = lastMonth.end;
          }
          if (elements.customStartDate) elements.customStartDate.value = state.startDate;
          if (elements.customEndDate) elements.customEndDate.value = state.endDate;
          // Don't auto-load for custom; wait for Apply click
          return;
        }

        // For this_month and last_month, load immediately
        state.selectedMonth = null;
        loadData();
      }

      function init() {
        loadStateFromStorage();

        if (elements.dateRangeSelect) {
          elements.dateRangeSelect.value = state.range;
          elements.dateRangeSelect.addEventListener("change", (e) => {
            state.range = e.target.value;
            saveStateToStorage();
            handleRangeChange();
          });
        }

        if (elements.exportCsvBtn) {
          elements.exportCsvBtn.addEventListener("click", exportCsv);
        }

        if (elements.customApplyBtn) {
          elements.customApplyBtn.addEventListener("click", () => {
            if (elements.customStartDate) state.startDate = elements.customStartDate.value;
            if (elements.customEndDate) state.endDate = elements.customEndDate.value;
            if (state.startDate && state.endDate) {
              saveStateToStorage();
              loadData();
            }
          });
        }

        // Trigger initial view
        handleRangeChange();
      }

      function buildApiUrl() {
        if (state.range === "monthly" && state.selectedMonth) {
          return `${API_BASE}?range=monthly&start=${encodeURIComponent(state.selectedMonth.start)}&end=${encodeURIComponent(state.selectedMonth.end)}`;
        }
        if (state.range === "custom" && state.startDate && state.endDate) {
          return `${API_BASE}?range=custom&start=${encodeURIComponent(state.startDate)}&end=${encodeURIComponent(state.endDate)}`;
        }
        if (state.range === "this_month") {
          const r = getThisMonthRange();
          return `${API_BASE}?range=monthly&start=${encodeURIComponent(r.start)}&end=${encodeURIComponent(r.end)}`;
        }
        // Default: last_month
        const r = getLastMonthRange();
        return `${API_BASE}?range=monthly&start=${encodeURIComponent(r.start)}&end=${encodeURIComponent(r.end)}`;
      }

      async function loadData() {
        // Show loading state
        if (elements.loadingRow) {
          elements.loadingRow.classList.remove("hidden");
        }
        if (elements.emptyRow) {
          elements.emptyRow.classList.add("hidden");
        }

        // Show spinner on chart
        if (elements.chartContainer) {
          elements.chartContainer.innerHTML = `
            <div class="flex items-center justify-center h-full">
              <div class="text-center">
                <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mx-auto"></div>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-4">Loading chart data...</p>
              </div>
            </div>
          `;
        }

        try {
          const response = await fetch(buildApiUrl());
          const data = await response.json();

          if (data && data.success && data.data) {
            state.performance = data.data.performance || [];
            state.stats = data.data.stats || { good: 0, average: 0, loss: 0, total: 0 };
            
            updateStats();
            renderChart();
            renderTable();
          } else {
            showError("Failed to load delivery analytics data");
          }
        } catch (error) {
          console.error("Error loading delivery analytics:", error);
          showError("Failed to load delivery analytics data");
        } finally {
          if (elements.loadingRow) {
            elements.loadingRow.classList.add("hidden");
          }
        }
      }

      function updateStats() {
        if (state.stats) {
          if (elements.goodProfitCount) {
            elements.goodProfitCount.textContent = state.stats.good || 0;
          }
          if (elements.averageProfitCount) {
            elements.averageProfitCount.textContent = state.stats.average || 0;
          }
          if (elements.lossMakingCount) {
            elements.lossMakingCount.textContent = state.stats.loss || 0;
          }
        }
      }

      function renderChart() {
        if (!elements.chartContainer) return;

        // Destroy existing chart
        if (state.chart) {
          state.chart.destroy();
        }

        if (state.performance.length === 0) {
          elements.chartContainer.innerHTML = `
            <div class="flex items-center justify-center h-full">
              <p class="text-sm text-gray-500 dark:text-gray-400">No data available for chart</p>
            </div>
          `;
          return;
        }

        // Sort by profit descending
        const sorted = [...state.performance].sort((a, b) => b.profit - a.profit);
        const labels = sorted.map(p => p.name || "Unknown");
        const profitData = sorted.map(p => p.profit);
        const salaryData = sorted.map(p => p.salary);
        
        // Create color arrays for Salary bars: red for loss-making (profit < salary), blue otherwise
        const salaryBackgroundColors = sorted.map(p => 
          p.profit < p.salary ? "rgba(239, 68, 68, 0.6)" : "rgba(59, 130, 246, 0.6)"
        );
        const salaryBorderColors = sorted.map(p => 
          p.profit < p.salary ? "rgba(239, 68, 68, 1)" : "rgba(59, 130, 246, 1)"
        );

        const ctx = document.createElement("canvas");
        elements.chartContainer.innerHTML = "";
        elements.chartContainer.appendChild(ctx);

        state.chart = new Chart(ctx, {
          type: "bar",
          data: {
            labels: labels,
            datasets: [
              {
                label: "Profit (20% of Revenue)",
                data: profitData,
                backgroundColor: "rgba(34, 197, 94, 0.6)",
                borderColor: "rgba(34, 197, 94, 1)",
                borderWidth: 1,
              },
              {
                label: "Salary",
                data: salaryData,
                backgroundColor: salaryBackgroundColors,
                borderColor: salaryBorderColors,
                borderWidth: 1,
              },
            ],
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: {
                display: true,
                position: "top",
                labels: {
                  color: window.matchMedia("(prefers-color-scheme: dark)").matches || document.documentElement.classList.contains("dark") 
                    ? "#e5e7eb" : "#374151",
                },
              },
              tooltip: {
                callbacks: {
                  label: function(context) {
                    return `${context.dataset.label}: ₹${formatNumber(context.parsed.y)}`;
                  },
                },
              },
            },
            scales: {
              y: {
                beginAtZero: true,
                ticks: {
                  callback: function(value) {
                    return "₹" + formatNumber(value);
                  },
                  color: window.matchMedia("(prefers-color-scheme: dark)").matches || document.documentElement.classList.contains("dark") 
                    ? "#9ca3af" : "#6b7280",
                },
                grid: {
                  color: window.matchMedia("(prefers-color-scheme: dark)").matches || document.documentElement.classList.contains("dark") 
                    ? "rgba(255, 255, 255, 0.1)" : "rgba(0, 0, 0, 0.1)",
                },
              },
              x: {
                ticks: {
                  maxRotation: 45,
                  minRotation: 45,
                  color: window.matchMedia("(prefers-color-scheme: dark)").matches || document.documentElement.classList.contains("dark") 
                    ? "#9ca3af" : "#6b7280",
                },
                grid: {
                  display: false,
                },
              },
            },
          },
        });
      }

      function renderTable() {
        if (!elements.tableBody) return;

        // Remove existing rows (except loading and empty rows)
        const existingRows = Array.from(elements.tableBody.querySelectorAll("tr:not(#deliveryPerformanceLoadingRow):not(#deliveryPerformanceEmptyRow)"));
        existingRows.forEach(row => row.remove());

        if (state.performance.length === 0) {
          if (elements.emptyRow) {
            elements.emptyRow.classList.remove("hidden");
          }
          return;
        }

        if (elements.emptyRow) {
          elements.emptyRow.classList.add("hidden");
        }

        // Sort by profit descending
        const sorted = [...state.performance].sort((a, b) => b.profit - a.profit);

        sorted.forEach((perf) => {
          const row = document.createElement("tr");
          row.className = "hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors";

          const net = perf.profit - perf.salary;
          const netClass = net >= 0 ? "text-emerald-600 dark:text-emerald-400" : "text-red-600 dark:text-red-400";
          
          let statusBadge = "";
          if (perf.category === "good") {
            statusBadge = '<span class="px-2 py-1 text-xs font-medium rounded-full bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300">Good</span>';
          } else if (perf.category === "average") {
            statusBadge = '<span class="px-2 py-1 text-xs font-medium rounded-full bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300">Average</span>';
          } else {
            statusBadge = '<span class="px-2 py-1 text-xs font-medium rounded-full bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300">Loss</span>';
          }

          row.innerHTML = `
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm font-medium text-gray-900 dark:text-white">${escapeHtml(perf.name)}</div>
              ${perf.phone ? `<div class="text-xs text-gray-500 dark:text-gray-400">${escapeHtml(perf.phone)}</div>` : ''}
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">
              ${perf.order_count || 0}
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white">
              ₹${formatNumber(perf.revenue)}
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-emerald-600 dark:text-emerald-400">
              ₹${formatNumber(perf.profit)}
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-blue-600 dark:text-blue-400">
              ₹${formatNumber(perf.salary)}
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400 capitalize">
              ${escapeHtml((perf.payment_type || "commission").replace(/_/g, " "))}
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold ${netClass}">
              ${net >= 0 ? '+' : ''}₹${formatNumber(Math.abs(net))}
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              ${statusBadge}
            </td>
          `;

          elements.tableBody.appendChild(row);
        });
      }

      function formatNumber(num) {
        return new Intl.NumberFormat("en-IN", {
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
        }).format(num || 0);
      }

      function escapeHtml(text) {
        const div = document.createElement("div");
        div.textContent = text;
        return div.innerHTML;
      }

      function exportCsv() {
        if (!state.performance || state.performance.length === 0) return;

        const sorted = [...state.performance].sort((a, b) => b.profit - a.profit);
        const headers = ["Delivery Boy", "Phone", "Orders", "Revenue", "Profit (20%)", "Salary", "Payment Type", "Net", "Status"];
        const rows = sorted.map(p => {
          const net = p.profit - p.salary;
          return [
            p.name || "Unknown",
            p.phone || "",
            p.order_count || 0,
            (p.revenue || 0).toFixed(2),
            (p.profit || 0).toFixed(2),
            (p.salary || 0).toFixed(2),
            (p.payment_type || "commission").replace(/_/g, " "),
            net.toFixed(2),
            p.category === "good" ? "Good" : p.category === "average" ? "Average" : "Loss",
          ];
        });

        // Escape CSV fields
        function csvEscape(val) {
          const str = String(val);
          if (str.includes(",") || str.includes('"') || str.includes("\n")) {
            return '"' + str.replace(/"/g, '""') + '"';
          }
          return str;
        }

        const csvContent = [headers.map(csvEscape).join(",")]
          .concat(rows.map(row => row.map(csvEscape).join(",")))
          .join("\n");

        const blob = new Blob([csvContent], { type: "text/csv;charset=utf-8;" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = "delivery-boy-performance.csv";
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
      }

      function showError(message) {
        if (elements.emptyRow) {
          elements.emptyRow.innerHTML = `
            <td colspan="8" class="px-6 py-6 text-center text-red-500 dark:text-red-400 text-sm">
              ${escapeHtml(message)}
            </td>
          `;
          elements.emptyRow.classList.remove("hidden");
        }
      }

      // ===== Delivery Issues Section =====
      const ISSUES_API_BASE = "/analytics/api/delivery/issues";
      const ISSUES_STORAGE_KEY = "deliveryIssuesState";

      const issuesState = {
        dateRange: "7d",
        startDate: null,
        endDate: null,
        statusCounts: [],
        typeCounts: [],
        issues: [],
        issueTypes: [],
        statuses: [],
        filters: {
          // Filters for "Issues by Delivery Boy" section
          deliveryBoySection: {
            issueType: "",
          },
          // Filters for "All Issues" table
          allIssuesTable: {
            issueType: "",
            status: "",
            deliveryBoy: "",
          },
        },
        pagination: {
          currentPage: 1,
          itemsPerPage: 10,
        },
        top5Chart: null,
        top5DeliveryBoysChart: null,
      };

      const issuesElements = {
        dateRangeSelect: document.getElementById("deliveryIssuesDateRange"),
        customDateRangeContainer: document.getElementById("customDateRangeContainer"),
        startDateInput: document.getElementById("deliveryIssuesStartDate"),
        endDateInput: document.getElementById("deliveryIssuesEndDate"),
        issueTypeFilter: document.getElementById("issueTypeFilter"),
        issueTypeCountsContainer: document.getElementById("issueTypeCountsContainer"),
        issueTypeCountsLoading: document.getElementById("issueTypeCountsLoading"),
        issueTypeCountsEmpty: document.getElementById("issueTypeCountsEmpty"),
        issueTypeCountsGrid: document.getElementById("issueTypeCountsGrid"),
        top5IssuesChart: document.getElementById("top5IssuesChart"),
        top5DeliveryBoysChart: document.getElementById("top5DeliveryBoysChart"),
        issuesFilterType: document.getElementById("issuesFilterType"),
        issuesFilterStatus: document.getElementById("issuesFilterStatus"),
        issuesFilterDeliveryBoy: document.getElementById("issuesFilterDeliveryBoy"),
        deliveryBoyCountsTableBody: document.getElementById("deliveryBoyCountsTableBody"),
        deliveryBoyCountsLoadingRow: document.getElementById("deliveryBoyCountsLoadingRow"),
        deliveryBoyCountsEmptyRow: document.getElementById("deliveryBoyCountsEmptyRow"),
        allIssuesTableBody: document.getElementById("allIssuesTableBody"),
        allIssuesLoadingRow: document.getElementById("allIssuesLoadingRow"),
        allIssuesEmptyRow: document.getElementById("allIssuesEmptyRow"),
        allIssuesPagination: document.getElementById("allIssuesPagination"),
        allIssuesPaginationInfo: document.getElementById("allIssuesPaginationInfo"),
        allIssuesPaginationPrev: document.getElementById("allIssuesPaginationPrev"),
        allIssuesPaginationNext: document.getElementById("allIssuesPaginationNext"),
        allIssuesPaginationPages: document.getElementById("allIssuesPaginationPages"),
      };

      function loadIssuesStateFromStorage() {
        try {
          const raw = localStorage.getItem(ISSUES_STORAGE_KEY);
          if (raw) {
            const saved = JSON.parse(raw);
            if (saved && typeof saved === "object") {
              if (saved.dateRange) issuesState.dateRange = saved.dateRange;
              if (saved.startDate) issuesState.startDate = saved.startDate;
              if (saved.endDate) issuesState.endDate = saved.endDate;
            }
          }
        } catch (error) {
          console.error("Failed to load delivery issues state", error);
        }
      }

      function saveIssuesStateToStorage() {
        try {
          localStorage.setItem(ISSUES_STORAGE_KEY, JSON.stringify({
            dateRange: issuesState.dateRange,
            startDate: issuesState.startDate,
            endDate: issuesState.endDate,
          }));
        } catch (error) {
          console.error("Failed to save delivery issues state", error);
        }
      }

      function initIssuesFilters() {
        loadIssuesStateFromStorage();

        // Initialize pagination event listeners
        if (issuesElements.allIssuesPaginationPrev) {
          issuesElements.allIssuesPaginationPrev.addEventListener("click", () => {
            if (issuesState.pagination.currentPage > 1) {
              issuesState.pagination.currentPage--;
              renderAllIssuesTable();
            }
          });
        }

        if (issuesElements.allIssuesPaginationNext) {
          issuesElements.allIssuesPaginationNext.addEventListener("click", () => {
            const totalItems = issuesState.issues.filter(issue => {
              if (issuesState.filters.allIssuesTable.issueType && issue.issue_type_name !== issuesState.filters.allIssuesTable.issueType) return false;
              if (issuesState.filters.allIssuesTable.status && issue.current_status_name !== issuesState.filters.allIssuesTable.status) return false;
              if (issuesState.filters.allIssuesTable.deliveryBoy && issue.delivery_boy_name !== issuesState.filters.allIssuesTable.deliveryBoy) return false;
              return true;
            }).length;
            const totalPages = Math.ceil(totalItems / issuesState.pagination.itemsPerPage);
            if (issuesState.pagination.currentPage < totalPages) {
              issuesState.pagination.currentPage++;
              renderAllIssuesTable();
            }
          });
        }

        if (issuesElements.dateRangeSelect) {
          issuesElements.dateRangeSelect.value = issuesState.dateRange || "7d";
          
          issuesElements.dateRangeSelect.addEventListener("change", (e) => {
            issuesState.dateRange = e.target.value;
            if (issuesState.dateRange === "custom") {
              if (issuesElements.customDateRangeContainer) {
                issuesElements.customDateRangeContainer.classList.remove("hidden");
              }
              // Set default dates if not set
              if (!issuesState.startDate || !issuesState.endDate) {
                const now = new Date();
                const sevenDaysAgo = new Date();
                sevenDaysAgo.setDate(now.getDate() - 7);
                issuesState.startDate = sevenDaysAgo.toISOString().split("T")[0];
                issuesState.endDate = now.toISOString().split("T")[0];
              }
              if (issuesElements.startDateInput) {
                issuesElements.startDateInput.value = issuesState.startDate;
              }
              if (issuesElements.endDateInput) {
                issuesElements.endDateInput.value = issuesState.endDate;
              }
            } else {
              if (issuesElements.customDateRangeContainer) {
                issuesElements.customDateRangeContainer.classList.add("hidden");
              }
            }
            saveIssuesStateToStorage();
            loadIssuesData();
          });
        }

        if (issuesElements.startDateInput && issuesElements.endDateInput) {
          issuesElements.startDateInput.addEventListener("change", (e) => {
            issuesState.startDate = e.target.value;
            saveIssuesStateToStorage();
            if (issuesState.dateRange === "custom") {
              loadIssuesData();
            }
          });

          issuesElements.endDateInput.addEventListener("change", (e) => {
            issuesState.endDate = e.target.value;
            saveIssuesStateToStorage();
            if (issuesState.dateRange === "custom") {
              loadIssuesData();
            }
          });
        }

        // Show custom date range if needed
        if (issuesState.dateRange === "custom" && issuesElements.customDateRangeContainer) {
          issuesElements.customDateRangeContainer.classList.remove("hidden");
        }
      }

      async function loadIssuesData() {
        // Show loading state
        if (issuesElements.issueTypeCountsLoading) {
          issuesElements.issueTypeCountsLoading.classList.remove("hidden");
        }
        if (issuesElements.issueTypeCountsEmpty) {
          issuesElements.issueTypeCountsEmpty.classList.add("hidden");
        }
        if (issuesElements.issueTypeCountsGrid) {
          issuesElements.issueTypeCountsGrid.classList.add("hidden");
        }
        if (issuesElements.allIssuesLoadingRow) {
          issuesElements.allIssuesLoadingRow.classList.remove("hidden");
        }
        if (issuesElements.allIssuesEmptyRow) {
          issuesElements.allIssuesEmptyRow.classList.add("hidden");
        }
        if (issuesElements.deliveryBoyCountsLoadingRow) {
          issuesElements.deliveryBoyCountsLoadingRow.classList.remove("hidden");
        }
        if (issuesElements.deliveryBoyCountsEmptyRow) {
          issuesElements.deliveryBoyCountsEmptyRow.classList.add("hidden");
        }

        try {
          let url = `${ISSUES_API_BASE}?range=${encodeURIComponent(issuesState.dateRange)}`;
          if (issuesState.dateRange === "custom" && issuesState.startDate && issuesState.endDate) {
            url += `&startDate=${encodeURIComponent(issuesState.startDate)}&endDate=${encodeURIComponent(issuesState.endDate)}`;
          }

          const response = await fetch(url);
          const data = await response.json();

          if (data && data.success && data.data) {
            issuesState.statusCounts = data.data.statusCounts || [];
            issuesState.typeCounts = data.data.typeCounts || [];
            issuesState.issues = data.data.issues || [];
            issuesState.issueTypes = data.data.issueTypes || [];
            issuesState.statuses = data.data.statuses || [];
            issuesState.startDate = data.data.startDate;
            issuesState.endDate = data.data.endDate;

            initIssueTypeFilter();
            renderIssueTypeCounts();
            renderTop5IssuesChart();
            renderTop5DeliveryBoysChart();
            initFilters();
            renderDeliveryBoyCounts();
            renderAllIssuesTable();
          } else {
            showIssuesError("Failed to load delivery issues data");
          }
        } catch (error) {
          console.error("Error loading delivery issues:", error);
          showIssuesError("Failed to load delivery issues data");
        } finally {
          if (issuesElements.issueTypeCountsLoading) {
            issuesElements.issueTypeCountsLoading.classList.add("hidden");
          }
          if (issuesElements.allIssuesLoadingRow) {
            issuesElements.allIssuesLoadingRow.classList.add("hidden");
          }
          if (issuesElements.deliveryBoyCountsLoadingRow) {
            issuesElements.deliveryBoyCountsLoadingRow.classList.add("hidden");
          }
        }
      }


      function renderIssueTypeCounts() {
        if (!issuesElements.issueTypeCountsGrid) return;

        // Show all types with positive counts (don't apply filter to cards)
        const filteredTypes = (issuesState.typeCounts || [])
          .filter(item => item.count > 0)
          .sort((a, b) => b.count - a.count);

        if (filteredTypes.length === 0) {
          if (issuesElements.issueTypeCountsEmpty) {
            issuesElements.issueTypeCountsEmpty.classList.remove("hidden");
          }
          if (issuesElements.issueTypeCountsGrid) {
            issuesElements.issueTypeCountsGrid.classList.add("hidden");
          }
          return;
        }

        if (issuesElements.issueTypeCountsEmpty) {
          issuesElements.issueTypeCountsEmpty.classList.add("hidden");
        }
        if (issuesElements.issueTypeCountsGrid) {
          issuesElements.issueTypeCountsGrid.classList.remove("hidden");
        }

        issuesElements.issueTypeCountsGrid.innerHTML = filteredTypes.map((item) => {
          const typeName = item.name || "Unknown";
          const escapedTypeName = escapeHtml(typeName);
          // Use data attribute and event delegation instead of inline onclick
          return `
            <a href="#" 
               class="issue-type-card block bg-gray-50 dark:bg-gray-700/50 border border-gray-200 dark:border-gray-600 rounded-lg p-4 hover:shadow-md transition-shadow cursor-pointer"
               data-issue-type="${escapedTypeName}">
              <div class="flex items-center justify-between">
                <div class="flex-1">
                  <p class="text-sm font-medium text-gray-900 dark:text-white">${escapedTypeName}</p>
                  <p class="text-2xl font-bold text-gray-900 dark:text-white mt-2">${item.count || 0}</p>
                </div>
              </div>
            </a>
          `;
        }).join("");

        // Add click handlers to cards using event delegation
        const cards = issuesElements.issueTypeCountsGrid.querySelectorAll('.issue-type-card');
        cards.forEach(card => {
          card.addEventListener('click', (e) => {
            e.preventDefault();
            const typeName = card.getAttribute('data-issue-type');
            if (typeName) {
              filterByIssueType(typeName);
            }
          });
        });
      }

      function renderTop5IssuesChart() {
        if (!issuesElements.top5IssuesChart) return;

        // Destroy existing chart
        if (issuesState.top5Chart) {
          issuesState.top5Chart.destroy();
          issuesState.top5Chart = null;
        }

        // Get top 5 issues
        const top5 = (issuesState.typeCounts || [])
          .filter(item => item.count > 0)
          .sort((a, b) => b.count - a.count)
          .slice(0, 5);

        if (top5.length === 0) {
          issuesElements.top5IssuesChart.innerHTML = `
            <div class="flex items-center justify-center h-full">
              <p class="text-sm text-gray-500 dark:text-gray-400">No data available for chart</p>
            </div>
          `;
          return;
        }

        const labels = top5.map(item => item.name || "Unknown");
        const data = top5.map(item => item.count || 0);

        // Color palette for bars
        const colors = [
          { bg: "rgba(239, 68, 68, 0.6)", border: "rgba(239, 68, 68, 1)" },      // red
          { bg: "rgba(249, 115, 22, 0.6)", border: "rgba(249, 115, 22, 1)" },    // orange
          { bg: "rgba(234, 179, 8, 0.6)", border: "rgba(234, 179, 8, 1)" },      // yellow
          { bg: "rgba(59, 130, 246, 0.6)", border: "rgba(59, 130, 246, 1)" },    // blue
          { bg: "rgba(139, 92, 246, 0.6)", border: "rgba(139, 92, 246, 1)" },    // purple
        ];

        const backgroundColors = top5.map((_, idx) => colors[idx]?.bg || colors[0].bg);
        const borderColors = top5.map((_, idx) => colors[idx]?.border || colors[0].border);

        const isDark = window.matchMedia("(prefers-color-scheme: dark)").matches || 
                       document.documentElement.classList.contains("dark");

        const ctx = document.createElement("canvas");
        issuesElements.top5IssuesChart.innerHTML = "";
        issuesElements.top5IssuesChart.appendChild(ctx);

        issuesState.top5Chart = new Chart(ctx, {
          type: "bar",
          data: {
            labels: labels,
            datasets: [{
              label: "Number of Issues",
              data: data,
              backgroundColor: backgroundColors,
              borderColor: borderColors,
              borderWidth: 2,
            }],
          },
          plugins: [ChartDataLabels],
          options: {
            responsive: true,
            maintainAspectRatio: false,
            indexAxis: 'y',
            layout: {
              padding: {
                right: 50,
              },
            },
            plugins: {
              legend: {
                display: false,
              },
              tooltip: {
                callbacks: {
                  label: function(context) {
                    return `Issues: ${context.parsed.x}`;
                  },
                },
              },
              datalabels: {
                anchor: 'end',
                align: 'start',
                color: isDark ? '#f3f4f6' : '#111827',
                font: {
                  weight: 'bold',
                  size: 14,
                },
                formatter: function(value) {
                  return value;
                },
                offset: 4,
              },
            },
            scales: {
              x: {
                beginAtZero: true,
                ticks: {
                  stepSize: 1,
                  color: isDark ? "#9ca3af" : "#6b7280",
                },
                grid: {
                  color: isDark ? "rgba(255, 255, 255, 0.1)" : "rgba(0, 0, 0, 0.1)",
                },
              },
              y: {
                ticks: {
                  color: isDark ? "#9ca3af" : "#6b7280",
                  font: {
                    size: 12,
                  },
                },
                grid: {
                  display: false,
                },
              },
            },
          },
        });
      }

      function renderTop5DeliveryBoysChart() {

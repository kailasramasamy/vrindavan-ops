<%
// Function to format currency in Indian lakh format
function formatIndianCurrency(amount) {
  if (amount === 0) return '0';
  
  // Use JavaScript's built-in toLocaleString with Indian numbering system
  try {
    return amount.toLocaleString('en-IN');
  } catch (e) {
    // Fallback to manual formatting if locale is not supported
    let [integerPart, decimalPart] = amount.toString().split('.');
    let formatted = '';
    let count = 0;
    
    for (let i = integerPart.length - 1; i >= 0; i--) {
      if (count === 3 || (count > 3 && (count - 3) % 2 === 0)) {
        if (i > 0) {
          formatted = ',' + formatted;
        }
      }
      formatted = integerPart[i] + formatted;
      count++;
    }
    
    if (decimalPart) {
      formatted += '.' + decimalPart;
    }
    
    return formatted;
  }
}

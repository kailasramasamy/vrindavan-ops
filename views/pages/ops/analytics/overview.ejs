<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>

<script>
  // Register the datalabels plugin
  Chart.register(ChartDataLabels);
  // Theme toggle functionality

  // Date range change handler
  document.getElementById('dateRange').addEventListener('change', function() {
    const range = this.value;
    const url = new URL(window.location);
    url.searchParams.set('range', range);
    window.location.href = url.toString();
  });

  // Initialize charts
  const trendData = <%- JSON.stringify(trendData) %>;

  // Orders Chart
  const ordersCtx = document.getElementById('ordersChart').getContext('2d');
  new Chart(ordersCtx, {
    type: 'line',
    data: {
    labels: trendData.map(item => {
      // Clean date formatting - extract only the date part and format as DD/MM
      if (item.period.includes('T') || item.period.includes(' ')) {
        // Handle ISO date strings or date with time
        const datePart = item.period.split('T')[0].split(' ')[0];
        // Format as DD/MM
        const [year, month, day] = datePart.split('-');
        return `${day}/${month}`;
      } else if (item.period.includes('-') && item.period.split('-').length === 3) {
        // Handle YYYY-MM-DD format
        const [year, month, day] = item.period.split('-');
        return `${day}/${month}`;
      } else if (item.period.includes('-') && item.period.split('-').length === 2) {
        // Handle YYYY-MM format
        const [year, month] = item.period.split('-');
        return `${month}`;
      }
      return item.period;
    }),
      datasets: [{
        label: 'Total Orders',
        data: trendData.map(item => item.orders),
        borderColor: 'rgb(59, 130, 246)',
        backgroundColor: 'rgba(59, 130, 246, 0.1)',
        tension: 0.4,
        pointRadius: 4,
        pointHoverRadius: 6,
        pointBackgroundColor: 'rgb(59, 130, 246)',
        pointBorderColor: '#ffffff',
        pointBorderWidth: 2
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          labels: {
            color: document.documentElement.classList.contains('dark') ? '#e5e7eb' : '#374151',
            usePointStyle: true,
            pointStyle: 'circle',
            padding: 25,
            boxWidth: 12,
            boxHeight: 12
          },
          position: 'top',
          margin: {
            top: 20,
            bottom: 0
          }
        },
        datalabels: {
          display: true,
          color: document.documentElement.classList.contains('dark') ? '#e5e7eb' : '#374151',
          font: {
            weight: 'bold',
            size: 10
          },
          formatter: function(value, context) {
            return value > 0 ? value : '';
          },
          anchor: 'end',
          align: 'top',
          offset: 4
        }
      },
      scales: {
        x: {
          ticks: {
            color: document.documentElement.classList.contains('dark') ? '#e5e7eb' : '#374151',
            maxRotation: 45,
            minRotation: 0,
            maxTicksLimit: 8
          },
          grid: {
            color: document.documentElement.classList.contains('dark') ? '#374151' : '#e5e7eb',
            display: false
          }
        },
        y: {
          ticks: {
            color: document.documentElement.classList.contains('dark') ? '#e5e7eb' : '#374151'
          },
          grid: {
            color: document.documentElement.classList.contains('dark') ? '#374151' : '#e5e7eb'
          }
        }
      }
    }
  });

  // Revenue Chart
  const revenueCtx = document.getElementById('revenueChart').getContext('2d');
  new Chart(revenueCtx, {
    type: 'bar',
    data: {
      labels: trendData.map(item => {
        // Clean date formatting - extract only the date part and format as DD/MM
        if (item.period.includes('T') || item.period.includes(' ')) {
          // Handle ISO date strings or date with time
          const datePart = item.period.split('T')[0].split(' ')[0];
          // Format as DD/MM
          const [year, month, day] = datePart.split('-');
          return `${day}/${month}`;
        } else if (item.period.includes('-') && item.period.split('-').length === 3) {
          // Handle YYYY-MM-DD format
          const [year, month, day] = item.period.split('-');
          return `${day}/${month}`;
        } else if (item.period.includes('-') && item.period.split('-').length === 2) {
          // Handle YYYY-MM format
          const [year, month] = item.period.split('-');
          return `${month}`;
        }
        return item.period;
      }),
      datasets: [{
        label: 'Revenue',
        data: trendData.map(item => item.revenue || 0), // Ensure we have data, default to 0
        backgroundColor: 'rgba(34, 197, 94, 0.8)',
        borderColor: 'rgb(34, 197, 94)',
        borderWidth: 1
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      layout: {
        padding: {
          top: 30
        }
      },
      plugins: {
        legend: {
          labels: {
            color: document.documentElement.classList.contains('dark') ? '#e5e7eb' : '#374151',
            usePointStyle: true,
            pointStyle: 'circle',
            padding: 25,
            boxWidth: 12,
            boxHeight: 12
          },
          position: 'top',
          margin: {
            top: 20,
            bottom: 0
          }
        },
        datalabels: {
          display: true,
          color: document.documentElement.classList.contains('dark') ? '#ffffff' : '#000000',
          font: {
            weight: 'bold',
            size: 9
          },
          formatter: function(value, context) {
            if (value > 0) {
              // Format numbers in k format (e.g., 46028 -> 46.0k)
              return (value / 1000).toFixed(1) + 'k';
            }
            return '';
          },
          anchor: 'end',
          align: 'top',
          offset: 8
        }
      },
      scales: {
        x: {
          ticks: {
            color: document.documentElement.classList.contains('dark') ? '#e5e7eb' : '#374151',
            maxRotation: 45,
            minRotation: 0
          },
          grid: {
            color: document.documentElement.classList.contains('dark') ? '#374151' : '#e5e7eb'
          }
        },
        y: {
          ticks: {
            color: document.documentElement.classList.contains('dark') ? '#e5e7eb' : '#374151',
            callback: function(value) {
              // Format y-axis ticks in k format
              return (value / 1000).toFixed(1) + 'k';
            }
          },
          grid: {
            color: document.documentElement.classList.contains('dark') ? '#374151' : '#e5e7eb'
          }
        }
      }
    }
  });

  // Loading spinner for Orders Analytics navigation
  document.getElementById('ordersAnalyticsLink').addEventListener('click', function(e) {
    const link = this;
    const icon = document.getElementById('ordersIcon');
    const linkText = document.getElementById('ordersLinkText');
    const arrowIcon = document.getElementById('ordersArrowIcon');
    
    // Show loading spinner
    link.style.pointerEvents = 'none';
    linkText.textContent = 'Loading...';
    
    // Replace icon with spinner
    icon.innerHTML = `
      <svg class="animate-spin w-6 h-6 text-blue-600 dark:text-blue-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
    `;
    
    // Hide arrow icon
    arrowIcon.style.display = 'none';
    
    // Add loading class to the card
    link.classList.add('opacity-75', 'cursor-wait');
  });

  // Loading spinner for Customers Analytics navigation
  document.getElementById('customersAnalyticsLink').addEventListener('click', function(e) {
    const link = this;
    const icon = document.getElementById('customersIcon');
    const linkText = document.getElementById('customersLinkText');
    const arrowIcon = document.getElementById('customersArrowIcon');

    link.style.pointerEvents = 'none';
    linkText.textContent = 'Loading...';
    icon.innerHTML = `
      <svg class="animate-spin w-6 h-6 text-green-600 dark:text-green-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
    `;
    arrowIcon.style.display = 'none';
    link.classList.add('opacity-75', 'cursor-wait');
  });
</script>


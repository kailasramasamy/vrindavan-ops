  <style>
    /* Dark mode support for month input */
    .dark input[type="month"] {
      color-scheme: dark;
    }
    
    input[type="month"]::-webkit-calendar-picker-indicator {
      cursor: pointer;
      opacity: 0.7;
      transition: opacity 0.2s;
    }
    
    input[type="month"]::-webkit-calendar-picker-indicator:hover {
      opacity: 1;
    }
    
    .dark input[type="month"]::-webkit-calendar-picker-indicator {
      filter: brightness(0) invert(1);
    }
  </style>

  <script>
    (function() {
      const API_BASE = "/payments/api";
      const STORAGE_KEY = "paymentsIndexState";
      
      const state = {
        month: null,
      };

      const elements = {
        monthInput: document.getElementById("paymentsMonth"),
        summaries: {
          delivery: document.getElementById("deliverySummary"),
          employee: document.getElementById("employeeSummary"),
          rent: document.getElementById("rentSummary"),
          transport: document.getElementById("transportSummary"),
          itServices: document.getElementById("itServicesSummary"),
          electricity: document.getElementById("electricitySummary"),
        },
        links: {
          delivery: document.getElementById("deliveryLink"),
          employee: document.getElementById("employeeLink"),
          rent: document.getElementById("rentLink"),
          transport: document.getElementById("transportLink"),
          itServices: document.getElementById("itServicesLink"),
          electricity: document.getElementById("electricityLink"),
          milk: document.getElementById("milkLink"),
        },
      };

      function loadStateFromStorage() {
        try {
          const raw = localStorage.getItem(STORAGE_KEY);
          if (raw) {
            const saved = JSON.parse(raw);
            if (saved.month) state.month = saved.month;
          }
        } catch (error) {
          console.error("Failed to load payments index state", error);
        }
      }

      function saveStateToStorage() {
        try {
          localStorage.setItem(STORAGE_KEY, JSON.stringify({
            month: state.month,
          }));
        } catch (error) {
          console.error("Failed to save payments index state", error);
        }
      }

      function getPreviousMonth() {
        const now = new Date();
        const prevMonth = new Date(now.getFullYear(), now.getMonth() - 1, 1);
        return `${prevMonth.getFullYear()}-${String(prevMonth.getMonth() + 1).padStart(2, '0')}`;
      }

      function updatePaymentLinks() {
        // Update all payment module links with the current month parameter
        const monthParam = state.month ? `?month=${encodeURIComponent(state.month)}` : '';
        
        if (elements.links.delivery) {
          elements.links.delivery.href = `/payments/delivery${monthParam}`;
        }
        if (elements.links.employee) {
          elements.links.employee.href = `/payments/employees${monthParam}`;
        }
        if (elements.links.rent) {
          elements.links.rent.href = `/payments/rent${monthParam}`;
        }
        if (elements.links.transport) {
          elements.links.transport.href = `/payments/transport${monthParam}`;
        }
        if (elements.links.itServices) {
          elements.links.itServices.href = `/payments/it-services${monthParam}`;
        }
        if (elements.links.electricity) {
          elements.links.electricity.href = `/payments/electricity${monthParam}`;
        }
        // Milk payments link doesn't need month parameter as it uses a different structure
        if (elements.links.milk) {
          elements.links.milk.href = `/procurement/billing/management`;
        }
      }

      function initMonthInput() {
        // Set default to previous month if not set
        const now = new Date();
        const currentMonth = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}`;
        const previousMonth = getPreviousMonth();
        
        if (!state.month) {
          state.month = previousMonth;
        }

        if (elements.monthInput) {
          elements.monthInput.value = state.month;
          elements.monthInput.max = currentMonth;
          elements.monthInput.addEventListener("change", (e) => {
            state.month = e.target.value || previousMonth;
            saveStateToStorage();
            updatePaymentLinks();
            loadSummary();
          });
        }
        
        // Update links initially
        updatePaymentLinks();
      }

      async function loadSummary() {
        const params = new URLSearchParams();
        if (state.month) params.append("month", state.month);

        try {
          const response = await fetch(`${API_BASE}/summary?${params.toString()}`);
          const data = await response.json();

          if (data && data.success && data.summary) {
            updateSummary("delivery", data.summary.delivery);
            updateSummary("employee", data.summary.employee);
            updateSummary("rent", data.summary.rent);
            updateSummary("transport", data.summary.transport);
            updateSummary("itServices", data.summary.itServices);
            updateSummary("electricity", data.summary.electricity);
          } else {
            showError("Failed to load summary");
          }
        } catch (error) {
          console.error("Error loading summary:", error);
          showError("Failed to load summary");
        }
      }

      function updateSummary(module, data) {
        const element = elements.summaries[module];
        if (!element) return;

        const { total, pending } = data || { total: 0, pending: 0 };
        
        if (total === 0) {
          element.innerHTML = '<span class="text-sm text-gray-400 dark:text-gray-500">No records</span>';
        } else {
          const pendingClass = pending > 0 ? "text-amber-600 dark:text-amber-400" : "text-emerald-600 dark:text-emerald-400";
          element.innerHTML = `
            <span class="${pendingClass} font-bold">${pending}</span>
            <span class="text-sm text-gray-500 dark:text-gray-400 font-normal">of</span>
            <span class="text-gray-700 dark:text-gray-300 font-bold">${total}</span>
            <span class="text-sm text-gray-500 dark:text-gray-400 font-normal">pending</span>
          `;
        }
      }

      function showError(message) {
        Object.values(elements.summaries).forEach(el => {
          if (el) {
            el.innerHTML = `<span class="text-red-500 dark:text-red-400">Error</span>`;
          }
        });
      }

      // Initialize
      document.addEventListener("DOMContentLoaded", () => {
        loadStateFromStorage();
        initMonthInput();
        loadSummary();
      });
    })();
  </script>
</body>
</html>

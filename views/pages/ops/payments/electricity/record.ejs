<%- include('../../../../partials/_head', { seo, pageKey }) %>

<script>
  (function () {
    const theme = localStorage.getItem("theme") || "dark";
    if (theme === "dark") {
      document.documentElement.classList.add("dark");
    } else {
      document.documentElement.classList.remove("dark");
    }
  })();
</script>

<body class="bg-slate-50 dark:bg-gray-900">
  <%- include('../../../../partials/_subnav', { user, section: 'Payments', subsection: 'Electricity Payments' }) %>

  <div class="min-h-screen pt-16">
    <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">
      <div class="flex items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <a href="/payments/electricity<%= selectedMonth ? `?month=${selectedMonth}` : "" %>" class="inline-flex items-center gap-2 text-sm text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Back to Electricity Payments
          </a>
        </div>
        <div>
          <% const statusClassMap = {
                pending: "bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300 border border-amber-200 dark:border-amber-800",
                ready: "bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300 border border-blue-200 dark:border-blue-800",
                paid: "bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300 border border-emerald-200 dark:border-emerald-800",
                on_hold: "bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300 border border-yellow-200 dark:border-yellow-800",
                cancelled: "bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300 border border-red-200 dark:border-red-800",
              };
              const statusText = (record.payment_status || "").replace(/_/g, " ") || "pending";
              const statusKey = (record.payment_status || "pending").toLowerCase();
              const statusClass = statusClassMap[statusKey] || statusClassMap.pending;
          %>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold <%= statusClass %>" data-field="status-badge">
            <%= statusText.charAt(0).toUpperCase() + statusText.slice(1) %>
          </span>
        </div>
      </div>

      <header class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-6 shadow-sm space-y-6">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
          <div>
            <h1 class="text-2xl font-semibold text-gray-900 dark:text-white" data-field="meter-name"><%= record.meter_name || "Meter" %></h1>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-2" data-field="meter-meta">
              <% if (record.meter_type) { %>
                Type: <%= record.meter_type.charAt(0).toUpperCase() + record.meter_type.slice(1) %>
              <% } %>
              <% if (record.invoice_number) { %>
                <% if (record.meter_type) { %> · <% } %>Invoice: <%= record.invoice_number %>
              <% } %>
            </p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
            <div class="space-y-1">
              <p class="text-xs uppercase font-semibold text-gray-500 dark:text-gray-400">Cycle</p>
              <p class="text-lg font-semibold text-gray-900 dark:text-white" data-field="cycle-range">
                <% if (cycle) { %>
                  <%= new Date(cycle.start_date).toLocaleDateString("en-IN", { month: "short", year: "numeric" }) %>
                <% } else { %>
                  —
                <% } %>
              </p>
            </div>
            <div class="space-y-1">
              <p class="text-xs uppercase font-semibold text-gray-500 dark:text-gray-400">Payment Date</p>
              <p class="text-lg font-semibold text-gray-900 dark:text-white" data-field="payment-date">
                <%= record.payment_date ? new Date(record.payment_date).toLocaleDateString("en-IN") : "—" %>
              </p>
            </div>
          </div>
        </div>
      </header>

      <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-5 shadow-sm">
          <p class="text-xs uppercase font-semibold text-gray-500 dark:text-gray-400">Invoice Amount</p>
          <p class="text-xl font-bold text-gray-900 dark:text-white mt-2" data-field="invoice-amount">₹<%= (Number(record.invoice_amount) || 0).toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></p>
          <% if (record.invoice_date) { %>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Invoice Date: <%= new Date(record.invoice_date).toLocaleDateString("en-IN") %></p>
          <% } %>
        </div>
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-5 shadow-sm">
          <p class="text-xs uppercase font-semibold text-gray-500 dark:text-gray-400">Adjustments</p>
          <p class="text-xl font-bold <%= Number(record.total_adjustments) >= 0 ? 'text-emerald-600 dark:text-emerald-400' : 'text-red-600 dark:text-red-400' %> mt-2" data-field="adjustments">
            <%= Number(record.total_adjustments) >= 0 ? '+' : '' %>₹<%= Math.abs(Number(record.total_adjustments) || 0).toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-5 shadow-sm">
          <p class="text-xs uppercase font-semibold text-gray-500 dark:text-gray-400">Net Pay</p>
          <p class="text-xl font-bold text-gray-900 dark:text-white mt-2" data-field="net">₹<%= (Number(record.net_pay) || 0).toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></p>
        </div>
      </section>

      <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-5 shadow-sm space-y-4">
          <div>
            <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-200">Payment Status</h2>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Update payment status and date</p>
          </div>
          <div class="space-y-3">
            <div>
              <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">Status</label>
              <select id="paymentStatusSelect" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-sm text-gray-900 dark:text-gray-100">
                <option value="pending" <%= record.payment_status === 'pending' ? 'selected' : '' %>>Pending</option>
                <option value="ready" <%= record.payment_status === 'ready' ? 'selected' : '' %>>Ready</option>
                <option value="paid" <%= record.payment_status === 'paid' ? 'selected' : '' %>>Paid</option>
                <option value="on_hold" <%= record.payment_status === 'on_hold' ? 'selected' : '' %>>On Hold</option>
                <option value="cancelled" <%= record.payment_status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">Payment Date</label>
              <input type="date" id="paymentDateInput" value="<%= record.payment_date || '' %>" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-sm text-gray-900 dark:text-gray-100">
            </div>
            <button id="updateStatusBtn" class="w-full px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
              Update Status
            </button>
          </div>
        </div>

        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-5 shadow-sm space-y-4">
          <div>
            <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-200">Remarks</h2>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Add notes or comments about this payment</p>
          </div>
          <div class="space-y-3">
            <textarea id="remarksTextarea" rows="4" placeholder="Enter remarks..." class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-sm text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500"><%= record.remarks || '' %></textarea>
            <button id="updateRemarksBtn" class="w-full px-4 py-2 bg-gray-600 text-white text-sm font-medium rounded-lg hover:bg-gray-700 transition-colors">
              Update Remarks
            </button>
          </div>
        </div>
      </section>

      <section class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-5 shadow-sm space-y-4">
        <div class="flex items-center justify-between">
          <div>
            <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-200">Adjustments & Entries</h2>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Add discounts, penalties, taxes, or other adjustments</p>
          </div>
          <button id="addEntryBtn" class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            Add Entry
          </button>
        </div>

        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-900">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Type</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Amount</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Date</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Description</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody id="entriesTableBody" class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
              <% if (entries && entries.length > 0) { %>
                <% entries.forEach(entry => { %>
                  <tr data-entry-id="<%= entry.id %>">
                    <td class="px-4 py-3 text-sm text-gray-900 dark:text-white capitalize"><%= (entry.entry_type || '').replace(/_/g, ' ') %></td>
                    <td class="px-4 py-3 text-sm font-medium <%= Number(entry.amount) >= 0 ? 'text-emerald-600 dark:text-emerald-400' : 'text-red-600 dark:text-red-400' %>">
                      <%= Number(entry.amount) >= 0 ? '+' : '' %>₹<%= Math.abs(Number(entry.amount) || 0).toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400">
                      <%= entry.entry_date ? new Date(entry.entry_date).toLocaleDateString("en-IN") : "—" %>
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400"><%= entry.description || "—" %></td>
                    <td class="px-4 py-3 text-sm">
                      <button class="text-red-600 dark:text-red-400 hover:text-red-700 dark:hover:text-red-300 delete-entry-btn" data-entry-id="<%= entry.id %>">
                        Delete
                      </button>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="5" class="px-4 py-6 text-center text-sm text-gray-500 dark:text-gray-400">No entries found</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </div>

  <script>
    window.ELECTRICITY_PAYMENT_RECORD_ID = <%= record.id %>;
    window.ELECTRICITY_PAYMENT_SELECTED_MONTH = "<%= selectedMonth || '' %>";
  </script>
  <script src="/assets/js/payments-electricity-record.js?v=<%= Date.now() %>"></script>
</body>
</html>



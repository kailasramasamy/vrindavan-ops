                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-gray-900">${Math.round(parseFloat(data.quantity_sold || 0))}</td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-gray-900">₹${parseFloat(data.unit_price || 0).toFixed(2)}</td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-semibold text-gray-900">₹${parseFloat(data.total_amount || 0).toFixed(2)}</td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                <div class="flex items-center justify-end space-x-2">
                  <button onclick="editSalesRecord(${recordId})" 
                          class="inline-flex items-center p-1.5 text-blue-600 hover:text-blue-900 dark:text-blue-400 dark:hover:text-blue-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg transition-colors"
                          title="Edit Record">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                  </button>
                  <button onclick="deleteSalesRecord(${recordId}, '${data.sale_date}', ${partnerId})" 
                          class="inline-flex items-center p-1.5 text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors"
                          title="Delete Record">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                  </button>
                </div>
              </td>
            `;
          }
        });
      }

       async function editSalesRecord(id) {
         try {
           // Find the record in the mutable salesRecords array
           const record = salesRecordsData.find(r => r.id === id);
           
           if (!record) {
             showToast("Sales record not found", "", "error");
             return;
           }

           // Store current partner ID
           currentPartnerId = record.partner_id;

           // Load partner products first
           const response = await fetch(`/sales/partners/${record.partner_id}/products`);
           const data = await response.json();

           if (data.success) {
             partnerProducts = data.products;

             // Set modal title
             document.getElementById("salesModalTitle").textContent = "Edit Sales Record";
             
             // Set hidden fields
             document.getElementById("salesRecordId").value = record.id;
             
             // Use the current page date (not the record's date to avoid timezone issues)
             // The record is shown on this page, so it belongs to this date
             document.getElementById("saleDate").value = '<%= date %>';
             document.getElementById("partnerId").value = record.partner_id;
             
             console.log('Edit record loaded:', { 
               id: record.id, 
               sale_date: '<%= date %>', 
               partner_id: record.partner_id,
               product_id: record.product_id,
               sales_channel: record.sales_channel
             });
             
             // Initialize searchable dropdown
             initializeProductSearch();
             
             // Set product search input display value
             document.getElementById("productSearchInput").value = `${record.product_name} (${record.unit_size})`;
             document.getElementById("productSelect").value = record.product_id;
             
             // Set other fields
             document.getElementById("quantitySold").value = parseFloat(record.quantity_sold || 0);
             document.getElementById("unitPrice").value = parseFloat(record.unit_price || 0);
             document.getElementById("totalAmount").value = parseFloat(record.total_amount || 0);
             document.querySelector('[name="notes"]').value = record.notes || '';
             
             // Show modal
             document.getElementById("salesModal").classList.remove("hidden");
           }
         } catch (error) {
           console.error("Error loading sales record:", error);
           showToast("Error loading record data", "", "error");
         }
       }

       async function deleteSalesRecord(id, date, partnerId) {
         if (!confirm("Are you sure you want to delete this sales record?")) return;

         try {
           const response = await fetch(`/sales/records/${id}`, {
             method: "DELETE",
             headers: { "Content-Type": "application/json" },
             body: JSON.stringify({ sale_date: date }),
           });

           const result = await response.json();

           if (result.success) {
             showToast(result.message, "", "success");
             
             // Remove from data array
             const dataIndex = salesRecordsData.findIndex(r => r.id === id);
             if (dataIndex !== -1) {
               salesRecordsData.splice(dataIndex, 1);
             }
             
             // Remove the row from table dynamically
             const tbody = document.querySelector(`#partner-${partnerId}-records tbody`);
             if (tbody) {
               const rows = tbody.querySelectorAll('tr');
               rows.forEach(row => {
                 const deleteBtn = row.querySelector(`button[onclick*="deleteSalesRecord(${id}"]`);
                 if (deleteBtn) {
                   row.remove();
                 }
               });
               
               // If no rows left, show "no records" message
               if (tbody.querySelectorAll('tr').length === 0) {
                 tbody.innerHTML = `
                   <tr>
                     <td colspan="5" class="px-6 py-8 text-center text-gray-500">
                       No sales records for this partner today. Click "Add Sales Record" to start.
                     </td>
                   </tr>
                 `;
               }
             }
           } else {
             showToast(result.error, "", "error");
           }
         } catch (error) {
           console.error("Error deleting sales record:", error);
           showToast("Error deleting record", "", "error");
         }
       }

       // App Sales Sync Functions
       function openSyncModal() {
         document.getElementById("syncModal").classList.remove("hidden");
       }

       function closeSyncModal() {
         document.getElementById("syncModal").classList.add("hidden");
       }

       const syncForm = document.getElementById("syncForm");
       if (syncForm) {
         syncForm.addEventListener("submit", async function (e) {
           e.preventDefault();

           const currentDate = "<%= date %>";
           const syncBtn = document.getElementById("syncBtn");
           const syncBtnText = document.getElementById("syncBtnText");
           const syncLoader = document.getElementById("syncLoader");

           // Show loading state
           syncBtn.disabled = true;
           syncBtnText.textContent = "Syncing...";
           syncLoader.classList.remove("hidden");

           try {
             const response = await fetch("/sales/api/sync-app-sales", {
               method: "POST",
               headers: { "Content-Type": "application/json" },
               body: JSON.stringify({ 
                 start_date: currentDate, 
                 end_date: currentDate 
               }),
             });

             const result = await response.json();

             if (result.success) {
               closeSyncModal();
               
               let message = result.message || "App sales synced successfully";
               
               // Log detailed results
               console.log("Sync Results:", {
                 synced: result.synced,
                 skipped: result.skipped,
                 totalItems: result.totalItems,
                 errors: result.errors
               });
               
               // Show detailed message if there were errors or skipped items
               if (result.errors && result.errors.length > 0) {
                 console.warn("Sync completed with errors:", result.errors);
                 message += `\n${result.errors.length} errors occurred. Check console for details.`;
                 // Show first 5 errors in console
                 result.errors.slice(0, 5).forEach((err, idx) => {
                   console.error(`Error ${idx + 1}:`, err);
                 });
               }
               
               if (result.skipped && result.skipped > 0) {
                 console.warn(`${result.skipped} items were skipped (likely no product mappings)`);
               }
               
               // Show appropriate toast
               const toastType = result.errors && result.errors.length > 0 ? "warning" : 
                                result.synced === 0 ? "warning" : "success";
               showToast(message, "", toastType);
               
               // Reload page to show synced data, maintaining partner_id=1
               setTimeout(() => {
                 window.location.href = `/sales/data-entry?date=${currentDate}&partner_id=1`;
               }, 2000);
             } else {
               console.error("Sync failed:", result.error);
               showToast(result.error || "Failed to sync app sales", "", "error");
             }
           } catch (error) {
             console.error("Error syncing app sales:", error);
             showToast("Error syncing app sales: " + error.message, "", "error");
           } finally {
             // Reset button state
             syncBtn.disabled = false;
             syncBtnText.textContent = "Sync Sales Data";
             syncLoader.classList.add("hidden");
           }
         });
       }
     </script>
</body>
</html>

<%- include('../../../partials/_head', { seo, pageKey }) %>
<link rel="stylesheet" href="/assets/css/sales-dark-mode.css">

<!-- Initialize theme immediately to prevent flash -->
<script>
  (function() {
    const theme = localStorage.getItem("sales_theme") || "dark";
    if (theme === "dark") {
      document.documentElement.classList.add("dark");
    }
  })();
</script>

<body class="bg-gray-50 dark:bg-gray-900">
  <%- include('../../../partials/_subnav', { user, section: 'Sales', subsection: 'Partners' }) %>

  
  <div class="min-h-screen pt-16">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Header -->
      <div class="mb-6 flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Sales Partners</h1>
          <p class="text-gray-600 mt-1">Manage sales partners and their product catalog</p>
        </div>

        <button onclick="openAddPartnerModal()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
          </svg>
          Add Partner
        </button>
      </div>

      <% if (locals.error) { %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6"><%= error %></div>
      <% } %>

      <!-- Partners Table -->
      <% if (partners && partners.length > 0) { %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50 dark:bg-gray-700">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Partner</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Contact</th>
                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Products</th>
                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Status</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
              <% partners.forEach(partner => { %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                <!-- Partner Info -->
                <td class="px-6 py-4">
                  <div class="flex items-start">
                    <div class="flex-1">
                      <div class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= partner.partner_name %></div>
                      <div class="text-sm text-gray-500 dark:text-gray-400 font-mono"><%= partner.partner_code %></div>
                      <% if (partner.address) { %>
                      <div class="text-xs text-gray-400 dark:text-gray-500 mt-1 max-w-xs truncate"><%= partner.address %></div>
                      <% } %>
                    </div>
                  </div>
                </td>
                
                <!-- Contact Info -->
                <td class="px-6 py-4">
                  <div class="space-y-1">
                    <% if (partner.contact_person) { %>
                    <div class="flex items-center text-sm text-gray-600 dark:text-gray-300">
                      <svg class="w-3 h-3 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                      </svg>
                      <%= partner.contact_person %>
                    </div>
                    <% } %>
                    <% if (partner.contact_email) { %>
                    <div class="flex items-center text-sm text-gray-600 dark:text-gray-300">
                      <svg class="w-3 h-3 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                      </svg>
                      <%= partner.contact_email %>
                    </div>
                    <% } %>
                    <% if (partner.contact_phone) { %>
                    <div class="flex items-center text-sm text-gray-600 dark:text-gray-300">
                      <svg class="w-3 h-3 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                      </svg>
                      <%= partner.contact_phone %>
                    </div>
                    <% } %>
                  </div>
                </td>
                
                <!-- Product Count -->
                <td class="px-6 py-4 text-center">
                  <div class="flex items-center justify-center">
                    <svg class="w-4 h-4 mr-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                    </svg>
                    <span class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= partner.product_count || 0 %></span>
                  </div>
                </td>
                
                <!-- Status -->
                <td class="px-6 py-4 text-center">
                  <% if (partner.is_active) { %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                    <svg class="w-1.5 h-1.5 mr-1" fill="currentColor" viewBox="0 0 8 8">
                      <circle cx="4" cy="4" r="3"/>
                    </svg>
                    Active
                  </span>
                  <% } else { %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200">
                    <svg class="w-1.5 h-1.5 mr-1" fill="currentColor" viewBox="0 0 8 8">
                      <circle cx="4" cy="4" r="3"/>
                    </svg>
                    Inactive
                  </span>
                  <% } %>
                </td>
                
                <!-- Actions -->
                <td class="px-6 py-4 text-right">
                  <div class="flex items-center justify-end space-x-2">
                    <button onclick="viewPartner(<%= partner.id %>)" 
                            class="inline-flex items-center px-3 py-1.5 bg-indigo-50 text-indigo-600 text-xs font-medium rounded-lg hover:bg-indigo-100 dark:bg-indigo-900 dark:text-indigo-200 dark:hover:bg-indigo-800 transition-colors"
                            title="View Details">
                      <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                      </svg>
                      View
                    </button>
                    <button onclick="manageProducts(<%= partner.id %>, '<%= partner.partner_name %>')" 
                            class="inline-flex items-center px-3 py-1.5 bg-blue-50 text-blue-600 text-xs font-medium rounded-lg hover:bg-blue-100 dark:bg-blue-900 dark:text-blue-200 dark:hover:bg-blue-800 transition-colors"
                            title="Manage Products">
                      <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                      </svg>
                      Products
                    </button>
                    <button onclick="editPartner(<%= partner.id %>)" 
                            class="inline-flex items-center px-3 py-1.5 bg-gray-50 text-gray-600 text-xs font-medium rounded-lg hover:bg-gray-100 dark:bg-gray-700 dark:text-gray-200 dark:hover:bg-gray-600 transition-colors"
                            title="Edit Partner">
                      <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                      </svg>
                      Edit
                    </button>
                    <% if (partner.partner_code !== 'VFA') { %>
                    <button onclick="deletePartner(<%= partner.id %>, '<%= partner.partner_name %>')" 
                            class="inline-flex items-center px-3 py-1.5 bg-red-50 text-red-600 text-xs font-medium rounded-lg hover:bg-red-100 dark:bg-red-900 dark:text-red-200 dark:hover:bg-red-800 transition-colors"
                            title="Delete Partner">
                      <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                      </svg>
                      Delete
                    </button>
                    <% } %>
                  </div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
      <% } else { %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-12 text-center">
        <svg class="w-16 h-16 mx-auto mb-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
        </svg>
        <h3 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-2">No Partners Found</h3>
        <p class="text-gray-600 dark:text-gray-400 mb-4">Get started by adding your first sales partner</p>
        <button onclick="openAddPartnerModal()" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
          </svg>
          Add First Partner
        </button>
      </div>
      <% } %>
    </main>
  </div>

  <%- include('../../../partials/_footer') %>
  <%- include('../../../partials/_toast') %>

     <!-- Add/Edit Partner Modal -->
    <div id="partnerModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
      <div class="bg-white rounded-xl shadow-xl max-w-2xl w-full mx-4 max-h-[90vh] overflow-y-auto">
        <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
          <h2 id="modalTitle" class="text-xl font-semibold text-gray-900">Add Partner</h2>
          <button onclick="closePartnerModal()" class="text-gray-400 hover:text-gray-600">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>

        <form id="partnerForm" class="p-6 space-y-4">
          <input type="hidden" id="partnerId" name="id" />

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Partner Name *</label>
              <input type="text" name="partner_name" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Partner Code *</label>
              <input type="text" name="partner_code" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" />
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Contact Person</label>
              <input type="text" name="contact_person" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Contact Phone</label>
              <input type="tel" name="contact_phone" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Contact Email</label>
            <input type="email" name="contact_email" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Address</label>
            <textarea name="address" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"></textarea>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Notes</label>
            <textarea name="notes" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"></textarea>
          </div>

          <div class="flex items-center">
            <input type="checkbox" name="is_active" id="is_active" value="1" checked class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" />
            <label for="is_active" class="ml-2 text-sm text-gray-700">Active</label>
          </div>

          <div class="flex gap-3 pt-4">
            <button type="submit" class="flex-1 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Save Partner</button>
            <button type="button" onclick="closePartnerModal()" class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300">Cancel</button>
          </div>
        </form>
      </div>
    </div>

    <!-- View Partner Details Modal -->
    <div id="viewPartnerModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl max-w-3xl w-full mx-4 max-h-[90vh] overflow-y-auto">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between sticky top-0 bg-white dark:bg-gray-800 z-10">
          <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Partner Details</h2>
          <button onclick="closeViewPartnerModal()" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>

        <div class="p-6 space-y-6">
          <!-- Partner Information -->
          <div class="bg-gray-50 dark:bg-gray-900 rounded-lg p-4">
            <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wide mb-4">Partner Information</h3>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Partner Name</label>
                <p id="viewPartnerName" class="text-sm font-medium text-gray-900 dark:text-white">-</p>
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Partner Code</label>
                <p id="viewPartnerCode" class="text-sm font-mono font-medium text-gray-900 dark:text-white">-</p>
              </div>
              <div class="col-span-2">
                <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Address</label>
                <p id="viewAddress" class="text-sm text-gray-700 dark:text-gray-300">-</p>
              </div>
            </div>
          </div>

          <!-- Contact Information -->
          <div class="bg-gray-50 dark:bg-gray-900 rounded-lg p-4">
            <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wide mb-4">Contact Information</h3>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Contact Person</label>
                <p id="viewContactPerson" class="text-sm text-gray-700 dark:text-gray-300">-</p>
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Contact Phone</label>
                <p id="viewContactPhone" class="text-sm text-gray-700 dark:text-gray-300">-</p>
              </div>
              <div class="col-span-2">
                <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Contact Email</label>
                <p id="viewContactEmail" class="text-sm text-gray-700 dark:text-gray-300">-</p>
              </div>
            </div>
          </div>

          <!-- Additional Information -->
          <div class="bg-gray-50 dark:bg-gray-900 rounded-lg p-4">
            <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wide mb-4">Additional Information</h3>
            <div class="space-y-3">
              <div>
                <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Status</label>
                <div id="viewStatus"></div>
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Product Count</label>
                <p id="viewProductCount" class="text-sm text-gray-700 dark:text-gray-300">-</p>
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Notes</label>
                <p id="viewNotes" class="text-sm text-gray-700 dark:text-gray-300 whitespace-pre-wrap">-</p>
              </div>
            </div>
          </div>

          <!-- Products List -->
          <div class="bg-gray-50 dark:bg-gray-900 rounded-lg p-4">
            <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wide mb-4">Associated Products</h3>
            <div id="viewProductsList" class="space-y-2 max-h-60 overflow-y-auto">
              <p class="text-sm text-gray-500 dark:text-gray-400 text-center py-4">Loading products...</p>
            </div>
          </div>
        </div>

        <div class="px-6 py-4 border-t border-gray-200 dark:border-gray-700 flex justify-end">
          <button onclick="closeViewPartnerModal()" class="px-4 py-2 bg-gray-200 dark:bg-gray-600 text-gray-700 dark:text-gray-200 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-500 transition-colors">Close</button>
        </div>
      </div>
    </div>

    <!-- Manage Products Modal -->
    <div id="productsModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl max-w-4xl w-full mx-4 max-h-[90vh] overflow-y-auto">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between sticky top-0 bg-white dark:bg-gray-800 z-10">
          <h2 id="productsModalTitle" class="text-xl font-semibold text-gray-900 dark:text-white">Manage Products</h2>
          <button onclick="closeProductsModal()" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>

        <form id="productsForm" class="p-6">
          <input type="hidden" id="productsPartnerId" />

          <!-- Product Search Dropdown -->
          <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Add Product</label>
            <div class="relative">
              <input 
                type="text" 
                id="productSearchInput" 
                placeholder="Search products..." 
                autocomplete="off"
                class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500"
              />
              <div id="productDropdown" class="hidden absolute z-50 w-full mt-1 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg shadow-lg max-h-60 overflow-y-auto">
                <!-- Products will be loaded dynamically -->
              </div>
            </div>
          </div>

          <!-- Selected Products List -->
          <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Selected Products</label>
            <div id="selectedProductsList" class="border border-gray-200 dark:border-gray-700 rounded-lg p-4 min-h-[200px] max-h-[400px] overflow-y-auto bg-gray-50 dark:bg-gray-900/50">
              <p class="text-sm text-gray-500 dark:text-gray-400 text-center py-8">No products selected</p>
            </div>
          </div>

          <div class="flex gap-3 pt-6 border-t border-gray-200 dark:border-gray-700 mt-6">
            <button type="submit" class="flex-1 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600">Save Products</button>
            <button type="button" onclick="closeProductsModal()" class="px-4 py-2 bg-gray-200 dark:bg-gray-600 text-gray-700 dark:text-gray-200 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-500">Cancel</button>
          </div>
        </form>
      </div>
    </div>

     <script>
      let editMode = false;

      function openAddPartnerModal() {
        editMode = false;
        document.getElementById("modalTitle").textContent = "Add Partner";
        document.getElementById("partnerForm").reset();
        document.getElementById("partnerId").value = "";
        document.getElementById("partnerModal").classList.remove("hidden");
      }

      function closePartnerModal() {
        document.getElementById("partnerModal").classList.add("hidden");
      }

      async function editPartner(id) {
        editMode = true;
        document.getElementById("modalTitle").textContent = "Edit Partner";

        try {
          const response = await fetch(`/sales/partners/${id}`);
          const data = await response.json();

          if (data.success) {
            const partner = data.partner;
            document.getElementById("partnerId").value = partner.id;
            document.querySelector('[name="partner_name"]').value = partner.partner_name || "";
            document.querySelector('[name="partner_code"]').value = partner.partner_code || "";
            document.querySelector('[name="contact_person"]').value = partner.contact_person || "";
            document.querySelector('[name="contact_phone"]').value = partner.contact_phone || "";
            document.querySelector('[name="contact_email"]').value = partner.contact_email || "";
            document.querySelector('[name="address"]').value = partner.address || "";
            document.querySelector('[name="notes"]').value = partner.notes || "";
            document.querySelector('[name="is_active"]').checked = partner.is_active;

            document.getElementById("partnerModal").classList.remove("hidden");
          }
        } catch (error) {
          console.error("Error fetching partner:", error);
          showToast("Error loading partner data", "", "error");
        }
      }

      document.getElementById("partnerForm").addEventListener("submit", async function (e) {
        e.preventDefault();

        const formData = new FormData(this);
        const data = Object.fromEntries(formData);
        data.is_active = formData.has("is_active") ? 1 : 0;

        const partnerId = document.getElementById("partnerId").value;
        const url = partnerId ? `/sales/partners/${partnerId}` : "/sales/partners";
        const method = partnerId ? "PUT" : "POST";

        try {
          const response = await fetch(url, {
            method: method,
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
          });

          const result = await response.json();

          if (result.success) {
            closePartnerModal();
            showToast(result.message, "", "success");
            setTimeout(() => location.reload(), 1000);
          } else {
            showToast(result.error, "", "error");
          }
        } catch (error) {
          console.error("Error saving partner:", error);
          showToast("Error saving partner", "", "error");
        }
      });

      async function deletePartner(id, name) {
        if (!confirm(`Are you sure you want to delete "${name}"?`)) return;

        try {
          const response = await fetch(`/sales/partners/${id}`, {
            method: "DELETE",
          });

          const result = await response.json();

          if (result.success) {
            showToast(result.message, "", "success");
            setTimeout(() => location.reload(), 1000);
          } else {
            showToast(result.error, "", "error");
          }
        } catch (error) {
          console.error("Error deleting partner:", error);
          showToast("Error deleting partner", "", "error");
        }
      }

      // View partner details
      async function viewPartner(id) {
        try {
          // Fetch partner details
          const response = await fetch(`/sales/partners/${id}`);
          const data = await response.json();

          if (!data.success) {
            showToast("Error loading partner details", "", "error");
            return;
          }

          const partner = data.partner;

          // Populate basic information
          document.getElementById("viewPartnerName").textContent = partner.partner_name || "-";
          document.getElementById("viewPartnerCode").textContent = partner.partner_code || "-";
          document.getElementById("viewAddress").textContent = partner.address || "-";

          // Populate contact information
          document.getElementById("viewContactPerson").textContent = partner.contact_person || "-";
          document.getElementById("viewContactPhone").textContent = partner.contact_phone || "-";
          document.getElementById("viewContactEmail").textContent = partner.contact_email || "-";

          // Populate status
          const statusHtml = partner.is_active 
            ? '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200"><svg class="w-1.5 h-1.5 mr-1" fill="currentColor" viewBox="0 0 8 8"><circle cx="4" cy="4" r="3"/></svg>Active</span>'
            : '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200"><svg class="w-1.5 h-1.5 mr-1" fill="currentColor" viewBox="0 0 8 8"><circle cx="4" cy="4" r="3"/></svg>Inactive</span>';
          document.getElementById("viewStatus").innerHTML = statusHtml;

          // Populate product count
          document.getElementById("viewProductCount").textContent = partner.product_count || "0";

          // Populate notes
          document.getElementById("viewNotes").textContent = partner.notes || "-";

          // Load products
          await loadPartnerProducts(id);

          // Show modal
          document.getElementById("viewPartnerModal").classList.remove("hidden");
        } catch (error) {
          console.error("Error fetching partner details:", error);
          showToast("Error loading partner details", "", "error");
        }
      }

      async function loadPartnerProducts(partnerId) {
        const productsList = document.getElementById("viewProductsList");
        productsList.innerHTML = '<p class="text-sm text-gray-500 dark:text-gray-400 text-center py-4">Loading products...</p>';

        try {
          const response = await fetch(`/sales/partners/${partnerId}/products`);
          const data = await response.json();

          if (data.success && data.products && data.products.length > 0) {
            productsList.innerHTML = data.products.map(product => {
              const displayName = product.product_name || 'Unknown Product';
              const unitSize = product.unit_size || '';
              const milkType = product.milk_type || '';
              
              return `
                <div class="flex items-center p-3 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg">
                  <div class="w-10 h-10 bg-blue-50 dark:bg-blue-900/20 rounded-lg flex items-center justify-center mr-3 flex-shrink-0">
                    <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-gray-900 dark:text-white truncate">${displayName}</p>
                    <p class="text-xs text-gray-500 dark:text-gray-400">${unitSize} ${milkType}</p>
                  </div>
                </div>
              `;
            }).join('');
          } else {
            productsList.innerHTML = '<p class="text-sm text-gray-500 dark:text-gray-400 text-center py-4">No products assigned</p>';
          }
        } catch (error) {
          console.error("Error loading partner products:", error);
          productsList.innerHTML = '<p class="text-sm text-red-500 dark:text-red-400 text-center py-4">Error loading products</p>';
        }
      }

      function closeViewPartnerModal() {
        document.getElementById("viewPartnerModal").classList.add("hidden");
      }

      // Products management state
      let allProducts = [];
      let selectedProducts = new Map(); // Map of productId -> product object

      // Load all products
      async function loadAllProducts() {
        try {
          const response = await fetch('/product-margin/api/v1/products');
          const data = await response.json();
          
          if (data.success && data.data) {
            allProducts = data.data;
          } else {
            console.error("Failed to load products:", data.error);
          }
        } catch (error) {
          console.error("Error loading products:", error);
        }
      }

      // Initialize product search dropdown
      function initProductSearch() {
        const searchInput = document.getElementById('productSearchInput');
        const dropdown = document.getElementById('productDropdown');

        if (!searchInput || !dropdown) return;

        // Show dropdown on focus
        searchInput.addEventListener('focus', () => {
          filterAndShowProducts('');
        });

        // Filter products as user types
        searchInput.addEventListener('input', (e) => {
          filterAndShowProducts(e.target.value);
        });

        // Hide dropdown when clicking outside
        const clickOutsideHandler = (e) => {
          if (!searchInput.contains(e.target) && !dropdown.contains(e.target)) {
            dropdown.classList.add('hidden');
          }
        };
        // Use capture phase and only add listener once
        document.removeEventListener('click', clickOutsideHandler);
        document.addEventListener('click', clickOutsideHandler);
      }

      // Filter and show products in dropdown
      function filterAndShowProducts(searchTerm) {
        const dropdown = document.getElementById('productDropdown');
        if (!dropdown) return;

        const term = searchTerm.toLowerCase();
        const filtered = allProducts.filter(p => {
          const name = (p.name || '').toLowerCase();
          const alias = (p.name_alias || '').toLowerCase();
          const unitSize = (p.unit_size || '').toLowerCase();
          return (name.includes(term) || alias.includes(term) || unitSize.includes(term)) && !selectedProducts.has(p.id);
        });

        if (filtered.length === 0) {
          dropdown.innerHTML = '<div class="px-3 py-2 text-gray-500 dark:text-gray-400 text-sm">No products found</div>';
          dropdown.classList.remove('hidden');
          return;
        }

        dropdown.innerHTML = filtered.map(product => {
          const displayName = product.name_alias || product.name;
          const unitSize = product.unit_size || product.grammage || '';
          return `
            <div 
              class="px-3 py-2 hover:bg-blue-50 dark:hover:bg-gray-600 cursor-pointer product-dropdown-item" 
              data-id="${product.id}"
              data-name="${displayName}"
              data-unit="${unitSize}"
            >
              <div class="font-medium text-gray-900 dark:text-white">${displayName}</div>
              <div class="text-sm text-gray-500 dark:text-gray-400">${unitSize} ${product.milk_type || ''}</div>
            </div>
          `;
        }).join('');

        // Add click handlers to dropdown items
        const searchInputElement = document.getElementById('productSearchInput');
        dropdown.querySelectorAll('.product-dropdown-item').forEach(item => {
          item.addEventListener('click', () => {
            const productId = parseInt(item.getAttribute('data-id'));
            const productName = item.getAttribute('data-name');
            const productUnit = item.getAttribute('data-unit');
            
            // Find full product object
            const product = allProducts.find(p => p.id === productId);
            if (product) {
              addProductToSelection(product);
              if (searchInputElement) {
                searchInputElement.value = '';
              }
              dropdown.classList.add('hidden');
            }
          });
        });

        dropdown.classList.remove('hidden');
      }

      // Add product to selection
      function addProductToSelection(product) {
        if (selectedProducts.has(product.id)) {
          return; // Already selected
        }

        selectedProducts.set(product.id, product);
        renderSelectedProducts();
      }

      // Remove product from selection (make it globally accessible for onclick)
      window.removeProductFromSelection = function(productId) {
        selectedProducts.delete(productId);
        renderSelectedProducts();
      };

      // Render selected products list
      function renderSelectedProducts() {
        const listContainer = document.getElementById('selectedProductsList');
        if (!listContainer) return;

        if (selectedProducts.size === 0) {
          listContainer.innerHTML = '<p class="text-sm text-gray-500 dark:text-gray-400 text-center py-8">No products selected</p>';
          return;
        }

        listContainer.innerHTML = Array.from(selectedProducts.values()).map(product => {
          const displayName = product.name_alias || product.name;
          const unitSize = product.unit_size || product.grammage || '';
          return `
            <div class="flex items-center justify-between p-3 mb-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg">
              <div class="flex-1">
                <div class="text-sm font-medium text-gray-900 dark:text-white">${displayName}</div>
                <div class="text-xs text-gray-500 dark:text-gray-400">${unitSize} ${product.milk_type || ''}</div>
              </div>
              <button 
                type="button" 
                onclick="removeProductFromSelection(${product.id})" 
                class="ml-4 text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300"
                title="Remove product"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </button>
            </div>
          `;
        }).join('');
      }

      async function manageProducts(partnerId, partnerName) {
        document.getElementById("productsModalTitle").textContent = `Manage Products - ${partnerName}`;
        document.getElementById("productsPartnerId").value = partnerId;

        // Reset state
        selectedProducts.clear();
        document.getElementById('productSearchInput').value = '';
        document.getElementById('productDropdown').classList.add('hidden');

        // Load all products first
        await loadAllProducts();

        // Load partner's current products
        try {
          const response = await fetch(`/sales/partners/${partnerId}/products`);
          const data = await response.json();

          if (data.success && data.products) {
            // Add partner's products to selection
            data.products.forEach((partnerProduct) => {
              const product = allProducts.find(p => p.id === partnerProduct.product_id);
              if (product) {
                addProductToSelection(product);
              }
            });
          }

          document.getElementById("productsModal").classList.remove("hidden");
          
          // Initialize search after modal is shown
          setTimeout(() => {
            initProductSearch();
          }, 100);
        } catch (error) {
          console.error("Error loading partner products:", error);
          showToast("Error loading products", "", "error");
        }
      }

      function closeProductsModal() {
        document.getElementById("productsModal").classList.add("hidden");
        selectedProducts.clear();
        renderSelectedProducts();
      }

      document.getElementById("productsForm").addEventListener("submit", async function (e) {
        e.preventDefault();

        const partnerId = document.getElementById("productsPartnerId").value;
        const selectedProductIds = Array.from(selectedProducts.keys());

        try {
          const response = await fetch(`/sales/partners/${partnerId}/products`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ product_ids: selectedProductIds }),
          });

          const result = await response.json();

          if (result.success) {
            closeProductsModal();
            showToast(result.message, "", "success");
            setTimeout(() => location.reload(), 1000);
          } else {
            showToast(result.error, "", "error");
          }
        } catch (error) {
          console.error("Error updating products:", error);
          showToast("Error updating products", "", "error");
         }
       });
     </script>
</body>
</html>

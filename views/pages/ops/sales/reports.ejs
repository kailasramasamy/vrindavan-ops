<%- include('../../../partials/_head', { seo, pageKey }) %>
<link rel="stylesheet" href="/assets/css/sales-dark-mode.css">

<!-- Initialize theme immediately to prevent flash -->
<script>
  (function() {
    const theme = localStorage.getItem("theme") || "dark";
    if (theme === "dark") {
      document.documentElement.classList.add("dark");
    }
  })();
</script>

<body class="bg-gray-50 dark:bg-gray-900">
  <%- include('../../../partials/_subnav', { user, section: 'Sales', subsection: 'Reports' }) %>
  
  <div class="min-h-screen pt-16">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-8">
    <!-- Header -->
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Sales Reports</h1>
      <p class="text-gray-600 dark:text-gray-400 mt-1">Analyze sales performance across different channels and products</p>
    </div>

    <% if (locals.error) { %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6">
        <%= error %>
      </div>
    <% } %>

    <!-- Partner Sales Trends Charts -->
    <div class="mb-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Partner Sales Trends</h2>
        <div class="flex items-center gap-2">
          <select id="chartDateRange" class="px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 rounded-lg focus:ring-2 focus:ring-blue-500">
            <option value="7">Last 7 Days</option>
            <option value="14">Last 14 Days</option>
            <option value="30">Last 30 Days</option>
            <option value="60">Last 60 Days</option>
            <option value="90">Last 90 Days</option>
          </select>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <% if (partners && partners.length > 0) { %>
          <% partners.forEach(partner => { %>
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">
                <%= partner.partner_name %>
                <span class="text-sm font-normal text-gray-500 dark:text-gray-400 ml-2">(<%= partner.partner_code %>)</span>
              </h3>
              <div class="relative" style="height: 300px;">
                <canvas id="partnerChart<%= partner.id %>"></canvas>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <div class="col-span-2 bg-gray-50 dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-12 text-center">
            <svg class="w-16 h-16 text-gray-400 dark:text-gray-600 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
            <p class="text-gray-500 dark:text-gray-400">No partners available</p>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Report Content -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white">
              <% if (report_type === 'summary') { %>
                Overall Summary Report
              <% } else if (report_type === 'product') { %>
                Product-wise Sales Report
              <% } else if (report_type === 'channel') { %>
                Channel-wise Sales Report
              <% } else if (report_type === 'trends') { %>
                Daily Sales Trends
              <% } %>
            </h2>
            <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
              <%= new Date(start_date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %> 
              to 
              <%= new Date(end_date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %>
            </p>
          </div>
          
          <% if (report_type === 'summary') { %>
            <!-- Filters inside header for summary report -->
            <form id="reportFilters" class="flex flex-wrap items-end gap-3">
              <div>
                <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">Start Date</label>
                <input 
                  type="date" 
                  name="start_date" 
                  value="<%= start_date %>" 
                  class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 rounded-lg focus:ring-2 focus:ring-blue-500"
                >
              </div>
              
              <div>
                <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">End Date</label>
                <input 
                  type="date" 
                  name="end_date" 
                  value="<%= end_date %>" 
                  class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 rounded-lg focus:ring-2 focus:ring-blue-500"
                >
              </div>

              <div>
                <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">Report Type</label>
                <select 
                  name="report_type" 
                  class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 rounded-lg focus:ring-2 focus:ring-blue-500"
                >
                  <option value="summary" <%= report_type === 'summary' ? 'selected' : '' %>>Overall Summary</option>
                  <option value="product" <%= report_type === 'product' ? 'selected' : '' %>>Product-wise</option>
                  <option value="channel" <%= report_type === 'channel' ? 'selected' : '' %>>Channel-wise</option>
                  <option value="trends" <%= report_type === 'trends' ? 'selected' : '' %>>Daily Trends</option>
                </select>
              </div>

              <div class="flex items-end gap-2">
                <button 
                  type="submit" 
                  class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-sm"
                >
                  Generate
                </button>
                <button 
                  type="button" 
                  onclick="exportReport()" 
                  class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors text-sm"
                  title="Export to CSV"
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                  </svg>
                </button>
              </div>
            </form>
          <% } else { %>
            <!-- Filters outside header for other report types -->
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-6">
              <form id="reportFilters" class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Start Date</label>
                  <input 
                    type="date" 
                    name="start_date" 
                    value="<%= start_date %>" 
                    class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 rounded-lg focus:ring-2 focus:ring-blue-500"
                  >
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">End Date</label>
                  <input 
                    type="date" 
                    name="end_date" 
                    value="<%= end_date %>" 
                    class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 rounded-lg focus:ring-2 focus:ring-blue-500"
                  >
                </div>

                <div>
                  <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Report Type</label>
                  <select 
                    name="report_type" 
                    class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 rounded-lg focus:ring-2 focus:ring-blue-500"
                  >
                    <option value="summary" <%= report_type === 'summary' ? 'selected' : '' %>>Overall Summary</option>
                    <option value="product" <%= report_type === 'product' ? 'selected' : '' %>>Product-wise</option>
                    <option value="channel" <%= report_type === 'channel' ? 'selected' : '' %>>Channel-wise</option>
                    <option value="trends" <%= report_type === 'trends' ? 'selected' : '' %>>Daily Trends</option>
                  </select>
                </div>

                <div class="flex items-end gap-2">
                  <button 
                    type="submit" 
                    class="flex-1 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
                  >
                    Generate
                  </button>
                  <button 
                    type="button" 
                    onclick="exportReport()" 
                    class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors"
                    title="Export to CSV"
                  >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg>
                  </button>
                </div>
              </form>
            </div>
          <% } %>
        </div>
      </div>

      <div class="overflow-x-auto">
        <% if (report_type === 'summary') { %>
          <!-- Overall Summary Report -->

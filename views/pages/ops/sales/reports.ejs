                  <td colspan="6" class="px-6 py-12 text-center text-gray-500">
                    No data available for the selected date range
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        <% } %>
      </div>
    </div>
    </main>
  </div>

  <%- include('../../../partials/_toast') %>

  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
  <script>
    // Register datalabels plugin after scripts load
    if (typeof Chart !== 'undefined' && typeof ChartDataLabels !== 'undefined') {
      Chart.register(ChartDataLabels);
    }
  </script>

  <script>
    document.getElementById('reportFilters').addEventListener('submit', function(e) {
      e.preventDefault();
      const formData = new FormData(this);
      const params = new URLSearchParams(formData);
      window.location.href = `?${params.toString()}`;
    });

    function exportReport() {
      const reportData = <%- JSON.stringify(reportData) %>;
      const reportType = '<%= report_type %>';
      
      if (!reportData || reportData.length === 0) {
        showToast('No data to export', 'warning');
        return;
      }

      // Convert to CSV
      let csv = '';
      const headers = Object.keys(reportData[0]);
      csv += headers.join(',') + '\n';
      
      reportData.forEach(row => {
        const values = headers.map(header => {
          const value = row[header] || '';
          return typeof value === 'string' && value.includes(',') ? `"${value}"` : value;
        });
        csv += values.join(',') + '\n';
      });

      // Download
      const blob = new Blob([csv], { type: 'text/csv' });
      const url = window.URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `sales-report-${reportType}-${new Date().toISOString().split('T')[0]}.csv`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      window.URL.revokeObjectURL(url);
      
      showToast('Report exported successfully', 'success');
    }

    // Partner Sales Trends Charts
    const partners = <%- JSON.stringify(partners || []) %>;
    let partnerCharts = {};

    // Function to load partner sales data
    async function loadPartnerSalesData(days = 7) {
      try {
        const today = new Date();
        const startDate = new Date(today);
        startDate.setDate(startDate.getDate() - (days - 1));

        const response = await fetch(`/sales/api/partner-sales-trends?start_date=${startDate.toISOString().split('T')[0]}&end_date=${today.toISOString().split('T')[0]}`);
        const result = await response.json();

        if (result.success) {
          renderPartnerCharts(result.data);
        } else {
          console.error('Failed to load partner sales data:', result.error);
        }
      } catch (error) {
        console.error('Error loading partner sales data:', error);
      }
    }

    // Function to render partner charts
    function renderPartnerCharts(data) {
      // Get the selected date range
      const days = parseInt(document.getElementById('chartDateRange').value || 7);
      
      // Generate all dates in the range (using local timezone)
      const today = new Date();
      today.setHours(0, 0, 0, 0); // Normalize to start of day
      const allDates = [];
      for (let i = days - 1; i >= 0; i--) {
        const date = new Date(today);
        date.setDate(date.getDate() - i);
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const day = String(date.getDate()).padStart(2, '0');
        allDates.push(`${year}-${month}-${day}`);
      }

      // Group data by partner and date
      const partnerData = {};
      
      data.forEach(row => {
        // Date is already in YYYY-MM-DD format from the API
        const normalizedDate = row.sale_date;

        if (!partnerData[row.partner_id]) {
          partnerData[row.partner_id] = {
            name: row.partner_name,
            dates: {},
          };
        }
        
        if (!partnerData[row.partner_id].dates[normalizedDate]) {
          partnerData[row.partner_id].dates[normalizedDate] = {
            total: 0,
            products: []
          };
        }
        
        const quantity = parseFloat(row.total_quantity || 0);
        partnerData[row.partner_id].dates[normalizedDate].total += quantity;
        partnerData[row.partner_id].dates[normalizedDate].products.push({
          name: row.product_name,
          milk_type: row.milk_type,
          quantity: quantity
        });
      });

      // Use all dates (sorted by definition)
      const sortedDates = allDates;

      // Create or update charts for each partner
      partners.forEach(partner => {
        const ctx = document.getElementById(`partnerChart${partner.id}`);
        if (!ctx) return;

        // Prepare data for this partner
        const chartData = sortedDates.map(date => {
          const dateData = partnerData[partner.id]?.dates[date];
          return dateData ? dateData.total : 0;
        });

        // Prepare tooltip data
        const tooltipData = sortedDates.map(date => {
          const dateData = partnerData[partner.id]?.dates[date];
          return dateData ? dateData.products : [];
        });

        // Format dates for labels (handle timezone correctly)
        const labels = sortedDates.map(date => {
          const [year, month, day] = date.split('-');
          const d = new Date(parseInt(year), parseInt(month) - 1, parseInt(day));
          return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        });

        // Destroy existing chart if it exists
        if (partnerCharts[partner.id]) {
          partnerCharts[partner.id].destroy();
        }

        // Detect dark mode for grid colors
        const isDarkMode = document.documentElement.classList.contains('dark');
        const yGridColor = isDarkMode ? 'rgba(255, 255, 255, 0.15)' : 'rgba(0, 0, 0, 0.1)';
        const xGridColor = isDarkMode ? 'rgba(255, 255, 255, 0.1)' : 'rgba(0, 0, 0, 0.05)';

        // Create new chart
        partnerCharts[partner.id] = new Chart(ctx, {
          type: 'line',
          data: {
            labels: labels,
            datasets: [{
              label: 'Total Products Sold',
              data: chartData,
              borderColor: 'rgb(59, 130, 246)',
              backgroundColor: 'rgba(59, 130, 246, 0.1)',
              tension: 0.4,
              fill: true,
              pointRadius: 6,
              pointHoverRadius: 8,
              pointBackgroundColor: 'rgb(59, 130, 246)',
              pointBorderColor: '#fff',
              pointBorderWidth: 2,
              spanGaps: false,
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: {
              intersect: false,
              mode: 'index'
            },
            plugins: {
              legend: {
                display: false
              },
              datalabels: {
                display: true,
                align: 'top',
                color: 'rgb(59, 130, 246)',
                font: {
                  weight: 'bold',
                  size: 11
                },
                formatter: function(value) {
                  return value > 0 ? Math.round(value) : '';
                }
              },
              tooltip: {
                backgroundColor: 'rgba(0, 0, 0, 0.8)',
                padding: 12,
                titleColor: '#fff',
                titleFont: {
                  size: 14,
                  weight: 'bold'
                },
                bodyColor: '#fff',
                bodyFont: {
                  size: 13
                },
                bodySpacing: 6,
                displayColors: false,
                callbacks: {
                  title: function(context) {
                    return `${labels[context[0].dataIndex]} - Total: ${chartData[context[0].dataIndex]}`;
                  },
                  label: function(context) {
                    return '';
                  },
                  afterLabel: function(context) {
                    const products = tooltipData[context.dataIndex];
                    if (!products || products.length === 0) {
                      return 'No sales';
                    }
                    return products.map(p => 
                      `${p.name} (${p.milk_type}): ${Math.round(p.quantity)}`
                    );
                  }
                }
              }
            },
            scales: {
              y: {
                beginAtZero: true,
                ticks: {
                  precision: 0,
                  color: isDarkMode ? 'rgba(255, 255, 255, 0.6)' : 'rgba(0, 0, 0, 0.6)'
                },
                grid: {
                  color: yGridColor,
                  display: true
                }
              },
              x: {
                ticks: {
                  color: isDarkMode ? 'rgba(255, 255, 255, 0.6)' : 'rgba(0, 0, 0, 0.6)'
                },
                grid: {
                  display: true,
                  color: xGridColor
                }
              }
            }
          }
        });
      });
    }

    // Date range change handler
    document.getElementById('chartDateRange').addEventListener('change', function(e) {
      loadPartnerSalesData(parseInt(e.target.value));
    });

    // Load initial data on page load
    if (partners && partners.length > 0) {
      loadPartnerSalesData(7);
    }
  </script>
</body>
</html>


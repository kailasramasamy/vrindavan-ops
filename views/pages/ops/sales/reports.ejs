            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Product</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Milk Type</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Produced</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Sold (App)</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Sold (Partners)</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Total Sold</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Unsold</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Avg/Day</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% if (reportData && reportData.length > 0) { %>
                <% reportData.forEach(row => { %>
                  <tr class="hover:bg-gray-50">
                    <td class="px-6 py-4">
                      <div class="font-medium text-gray-900"><%= row.product_name %></div>
                      <div class="text-sm text-gray-500"><%= row.unit_size %></div>
                    </td>
                    <td class="px-6 py-4">
                      <% 
                        const milkTypeBadge = row.milk_type === 'A1' ? 'bg-green-100 text-green-800 dark:bg-green-900/20 dark:text-green-300' : 
                                             row.milk_type === 'A2' ? 'bg-orange-100 text-orange-800 dark:bg-orange-900/20 dark:text-orange-300' : 
                                             'bg-blue-100 text-blue-800 dark:bg-blue-900/20 dark:text-blue-300';
                      %>
                      <span class="px-2 py-1 text-xs font-semibold rounded-full <%= milkTypeBadge %>">
                        <%= row.milk_type %>
                      </span>
                    </td>
                    <td class="px-6 py-4 text-right text-sm text-blue-600 font-medium">
                      <%= Math.round(parseFloat(row.total_produced || 0)) %>
                    </td>
                    <td class="px-6 py-4 text-right text-sm text-green-600">
                      <%= Math.round(parseFloat(row.total_sold_app || 0)) %>
                    </td>
                    <td class="px-6 py-4 text-right text-sm text-green-600">
                      <%= Math.round(parseFloat(row.total_sold_partners || 0)) %>
                    </td>
                    <td class="px-6 py-4 text-right text-sm font-semibold text-green-700">
                      <%= Math.round(parseFloat(row.total_sold || 0)) %>
                    </td>
                    <td class="px-6 py-4 text-right text-sm text-orange-600 font-medium">
                      <%= Math.round(parseFloat(row.total_unsold || 0)) %>
                    </td>
                    <td class="px-6 py-4 text-right text-sm text-gray-600">
                      <%= Math.round(parseFloat(row.avg_sold || 0)) %>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="8" class="px-6 py-12 text-center text-gray-500">
                    No data available for the selected date range
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>

        <% } else if (report_type === 'product') { %>
          <!-- Product-wise Report -->
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Product</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Category</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Total Quantity</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Revenue</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Days Sold</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% if (reportData && reportData.length > 0) { %>
                <% reportData.forEach(row => { %>
                  <tr class="hover:bg-gray-50">
                    <td class="px-6 py-4">
                      <div class="font-medium text-gray-900"><%= row.product_name %></div>
                      <div class="text-sm text-gray-500"><%= row.unit_size %></div>
                    </td>
                    <td class="px-6 py-4 text-sm text-gray-600">
                      <%= row.category_name || 'N/A' %>
                    </td>
                    <td class="px-6 py-4 text-right text-sm font-semibold text-gray-900">
                      <%= parseFloat(row.total_quantity || 0).toFixed(2) %>
                    </td>
                    <td class="px-6 py-4 text-right text-sm font-semibold text-green-700">
                      ₹<%= parseFloat(row.total_revenue || 0).toFixed(2) %>
                    </td>
                    <td class="px-6 py-4 text-right text-sm text-gray-600">
                      <%= row.sales_days || 0 %>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="5" class="px-6 py-12 text-center text-gray-500">
                    No data available for the selected date range
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>

        <% } else if (report_type === 'channel') { %>
          <!-- Channel-wise Report -->
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Channel</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Partner</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Records</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Total Quantity</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Revenue</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% if (reportData && reportData.length > 0) { %>
                <% reportData.forEach(row => { %>
                  <tr class="hover:bg-gray-50">
                    <td class="px-6 py-4">
                      <% const channelBadge = row.sales_channel === 'app' ? 'bg-blue-100 text-blue-800' : 'bg-purple-100 text-purple-800'; %>

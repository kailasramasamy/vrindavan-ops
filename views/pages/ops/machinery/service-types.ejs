<%- include('../../../partials/_head', { seo, pageKey }) %>

<body class="bg-gray-50 dark:bg-gray-900">
  <!-- Sub Navigation -->
  <%- include('../../../partials/_subnav', { user, section: 'Machinery', subsection: 'Service Types' }) %>
  
  <!-- Toast Notification -->
  <%- include('../../../partials/_toast') %>

  <div class="min-h-screen pt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Page Header -->
      <div class="mb-8">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
          <div>
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Service Types Management</h1>
            <p class="text-gray-600 dark:text-gray-300">Define category-specific maintenance and service activities with estimated costs</p>
          </div>
          <div class="mt-4 sm:mt-0">
            <button onclick="openAddServiceTypeModal()" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
              </svg>
              Add Service Type
            </button>
          </div>
        </div>
      </div>

      <!-- Category Filter -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 mb-6">
        <div class="p-6">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Filter by Machine Category</h3>
          <div class="flex flex-wrap gap-2">
            <button onclick="filterByCategory('all')" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
              All Categories
            </button>
            <% categories.forEach(category => { %>
              <button onclick="filterByCategory('<%= category.id %>')" class="px-4 py-2 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 text-sm font-medium rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors">
                <%= category.name %>
              </button>
            <% }) %>
          </div>
        </div>
      </div>

      <!-- Service Types Grid -->
      <div id="serviceTypesGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% if (serviceTypes && serviceTypes.length > 0) { %>
          <% serviceTypes.forEach(serviceType => { %>
            <div class="service-type-card bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 hover:shadow-md transition-shadow" data-category-id="<%= serviceType.category_id || 'none' %>">
              <div class="p-6">
                <!-- Service Type Header -->
                <div class="flex items-start justify-between mb-4">
                  <div class="flex-1">
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white"><%= serviceType.name %></h3>
                    <% if (serviceType.category_name) { %>
                      <div class="flex items-center mt-1">
                        <div class="w-3 h-3 rounded-full mr-2" style="background-color: <%= serviceType.category_color || '#6B7280' %>"></div>
                        <span class="text-sm text-gray-600 dark:text-gray-300 font-medium"><%= serviceType.category_name %></span>
                      </div>
                    <% } else { %>
                      <span class="text-sm text-gray-400 dark:text-gray-500 italic">No category assigned</span>
                    <% } %>
                  </div>
                  <div class="flex space-x-2">
                    <button onclick="editServiceType(<%= serviceType.id %>)" class="w-8 h-8 bg-blue-50 dark:bg-blue-900/30 rounded-lg flex items-center justify-center hover:bg-blue-100 dark:hover:bg-blue-900/50 transition-colors group">
                      <svg class="w-4 h-4 text-blue-500 dark:text-blue-400 group-hover:text-blue-600 dark:group-hover:text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                      </svg>
                    </button>
                    <button onclick="deleteServiceType(<%= serviceType.id %>)" class="w-8 h-8 bg-red-50 dark:bg-red-900/30 rounded-lg flex items-center justify-center hover:bg-red-100 dark:hover:bg-red-900/50 transition-colors group">
                      <svg class="w-4 h-4 text-red-500 dark:text-red-400 group-hover:text-red-600 dark:group-hover:text-red-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                      </svg>
                    </button>
                  </div>
                </div>

                <!-- Service Type Details -->
                <% if (serviceType.description) { %>
                  <p class="text-sm text-gray-600 dark:text-gray-300 mb-4"><%= serviceType.description %></p>
                <% } %>

                <div class="space-y-3 mb-4">
                  <div class="flex justify-between items-center">
                    <span class="text-sm text-gray-500 dark:text-gray-400">Duration:</span>
                    <span class="text-sm font-medium text-gray-900 dark:text-white"><%= serviceType.estimated_duration_hours %> hours</span>
                  </div>
                  <div class="flex justify-between items-center">
                    <span class="text-sm text-gray-500 dark:text-gray-400">Estimated Cost:</span>
                    <span class="text-lg font-bold text-green-600 dark:text-green-400">₹<%= serviceType.estimated_cost %></span>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="col-span-full">
            <div class="text-center py-12">
              <div class="w-16 h-16 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
              </div>
              <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">No Service Types Found</h3>
              <p class="text-gray-600 dark:text-gray-400 mb-4">Create your first service type to define maintenance activities.</p>
              <button onclick="openAddServiceTypeModal()" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                </svg>
                Add Service Type
              </button>
            </div>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Add Service Type Modal -->
  <div id="addServiceTypeModal" class="fixed inset-0 bg-gray-600 dark:bg-gray-900 bg-opacity-50 dark:bg-opacity-75 hidden z-50">
    <div class="flex items-center justify-center min-h-screen p-4">
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-xl max-w-md w-full border dark:border-gray-700">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Add Service Type</h3>
        </div>
        <form id="addServiceTypeForm" method="POST" action="/machinery/service-types" class="p-6">
          <div class="space-y-4">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Service Type Name *</label>
              <input type="text" id="name" name="name" required class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-gray-900 dark:text-white bg-white dark:bg-gray-700 placeholder:text-gray-500 dark:placeholder:text-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
            <div>
              <label for="description" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Description</label>
              <textarea id="description" name="description" rows="3" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-gray-900 dark:text-white bg-white dark:bg-gray-700 placeholder:text-gray-500 dark:placeholder:text-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"></textarea>
            </div>
            <div>
              <label for="category_id" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Category</label>
              <select id="category_id" name="category_id" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-gray-900 dark:text-white bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                <option value="">Select Category (Optional)</option>
                <% categories.forEach(category => { %>
                  <option value="<%= category.id %>"><%= category.name %></option>
                <% }) %>
              </select>
            </div>
            <div>
              <label for="estimated_duration_hours" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Estimated Duration (Hours) *</label>
              <input type="number" id="estimated_duration_hours" name="estimated_duration_hours" min="1" value="1" required class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-gray-900 dark:text-white bg-white dark:bg-gray-700 placeholder:text-gray-500 dark:placeholder:text-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
            <div>
              <label for="estimated_cost" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Estimated Cost (₹) *</label>
              <input type="number" id="estimated_cost" name="estimated_cost" min="0" step="0.01" value="0" required class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-gray-900 dark:text-white bg-white dark:bg-gray-700 placeholder:text-gray-500 dark:placeholder:text-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
          </div>
          <div class="flex justify-end space-x-3 mt-6">
            <button type="button" onclick="closeAddServiceTypeModal()" class="px-4 py-2 bg-gray-300 dark:bg-gray-700 text-gray-700 dark:text-gray-300 text-sm font-medium rounded-lg hover:bg-gray-400 dark:hover:bg-gray-600 transition-colors">
              Cancel
            </button>
            <button type="submit" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
              Add Service Type
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Edit Service Type Modal -->
  <div id="editServiceTypeModal" class="fixed inset-0 bg-gray-600 dark:bg-gray-900 bg-opacity-50 dark:bg-opacity-75 hidden z-50">
    <div class="flex items-center justify-center min-h-screen p-4">
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-xl max-w-md w-full border dark:border-gray-700">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Edit Service Type</h3>
        </div>
        <form id="editServiceTypeForm" method="POST" action="/machinery/service-types" class="p-6">
          <div class="space-y-4">
            <div>
              <label for="editName" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Service Type Name *</label>
              <input type="text" id="editName" name="name" required class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-gray-900 dark:text-white bg-white dark:bg-gray-700 placeholder:text-gray-500 dark:placeholder:text-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
            <div>
              <label for="editDescription" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Description</label>
              <textarea id="editDescription" name="description" rows="3" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-gray-900 dark:text-white bg-white dark:bg-gray-700 placeholder:text-gray-500 dark:placeholder:text-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"></textarea>
            </div>
            <div>
              <label for="editCategoryId" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Category</label>
              <select id="editCategoryId" name="category_id" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-gray-900 dark:text-white bg-white dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                <option value="">Select Category (Optional)</option>
                <% categories.forEach(category => { %>
                  <option value="<%= category.id %>"><%= category.name %></option>
                <% }) %>
              </select>
            </div>
            <div>
              <label for="editEstimatedDurationHours" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Estimated Duration (Hours) *</label>
              <input type="number" id="editEstimatedDurationHours" name="estimated_duration_hours" min="1" required class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-gray-900 dark:text-white bg-white dark:bg-gray-700 placeholder:text-gray-500 dark:placeholder:text-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
            <div>
              <label for="editEstimatedCost" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Estimated Cost (₹) *</label>
              <input type="number" id="editEstimatedCost" name="estimated_cost" min="0" step="0.01" required class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-gray-900 dark:text-white bg-white dark:bg-gray-700 placeholder:text-gray-500 dark:placeholder:text-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
          </div>
          <div class="flex justify-end space-x-3 mt-6">
            <button type="button" onclick="closeEditServiceTypeModal()" class="px-4 py-2 bg-gray-300 dark:bg-gray-700 text-gray-700 dark:text-gray-300 text-sm font-medium rounded-lg hover:bg-gray-400 dark:hover:bg-gray-600 transition-colors">
              Cancel
            </button>
            <button type="submit" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
              Update Service Type
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    // Service types data for edit functionality
    const serviceTypesData = <%- JSON.stringify(serviceTypes) %>;
    
    function openAddServiceTypeModal() {
      document.getElementById('addServiceTypeModal').classList.remove('hidden');
    }

    function closeAddServiceTypeModal() {
      document.getElementById('addServiceTypeModal').classList.add('hidden');
      document.getElementById('addServiceTypeForm').reset();
    }

    function editServiceType(id) {
      try {
        // Find service type data
        const serviceType = serviceTypesData.find(st => st.id == id);
        
        if (!serviceType) {
          console.error('Service type not found with id:', id);
          alert('Service type not found');
          return;
        }
        
        // Show modal
        const modal = document.getElementById('editServiceTypeModal');
        modal.classList.remove('hidden');
        
        // Populate form fields
        document.getElementById('editName').value = serviceType.name || '';
        document.getElementById('editDescription').value = serviceType.description || '';
        document.getElementById('editCategoryId').value = serviceType.category_id || '';
        document.getElementById('editEstimatedDurationHours').value = serviceType.estimated_duration_hours || '';
        document.getElementById('editEstimatedCost').value = serviceType.estimated_cost || '';
        
        // Update form action
        const form = document.getElementById('editServiceTypeForm');
        form.action = `/machinery/service-types/${id}/update`;
        
        console.log('Service type data loaded:', serviceType);
        
      } catch (error) {
        console.error('Error loading service type:', error);
        alert('Error loading service type data');
      }
    }

    function closeEditServiceTypeModal() {
      document.getElementById('editServiceTypeModal').classList.add('hidden');
    }

    function deleteServiceType(id) {
      if (confirm('Are you sure you want to delete this service type? This action cannot be undone.')) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/machinery/service-types/${id}`;
        
        const methodInput = document.createElement('input');
        methodInput.type = 'hidden';
        methodInput.name = '_method';
        methodInput.value = 'DELETE';
        
        form.appendChild(methodInput);
        document.body.appendChild(form);
        form.submit();
      }
    }

    // Close modals when clicking outside
    document.getElementById('addServiceTypeModal').addEventListener('click', function(e) {
      if (e.target === this) {
        closeAddServiceTypeModal();
      }
    });

    document.getElementById('editServiceTypeModal').addEventListener('click', function(e) {
      if (e.target === this) {
        closeEditServiceTypeModal();
      }
    });

    // Category filtering functionality
    function filterByCategory(categoryId) {
      const cards = document.querySelectorAll('.service-type-card');
      const buttons = document.querySelectorAll('[onclick^="filterByCategory"]');
      
      // Update button styles
      buttons.forEach(button => {
        button.classList.remove('bg-blue-600', 'text-white');
        button.classList.add('bg-gray-100', 'text-gray-700');
      });
      
      // Highlight selected button
      const selectedButton = document.querySelector(`[onclick="filterByCategory('${categoryId}')"]`);
      if (selectedButton) {
        selectedButton.classList.remove('bg-gray-100', 'text-gray-700');
        selectedButton.classList.add('bg-blue-600', 'text-white');
      }
      
      // Show/hide cards based on category
      cards.forEach(card => {
        const cardCategoryId = card.getAttribute('data-category-id');
        if (categoryId === 'all' || cardCategoryId === categoryId) {
          card.style.display = 'block';
        } else {
          card.style.display = 'none';
        }
      });
    }
  </script>

  <%- include('../../../partials/_footer') %>
</body>
</html>


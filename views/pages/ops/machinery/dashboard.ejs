<%- include('../../../partials/_head', { seo, pageKey }) %>

<body class="bg-gray-50 dark:bg-gray-900">
  <%- include('../../../partials/_subnav', { user, section: 'Machinery', subsection: 'Dashboard' }) %>
  
  <!-- Toast Notification -->
  <%- include('../../../partials/_toast') %>

  <div class="min-h-screen pt-16">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Header -->
      <div class="mb-6">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">Machinery Management Dashboard</h1>
            <p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 mt-1">Monitor and manage your machinery, maintenance schedules, and service history. For machine and category management, visit the <a href="/admin" class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 underline">Admin Panel</a>.</p>
          </div>
        </div>
      </div>

      <!-- Quick Action Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        <!-- Service Schedules -->
        <a href="/machinery/service-schedules" class="bg-white dark:bg-gray-800 rounded-lg shadow-sm p-4 border border-gray-200 dark:border-gray-700 hover:shadow-md transition-shadow cursor-pointer">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 bg-green-100 dark:bg-green-900/20 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
              </div>
            </div>
            <div class="ml-3">
              <p class="text-sm font-medium text-gray-900 dark:text-white">Service Schedules</p>
              <p class="text-xs text-gray-500 dark:text-gray-400">Manage maintenance</p>
            </div>
          </div>
        </a>

        <!-- Service History -->
        <a href="/machinery/service-history" class="bg-white dark:bg-gray-800 rounded-lg shadow-sm p-4 border border-gray-200 dark:border-gray-700 hover:shadow-md transition-shadow cursor-pointer">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 bg-yellow-100 dark:bg-yellow-900/20 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-yellow-600 dark:text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                </svg>
              </div>
            </div>
            <div class="ml-3">
              <p class="text-sm font-medium text-gray-900 dark:text-white">Service History</p>
              <p class="text-xs text-gray-500 dark:text-gray-400">View records</p>
            </div>
          </div>
        </a>

        <!-- All Issues -->
        <a href="/machinery/issues" class="bg-white dark:bg-gray-800 rounded-lg shadow-sm p-4 border border-gray-200 dark:border-gray-700 hover:shadow-md transition-shadow cursor-pointer">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 bg-red-100 dark:bg-red-900/20 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                </svg>
              </div>
            </div>
            <div class="ml-3">
              <p class="text-sm font-medium text-gray-900 dark:text-white">All Issues</p>
              <p class="text-xs text-gray-500 dark:text-gray-400">Manage issues</p>
            </div>
          </div>
        </a>
      </div>

      <!-- Quick Stats -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 mb-8">
        <!-- Total Machines -->
        <a href="/machinery/machines" class="bg-white dark:bg-gray-800 rounded-lg shadow-sm p-6 border border-gray-200 dark:border-gray-700 hover:shadow-md transition-shadow cursor-pointer">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 bg-blue-100 dark:bg-blue-900/20 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                </svg>
              </div>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Total Machines</p>
              <p class="text-2xl font-semibold text-gray-900 dark:text-white"><%= machineStats.total_machines || 0 %></p>
            </div>
          </div>
        </a>

        <!-- Active Machines -->
        <a href="/machinery/machines?status=active" class="bg-white dark:bg-gray-800 rounded-lg shadow-sm p-6 border border-gray-200 dark:border-gray-700 hover:shadow-md transition-shadow cursor-pointer">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 bg-green-100 dark:bg-green-900/20 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Active Machines</p>
              <p class="text-2xl font-semibold text-gray-900 dark:text-white"><%= machineStats.active_machines || 0 %></p>
            </div>
          </div>
        </a>

        <!-- Overdue Services -->
        <a href="/machinery/service-schedules?overdue_only=true" class="bg-white dark:bg-gray-800 rounded-lg shadow-sm p-6 border <%= (overdueServices && overdueServices.length > 0) ? 'border-red-300 dark:border-red-600' : 'border-gray-200 dark:border-gray-700' %> hover:shadow-md transition-shadow cursor-pointer">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 <%= (overdueServices && overdueServices.length > 0) ? 'bg-red-100 dark:bg-red-900/20' : 'bg-gray-100 dark:bg-gray-700' %> rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 <%= (overdueServices && overdueServices.length > 0) ? 'text-red-600 dark:text-red-400' : 'text-gray-600 dark:text-gray-400' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Overdue Services</p>
              <p class="text-2xl font-semibold <%= (overdueServices && overdueServices.length > 0) ? 'text-red-600 dark:text-red-400' : 'text-gray-900 dark:text-white' %>"><%= overdueServices ? overdueServices.length : 0 %></p>
            </div>
          </div>
        </a>

        <!-- Warranty Expiring -->
        <a href="/machinery/machines?warranty_expiring=true" class="bg-white dark:bg-gray-800 rounded-lg shadow-sm p-6 border border-gray-200 dark:border-gray-700 hover:shadow-md transition-shadow cursor-pointer">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 bg-red-100 dark:bg-red-900/20 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Warranty Expiring Soon</p>
              <p class="text-2xl font-semibold text-gray-900 dark:text-white"><%= machineStats.warranty_expiring_soon || 0 %></p>
            </div>
          </div>
        </a>

        <!-- Pending Issues -->
        <a href="/machinery/issues" class="bg-white dark:bg-gray-800 rounded-lg shadow-sm p-6 border <%= (Number(issueStats.open_issues || 0) + Number(issueStats.in_progress_issues || 0)) > 0 ? 'border-orange-300 dark:border-orange-600' : 'border-gray-200 dark:border-gray-700' %> hover:shadow-md transition-shadow cursor-pointer">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 <%= (Number(issueStats.open_issues || 0) + Number(issueStats.in_progress_issues || 0)) > 0 ? 'bg-orange-100 dark:bg-orange-900/20' : 'bg-gray-100 dark:bg-gray-700' %> rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 <%= (Number(issueStats.open_issues || 0) + Number(issueStats.in_progress_issues || 0)) > 0 ? 'text-orange-600 dark:text-orange-400' : 'text-gray-600 dark:text-gray-400' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                </svg>
              </div>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Pending Issues</p>
              <p class="text-2xl font-semibold <%= (Number(issueStats.open_issues || 0) + Number(issueStats.in_progress_issues || 0)) > 0 ? 'text-orange-600 dark:text-orange-400' : 'text-gray-900 dark:text-white' %>"><%= Number(issueStats.open_issues || 0) + Number(issueStats.in_progress_issues || 0) %></p>
              <% if ((issueStats.critical_issues || 0) > 0) { %>
                <p class="text-xs text-red-600 dark:text-red-400 font-medium mt-1"><%= issueStats.critical_issues || 0 %> Critical</p>
              <% } %>
            </div>
          </div>
        </a>
      </div>

      <!-- Main Content Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
        <!-- Top Machines Overview -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-600">
            <div class="flex items-center justify-between">
              <div>
                <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Top Machines</h2>
                <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Recent and active machinery</p>
              </div>
              <a href="/machinery/machines" class="text-sm text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 font-medium">View All →</a>
            </div>
          </div>
          <div class="p-6">
            <% if (topMachines && topMachines.length > 0) { %>
              <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-600">
                  <thead class="bg-gray-50 dark:bg-gray-700">
                    <tr>
                      <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Machine</th>
                      <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Status</th>
                      <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Issues</th>
                    </tr>
                  </thead>
                  <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-600">
                    <% topMachines.forEach(machine => { %>
                      <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                        <td class="px-4 py-4 whitespace-nowrap">
                          <div class="flex items-center">
                            <!-- Machine Image Thumbnail -->
                            <div class="w-12 h-12 rounded-lg overflow-hidden mr-4 flex-shrink-0 bg-gray-100">
                              <% if (machine.images && machine.images !== 'null' && machine.images.trim() !== '') { %>
                                <% try { %>
                                  <% const images = JSON.parse(machine.images); %>
                                  <% if (images && images.length > 0 && images[0].path) { %>
                                    <img src="<%= images[0].path %>" alt="<%= machine.name %>" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                    <div class="w-full h-full bg-gray-100 flex items-center justify-center" style="display: none;">
                                      <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                                      </svg>
                                    </div>
                                  <% } else { %>
                                    <div class="w-full h-full bg-gray-100 flex items-center justify-center">
                                      <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                                      </svg>
                                    </div>
                                  <% } %>
                                <% } catch (e) { %>
                                  <div class="w-full h-full bg-gray-100 flex items-center justify-center">
                                    <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                                    </svg>
                                  </div>
                                <% } %>
                              <% } else { %>
                                <div class="w-full h-full bg-gray-100 flex items-center justify-center">
                                  <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                                  </svg>
                                </div>
                              <% } %>
                            </div>
                          <div>
                            <div class="text-sm font-medium text-gray-900 dark:text-white"><%= machine.name %></div>
                            <div class="text-sm text-gray-500 dark:text-gray-400"><%= machine.model || 'N/A' %></div>
                          </div>
                          </div>
                        </td>
                        <td class="px-4 py-4 whitespace-nowrap">
                          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                            <%= machine.status === 'active' ? 'bg-green-100 dark:bg-green-900/20 text-green-800 dark:text-green-400' : 
                                machine.status === 'maintenance' ? 'bg-yellow-100 dark:bg-yellow-900/20 text-yellow-800 dark:text-yellow-400' : 
                                machine.status === 'inactive' ? 'bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-300' : 
                                'bg-red-100 dark:bg-red-900/20 text-red-800 dark:text-red-400' %>">
                            <%= machine.status || 'Unknown' %>
                          </span>
                        </td>
                        <td class="px-4 py-4 whitespace-nowrap">
                          <div class="flex space-x-2">
                            <% if (machine.active_issues > 0) { %>
                              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-100 dark:bg-red-900/20 text-red-800 dark:text-red-400">
                                <%= machine.active_issues %> Active
                              </span>
                            <% } %>
                            <% if (machine.pending_issues > 0) { %>
                              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-yellow-100 dark:bg-yellow-900/20 text-yellow-800 dark:text-yellow-400">
                                <%= machine.pending_issues %> Pending
                              </span>
                            <% } %>
                            <% if ((machine.active_issues || 0) === 0 && (machine.pending_issues || 0) === 0) { %>
                              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/20 text-green-800 dark:text-green-400">
                                No Issues
                              </span>
                            <% } %>
                          </div>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } else { %>
              <div class="text-center py-8">
                <div class="w-16 h-16 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center mx-auto mb-4">
                  <svg class="w-8 h-8 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                  </svg>
                </div>
                <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">No Machines Found</h3>
                <p class="text-gray-600 dark:text-gray-400">Add your first machine to get started.</p>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Active Issues -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-600">
            <div class="flex items-center justify-between">
              <div>
                <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Active Issues</h2>
                <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Open and in-progress issues requiring attention</p>
              </div>
              <a href="/machinery/issues" class="text-sm text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 font-medium">View All →</a>
            </div>
          </div>
          <div class="p-6">
            <% if (activeIssues && activeIssues.length > 0) { %>
              <div class="space-y-4">
                <% activeIssues.forEach(issue => { %>
                  <div class="flex items-center justify-between p-4 rounded-lg border border-gray-100 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                    <div class="flex items-center flex-1 min-w-0">
                      <!-- Machine Thumbnail -->
                      <div class="w-12 h-12 rounded-lg overflow-hidden mr-4 flex-shrink-0 bg-gray-100 dark:bg-gray-700">
                        <% if (issue.machine_images && issue.machine_images !== 'null' && issue.machine_images.trim() !== '') { %>
                          <% try { %>
                            <% const images = JSON.parse(issue.machine_images); %>
                            <% if (images && images.length > 0 && images[0].path) { %>
                              <img src="<%= images[0].path %>" alt="<%= issue.machine_name %>" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                              <div class="w-full h-full bg-gray-100 flex items-center justify-center" style="display: none;">
                                <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                                </svg>
                              </div>
                            <% } else { %>
                              <div class="w-full h-full bg-gray-100 flex items-center justify-center">
                                <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                                </svg>
                              </div>
                            <% } %>
                          <% } catch (e) { %>
                            <div class="w-full h-full bg-gray-100 flex items-center justify-center">
                              <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                              </svg>
                            </div>
                          <% } %>
                        <% } else { %>
                          <div class="w-full h-full bg-gray-100 flex items-center justify-center">
                            <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                            </svg>
                          </div>
                        <% } %>
                      </div>
                      
                      <!-- Issue Details -->
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center">
                          <div class="w-3 h-3 rounded-full mr-3 flex-shrink-0" style="background-color: <%= issue.category_color || '#6B7280' %>"></div>
                          <div class="flex-1 min-w-0">
                            <h3 class="font-medium text-gray-900 dark:text-white truncate"><%= issue.title %></h3>
                            <p class="text-sm text-gray-500 dark:text-gray-400 truncate"><%= issue.machine_name %></p>
                          </div>
                        </div>
                      </div>
                    </div>
                    
                    <!-- View Issue Link -->
                    <div class="flex-shrink-0">
                      <a href="/machinery/issues/<%= issue.id %>" class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 text-sm font-medium flex items-center">
                        View
                        <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                        </svg>
                      </a>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <div class="text-center py-8">
                <div class="w-16 h-16 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center mx-auto mb-4">
                  <svg class="w-8 h-8 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                </div>
                <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">No Active Issues</h3>
                <p class="text-gray-600 dark:text-gray-400">All issues have been resolved.</p>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Upcoming Service Schedules -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-600">
          <div class="flex items-center justify-between">
            <div>
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Upcoming Service Schedules</h2>
              <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Next 7 days of scheduled maintenance</p>
            </div>
            <a href="/machinery/service-schedules" class="text-sm text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 font-medium">View All →</a>
          </div>
        </div>
        <div class="p-6">
          <% if (upcomingServices && upcomingServices.length > 0) { %>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-600">
                <thead class="bg-gray-50 dark:bg-gray-700">
                  <tr>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Machine</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Service Type</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Scheduled Date</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Status</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Actions</th>
                  </tr>
                </thead>
                <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-600">
                  <% upcomingServices.forEach(schedule => { %>
                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                      <td class="px-4 py-4 whitespace-nowrap">
                        <div class="flex items-center">
                          <!-- Machine Image Thumbnail -->
                          <div class="w-12 h-12 rounded-lg overflow-hidden mr-4 flex-shrink-0 bg-gray-100 dark:bg-gray-700">
                            <% if (schedule.machine_images && schedule.machine_images !== 'null' && schedule.machine_images.trim() !== '') { %>
                              <% try { %>
                                <% const images = JSON.parse(schedule.machine_images); %>
                                <% if (images && images.length > 0 && images[0].path) { %>
                                  <img src="<%= images[0].path %>" alt="<%= schedule.machine_name %>" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                  <div class="w-full h-full bg-gray-100 flex items-center justify-center" style="display: none;">
                                    <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                                    </svg>
                                  </div>
                                <% } else { %>
                                  <div class="w-full h-full bg-gray-100 flex items-center justify-center">
                                    <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                                    </svg>
                                  </div>
                                <% } %>
                              <% } catch (e) { %>
                                <div class="w-full h-full bg-gray-100 flex items-center justify-center">
                                  <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                                  </svg>
                                </div>
                              <% } %>
                            <% } else { %>
                              <div class="w-full h-full bg-gray-100 flex items-center justify-center">
                                <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                                </svg>
                              </div>
                            <% } %>
                          </div>
                          <div>
                            <div class="text-sm font-medium text-gray-900 dark:text-white"><%= schedule.machine_name %></div>
                            <div class="text-sm text-gray-500 dark:text-gray-400"><%= schedule.serial_number || 'N/A' %></div>
                          </div>
                        </div>
                      </td>
                      <td class="px-4 py-4 whitespace-nowrap">
                        <div class="flex items-center">
                          <div class="w-3 h-3 rounded-full mr-3 flex-shrink-0" style="background-color: <%= schedule.category_color || '#6B7280' %>"></div>
                          <div class="text-sm font-medium text-gray-900 dark:text-white"><%= schedule.service_type_name %></div>
                        </div>
                      </td>
                      <td class="px-4 py-4 whitespace-nowrap">
                        <div class="text-sm text-gray-900 dark:text-white"><%= new Date(schedule.next_service_date).toLocaleDateString() %></div>
                        <div class="text-sm text-gray-500 dark:text-gray-400">
                          <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                          </svg>
                          <%= new Date(schedule.next_service_date).toLocaleDateString('en-US', { weekday: 'long' }) %>
                        </div>
                      </td>
                      <td class="px-4 py-4 whitespace-nowrap">
                        <% if (schedule.days_until_due !== undefined) { %>
                          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= schedule.days_until_due <= 1 ? 'bg-red-100 dark:bg-red-900/20 text-red-800 dark:text-red-400' : schedule.days_until_due <= 3 ? 'bg-yellow-100 dark:bg-yellow-900/20 text-yellow-800 dark:text-yellow-400' : 'bg-green-100 dark:bg-green-900/20 text-green-800 dark:text-green-400' %>">
                            <%= schedule.days_until_due === 0 ? 'Today' : schedule.days_until_due === 1 ? 'Tomorrow' : `${schedule.days_until_due} days` %>
                          </span>
                        <% } else { %>
                          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-300">
                            Scheduled
                          </span>
                        <% } %>
                      </td>
                      <td class="px-4 py-4 whitespace-nowrap text-sm font-medium">
                        <a href="/machinery/service-schedules/<%= schedule.id %>" class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 flex items-center">
                          View Details
                          <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                          </svg>
                        </a>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="text-center py-8">
              <div class="w-16 h-16 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
              </div>
              <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">No Upcoming Services</h3>
              <p class="text-gray-600 dark:text-gray-400">No service schedules scheduled for the next 7 days.</p>
            </div>
          <% } %>
        </div>
      </div>

    </main>
  </div>

  <%- include('../../../partials/_footer') %>
</body>
</html>

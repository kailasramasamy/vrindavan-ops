  <script>
    function openAddServiceModal() {
      // Reset form to add mode
      document.getElementById('addServiceForm').action = '/machinery/service-history';
      document.getElementById('addServiceForm').method = 'POST';
      document.querySelector('#addServiceModal h3').textContent = 'Add Service Record';
      document.querySelector('#addServiceModal p').textContent = 'Create a new maintenance service record';
      
      // Remove method override if it exists
      const methodInput = document.getElementById('_method');
      if (methodInput) {
        methodInput.remove();
      }
      
      // Always reset form when opening for adding
      document.getElementById('addServiceForm').reset();
      
      // Ensure dropdowns are reset to default values
      const machineSelect = document.getElementById('modal_machine_id');
      const serviceTypeSelect = document.getElementById('modal_service_type_id');
      if (machineSelect) machineSelect.value = '';
      if (serviceTypeSelect) serviceTypeSelect.value = '';
      
      document.getElementById('addServiceModal').classList.remove('hidden');
    }

    function closeAddServiceModal() {
      document.getElementById('addServiceModal').classList.add('hidden');
      // Only reset form if we're not in edit mode
      const modalTitle = document.querySelector('#addServiceModal h3').textContent;
      if (modalTitle === 'Add Service Record') {
      document.getElementById('addServiceForm').reset();
      }
    }

    function openEditModal(id) {
      // Don't reset form - we'll populate it with data
      document.getElementById('addServiceModal').classList.remove('hidden');
    }

    function viewServiceDetails(id) {
      // Fetch service record details
      fetch(`/machinery/service-history/${id}`)
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            displayServiceDetails(data.record);
            document.getElementById('viewServiceModal').classList.remove('hidden');
          } else {
            toastManager.error('Failed to load service details');
          }
        })
        .catch(error => {
          console.error('Error fetching service details:', error);
          toastManager.error('Failed to load service details');
        });
    }

    function editServiceRecord(id) {
      // Fetch service record details for editing
      fetch(`/machinery/service-history/${id}`)
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            
            // Change modal title to "Edit Service Record"
            document.querySelector('#addServiceModal h3').textContent = 'Edit Service Record';
            document.querySelector('#addServiceModal p').textContent = 'Update service record information';
            
            // Change form action to update
            document.getElementById('addServiceForm').action = `/machinery/service-history/${id}`;
            document.getElementById('addServiceForm').method = 'POST';
            
            // Add method override input
            let methodInput = document.getElementById('_method');
            if (!methodInput) {
              methodInput = document.createElement('input');
              methodInput.type = 'hidden';
              methodInput.name = '_method';
              methodInput.id = '_method';
              document.getElementById('addServiceForm').appendChild(methodInput);
            }
            methodInput.value = 'PUT';
            
            // Open modal first
            openEditModal(id);
            
            // Populate form fields with record data after a short delay
            setTimeout(() => {
              populateEditForm(data.record);
            }, 50);
          } else {
            console.error('Failed to load service record:', data.error);
            toastManager.error('Failed to load service record for editing');
          }
        })
        .catch(error => {
          console.error('Error fetching service record:', error);
          toastManager.error('Failed to load service record for editing');
        });
    }


            <h4 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-4 flex items-center">
              <svg class="w-5 h-5 mr-2 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"></path>
              </svg>
              Additional Information
            </h4>
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Description</label>
                <p class="text-sm text-gray-900 mt-1">${record.description || 'No description provided'}</p>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Notes</label>
                <p class="text-sm text-gray-900 mt-1">${record.notes || 'No notes provided'}</p>
              </div>
              ${record.invoice_file ? `
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Invoice</label>
                ${(() => {
                  try {
                    const invoiceData = typeof record.invoice_file === 'string' ? JSON.parse(record.invoice_file) : record.invoice_file;
                    return `<a href="${invoiceData.path}" target="_blank" class="inline-flex items-center text-blue-600 hover:text-blue-800 mt-1">
                      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                      </svg>
                      View Invoice (${invoiceData.originalName || 'PDF'})
                    </a>`;
                  } catch (error) {
                    console.error('Error parsing invoice file data:', error);
                    return '<p class="text-sm text-red-600 mt-1">Invoice file data corrupted</p>';
                  }
                })()}
              </div>
              ` : ''}
            </div>
          </div>
        </div>
      `;
    }

    function populateEditForm(record) {
      // Helper function to convert ISO date to YYYY-MM-DD format
      function formatDateForInput(dateString) {
        if (!dateString) return '';
        const date = new Date(dateString);
        return date.toISOString().split('T')[0];
      }
      
      // Function to set dropdown value with verification
      function setDropdownValue(selectElement, value, fieldName) {
        if (!selectElement) {
          console.error(`${fieldName} select element not found!`);
          return false;
        }
        
        // Check if the option exists
        const optionExists = Array.from(selectElement.options).some(opt => opt.value === value.toString());
        if (!optionExists) {
          console.error(`${fieldName} option with value ${value} not found!`);
          return false;
        }
        
        selectElement.value = value;
        selectElement.dispatchEvent(new Event('change', { bubbles: true }));
        
        // Verify the value was set
        if (selectElement.value === value.toString()) {
          return true;
        } else {
          console.error(`❌ ${fieldName} value not set correctly. Expected: ${value}, Got: ${selectElement.value}`);
          return false;
        }
      }
      
      // Populate form fields with record data
      const machineSelect = document.getElementById('modal_machine_id');
      const serviceTypeSelect = document.getElementById('modal_service_type_id');
      
      // Set dropdown values with verification
      const machineSet = setDropdownValue(machineSelect, record.machine_id, 'Machine');
      const serviceTypeSet = setDropdownValue(serviceTypeSelect, record.service_type_id, 'Service Type');
      
      // If dropdowns didn't set correctly, try again with a delay
      if (!machineSet || !serviceTypeSet) {
        setTimeout(() => {
          setDropdownValue(machineSelect, record.machine_id, 'Machine');
          setDropdownValue(serviceTypeSelect, record.service_type_id, 'Service Type');
        }, 200);
      }
      
      // Populate other fields
      const serviceDateField = document.getElementById('service_date');
      const statusField = document.getElementById('status');
      const providerField = document.getElementById('service_provider');
      const technicianField = document.getElementById('technician_name');
      const laborHoursField = document.getElementById('labor_hours');
      const totalCostField = document.getElementById('total_cost');
      const nextServiceField = document.getElementById('next_service_due');
      const descriptionField = document.getElementById('description');
      const notesField = document.getElementById('notes');
      
      if (serviceDateField) serviceDateField.value = formatDateForInput(record.service_date);
      if (statusField) statusField.value = record.status;
      if (providerField) providerField.value = record.service_provider || '';
      if (technicianField) technicianField.value = record.technician_name || '';
      if (laborHoursField) laborHoursField.value = record.labor_hours || '';
      if (totalCostField) totalCostField.value = record.total_cost || '';
      if (nextServiceField) nextServiceField.value = formatDateForInput(record.next_service_due);
      if (descriptionField) descriptionField.value = record.description || '';
      if (notesField) notesField.value = record.notes || '';
    }

    function getStatusClass(status) {
      switch(status) {
        case 'completed': return 'bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200';
        case 'pending': return 'bg-yellow-100 dark:bg-yellow-900 text-yellow-800 dark:text-yellow-200';
        case 'cancelled': return 'bg-red-100 dark:bg-red-900 text-red-800 dark:text-red-200';
        default: return 'bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200';
      }
    }

    function closeViewServiceModal() {
      document.getElementById('viewServiceModal').classList.add('hidden');
    }

    // Close modal when clicking outside
    document.getElementById('addServiceModal').addEventListener('click', function(e) {
      if (e.target === this) {
        closeAddServiceModal();
      }
    });

    // Handle invoice file upload
    document.getElementById('service_invoice').addEventListener('change', function(e) {
      const file = e.target.files[0];
      const preview = document.getElementById('invoice-preview');
      const filename = document.getElementById('invoice-filename');
      
      if (file) {
        // Validate file type
        if (file.type !== 'application/pdf') {
          alert('Please select a PDF file only.');
          e.target.value = '';
          return;
        }
        
        // Validate file size (10MB limit)
        if (file.size > 10 * 1024 * 1024) {
          alert('File size must be less than 10MB.');
          e.target.value = '';
          return;
        }
        
        // Show preview
        filename.textContent = file.name;
        preview.classList.remove('hidden');
      } else {
        preview.classList.add('hidden');
      }
    });

    // Remove invoice function
    function removeInvoice() {
      document.getElementById('service_invoice').value = '';
      document.getElementById('invoice-preview').classList.add('hidden');
    }

    // Drag and drop functionality
    const dropZone = document.querySelector('.border-dashed');
    
    dropZone.addEventListener('dragover', function(e) {
      e.preventDefault();
      dropZone.classList.add('border-blue-400', 'bg-blue-50', 'dark:bg-blue-900');
    });
    
    dropZone.addEventListener('dragleave', function(e) {
      e.preventDefault();
      dropZone.classList.remove('border-blue-400', 'bg-blue-50', 'dark:bg-blue-900');
    });
    
    dropZone.addEventListener('drop', function(e) {
      e.preventDefault();
      dropZone.classList.remove('border-blue-400', 'bg-blue-50', 'dark:bg-blue-900');
      
      const files = e.dataTransfer.files;
      if (files.length > 0) {
        const file = files[0];
        if (file.type === 'application/pdf' && file.size <= 10 * 1024 * 1024) {
          document.getElementById('service_invoice').files = files;
          document.getElementById('service_invoice').dispatchEvent(new Event('change'));
        } else {
          alert('Please drop a PDF file that is less than 10MB.');
        }
      }
    });

    // Handle session toasts
    <% if (typeof toast !== 'undefined' && toast) { %>
      toastManager.show('<%= toast.message %>', '<%= toast.type %>', 6000);
    <% } %>
  </script>

  <%- include('../../../partials/_footer') %>
</body>
</html>



# --- Node/Express standard ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Lockfiles are usually tracked. Remove comment to ignore if desired.
# package-lock.json

# Logs and runtime state
logs/
*.log
*.log.*
pids/
*.pid
*.pid.lock

# Order files (if you want to ignore them)
public/data/orders.json

# Test coverage (if added later)
coverage/
.nyc_output/

# Environment files (keep secrets out of git)
.env
.env.*
!.env.example

# Build and cache directories (generic)
dist/
build/
.tmp/
.cache/
.parcel-cache/
.eslintcache
.prettier-cache

# Tailwind/PostCSS output (optional). Comment out if you want to commit compiled CSS.
public/assets/styles.css

# IDE/editor & OS cruft
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/
*.swp
*.swo

# Misc
*.orig
*.rej
*.tgz
dump.rdb

# Uploads
public/uploads/

# SQL scripts
sql/

# Scripts
scripts/
src/modules/analytics/models/ordersAnalyticsModelSimple.js
